  .print-font-card{background:#fff;border:1px solid rgba(55,58,54,.1);border-radius:16px;overflow:hidden;transition:box-shadow .2s ease}
  .print-font-card:hover{box-shadow:0 8px 24px rgba(0,0,0,.05)}
  .print-font-header{display:flex;justify-content:space-between;align-items:center;padding:16px 24px;border-bottom:1px solid rgba(55,58,54,.06);background:rgba(55,58,54,.02)}
  .print-font-header h4{font-size:15px;font-weight:600;color:var(--c-dark);margin:0}
  .print-font-role{font-size:12px;color:rgba(55,58,54,.58);font-weight:500}
  .print-font-specimen{padding:20px 24px}
  .print-font-alpha{font-size:15px;letter-spacing:.08em;color:var(--c-dark);margin-bottom:4px;line-height:1.6}
  .print-font-alpha-lower{font-size:15px;letter-spacing:.04em;color:rgba(55,58,54,.6);margin-bottom:4px;line-height:1.6}
  .print-font-nums{font-size:15px;letter-spacing:.06em;color:rgba(55,58,54,.58);line-height:1.6}

  /* ═══ SOCIAL SPECS TABLE ═══ */
  .specs-table-wrap{background:#fff;border:1px solid rgba(55,58,54,.1);border-radius:16px;overflow:hidden}
  .specs-table{width:100%;border-collapse:collapse;font-size:14px}
  .specs-table th{text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:rgba(55,58,54,.58);padding:14px 20px;border-bottom:2px solid rgba(55,58,54,.08);background:rgba(55,58,54,.02)}
  .specs-table td{padding:14px 20px;border-bottom:1px solid rgba(55,58,54,.04);color:rgba(55,58,54,.65)}
  .specs-table tr:last-child td{border-bottom:none}
  .specs-platform{font-weight:600;color:var(--c-dark)}
  .specs-dims{font-family:'SF Mono','Courier New',monospace;font-size:13px;background:var(--c-warm-gray,#F5F4F0);padding:4px 10px;border-radius:6px;display:inline-block}

  /* Toast */
  .brand-toast{position:fixed;bottom:32px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--c-dark-deep);color:#fff;padding:12px 24px;border-radius:10px;font-size:14px;font-weight:500;opacity:0;pointer-events:none;transition:all .3s ease;z-index:999;box-shadow:0 8px 32px rgba(0,0,0,.2)}
  .brand-toast.visible{opacity:1;transform:translateX(-50%) translateY(0)}

  /* ═══ RESPONSIVE ═══ */
  @media(max-width:1024px){.brand-sidebar{display:none}.brand-layout{padding:32px 20px 48px}.logo-grid-3{grid-template-columns:repeat(3,1fr)}.brand-mobile-nav{display:block}.brand-section{scroll-margin-top:160px}}
  @media(max-width:900px){.logo-grid-3{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:768px){.brand-hero{padding:72px 20px 60px}.logo-grid{grid-template-columns:1fr}.logo-grid-3{grid-template-columns:1fr}.usage-grid{grid-template-columns:1fr}.dodont-grid{grid-template-columns:1fr}.color-grid{grid-template-columns:1fr 1fr}.two-col{grid-template-columns:1fr}.vis-grid{grid-template-columns:1fr 1fr}.section-header-row{flex-direction:column}.media-details-grid{grid-template-columns:1fr}.dl-btn{padding:10px 16px;font-size:13px;min-height:44px}.specs-table-wrap{overflow-x:auto}.specs-table{min-width:540px}.print-fonts-grid{grid-template-columns:1fr}}
  @media(max-width:480px){.color-grid{grid-template-columns:1fr}.vis-grid{grid-template-columns:1fr}.hero-btn{width:100%;justify-content:center}}

  /* ═══ REDUCED MOTION ═══ */
  @media(prefers-reduced-motion:reduce){
    .card,.usage-card,.color-card,.print-font-card,.media-card,.brand-toast{transition:none}
    .card:hover{transform:none;box-shadow:none}
    .color-card:hover{transform:none;box-shadow:none}
    .hero-btn-primary:hover{transform:none}
    .brand-toast.visible{transition:none}
    .sidebar-link,.copy-btn,.dl-btn,.download-all-btn,.mobile-nav-link,.media-detail-value a{transition:none}
  }
</style>

<script>
  let _brandObserver: IntersectionObserver | null = null;

  function cleanupBranding() {
    _brandObserver?.disconnect();
    _brandObserver = null;
  }

  function initBranding() {
    const cards = document.querySelectorAll('.color-card');
    if (!cards.length) return;

    cleanupBranding();

    cards.forEach(card=>{card.addEventListener('click',()=>{const hex=(card as HTMLElement).dataset.hex;navigator.clipboard.writeText(hex!);let toast=document.querySelector('.brand-toast');if(!toast){toast=document.createElement('div');toast.className='brand-toast';document.body.appendChild(toast)}toast.textContent=`Copied ${hex}`;toast.classList.add('visible');setTimeout(()=>toast.classList.remove('visible'),2000)})});

    // Copy buttons on media cards
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const card = btn.closest('.media-card');
        if (!card) return;
        const textEl = card.querySelector('.media-copy-text');
        if (!textEl) return;
        const text = (textEl as HTMLElement).innerText.trim();
        navigator.clipboard.writeText(text);
        btn.classList.add('copied');
        btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Copied!';
        setTimeout(() => {
          btn.classList.remove('copied');
          btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>Copy';
        }, 2000);
      });
    });

    const sections=document.querySelectorAll('.brand-section');const sideLinks=document.querySelectorAll('.sidebar-link');const mobLinks=document.querySelectorAll('.mobile-nav-link');_brandObserver=new IntersectionObserver(entries=>{entries.forEach(entry=>{if(entry.isIntersecting){sideLinks.forEach(l=>l.classList.remove('active'));mobLinks.forEach(l=>l.classList.remove('active'));const id=entry.target.id;const sideActive=document.querySelector(`.sidebar-link[href="#${id}"]`);if(sideActive)sideActive.classList.add('active');const mobActive=document.querySelector(`.mobile-nav-link[href="#${id}"]`);if(mobActive){mobActive.classList.add('active');mobActive.scrollIntoView({behavior:'smooth',block:'nearest',inline:'center'})}}})},{rootMargin:'-100px 0px -60% 0px'});sections.forEach(s=>_brandObserver!.observe(s));
  }

  document.addEventListener('astro:page-load', initBranding);
  document.addEventListener('astro:before-swap', cleanupBranding);
</script>
