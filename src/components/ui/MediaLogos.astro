---
/**
 * MediaLogos.astro
 * "As Featured In" media outlet logo bar using CF Images.
 * Logos are grayscale by default, darken on hover.
 * Used on homepage and publicity page.
 */
interface Props {
  theme?: 'light' | 'dark';
  linked?: boolean;
}

const { theme = 'dark', linked = true } = Astro.props;
import { getCollection } from 'astro:content';
import { CF_BASE as CF, cfSrcset, cfId } from '../../utils/cf-image';
const href = linked ? '/publicity' : undefined;

const allLogos = await getCollection('medialogos');
const logos = allLogos
  .map(entry => entry.data)
  .sort((a, b) => (a.order || 0) - (b.order || 0));
---

{logos.length > 0 && (
<div class="ml" data-theme={theme}>
  <div class="ml__label">As Featured</div>
  <div class="ml__row">
    {logos.map(logo => { const id = cfId(logo.logo); return href ? (
      <a href={href} class="ml__item" aria-label={`Featured on ${logo.name}`}>
        <img
          src={`${CF}/${id}/w=160,q=75`}
          srcset={cfSrcset(id, [120, 160, 240, 320], { quality: 75 })}
          sizes="160px"
          alt={logo.name}
          class="ml__logo"
          loading="eager"
          fetchpriority="low"
          decoding="async"
          width="160" height="48"
        />
      </a>
    ) : (
      <div class="ml__item">
        <img
          src={`${CF}/${id}/w=160,q=75`}
          srcset={cfSrcset(id, [120, 160, 240, 320], { quality: 75 })}
          sizes="160px"
          alt={logo.name}
          class="ml__logo"
          loading="eager"
          fetchpriority="low"
          decoding="async"
          width="160" height="48"
        />
      </div>
    )})}
  </div>
</div>
)}

<style>
  .ml {
    padding: 48px 0;
    overflow: hidden;
  }
  .ml[data-theme="dark"] {
    background: var(--c-warm-gray, #F5F4F0);
    border-top: 1px solid var(--c-border, #E5E4E0);
    border-bottom: 1px solid var(--c-border, #E5E4E0);
  }
  .ml[data-theme="light"] {
    background: rgba(255,255,255,0.04);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .ml__label {
    text-align: center;
    margin-bottom: 32px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }
  .ml[data-theme="dark"] .ml__label { color: var(--c-text-light, #6D6E74); }
  .ml[data-theme="light"] .ml__label { color: rgba(255,255,255,0.55); }

  .ml__row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 20px 48px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 2rem);
  }

  .ml__item {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .ml[data-theme="dark"] .ml__item { opacity: 0.35; }
  .ml[data-theme="light"] .ml__item { opacity: 0.4; }

  .ml__item:hover {
    opacity: 0.8 !important;
    transform: translateY(-1px);
  }

  .ml__logo {
    height: 48px;
    width: auto;
    max-width: 200px;
    object-fit: contain;
  }
  /* Light theme: invert the dark logos to white */
  .ml[data-theme="light"] .ml__logo {
    filter: invert(1) brightness(2);
  }

  /* ── Tablet ── */
  @media (max-width: 900px) {
    .ml__row { gap: 16px 32px; }
    .ml__logo { height: 40px; }
    .ml { padding: 40px 0; }
  }
  /* ── Mobile ── */
  @media (max-width: 600px) {
    .ml__row { gap: 12px 24px; }
    .ml__logo { height: 32px; }
    .ml { padding: 32px 0; }
    .ml__label { margin-bottom: 24px; }
  }
</style>
