      0 24px 64px rgba(0, 0, 0, 0.12);
  }

  .yt-facade,
  .stream-facade {
    position: relative;
    aspect-ratio: 16 / 9;
    cursor: pointer;
    background: var(--c-dark);
  }

  .video__thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), filter 0.5s ease;
  }

  .yt-facade:hover .video__thumb,
  .stream-facade:hover .video__thumb {
    transform: scale(1.04);
    filter: brightness(0.82);
  }

  .video__play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.92;
    transition: opacity 0.25s ease, transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    filter: drop-shadow(0 6px 24px rgba(0, 0, 0, 0.45));
  }

  .yt-facade:hover .video__play,
  .stream-facade:hover .video__play {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.1);
  }

  /* ═══ Bento Photo Gallery ════════════════════════════
     Warm gray background creates the emotional shift
     from "understanding the story" to "seeing the impact."
     Premium gallery with generous gaps and dramatic hover.
     ═══════════════════════════════════════════════════ */
  .gallery {
    padding-block: 80px;
    background: var(--c-warm-gray);
    content-visibility: auto;
    contain-intrinsic-size: auto 800px;
  }

  .gallery__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: 40px;
  }

  .gallery__header .section-label {
    margin-bottom: 0;
  }

  .gallery__credit {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--c-text-muted);
    font-size: 0.82rem;
    font-weight: 400;
  }

  /* ── Bento Grid — editorial gallery with breathing room ── */
  .bento {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 220px;
    gap: 10px;
  }

  .bento__hero {
    grid-column: span 2;
    grid-row: span 2;
  }

  .bento__tall {
    grid-row: span 2;
  }

  .bento__wide {
    grid-column: span 2;
  }

  .bento__cell {
    position: relative;
    display: block;
    border: none;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    border-radius: 10px;
    background-color: var(--c-cream);
    background-image: var(--lqip);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    transform: translateZ(0);
    transition: box-shadow 0.4s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .bento__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    position: relative;
    z-index: 2;
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1),
                filter 0.6s ease;
  }

  .bento__overlay {
    position: absolute;
    inset: 0;
    z-index: 3;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.45) 0%,
      rgba(0, 0, 0, 0.12) 25%,
      rgba(0, 0, 0, 0) 50%
    );
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 14px 16px;
    opacity: 0;
    transition: opacity 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
  }

  .bento__expand {
    color: rgba(255, 255, 255, 0.85);
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.4);
  }

  .bento__counter {
    color: rgba(255, 255, 255, 0.65);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    font-variant-numeric: tabular-nums;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.4);
  }

  /* ── Ken-Burns hover: cinematic drift + shadow lift ── */
  @media (hover: hover) {
    .bento__cell:hover {
      z-index: 2;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
      transform: translateZ(0) scale(1.01);
    }

    .bento__cell:hover .bento__img {
      transform: scale(1.06);
      transition-duration: 6s;
      transition-timing-function: cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .bento__cell:hover .bento__overlay {
      opacity: 1;
    }
  }

  .bento__cell:focus-visible {
    outline: 3px solid var(--c-yellow);
    outline-offset: 2px;
    z-index: 4;
  }

  /* ── Staggered bento entrance ── */
  @supports (animation-timeline: view()) {
    .bento__cell {
      animation: bento-enter 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
      animation-timeline: view();
      animation-range: entry 0% entry 35%;
    }

    @keyframes bento-enter {
      from {
        opacity: 0;
        transform: scale(0.96) translateY(8px);
      }
      to {
        opacity: 1;
        transform: scale(1) translateY(0);
      }
    }
  }

  /* ═══ Partners ═════════════════════════════ */
  .partners {
    padding-block: 80px;
    background: var(--c-white);
    content-visibility: auto;
    contain-intrinsic-size: auto 300px;
  }

  .partners__sub {
    text-align: center;
    color: var(--c-text-muted);
    font-size: 0.92rem;
    margin-top: -12px;
    margin-bottom: 40px;
    line-height: 1.5;
  }

  .partners__grid {
    display: flex;
    flex-wrap: wrap;
    gap: 32px;
    justify-content: center;
    align-items: center;
  }

  .partners__logo {
    width: 130px;
    opacity: 0.55;
    transition: opacity 0.4s ease, filter 0.4s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    filter: grayscale(80%);
  }

  .partners__logo:hover {
    opacity: 1;
    filter: grayscale(0%);
    transform: scale(1.1);
  }

  .partners__logo img {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  /* ═══ Related Kids — Premium Card Grid ════ */
  .related {
    padding-block: 80px;
    background: var(--c-warm-gray);
    content-visibility: auto;
    contain-intrinsic-size: auto 500px;
  }

  .related__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .related__card {
    text-decoration: none;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .related__img-wrap {
    position: relative;
    border-radius: var(--profile-radius);
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background-color: var(--c-cream);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    transition: box-shadow 0.5s ease;
  }

  .related__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    position: relative;
    z-index: 2;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (hover: hover) {
    .related__card:hover {
      transform: translateY(-8px);
    }
    .related__card:hover .related__img-wrap {
      box-shadow: 0 16px 48px rgba(0, 0, 0, 0.12);
    }
    .related__card:hover .related__img {
      transform: scale(1.06);
    }
  }

  .related__meta {
    padding: 14px 4px 0;
  }

  .related__name {
    display: block;
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--c-text);
    line-height: 1.3;
  }

  .related__tag {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-dark);
    background: rgba(255, 218, 36, 0.2);
    padding: 3px 8px;
    border-radius: 100px;
    margin-top: 6px;
  }

  .related__diagnosis {
    display: block;
    font-size: 0.8rem;
    color: var(--c-text-muted);
    line-height: 1.4;
    margin-top: 4px;
  }

  /* ═══ Prev / Next Nav — Refined ═══════════ */
  .kid-nav {
    border-top: 1px solid var(--c-border);
    padding-block: 32px;
    background: var(--c-cream);
  }

  .kid-nav__grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-lg);
  }

  .kid-nav__thumb {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .kid-nav__link {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    padding: 16px 20px;
    border-radius: 16px;
    transition: background 0.2s ease, box-shadow 0.2s ease;
  }

  .kid-nav__link:hover {
    background: var(--c-warm-gray);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .kid-nav__link--next {
    justify-self: end;
  }

  .kid-nav__label {
    display: block;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-text-muted);
    margin-bottom: 2px;
  }

  .kid-nav__name {
    display: block;
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--c-dark);
    line-height: 1.25;
  }

  .kid-nav__all {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--c-text-muted);
    font-size: 0.8rem;
    font-weight: 500;
    text-decoration: none;
    padding: 10px 16px;
    border-radius: 12px;
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .kid-nav__all:hover {
    color: var(--c-dark);
    background: var(--c-warm-gray);
  }

  /* ═══ CTA — Cinematic Dark Section ════════ */
  .cta {
    padding-block: 100px;
    background: var(--c-dark);
    position: relative;
  }

  /* Subtle gradient texture */
  .cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(255, 218, 36, 0.04) 0%, transparent 60%);
    pointer-events: none;
  }

  /* Giant decorative watermark text */
  .cta__watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-display);
    font-size: clamp(8rem, 20vw, 20rem);
    font-weight: 700;
    color: rgba(255, 255, 255, 0.04);
    white-space: nowrap;
    pointer-events: none;
    letter-spacing: -0.05em;
    line-height: 1;
    user-select: none;
  }

  .cta__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    color: var(--c-white);
    margin-bottom: 16px;
    letter-spacing: -0.02em;
    position: relative;
  }

  .cta__text {
    color: rgba(255, 255, 255, 0.65);
    font-size: 1.08rem;
    max-width: 480px;
    margin-inline: auto;
    margin-bottom: 36px;
    line-height: 1.65;
    position: relative;
  }

  .cta__buttons {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
    position: relative;
  }

  .cta__buttons :global(.btn--outline) {
    color: var(--c-white);
    box-shadow: inset 0 0 0 2px rgba(255, 255, 255, 0.35);
  }

  .cta__buttons :global(.btn--outline:hover) {
    background: rgba(255, 255, 255, 0.1);
    box-shadow: inset 0 0 0 2px rgba(255, 255, 255, 0.65);
    color: var(--c-white);
  }

  /* ═══ Lightbox — premium gallery ═══════════ */
  .lightbox[hidden] { display: none; }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Smooth open / close ─────────────────── */
  .lightbox__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    opacity: 0;
    transition: opacity 0.22s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .lightbox--open .lightbox__backdrop { opacity: 1; }

  .lightbox__close,
  .lightbox__nav {
    opacity: 0;
    transition: opacity 0.18s ease-out, background 0.15s ease-out;
  }
  .lightbox--open .lightbox__close,
  .lightbox--open .lightbox__nav { opacity: 1; }

  .lightbox__close {
    position: absolute;
    top: var(--space-lg);
    right: var(--space-lg);
    z-index: 10;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--c-white);
    cursor: pointer;
  }

  .lightbox__close:hover { background: rgba(255, 255, 255, 0.2); }

  .lightbox__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--c-white);
    cursor: pointer;
  }

  .lightbox__nav:hover { background: rgba(255, 255, 255, 0.2); }
  .lightbox__nav--prev { left: var(--space-lg); }
  .lightbox__nav--next { right: var(--space-lg); }

  /* ── Stage + frame layout ────────────────── */
  .lightbox__stage {
    position: relative;
    z-index: 5;
    /* Fixed viewport dimensions — images resize inside via object-fit,
       so landscape ↔ portrait never causes layout shift or frame resize.
       Directional slide always moves the same-sized box. */
    width: 90vw;
    height: 85vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    /* Entrance: scale up + fade in */
    transform: scale(0.94);
    opacity: 0;
    transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1),
                opacity 0.22s ease-out;
  }
  .lightbox--open .lightbox__stage {
    transform: scale(1);
    opacity: 1;
  }

  .lightbox__frame {
    position: relative;
    width: 100%;
    flex: 1 1 0%;
    min-height: 0;
    display: grid;
    grid-template: 1fr / 1fr;
    justify-items: center;
    align-items: center;
  }
  /* Promote to GPU layer only while lightbox is open */
  .lightbox--open .lightbox__frame {
    will-change: transform, opacity;
  }

  .lightbox__placeholder,
  .lightbox__img {
    grid-row: 1;
    grid-column: 1;
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 12px;
    outline: none;
    transition: opacity 0.12s ease-out;
  }
  .lightbox--open .lightbox__placeholder,
  .lightbox--open .lightbox__img {
    will-change: opacity;
  }

  .lightbox__placeholder {
    z-index: 1;
    filter: blur(2px);
    pointer-events: none;
  }

  .lightbox__img {
    z-index: 2;
  }

  /* ── Loading ring (appears after 180ms) ──── */
  .lightbox__loader {
    grid-row: 1;
    grid-column: 1;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease-out;
  }
  .lightbox__loader--visible { opacity: 1; }

  .lightbox__loader-ring {
    width: 36px;
    height: 36px;
    border: 3px solid rgba(255, 255, 255, 0.15);
    border-top-color: rgba(255, 255, 255, 0.7);
    border-radius: 50%;
    animation: lb-spin 0.7s linear infinite;
  }

  @keyframes lb-spin {
    to { transform: rotate(360deg); }
  }

  .lightbox__counter {
    flex-shrink: 0;
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  /* ── Reduced motion ─────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .lightbox__backdrop,
    .lightbox__close,
    .lightbox__nav,
    .lightbox__stage,
    .lightbox__placeholder,
    .lightbox__img,
    .lightbox__loader {
      transition: none !important;
    }
    .lightbox__stage {
      transform: none;
      opacity: 1;
    }
    .lightbox__backdrop { opacity: 1; }
    .lightbox__close,
    .lightbox__nav { opacity: 1; }
    .lightbox__loader-ring { animation: none; }
  }

  /* ═══ View Transitions ═════════════════════ */
  ::view-transition-group(kid-hero) {
    animation-duration: 280ms;
    animation-timing-function: cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  ::view-transition-group(kid-name) {
    animation-duration: 220ms;
    animation-timing-function: cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  /* ═══ Responsive: Tablet ═══════════════════ */
  @media (max-width: 1100px) {
    .related__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }

    .essay__break {
      border-radius: 16px;
    }

    .essay__quote {
      border-radius: 16px;
      margin-inline: var(--page-padding);
    }
  }

  /* ═══ Responsive: Mobile — Premium ════════ */
  @media (max-width: 768px) {
    .hero {
      padding-top: 24px;
    }

    .hero__split {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .hero__portrait {
      aspect-ratio: 4 / 5;
      max-height: 55vh;
    }

    .hero__info {
      padding: 28px var(--page-padding) 20px;
    }

    .hero__back {
      margin-bottom: 16px;
    }

    .hero__name {
      font-size: clamp(2.8rem, 13vw, 4.5rem);
      margin-bottom: 16px;
    }

    .hero__name::after {
      width: 36px;
      margin-top: 12px;
    }

    .hero__diagnosis {
      font-size: 1.02rem;
      max-width: none;
    }

    /* Touch targets: minimum 44px */
    .hero__donate-btn,
    .hero__share-btn {
      min-height: 44px;
      padding-inline: 24px;
    }

    .lede {
      padding: 48px 0 40px;
    }

    .lede::after {
      height: 80px;
    }

    .lede__text {
      font-size: 1.12rem;
    }

    .story {
      padding-block: 48px;
    }

    .story__body { font-size: 1.02rem; }

    /* Essay — tighter on mobile */
    .essay__flow { font-size: 1.02rem; }

    /* Breakout photos: edge-to-edge on mobile */
    .essay__break {
      border-radius: 0;
      box-shadow: none;
      margin-block: 1.8em 1.4em;
    }

    /* Floats become full-width on mobile — no wrapping on small screens */
    .essay__float {
      float: none;
      width: 100%;
      max-width: none;
      margin: 0 0 1.2em 0;
      border-radius: var(--profile-radius);
    }

    .essay__float--right,
    .essay__float--left {
      margin: 0 0 1.2em 0;
    }

    .essay__quote {
      padding: 48px var(--page-padding);
      border-radius: 0;
      margin-inline: calc(-1 * var(--page-padding));
      width: calc(100% + var(--page-padding) * 2);
      max-width: none;
      transform: none;
    }
    .essay__quote-mark { width: 44px; height: 44px; }
    .essay__quote p { font-size: 1.25rem; }

    .bento {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 180px;
      gap: 8px;
    }

    .bento__cell { border-radius: 8px; }

    .bento__hero {
      grid-column: 1 / -1;
      grid-row: span 2;
    }

    .bento__tall { grid-row: span 2; }
    .bento__wide { grid-column: 1 / -1; }

    .bento__expand { display: none; }

    .gallery { padding-block: 56px; }

    .related { padding-block: 56px; }
    .related__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
    .related__name { font-size: 0.92rem; }
    .related__diagnosis { font-size: 0.75rem; }
    .related__img-wrap {
      border-radius: 16px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    }

    .kid-nav__grid {
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    .kid-nav__all {
      grid-column: 1 / -1;
      justify-self: center;
      order: -1;
    }

    .kid-nav__link { padding: 10px; border-radius: 12px; }
    .kid-nav__name { font-size: 0.95rem; }
    .kid-nav__thumb { width: 36px; height: 36px; }

    .lightbox__nav--prev { left: 8px; }
    .lightbox__nav--next { right: 8px; }
    .lightbox__close { top: 8px; right: 8px; }
    .lightbox__nav, .lightbox__close { width: 44px; height: 44px; }

    .pullquote {
      padding: 28px 24px 28px 36px;
    }
    .pullquote p { font-size: 1.08rem; }

    .fundraise { padding-block: 32px; }
    .fundraise__card {
      flex-direction: column;
      text-align: center;
      padding: 28px 24px;
      gap: 16px;
    }

    .partners { padding-block: 56px; }
    .partners__logo { width: 100px; }
    .partners__grid { gap: 24px; }

    .cta { padding-block: 72px; }
