    )}

    <!-- ═══ Final CTA ═══ -->
    <section class="page-cta">
      <div class="container container--narrow">
        <div class="page-cta__inner">
          {kid.fundraisingUrl ? (
            <>
              <h2 class="page-cta__title">Support {kid.name}'s Room</h2>
              <p class="page-cta__text">100% of your donation goes directly to transforming {kid.name}'s space.</p>
              <a href={kid.fundraisingUrl} target="_blank" rel="noopener noreferrer" class="page-cta__btn">
                Donate Now
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </>
          ) : (
            <>
              <h2 class="page-cta__title">Help Kids Like {kid.name}</h2>
              <p class="page-cta__text">Every donation transforms a child's space into a place of comfort and joy.</p>
              <a href="/donate/" class="page-cta__btn">
                Donate Now
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </>
          )}
        </div>
      </div>
    </section>

    <!-- ═══ Prev / Next Navigation ═══ -->
    <nav class="kid-nav" aria-label="Navigate between kid profiles">
      <div class="container">
        <div class="kid-nav__grid">
          {prevKid ? (
            <a href={`/kids/${prevKid.slug}/`} class="kid-nav__link kid-nav__link--prev">
              <span class="kid-nav__arrow" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
              </span>
              <span class="kid-nav__name">{prevKid.name}</span>
            </a>
          ) : <span />}
          <a href="/kids/" class="kid-nav__all">All Kids</a>
          {nextKid ? (
            <a href={`/kids/${nextKid.slug}/`} class="kid-nav__link kid-nav__link--next">
              <span class="kid-nav__name">{nextKid.name}</span>
              <span class="kid-nav__arrow" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
              </span>
            </a>
          ) : <span />}
        </div>
      </div>
    </nav>
  </article>

  <!-- ═══ Lightbox ═══ -->
  <div id="lb-meta" data-gallery-count={galleryPhotos.length} data-plan-count={plans.length} hidden></div>
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer" hidden>
    <div class="lightbox__backdrop" data-close aria-hidden="true"></div>
    <button class="lightbox__close" data-close aria-label="Close photo viewer">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>
    <button class="lightbox__nav lightbox__nav--prev" id="lb-prev" aria-label="Previous photo">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </button>
    <button class="lightbox__nav lightbox__nav--next" id="lb-next" aria-label="Next photo">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>
    <div class="lightbox__stage" id="lb-stage">
      <div class="lightbox__frame" id="lb-frame">
        <img class="lightbox__placeholder" id="lb-placeholder" src="" alt="" aria-hidden="true" />
        <img class="lightbox__img" id="lb-img" src="" alt="" tabindex="0" />
        <div class="lightbox__loader" id="lb-loader" aria-hidden="true">
          <div class="lightbox__loader-ring"></div>
        </div>
      </div>
      <p class="lightbox__counter" id="lb-counter" aria-live="polite"></p>
    </div>
  </div>
</BaseLayout>

<!-- ═══ Client-side JS ═══ -->
<script>
  let _kidObserver: IntersectionObserver | null = null;
  let _staggerObserver: IntersectionObserver | null = null;
  let _chapterObserver: IntersectionObserver | null = null;
  let _revealObserver: IntersectionObserver | null = null;
  let _galleryCascadeObserver: IntersectionObserver | null = null;
  let _cleanupFns: (() => void)[] = [];

  function cleanupKidPage() {
    _kidObserver?.disconnect();
    _kidObserver = null;
    _staggerObserver?.disconnect();
    _staggerObserver = null;
    _chapterObserver?.disconnect();
    _chapterObserver = null;
    _revealObserver?.disconnect();
    _revealObserver = null;
    _galleryCascadeObserver?.disconnect();
    _galleryCascadeObserver = null;
    _cleanupFns.forEach(fn => fn());
    _cleanupFns = [];
    document.documentElement.classList.remove('kid-page-active');
  }

  function initKidPage() {
    cleanupKidPage();
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Override global scroll-padding for accurate chapter nav positioning
    document.documentElement.classList.add('kid-page-active');

    // ── Premium Hero Choreography ────────────────
    const heroElements = {
      eyebrow: document.querySelector('[data-reveal="eyebrow"]'),
      name: document.querySelector('[data-reveal="name"]'),
      diagnosis: document.querySelector('[data-reveal="diagnosis"]'),
      transform: document.querySelector('[data-reveal="transform"]'),
      hook: document.querySelector('[data-reveal="hook"]'),
      actions: document.querySelector('[data-reveal="actions"]'),
      meta: document.querySelector('[data-reveal="meta"]'),
      accent: document.querySelector('[data-reveal="accent"]'),
      connector: document.querySelector('.hero__connector'),
    };

    // Orchestrated timing sequence (in ms)
    const heroTiming = {
      eyebrow: 100,
      name: 200,
      diagnosis: 400,
      transform: 550,
      hook: 700,
      actions: 850,
      meta: 950,
      accent: 500,
      connector: 400,
    };

    if (!prefersReducedMotion) {
      // Choreographed reveal sequence
      Object.entries(heroTiming).forEach(([key, delay]) => {
        const el = heroElements[key as keyof typeof heroElements];
        if (el) {
          setTimeout(() => el.classList.add('revealed'), delay);
        }
      });
    } else {
      // Instant reveal for reduced motion
      Object.values(heroElements).forEach(el => {
        if (el) el.classList.add('revealed');
      });
    }

    // Legacy stagger support for any remaining elements
    const heroStaggers = document.querySelectorAll('.hero .stagger');
    heroStaggers.forEach((el, i) => {
      const htmlEl = el as HTMLElement;
      htmlEl.style.setProperty('--stagger-delay', `${i * 50}ms`);
      requestAnimationFrame(() => htmlEl.classList.add('stagger--visible'));
    });

    // ── Staggered section reveals ─────────────
    if (!prefersReducedMotion) {
      _staggerObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const section = entry.target as HTMLElement;
              section.classList.add('stagger-section--visible');
              _staggerObserver?.unobserve(section);
            }
          });
        },
        { rootMargin: '40px', threshold: 0.08 }
      );
      document.querySelectorAll('.stagger-section').forEach(el => {
        _staggerObserver!.observe(el);
      });
    } else {
      document.querySelectorAll('.stagger-section').forEach(el => {
        el.classList.add('stagger-section--visible');
      });
    }

    // ── Per-element scroll reveals ────────────
    if (!prefersReducedMotion) {
      _revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              (entry.target as HTMLElement).classList.add('revealed');
              _revealObserver?.unobserve(entry.target);
            }
          });
        },
        { rootMargin: '20px', threshold: 0.1 }
      );
      document.querySelectorAll('[data-reveal]').forEach(el => {
        _revealObserver!.observe(el);
      });
    } else {
      document.querySelectorAll('[data-reveal]').forEach(el => {
        el.classList.add('revealed');
      });
    }

    // ── Gallery cascade ───────────────────────
    const galleryGrid = document.getElementById('gallery');
    if (galleryGrid && !prefersReducedMotion) {
      _galleryCascadeObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              galleryGrid.classList.add('gallery__grid--visible');
              _galleryCascadeObserver?.unobserve(galleryGrid);
            }
          });
        },
        { rootMargin: '40px', threshold: 0.05 }
      );
      _galleryCascadeObserver.observe(galleryGrid);
    } else if (galleryGrid) {
      galleryGrid.classList.add('gallery__grid--visible');
    }


    // ── Sticky Chapter Nav (Elite Spring Physics) ────────────
    const chapterNav = document.getElementById('chapter-nav');
    const chapterLinks = document.querySelectorAll<HTMLAnchorElement>('.chapter-nav__link');
    const chapterSections = document.querySelectorAll<HTMLElement>('[data-chapter]');
    const chapterTrack = document.querySelector<HTMLElement>('.chapter-nav__track');
    const chapterPill = document.querySelector<HTMLElement>('.chapter-nav__pill');

    if (chapterNav && chapterLinks.length && chapterSections.length && chapterTrack && chapterPill) {
      /* ── Show nav after scrolling past hero ── */
      const heroSection = document.querySelector('.hero');
      if (heroSection) {
        const navVisibilityObserver = new IntersectionObserver(
          ([entry]) => {
            chapterNav.classList.toggle('is-visible', !entry.isIntersecting || entry.intersectionRatio < 0.3);
          },
          { threshold: [0, 0.3, 0.5, 1] }
        );
        navVisibilityObserver.observe(heroSection);
        (_cleanupFns as (() => void)[]).push(() => navVisibilityObserver.disconnect());
      }

      /* ── Stuck shadow ── */
      const sentinel = document.createElement('div');
      sentinel.style.cssText = 'height:1px;width:1px;pointer-events:none;position:absolute;';
      chapterNav.before(sentinel);
      const stuckObs = new IntersectionObserver(
        ([e]) => { chapterNav.classList.toggle('is-stuck', !e.isIntersecting); },
        { threshold: 0 }
      );
      stuckObs.observe(sentinel);
      (_cleanupFns as (() => void)[]).push(() => { stuckObs.disconnect(); sentinel.remove(); });

      /* ── Spring physics for pill ── */
      const TENSION = 170, FRICTION = 26;
      let pillX = 0, pillW = 80, pillVelX = 0, pillVelW = 0;
      let pillTargetX = 0, pillTargetW = 80;
      let pillRaf: number | null = null;

      function springStep(cur: number, vel: number, target: number, dt: number): [number, number] {
        const force = -TENSION * (cur - target) - FRICTION * vel;
        return [cur + vel * dt, vel + force * dt];
      }

      function animatePill() {
        const dt = 1 / 60;
        [pillX, pillVelX] = springStep(pillX, pillVelX, pillTargetX, dt);
        [pillW, pillVelW] = springStep(pillW, pillVelW, pillTargetW, dt);
        chapterPill!.style.transform = `translateX(${pillX}px) translateY(-50%)`;
        chapterPill!.style.width = `${pillW}px`;
        const moving = Math.abs(pillVelX) > 0.01 || Math.abs(pillVelW) > 0.01 ||
                       Math.abs(pillX - pillTargetX) > 0.1 || Math.abs(pillW - pillTargetW) > 0.1;
        if (moving && !prefersReducedMotion) {
          pillRaf = requestAnimationFrame(animatePill);
        } else {
          pillX = pillTargetX; pillW = pillTargetW;
          chapterPill!.style.transform = `translateX(${pillX}px) translateY(-50%)`;
          chapterPill!.style.width = `${pillW}px`;
          pillRaf = null;
        }
      }

      function movePill(link: HTMLElement, instant = false) {
        const trackRect = chapterTrack!.getBoundingClientRect();
        const linkRect = link.getBoundingClientRect();
        pillTargetX = linkRect.left - trackRect.left + chapterTrack!.scrollLeft;
        pillTargetW = linkRect.width;
        if (instant || prefersReducedMotion) {
          pillX = pillTargetX; pillW = pillTargetW;
          pillVelX = pillVelW = 0;
          chapterPill!.style.transform = `translateX(${pillX}px) translateY(-50%)`;
          chapterPill!.style.width = `${pillW}px`;
        } else if (!pillRaf) {
          pillRaf = requestAnimationFrame(animatePill);
        }
      }

      /* ── Activate a link ── */
      function activate(id: string, instant = false) {
        chapterLinks.forEach(l => {
          const active = l.dataset.target === id;
          l.classList.toggle('is-active', active);
          if (active) {
            movePill(l, instant);
            // Center active link in track
            const sl = l.offsetLeft - chapterTrack!.offsetWidth / 2 + l.offsetWidth / 2;
            chapterTrack!.scrollTo({ left: sl, behavior: instant ? 'auto' : 'smooth' });
          }
        });
      }

      /* ── Init pill position ── */
      const firstActive = chapterTrack.querySelector<HTMLAnchorElement>('.chapter-nav__link.is-active');
      if (firstActive) {
        movePill(firstActive, true);
        requestAnimationFrame(() => chapterPill.classList.add('is-ready'));
        document.fonts.ready.then(() => {
          const active = chapterTrack.querySelector<HTMLElement>('.chapter-nav__link.is-active');
          if (active) movePill(active, true);
        });
      }

      /* ── Scroll-spy ── */
      let clickScrolling = false;
      _chapterObserver = new IntersectionObserver((entries) => {
        if (clickScrolling) return;
        for (const e of entries) {
          if (e.isIntersecting && e.target.id) {
            activate(e.target.id);
            break;
          }
        }
      }, { rootMargin: '-25% 0px -65% 0px' });
      chapterSections.forEach(t => { if (t.id) _chapterObserver!.observe(t); });

      /* ── Scroll offset ── */
      function getOffset() {
        const headerH = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--header-height')) || 84;
        return headerH + chapterNav.offsetHeight - 2;
      }

      /* ── Click ── */
      chapterLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          const hash = link.hash || link.getAttribute('href');
          const section = hash && document.querySelector<HTMLElement>(hash);
          if (!section) return;
          e.preventDefault();
          clickScrolling = true;
          activate(link.dataset.target || section.id);
          const top = section.getBoundingClientRect().top + window.scrollY - getOffset();
          window.scrollTo({ top, behavior: prefersReducedMotion ? 'auto' : 'smooth' });
          setTimeout(() => { clickScrolling = false; }, prefersReducedMotion ? 100 : 800);
        });
      });

      /* ── Resize handler ── */
      const handleResize = () => {
        const active = chapterTrack.querySelector<HTMLElement>('.chapter-nav__link.is-active');
        if (active) movePill(active, true);
      };
      window.addEventListener('resize', handleResize, { passive: true });
      (_cleanupFns as (() => void)[]).push(() => {
        window.removeEventListener('resize', handleResize);
        if (pillRaf) cancelAnimationFrame(pillRaf);
      });
    }

    // ── Before/After Sliders (Best-in-Class) ────
    // Physics: momentum with friction, spring bounce at edges
    const FRICTION = 0.92, MIN_VEL = 0.1, SPRING = 0.15, VEL_SCALE = 0.4;

    // Keyboard: arrows for fine control
    let activeSlider: { upd: (v:number)=>void; pos:()=>number } | null = null;
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft' || e.key === 'ArrowRight') {
        const d = (e.key === 'ArrowLeft' ? -1 : 1) * (e.shiftKey ? 10 : 1);
        if (activeSlider) { e.preventDefault(); activeSlider.upd(Math.max(0, Math.min(100, activeSlider.pos() + d))); }
      }
    });

    document.querySelectorAll<HTMLElement>('[data-ba-slider]').forEach(slider => {
      const container = slider.querySelector<HTMLElement>('[data-ba-container]');
      const range = slider.querySelector<HTMLInputElement>('.ba-slider__range');
      const hint = slider.querySelector<HTMLElement>('[data-ba-hint]');
      const labelBefore = slider.querySelector<HTMLElement>('[data-ba-label="before"]');
      const labelAfter = slider.querySelector<HTMLElement>('[data-ba-label="after"]');
      if (!container || !range) return;

      let pos = 50, vel = 0, momRaf: number | null = null, interacted = false;
      let isDrag = false, lastX = 0, lastT = 0, vels: number[] = [];

      const updatePos = (v: number, sync = true) => {
        pos = Math.max(0, Math.min(100, v));
        container.style.setProperty('--ba-pos', `${pos}%`);
        if (sync) range.value = String(pos);
        if (labelBefore) labelBefore.toggleAttribute('data-fade', pos < 20);
        if (labelAfter) labelAfter.toggleAttribute('data-fade', pos > 80);
      };

      const hideHint = () => { if (hint && !interacted) { interacted = true; hint.hidden = true; } };
      const getP = (x: number) => ((x - container.getBoundingClientRect().left) / container.getBoundingClientRect().width) * 100;

      // Momentum animation loop
      const runMomentum = () => {
        vel *= FRICTION;
        let p = pos + vel;
        if (p < 0) { p = 0; vel = -vel * SPRING; } else if (p > 100) { p = 100; vel = -vel * SPRING; }
        updatePos(p);
        if (Math.abs(vel) > MIN_VEL) momRaf = requestAnimationFrame(runMomentum);
      };

      // Double-tap to reset to center
      let lastTap = 0;
      container.addEventListener('touchend', (e) => {
        const now = Date.now();
        if (now - lastTap < 300) {
          e.preventDefault();
          // Animate to center
          if (!prefersReducedMotion) {
            const from = pos, to = 50;
            let start: number | null = null;
            const anim = (ts: number) => {
              if (!start) start = ts;
              const p = Math.min((ts - start) / 300, 1);
              const ease = 1 - Math.pow(1 - p, 3);
              updatePos(from + (to - from) * ease);
              if (p < 1) requestAnimationFrame(anim);
            };
            requestAnimationFrame(anim);
          } else {
            updatePos(50);
          }
        }
        lastTap = now;
      }, { passive: false });

      // Pointer events for buttery-smooth dragging with momentum
      container.addEventListener('pointerdown', (e) => {
        if ((e.target as HTMLElement).closest('button')) return;
        isDrag = true; lastX = e.clientX; lastT = performance.now(); vels = [];
        if (momRaf) cancelAnimationFrame(momRaf);
        vel = 0; hideHint();
        container.setPointerCapture(e.pointerId);
        container.classList.add('is-dragging');
        // Prevent scroll during drag
        document.body.style.touchAction = 'none';
        document.body.style.overscrollBehavior = 'none';
        activeSlider = { upd: (v) => updatePos(v), pos: () => pos };
      });

      container.addEventListener('pointermove', (e) => {
        if (!isDrag) return;
        const now = performance.now(), dt = now - lastT, dx = e.clientX - lastX;
        if (dt > 0) { vels.push((dx / container.getBoundingClientRect().width) * 100 / dt * 16); if (vels.length > 5) vels.shift(); }
        lastX = e.clientX; lastT = now;
        updatePos(getP(e.clientX));
      });

      const onUp = (e: PointerEvent) => {
        if (!isDrag) return;
        isDrag = false;
        container.releasePointerCapture(e.pointerId);
        container.classList.remove('is-dragging');
        // Restore scroll
        document.body.style.touchAction = '';
        document.body.style.overscrollBehavior = '';
        // Apply momentum if we have velocity samples
        if (vels.length && !prefersReducedMotion) {
          vel = vels.reduce((a,b) => a+b, 0) / vels.length * VEL_SCALE;
          if (Math.abs(vel) > MIN_VEL) runMomentum();
        }
      };
      container.addEventListener('pointerup', onUp);
      container.addEventListener('pointercancel', onUp);

      // Range input for accessibility
      range.addEventListener('input', () => { hideHint(); updatePos(parseFloat(range.value), false); });
      range.addEventListener('focus', () => { activeSlider = { upd: (v) => updatePos(v), pos: () => pos }; });

      // Auto-reveal with overshoot easing (easeOutBack)
      if (!prefersReducedMotion) {
        pos = 100; updatePos(100);
        const obs = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              obs.disconnect();
              let start: number | null = null;
              const dur = 1600;
              const easeOutBack = (t: number) => { const c = 1.70158; return 1 + (c+1) * Math.pow(t-1,3) + c * Math.pow(t-1,2); };
              const anim = (ts: number) => {
                if (!start) start = ts;
                const p = Math.min((ts - start) / dur, 1);
                updatePos(100 + (50 - 100) * easeOutBack(p));
                if (p < 1) requestAnimationFrame(anim);
              };
              requestAnimationFrame(anim);
            }
          });
        }, { threshold: 0.4 });
        obs.observe(slider);
      }
    });

    // Scroll progress — CSS animation-timeline with JS fallback
    const progressBar = document.querySelector('.scroll-progress') as HTMLElement;
    if (progressBar && !CSS.supports('animation-timeline', 'scroll()')) {
      const updateProgress = () => {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? Math.min(scrollTop / docHeight, 1) : 0;
        progressBar.style.transform = `scaleX(${progress})`;
      };
      progressBar.style.animation = 'none';
      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    }

    // ── Story expand button (smooth height animation) ──��──────────────
    const storyExpand = document.getElementById('story-expand');
    const storyMore = document.getElementById('story-more');
    if (storyExpand && storyMore) {
      storyExpand.addEventListener('click', () => {
        const isExpanded = storyExpand.getAttribute('aria-expanded') === 'true';

        if (isExpanded) {
          // Collapse: animate height to 0, then hide
          const height = storyMore.scrollHeight;
          storyMore.style.height = `${height}px`;
          storyMore.offsetHeight; // force reflow
          storyMore.style.height = '0';
          storyMore.style.opacity = '0';
          setTimeout(() => {
            storyMore.hidden = true;
            storyMore.style.height = '';
            storyMore.style.opacity = '';
          }, prefersReducedMotion ? 10 : 400);
        } else {
          // Expand: show then animate height from 0
          storyMore.hidden = false;
          storyMore.style.height = '0';
          storyMore.style.opacity = '0';
          storyMore.offsetHeight; // force reflow
          const height = storyMore.scrollHeight;
          storyMore.style.height = `${height}px`;
          storyMore.style.opacity = '1';
          setTimeout(() => {
            storyMore.style.height = ''; // allow natural height
          }, prefersReducedMotion ? 10 : 400);
        }

        storyExpand.setAttribute('aria-expanded', String(!isExpanded));
        storyExpand.textContent = isExpanded ? 'Continue reading' : 'Show less';
      });
    }

    // ── Gallery expand button ─────────────────
    const expandBtn = document.getElementById('gallery-expand');
    const overflowEl = document.getElementById('gallery-overflow');
    if (expandBtn && overflowEl) {
      expandBtn.addEventListener('click', () => {
        overflowEl.hidden = false;
        expandBtn.style.display = 'none';
        // Re-wire lightbox for new items
        const newItems = overflowEl.querySelectorAll<HTMLButtonElement>('.masonry__item');
        newItems.forEach((item) => {
          item.addEventListener('click', () => {
            const idx = parseInt(item.dataset.index || '0', 10);
            openLightboxAtIndex(idx);
          });
        });
      });
    }

    // ── YouTube facade ──────────────────────
    const facade = document.getElementById('yt-facade');
    const revealFrame = document.querySelector('.reveal__frame') as HTMLElement;
    if (facade) {
      const activate = () => {
        const id = facade.dataset.id;
        // Show loading state
        revealFrame?.classList.add('reveal__frame--loading');
        const wrapper = document.createElement('div');
        wrapper.style.cssText = 'position:relative;aspect-ratio:16/9;overflow:hidden';
        const iframe = document.createElement('iframe');
        iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
        iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
        iframe.allowFullscreen = true;
        iframe.title = 'Video player';
        iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;opacity:0;transition:opacity 0.3s ease';
        iframe.onload = () => {
          iframe.style.opacity = '1';
          revealFrame?.classList.remove('reveal__frame--loading');
        };
        wrapper.appendChild(iframe);
        facade.replaceWith(wrapper);
      };
      facade.addEventListener('click', activate);
      facade.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(); }
      });
    }

    // ── Cloudflare Stream facade ────────────
    const streamFacade = document.getElementById('stream-facade');
    if (streamFacade) {
      const activateStream = () => {
        const id = streamFacade.dataset.id;
        // Show loading state
        revealFrame?.classList.add('reveal__frame--loading');
        const wrapper = document.createElement('div');
        wrapper.style.cssText = 'position:relative;aspect-ratio:16/9;overflow:hidden';
        const iframe = document.createElement('iframe');
        iframe.src = `https://iframe.videodelivery.net/${id}?autoplay=true&preload=true`;
        iframe.allow = 'accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture';
        iframe.allowFullscreen = true;
        iframe.title = 'Video player';
        iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;opacity:0;transition:opacity 0.3s ease';
        iframe.onload = () => {
          iframe.style.opacity = '1';
          revealFrame?.classList.remove('reveal__frame--loading');
        };
        wrapper.appendChild(iframe);
        streamFacade.replaceWith(wrapper);
      };
      streamFacade.addEventListener('click', activateStream);
      streamFacade.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activateStream(); }
      });
    }

    // ═══ Lightbox — unified gallery + plans ═══
    const lightbox = document.getElementById('lightbox') as HTMLElement;
    const lbImg = document.getElementById('lb-img') as HTMLImageElement;
    const lbPlaceholder = document.getElementById('lb-placeholder') as HTMLImageElement;
    const lbFrame = document.getElementById('lb-frame') as HTMLElement;
    const lbLoader = document.getElementById('lb-loader') as HTMLElement;
    const lbCounter = document.getElementById('lb-counter') as HTMLElement;
    const lbPrev = document.getElementById('lb-prev') as HTMLButtonElement;
    const lbNext = document.getElementById('lb-next') as HTMLButtonElement;
    // Sort masonry items by data-index to ensure correct lightbox order
    const sortByDataIndex = (items: NodeListOf<HTMLButtonElement> | HTMLButtonElement[]) => {
      return Array.from(items).sort((a, b) => {
        const aIdx = parseInt(a.dataset.index || '0', 10);
        const bIdx = parseInt(b.dataset.index || '0', 10);
        return aIdx - bIdx;
      });
    };
    let galleryItems: HTMLButtonElement[] = sortByDataIndex(document.querySelectorAll<HTMLButtonElement>('.masonry__item'));

    const lbMeta = document.getElementById('lb-meta');
    const galleryCount = parseInt(lbMeta?.dataset.galleryCount || '0', 10);
    const planCount = parseInt(lbMeta?.dataset.planCount || '0', 10);

    // Expose for gallery expand
    function openLightboxAtIndex(index: number) {
      openLightbox(index);
    }
    (window as any).__openLightbox = openLightboxAtIndex;

    if (lightbox && galleryItems.length > 0) {
      let currentIndex = 0;
      let previousFocus: HTMLElement | null = null;
      let navGeneration = 0;
      let loaderTimer = 0;

      const cache = new Map<number, { img: HTMLImageElement; decoded: boolean; promise: Promise<HTMLImageElement> }>();

      function ensureCached(index: number): { img: HTMLImageElement; decoded: boolean; promise: Promise<HTMLImageElement> } {
        // Refresh list in case overflow was expanded
        galleryItems = sortByDataIndex(document.querySelectorAll<HTMLButtonElement>('.masonry__item'));
        if (cache.has(index)) return cache.get(index)!;
        const item = galleryItems[index];
        if (!item) {
          const dummy = new Image();
          return { img: dummy, decoded: false, promise: Promise.resolve(dummy) };
        }
        const img = new Image();
        img.srcset = item.dataset.srcset || '';
        img.sizes = '90vw';
        img.src = item.dataset.src || '';
        const entry = {
          img,
          decoded: false,
          promise: (img.decode
            ? img.decode().then(() => { entry.decoded = true; return img; }).catch(() => { entry.decoded = true; return img; })
            : new Promise<HTMLImageElement>(r => { img.onload = img.onerror = () => { entry.decoded = true; r(img); }; })
          ),
        };
        cache.set(index, entry);
        return entry;
      }

      function getPreloadRadius(): number {
        const conn = (navigator as any).connection;
        if (!conn) return 3;
        // Respect data saver mode
        if (conn.saveData) return 0;
        const et = conn.effectiveType;
        if (et === '4g') return 3;
        if (et === '3g') return 1;
        return 0; // 2g or slow-2g
      }

      function preloadNeighbours(center: number) {
        galleryItems = sortByDataIndex(document.querySelectorAll<HTMLButtonElement>('.masonry__item'));
        const r = getPreloadRadius();
        for (let d = 1; d <= r; d++) {
          if (center + d < galleryItems.length) ensureCached(center + d);
          if (center - d >= 0) ensureCached(center - d);
        }
      }

      let idlePreloadStarted = false;
      function startIdlePreload() {
        if (idlePreloadStarted) return;
        // Skip idle preload if user has data saver enabled
        const conn = (navigator as any).connection;
        if (conn?.saveData) return;
        idlePreloadStarted = true;
        const ric = (window as any).requestIdleCallback || ((cb: Function) => setTimeout(cb, 200));
        let nextIdx = 0;
        function step(deadline?: { timeRemaining: () => number }) {
          galleryItems = sortByDataIndex(document.querySelectorAll<HTMLButtonElement>('.masonry__item'));
          const budget = deadline ? deadline.timeRemaining() : 16;
          while (nextIdx < galleryItems.length && budget > 2) {
            ensureCached(nextIdx);
            nextIdx++;
            if (nextIdx % 4 === 0) break;
          }
          if (nextIdx < galleryItems.length) ric(step);
        }
        ric(step);
      }

      function showLoader() {
        clearTimeout(loaderTimer);
        lbLoader.classList.remove('lightbox__loader--visible');
        loaderTimer = window.setTimeout(() => {
          lbLoader.classList.add('lightbox__loader--visible');
        }, 180);
      }
      function hideLoader() {
        clearTimeout(loaderTimer);
        lbLoader.classList.remove('lightbox__loader--visible');
      }

      function slideFrame(direction: number) {
        if (prefersReducedMotion || direction === 0) return;
        lbFrame.getAnimations().forEach(a => a.cancel());
        const dist = direction > 0 ? 40 : -40;
        lbFrame.animate([
          { transform: `translateX(${dist}px)`, opacity: 0.7 },
          { transform: 'translateX(0)', opacity: 1 },
        ], {
          duration: 180,
          easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
          fill: 'none',
        });
      }

      function showPhoto(index: number, direction: number = 0) {
        galleryItems = sortByDataIndex(document.querySelectorAll<HTMLButtonElement>('.masonry__item'));
        const item = galleryItems[index];
        if (!item) return;
        currentIndex = index;
        const gen = ++navGeneration;
        const alt = item.dataset.alt || '';

        slideFrame(direction);

        const lqipUrl = item.style.getPropertyValue('--lqip');
        const lqipMatch = lqipUrl.match(/url\(['"]?([^'"]+)['"]?\)/);
        if (lqipMatch) lbPlaceholder.src = lqipMatch[1];
        const thumbImg = item.querySelector('img') as HTMLImageElement | null;
        if (thumbImg && thumbImg.currentSrc) lbPlaceholder.src = thumbImg.currentSrc;
        lbPlaceholder.alt = alt;
        lbPlaceholder.style.opacity = '1';

        const entry = ensureCached(index);
        const isPlanItem = item.dataset.plan === 'true';
        const imgSizes = isPlanItem ? 'min(900px, 80vw)' : '90vw';

        if (entry.decoded && entry.img.complete && entry.img.naturalWidth > 0) {
          hideLoader();
          lbImg.srcset = entry.img.srcset;
          lbImg.sizes = imgSizes;
          lbImg.src = entry.img.src;
          lbImg.alt = alt;
          lbImg.style.opacity = '1';
          lbPlaceholder.style.opacity = '0';
        } else {
          lbImg.style.opacity = '0';
          showLoader();
          entry.promise.then((img) => {
            if (navGeneration !== gen) return;
            hideLoader();
            lbImg.srcset = img.srcset;
            lbImg.sizes = imgSizes;
            lbImg.src = img.src;
            lbImg.alt = alt;
            const ready = lbImg.decode ? lbImg.decode().catch(() => {}) : Promise.resolve();
            ready.then(() => {
              if (navGeneration !== gen) return;
              lbImg.style.opacity = '1';
              lbPlaceholder.style.opacity = '0';
            });
          });
        }

        const dataIdx = parseInt(item.dataset.index || '0', 10);
        const isPlan = item.dataset.plan === 'true' || (planCount > 0 && dataIdx >= galleryCount);
        lightbox.classList.toggle('lightbox--plan', isPlan);
        if (isPlan) {
          lbCounter.textContent = `Plan ${dataIdx - galleryCount + 1} / ${planCount}`;
        } else {
          lbCounter.textContent = galleryCount > 0
            ? `Photo ${dataIdx + 1} / ${galleryCount}`
            : `${index + 1} / ${galleryItems.length}`;
        }

        lbPrev.style.visibility = index === 0 ? 'hidden' : '';
        lbPrev.style.pointerEvents = index === 0 ? 'none' : '';
        lbNext.style.visibility = index === galleryItems.length - 1 ? 'hidden' : '';
        lbNext.style.pointerEvents = index === galleryItems.length - 1 ? 'none' : '';
        preloadNeighbours(index);
      }

      function openLightbox(index: number) {
        previousFocus = document.activeElement as HTMLElement;
        showPhoto(index, 0);
        lightbox.hidden = false;
        document.body.style.overflow = 'hidden';
        if (!prefersReducedMotion) {
          lightbox.classList.remove('lightbox--open');
          requestAnimationFrame(() => {
            requestAnimationFrame(() => lightbox.classList.add('lightbox--open'));
          });
        } else {
          lightbox.classList.add('lightbox--open');
        }
        lbImg.focus();
        startIdlePreload();
      }

      function closeLightbox() {
        hideLoader();
        if (!prefersReducedMotion) {
          lightbox.classList.remove('lightbox--open');
          const onDone = () => {
            lightbox.hidden = true;
            lightbox.classList.remove('lightbox--plan');
            lightbox.removeEventListener('transitionend', onDone);
          };
          lightbox.addEventListener('transitionend', onDone);
          setTimeout(() => { lightbox.hidden = true; lightbox.classList.remove('lightbox--plan'); }, 300);
        } else {
          lightbox.classList.remove('lightbox--open');
          lightbox.classList.remove('lightbox--plan');
          lightbox.hidden = true;
        }
        document.body.style.overflow = '';
        previousFocus?.focus();
      }

      function trapFocus(e: KeyboardEvent) {
        if (e.key !== 'Tab') return;
        const focusable = lightbox.querySelectorAll<HTMLElement>(
          'button:not([hidden]), [tabindex="0"]'
        );
        const list = Array.from(focusable).filter(el =>
          el.offsetParent !== null && getComputedStyle(el).visibility !== 'hidden'
        );
        if (list.length === 0) return;
        const first = list[0];
        const last = list[list.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }

      function goNext() {
        galleryItems = sortByDataIndex(document.querySelectorAll<HTMLButtonElement>('.masonry__item'));
        if (currentIndex < galleryItems.length - 1) showPhoto(currentIndex + 1, 1);
      }
      function goPrev() { if (currentIndex > 0) showPhoto(currentIndex - 1, -1); }

      galleryItems.forEach((item, i) => {
        item.addEventListener('click', () => openLightbox(i));
        item.addEventListener('pointerenter', () => ensureCached(i), { passive: true });
      });

      const galleryEl = document.getElementById('gallery');
      if (galleryEl) {
        galleryEl.addEventListener('pointerenter', () => {
          for (let i = 0; i < Math.min(5, galleryItems.length); i++) ensureCached(i);
        }, { once: true, passive: true });
      }

      // Visible plan card buttons - open lightbox at their data-lb-index
      document.querySelectorAll<HTMLButtonElement>('.design__item[data-lb-index]').forEach(btn => {
        btn.addEventListener('click', () => {
          const idx = parseInt(btn.dataset.lbIndex || '0', 10);
          openLightbox(idx);
        });
      });

      // View All Plans button - opens lightbox at first plan
      const viewAllBtn = document.getElementById('design-view-all');
      if (viewAllBtn) {
        viewAllBtn.addEventListener('click', () => {
          const firstPlanIndex = parseInt(viewAllBtn.dataset.firstPlanIndex || '0', 10);
          openLightbox(firstPlanIndex);
        });
      }

      lbPrev.addEventListener('click', goPrev);
      lbNext.addEventListener('click', goNext);

      lightbox.querySelectorAll('[data-close]').forEach(el => {
        el.addEventListener('click', closeLightbox);
      });

      lightbox.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') goPrev();
        if (e.key === 'ArrowRight') goNext();
        trapFocus(e);
      });

      // ── Premium touch gestures with velocity detection ──
      let touchStartX = 0;
      let touchStartY = 0;
      let touchStartTime = 0;
      let isSwiping = false;

      lightbox.addEventListener('touchstart', (e: TouchEvent) => {
        touchStartX = e.changedTouches[0].screenX;
        touchStartY = e.changedTouches[0].screenY;
        touchStartTime = Date.now();
        isSwiping = false;
      }, { passive: true });

      lightbox.addEventListener('touchmove', (e: TouchEvent) => {
        if (isSwiping) return;
        const dx = e.changedTouches[0].screenX - touchStartX;
        const dy = e.changedTouches[0].screenY - touchStartY;
        // Detect horizontal swipe intent early
        if (Math.abs(dx) > 10 && Math.abs(dx) > Math.abs(dy) * 1.2) {
          isSwiping = true;
        }
      }, { passive: true });

      lightbox.addEventListener('touchend', (e: TouchEvent) => {
        const dx = e.changedTouches[0].screenX - touchStartX;
        const dy = e.changedTouches[0].screenY - touchStartY;
        const dt = Date.now() - touchStartTime;
        const velocity = Math.abs(dx) / dt;

        // Trigger on distance OR velocity (quick flicks)
        const distanceThreshold = Math.abs(dx) > 50;
        const velocityThreshold = velocity > 0.3 && Math.abs(dx) > 20;
        const isHorizontal = Math.abs(dx) > Math.abs(dy) * 1.3;

        if ((distanceThreshold || velocityThreshold) && isHorizontal) {
          // Haptic feedback if available
          if (navigator.vibrate) navigator.vibrate(10);
          if (dx < 0) goNext();
          if (dx > 0) goPrev();
        }
      }, { passive: true });
    }


    // ── Share functionality ───────────────────────
    const shareData = {
      title: document.title,
      url: window.location.href,
    };

    async function handleShare(btn: HTMLElement) {
      try {
        if (navigator.share) {
          await navigator.share(shareData);
        } else {
          await navigator.clipboard.writeText(shareData.url);
          btn.classList.add('shared');
          const originalHTML = btn.innerHTML;
          btn.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg> Copied!';
          setTimeout(() => {
            btn.classList.remove('shared');
            btn.innerHTML = originalHTML;
          }, 2000);
        }
      } catch { /* user cancelled share */ }
    }

    const shareBtn = document.getElementById('share-btn');
    if (shareBtn) {
      shareBtn.addEventListener('click', () => handleShare(shareBtn));
    }

  } // end initKidPage

  document.addEventListener('astro:page-load', initKidPage);
