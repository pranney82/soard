  /* Highlight — editorial underline on <em>, matching home page */
  :is(h1, h2, h3) em {
    font-style: italic;
    background-image: linear-gradient(transparent 52%, var(--c-yellow-soft) 52%);
  }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
