---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Brand Guidelines" description="Official brand resources, logos, and usage guidelines for representing Sunshine on a Ranney Day.">

  <section class="page-hero">
    <div class="container">
      <p class="hero-label">Brand Resources</p>
      <h1>Brand Guidelines</h1>
      <p class="page-hero-sub">Official brand resources, logos, and usage guidelines for representing Sunshine on a Ranney Day.</p>
    </div>
  </section>

  <div class="brand-layout">
    <aside class="brand-sidebar">
      <div class="sidebar-inner">
        <p class="sidebar-label">Contents</p>
        <a href="#logos" class="sidebar-link active">Logos</a>
        <a href="#icons" class="sidebar-link">Icons</a>
        <a href="#logo-usage" class="sidebar-link">Logo Usage</a>
        <a href="#colors" class="sidebar-link">Colors</a>
        <a href="#typography" class="sidebar-link">Typography</a>
        <a href="#voice" class="sidebar-link">Voice & Tone</a>
      </div>
    </aside>

    <div class="brand-content">

      <section id="logos" class="brand-section">
        <div class="section-header-row">
          <div><h2>Logos</h2><p>Download our official logos in various formats and variations.</p></div>
          <a href="/SOARD-Brand-Guidelines.pdf" download class="download-all-btn"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>Download All Assets</a>
        </div>
        <div class="logo-grid">
          <div class="card"><div class="card-preview bg-light"><img src="/images/logos/logo-light-bg.png" alt="Primary Logo" class="logo-img" loading="lazy"/></div><div class="card-body"><h3>Primary Logo</h3><p>Main logo for light backgrounds</p><div class="btn-row"><a href="/images/logos/logo-light-bg.png" download class="dl-btn"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>PNG</a><a href="/images/logos/logo-light-bg.webp" download class="dl-btn"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>WebP</a></div></div></div>
          <div class="card"><div class="card-preview bg-dark"><img src="/images/logos/logo-dark-bg.png" alt="White Logo" class="logo-img" loading="lazy"/></div><div class="card-body"><h3>White Logo</h3><p>Logo for dark backgrounds</p><div class="btn-row"><a href="/images/logos/logo-dark-bg.png" download class="dl-btn"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>PNG</a><a href="/images/logos/logo-dark-bg.webp" download class="dl-btn"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>WebP</a></div></div></div>
        </div>
      </section>

      <section id="icons" class="brand-section">
        <h2>Icons</h2>
        <p class="section-desc">Square icons, badges, and mascot marks for web, mobile, and social use.</p>
        <div class="icon-grid">
          <div class="card"><div class="card-preview-sq bg-dark"><img src="/images/logos/logo-circle.png" alt="Circle Badge" class="icon-img" loading="lazy"/></div><div class="card-body"><h3>Circle Badge</h3><p>Social profiles, stickers</p><div class="btn-row"><a href="/images/logos/logo-circle.png" download class="dl-btn"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>PNG</a></div></div></div>
          <div class="card"><div class="card-preview-sq bg-dark"><img src="/images/logos/sunny.png" alt="Sunny the Dream Pig" class="icon-img" loading="lazy"/></div><div class="card-body"><h3>Sunny the Dream Pig</h3><p>Mascot mark</p><div class="btn-row"><a href="/images/logos/sunny.png" download class="dl-btn"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>PNG</a></div></div></div>
        </div>
      </section>

      <section id="logo-usage" class="brand-section">
        <h2>Logo Usage</h2>
        <p class="section-desc">Guidelines for proper logo implementation and presentation.</p>
        <div class="usage-grid">
          <div class="usage-card"><div class="usage-label">Light Background</div><div class="usage-preview bg-light"><img src="/images/logos/logo-light-bg.png" alt="Logo on light background" class="logo-img" loading="lazy"/></div><p class="usage-text">Use the primary logo on light backgrounds. Ensure adequate contrast and clear space.</p></div>
          <div class="usage-card"><div class="usage-label">Dark Background</div><div class="usage-preview bg-dark"><img src="/images/logos/logo-dark-bg.png" alt="Logo on dark background" class="logo-img" loading="lazy"/></div><p class="usage-text">Use white or inverted version on dark backgrounds. Maintain strong contrast.</p></div>
        </div>
        <h3>Logo Guidelines</h3>
        <div class="dodont-grid">
          <div class="dodont-card do"><h4>✓ Do</h4><ul><li><span class="chk">✓</span>Maintain clear space around logo</li><li><span class="chk">✓</span>Scale proportionally</li><li><span class="chk">✓</span>Ensure sufficient contrast</li><li><span class="chk">✓</span>Min. 1.25" print, 75px digital</li></ul></div>
          <div class="dodont-card dont"><h4>✗ Don't</h4><ul><li><span class="x">✗</span>Distort or rotate the logo</li><li><span class="x">✗</span>Change logo colors</li><li><span class="x">✗</span>Add effects or shadows</li><li><span class="x">✗</span>Modify or recreate</li></ul></div>
        </div>
        <h3>Visual Examples</h3>
        <div class="vis-grid">
          <div class="vis-card ok"><div class="vis-badge ok">Correct</div><div class="vis-preview bg-light"><img src="/images/logos/logo-light-bg.png" alt="Correct" class="vis-logo" loading="lazy"/></div><p>Proper proportions and clear space</p></div>
          <div class="vis-card bad"><div class="vis-badge bad">Incorrect</div><div class="vis-preview bg-light"><img src="/images/logos/logo-light-bg.png" alt="Incorrect" class="vis-logo" style="transform:scaleX(1.4);" loading="lazy"/></div><p>Don't stretch or distort</p></div>
          <div class="vis-card ok"><div class="vis-badge ok">Correct</div><div class="vis-preview bg-dark"><img src="/images/logos/logo-dark-bg.png" alt="Correct" class="vis-logo" loading="lazy"/></div><p>Good contrast with background</p></div>
          <div class="vis-card bad"><div class="vis-badge bad">Incorrect</div><div class="vis-preview" style="background:#e8e0c0;"><img src="/images/logos/logo-light-bg.png" alt="Incorrect" class="vis-logo" style="opacity:0.3;" loading="lazy"/></div><p>Don't use on low-contrast backgrounds</p></div>
        </div>
      </section>

      <section id="colors" class="brand-section">
        <h2>Color Palette</h2>
        <p class="section-desc">Our color system ensures visual consistency and brand recognition.</p>
        <div class="color-grid">
          <div class="color-card" data-hex="#FFDA24"><div class="color-swatch" style="background:#FFDA24;"></div><div class="color-body"><h3>Sunshine Yellow</h3><p class="color-usage">CTAs, brand accents</p><div class="color-vals"><span class="pms">PMS 116 C</span><span class="hex">#FFDA24</span><span>RGB 254, 217, 37</span><span>CMYK 0, 6, 87, 0</span></div></div></div>
          <div class="color-card" data-hex="#373A36"><div class="color-swatch" style="background:#373A36;"></div><div class="color-body"><h3>SOARD Dark</h3><p class="color-usage">Primary text, headings</p><div class="color-vals"><span class="pms">PMS 447 C</span><span class="hex">#373A36</span><span>RGB 55, 58, 54</span><span>CMYK 50, 30, 40, 90</span></div></div></div>
          <div class="color-card" data-hex="#FFFFFF"><div class="color-swatch" style="background:#FFFFFF;border-bottom:1px solid #E5E7EB;"></div><div class="color-body"><h3>White</h3><p class="color-usage">Backgrounds</p><div class="color-vals"><span class="hex">#FFFFFF</span><span>RGB 255, 255, 255</span><span>CMYK 0, 0, 0, 0</span></div></div></div>

          <div class="color-card" data-hex="#1A1B1F"><div class="color-swatch" style="background:#1A1B1F;"></div><div class="color-body"><h3>Dark Deep</h3><p class="color-usage">Footer, dark sections</p><div class="color-vals"><span class="hex">#1A1B1F</span><span>RGB 26, 27, 31</span></div></div></div>
          <div class="color-card" data-hex="#FEFCF5"><div class="color-swatch" style="background:#FEFCF5;border-bottom:1px solid #E5E7EB;"></div><div class="color-body"><h3>Cream</h3><p class="color-usage">Page backgrounds</p><div class="color-vals"><span class="hex">#FEFCF5</span><span>RGB 254, 252, 245</span></div></div></div>
        </div>
        <div class="info-box"><p>💡 <strong>Color Usage</strong></p><p>Use Sunshine Yellow (#FFDA24) sparingly for CTAs and highlights. SOARD Dark and neutrals form the foundation. <strong>Important:</strong> The three core brand colors — Sunshine Yellow (PMS 116 C), SOARD Dark (PMS 447 C), and White — are required for all print materials. Ensure WCAG AA contrast minimum for accessibility. Click any color to copy HEX.</p></div>
      </section>

      <section id="typography" class="brand-section">
        <h2>Typography</h2>
        <p class="section-desc">We use Libre Baskerville for display and Outfit for body text, providing an editorial feel with modern readability.</p>
        <div class="type-block"><div class="type-block-header"><h3>Libre Baskerville</h3><span>Display / Headlines</span></div><div class="type-rows"><div class="type-row"><span class="wt-name">Regular (400)</span><span class="wt-sample" style="font-family:var(--font-display);font-weight:400;">Dreams built here since 2012</span></div><div class="type-row"><span class="wt-name">Italic (400)</span><span class="wt-sample" style="font-family:var(--font-display);font-style:italic;">Dreams built here since 2012</span></div><div class="type-row"><span class="wt-name">Bold (700)</span><span class="wt-sample" style="font-family:var(--font-display);font-weight:700;">Dreams built here since 2012</span></div></div></div>
        <div class="type-block"><div class="type-block-header"><h3>Outfit</h3><span>Body / UI</span></div><div class="type-rows"><div class="type-row"><span class="wt-name">Light (300)</span><span class="wt-sample" style="font-family:var(--font-body);font-weight:300;">The quick brown fox jumps over the lazy dog</span></div><div class="type-row"><span class="wt-name">Regular (400)</span><span class="wt-sample" style="font-family:var(--font-body);font-weight:400;">The quick brown fox jumps over the lazy dog</span></div><div class="type-row"><span class="wt-name">Medium (500)</span><span class="wt-sample" style="font-family:var(--font-body);font-weight:500;">The quick brown fox jumps over the lazy dog</span></div><div class="type-row"><span class="wt-name">Semibold (600)</span><span class="wt-sample" style="font-family:var(--font-body);font-weight:600;">The quick brown fox jumps over the lazy dog</span></div><div class="type-row"><span class="wt-name">Bold (700)</span><span class="wt-sample" style="font-family:var(--font-body);font-weight:700;">The quick brown fox jumps over the lazy dog</span></div></div></div>
        <div class="two-col"><div class="info-card"><h4>Font Weight Usage</h4><ul><li><span class="bullet">●</span>Light (300) for hero text, large displays</li><li><span class="bullet">●</span>Regular (400) for body copy</li><li><span class="bullet">●</span>Semibold (600) for emphasis, buttons</li><li><span class="bullet">●</span>Bold (700) for headings, CTAs</li></ul></div><div class="info-card"><h4>Spacing &amp; Hierarchy</h4><ul><li><span class="bullet">●</span>Very tight leading (1.05–1.2) for headings</li><li><span class="bullet">●</span>Relaxed leading (1.625) for body text</li><li><span class="bullet">●</span>Tight tracking for headlines</li><li><span class="bullet">●</span>Wide tracking (0.05em) for uppercase labels</li></ul></div></div>
      </section>

      <section id="voice" class="brand-section" style="border-bottom:none;">
        <h2>Voice &amp; Tone</h2>
        <p class="section-desc">Our brand voice reflects who we are and how we communicate.</p>
        <div class="two-col">
          <div class="info-card"><h3>We are</h3><div class="voice-items"><div class="voice-item"><h5>Warm &amp; Genuine</h5><p>Approachable and heartfelt in every interaction</p></div><div class="voice-item"><h5>Hopeful &amp; Empowering</h5><p>Focused on possibility, never pity</p></div><div class="voice-item"><h5>Professional</h5><p>Yet approachable and human</p></div><div class="voice-item"><h5>Joyful</h5><p>Building dream rooms is what we do — let the energy show</p></div></div></div>
          <div class="info-card"><h3>We are not</h3><div class="voice-items"><div class="voice-item"><h5>Pitying</h5><p>Never reduce children to their diagnosis</p></div><div class="voice-item"><h5>Clinical</h5><p>Not stiff or corporate — always personal</p></div><div class="voice-item"><h5>Guilt-Driven</h5><p>Inspire through joy, never through pressure</p></div><div class="voice-item"><h5>Sloppy</h5><p>Playful doesn't mean careless</p></div></div></div>
        </div>
      </section>

    </div>
  </div>

</BaseLayout>

<style>
  .page-hero{background:var(--c-warm-gray);padding:80px 0 60px;text-align:center}
  .hero-label{font-size:13px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--c-yellow);margin-bottom:16px}
  .page-hero h1{font-size:clamp(2.5rem,5vw,3.75rem);font-weight:300;color:var(--c-dark);margin-bottom:16px;letter-spacing:-.02em}
  .page-hero-sub{font-size:clamp(1.1rem,2vw,1.35rem);color:rgba(55,58,54,.6);max-width:600px;margin-inline:auto;line-height:1.6}
  .brand-layout{max-width:1280px;margin:0 auto;padding:48px 24px 64px;display:flex;gap:48px}
  .brand-sidebar{width:220px;flex-shrink:0}
  .sidebar-inner{position:sticky;top:96px;display:flex;flex-direction:column;gap:4px}
  .sidebar-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:rgba(55,58,54,.5);padding:0 16px;margin-bottom:8px}
  .sidebar-link{display:block;padding:10px 16px;font-size:14px;font-weight:500;color:rgba(55,58,54,.6);border-radius:8px;text-decoration:none;transition:all .15s}
  .sidebar-link:hover{color:var(--c-dark);background:rgba(55,58,54,.05)}
  .sidebar-link.active{background:var(--c-yellow);color:var(--c-dark);font-weight:600;box-shadow:0 1px 3px rgba(0,0,0,.08)}
  .brand-content{flex:1;min-width:0;max-width:900px}
  .brand-section{margin-bottom:80px;scroll-margin-top:96px}
  .brand-section h2{font-size:clamp(1.75rem,3vw,2.25rem);font-weight:300;color:var(--c-dark);margin-bottom:12px;letter-spacing:-.01em}
  .brand-section h3{font-size:18px;font-weight:600;color:var(--c-dark);margin-bottom:16px;margin-top:40px}
  .section-desc{font-size:16px;color:rgba(55,58,54,.6);line-height:1.6;margin-bottom:32px}
  .section-header-row{display:flex;flex-wrap:wrap;justify-content:space-between;align-items:flex-start;gap:24px;margin-bottom:32px}
  .section-header-row h2{margin-bottom:8px}
  .section-header-row p{font-size:16px;color:rgba(55,58,54,.6);line-height:1.6}
  .card{background:#fff;border:1px solid rgba(55,58,54,.12);border-radius:12px;overflow:hidden;transition:transform .15s,box-shadow .15s}
  .card:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.06)}
  .card-preview{padding:40px;border-bottom:1px solid rgba(55,58,54,.12);display:flex;align-items:center;justify-content:center;min-height:200px;background:linear-gradient(135deg,#f9fafb,#f3f4f6)}
  .card-preview-sq{padding:24px;border-bottom:1px solid rgba(55,58,54,.12);display:flex;align-items:center;justify-content:center;aspect-ratio:1;background:linear-gradient(135deg,#f9fafb,#f3f4f6)}
  .bg-dark{background:var(--c-dark-deep)!important}
  .bg-light{background:linear-gradient(135deg,#f9fafb,#f3f4f6)!important}
  .card-body{padding:20px 24px}
  .card-body h3{font-family:var(--font-body);font-size:15px;font-weight:600;color:var(--c-dark);margin:0 0 4px}
  .card-body p{font-size:14px;color:rgba(55,58,54,.6);margin-bottom:16px}
  .download-all-btn{display:inline-flex;align-items:center;gap:8px;padding:10px 20px;background:var(--c-yellow);color:var(--c-dark);font-size:14px;font-weight:600;border-radius:8px;text-decoration:none;transition:all .15s;box-shadow:0 1px 3px rgba(0,0,0,.08);flex-shrink:0}
  .download-all-btn:hover{filter:brightness(1.05);box-shadow:0 2px 8px rgba(0,0,0,.1)}
  .dl-btn{display:inline-flex;align-items:center;gap:6px;padding:8px 14px;background:var(--c-yellow);color:var(--c-dark);font-size:13px;font-weight:600;border-radius:8px;text-decoration:none;transition:all .15s;box-shadow:0 1px 3px rgba(0,0,0,.08)}
  .dl-btn:hover{filter:brightness(1.05);box-shadow:0 2px 8px rgba(0,0,0,.1)}
  .btn-row{display:flex;gap:8px}
  .logo-img{max-width:100%;max-height:160px;height:48px;width:auto;object-fit:contain}
  .icon-img{width:96px;height:96px;object-fit:contain;border-radius:16px}
  .vis-logo{max-width:80%;max-height:48px;object-fit:contain}
  .logo-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
  .icon-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
  .usage-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;margin-bottom:40px}
  .dodont-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;margin-bottom:40px}
  .vis-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
  .color-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-bottom:32px}
  .two-col{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;margin-top:24px}
  .usage-card{border:1px solid rgba(55,58,54,.12);border-radius:12px;overflow:hidden;background:#fff}
  .usage-label{font-size:14px;font-weight:600;color:var(--c-dark);padding:14px 20px 0}
  .usage-preview{height:180px;display:flex;align-items:center;justify-content:center;padding:32px}
  .usage-text{font-size:14px;color:rgba(55,58,54,.6);padding:16px 20px;border-top:1px solid rgba(55,58,54,.12)}
  .dodont-card{border-radius:12px;padding:28px;border:2px solid}
  .dodont-card.do{background:linear-gradient(135deg,#f0fdf4,#ecfdf5);border-color:#bbf7d0}
  .dodont-card.dont{background:linear-gradient(135deg,#fef2f2,#fff1f2);border-color:#fecaca}
  .dodont-card h4{font-size:15px;font-weight:600;margin-bottom:16px;display:flex;align-items:center;gap:8px}
  .dodont-card.do h4{color:#166534}
  .dodont-card.dont h4{color:#991b1b}
  .dodont-card ul{display:flex;flex-direction:column;gap:10px}
  .dodont-card li{font-size:14px;display:flex;align-items:flex-start;gap:8px;line-height:1.5}
  .chk{color:#16a34a;font-weight:700;flex-shrink:0}
  .x{color:#dc2626;font-weight:700;flex-shrink:0}
  .vis-card{border-radius:12px;overflow:hidden;border:2px solid}
  .vis-card.ok{border-color:#bbf7d0}
  .vis-card.bad{border-color:#fecaca}
  .vis-badge{font-size:12px;font-weight:600;padding:8px 14px}
  .vis-badge.ok{background:#f0fdf4;color:#166534}
  .vis-badge.bad{background:#fef2f2;color:#991b1b}
  .vis-preview{height:100px;display:flex;align-items:center;justify-content:center;padding:16px}
  .vis-card p{font-size:12px;color:rgba(55,58,54,.6);padding:10px 14px;border-top:1px solid rgba(55,58,54,.08)}
  .color-card{border:1px solid rgba(55,58,54,.12);border-radius:12px;overflow:hidden;cursor:pointer;background:#fff;transition:transform .15s,box-shadow .15s}
  .color-card:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.06)}
  .color-swatch{height:128px;position:relative}
  .color-body{padding:16px 20px}
  .color-body h3{font-family:var(--font-body);font-size:15px;font-weight:600;margin:0 0 4px}
  .color-usage{font-size:13px;color:rgba(55,58,54,.6);margin-bottom:12px}
  .color-vals{display:flex;flex-direction:column;gap:3px}
  .color-vals span{font-size:13px;font-family:'SF Mono','Courier New',monospace;color:rgba(55,58,54,.6)}
  .color-vals .hex{font-weight:700;color:var(--c-dark)}
  .color-vals .pms{font-weight:700;color:var(--c-dark);font-family:var(--font-body);font-size:11px;letter-spacing:.04em}
  .info-box{background:linear-gradient(135deg,#f9fafb,#f3f4f6);border:1px solid rgba(55,58,54,.12);border-radius:12px;padding:24px}
  .info-box p{font-size:14px;line-height:1.65}
  .info-box strong{color:var(--c-dark)}
  .info-card{border:1px solid rgba(55,58,54,.12);border-radius:12px;padding:24px 28px;background:#fff}
  .info-card h3{font-size:18px;margin-top:0;margin-bottom:24px}
  .info-card h4{font-family:var(--font-body);font-size:15px;font-weight:700;margin-bottom:16px}
  .info-card ul{display:flex;flex-direction:column;gap:8px}
  .info-card li{font-size:14px;display:flex;align-items:flex-start;gap:8px;line-height:1.5}
  .bullet{color:var(--c-yellow);font-size:18px;line-height:1;flex-shrink:0;margin-top:2px}
  .type-block{border:1px solid rgba(55,58,54,.12);border-radius:12px;overflow:hidden;margin-bottom:24px;background:#fff}
  .type-block-header{padding:20px 28px;border-bottom:1px solid rgba(55,58,54,.12);display:flex;justify-content:space-between;align-items:baseline}
  .type-block-header h3{font-size:18px;margin:0}
  .type-block-header span{font-size:14px;color:rgba(55,58,54,.5)}
  .type-row{display:flex;align-items:baseline;justify-content:space-between;padding:14px 28px;border-bottom:1px solid rgba(55,58,54,.06);gap:16px}
  .type-row:last-child{border-bottom:none}
  .wt-name{font-size:13px;font-weight:500;color:rgba(55,58,54,.5);min-width:100px;flex-shrink:0}
  .wt-sample{font-size:20px;color:var(--c-dark);flex:1}
  .voice-items{display:flex;flex-direction:column;gap:24px}
  .voice-item h5{font-family:var(--font-body);font-size:15px;font-weight:600;color:var(--c-dark);margin-bottom:4px}
  .voice-item p{font-size:14px;color:rgba(55,58,54,.6)}
  .brand-toast{position:fixed;bottom:32px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--c-dark-deep);color:#fff;padding:12px 24px;border-radius:10px;font-size:14px;font-weight:500;opacity:0;pointer-events:none;transition:all .3s ease;z-index:999;box-shadow:0 8px 32px rgba(0,0,0,.2)}
  .brand-toast.visible{opacity:1;transform:translateX(-50%) translateY(0)}
  @media(max-width:1024px){.brand-sidebar{display:none}.brand-layout{padding:32px 20px 48px}}
  @media(max-width:768px){.logo-grid{grid-template-columns:1fr}.icon-grid{grid-template-columns:1fr}.usage-grid{grid-template-columns:1fr}.dodont-grid{grid-template-columns:1fr}.color-grid{grid-template-columns:1fr 1fr}.two-col{grid-template-columns:1fr}.vis-grid{grid-template-columns:1fr 1fr}.section-header-row{flex-direction:column}}
  @media(max-width:480px){.color-grid{grid-template-columns:1fr}.vis-grid{grid-template-columns:1fr}}
</style>

<script>
  let _brandObserver: IntersectionObserver | null = null;

  function cleanupBranding() {
    _brandObserver?.disconnect();
    _brandObserver = null;
  }

  function initBranding() {
    const cards = document.querySelectorAll('.color-card');
    if (!cards.length) return;

    cleanupBranding();

    cards.forEach(card=>{card.addEventListener('click',()=>{const hex=(card as HTMLElement).dataset.hex;navigator.clipboard.writeText(hex!);let toast=document.querySelector('.brand-toast');if(!toast){toast=document.createElement('div');toast.className='brand-toast';document.body.appendChild(toast)}toast.textContent=`Copied ${hex}`;toast.classList.add('visible');setTimeout(()=>toast.classList.remove('visible'),2000)})});
    const sections=document.querySelectorAll('.brand-section');const links=document.querySelectorAll('.sidebar-link');_brandObserver=new IntersectionObserver(entries=>{entries.forEach(entry=>{if(entry.isIntersecting){links.forEach(l=>l.classList.remove('active'));const id=entry.target.id;const active=document.querySelector(`.sidebar-link[href="#${id}"]`);if(active)active.classList.add('active')}})},{rootMargin:'-100px 0px -60% 0px'});sections.forEach(s=>_brandObserver!.observe(s));
  }

  document.addEventListener('astro:page-load', initBranding);
  document.addEventListener('astro:before-swap', cleanupBranding);
</script>
