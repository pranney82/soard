---
/**
 * PageLayout.astro
 * Standard page layout with optional hero section, main content area,
 * and optional bottom CTA. Wraps BaseLayout.
 */
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  heroTitle?: string;
  heroSubtitle?: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: object | object[];
  breadcrumbs?: { name: string; url: string }[];
  datePublished?: string;
  dateModified?: string;
  noindex?: boolean;
}

const { title, description, heroTitle, heroSubtitle, ogImage, ogType, jsonLd, breadcrumbs, datePublished, dateModified, noindex } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage} ogType={ogType} jsonLd={jsonLd} breadcrumbs={breadcrumbs} datePublished={datePublished} dateModified={dateModified} noindex={noindex}>
  {(heroTitle || heroSubtitle) && (
    <section class="page-hero">
      <div class="container">
        {heroTitle && <h1 class="page-hero__title">{heroTitle}</h1>}
        {heroSubtitle && <p class="page-hero__subtitle">{heroSubtitle}</p>}
      </div>
    </section>
  )}

  <article class="page-content">
    <slot />
  </article>

  <slot name="cta" />
</BaseLayout>

<style>
  .page-hero {
    background: var(--c-cream);
    color: var(--c-text);
    padding-block: var(--space-4xl) var(--space-3xl);
    text-align: center;
    border-bottom: 1px solid var(--c-border);
  }

  .page-hero__title {
    color: var(--c-text);
    font-size: clamp(2rem, 5vw, 3.25rem);
    letter-spacing: -0.02em;
  }

  .page-hero__subtitle {
    margin-top: var(--space-lg);
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    line-height: 1.7;
    color: var(--c-text-muted);
    max-width: 580px;
    margin-inline: auto;
  }

  .page-content {
    min-height: 40vh;
  }

  @media (max-width: 768px) {
    .page-hero {
      padding-block: var(--space-3xl) var(--space-2xl);
    }
  }
</style>
