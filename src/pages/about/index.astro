---
/**
 * Our Story — Sunshine on a Ranney Day
 * Editorial long-form page: founding story, milestones, mascot, mission
 * 
 * PERF NOTES:
 * - Hero image: fetchpriority="high", eager loading, explicit dimensions
 * - All below-fold images: loading="lazy"
 * - data-reveal only on below-fold elements
 * - Team photos from CF Images
 */
import PageLayout from '../../layouts/PageLayout.astro';
import { getWebPageSchema, getBreadcrumbSchema, buildSchemaGraph } from '../../utils/schema';
import { getSiteStats } from '../../utils/stats';
import page from '../../content/site/our-story.json';

import { CF_BASE as CF, cfUrl, cfSrcset } from '../../utils/cf-image';

/* ── Auto-computed stats ── */
const computed = await getSiteStats();
const stats = {
  totalKids: computed.totalKids,
  totalRooms: computed.totalRooms,
  years: computed.years,
};
const founderPhotoId = page.images.founder;
const storePhotoId = page.images.store;
const graciePhotoId = page.images.gracie;
const trippPhotoId = page.images.tripp;
const milestones = page.milestones;

/* ── Schema ── */
const pageUrl = 'https://sunshineonaranneyday.com/about/';
const aboutDesc = `How Peter and Holly Ranney founded Sunshine on a Ranney Day in 2012 — and built a movement that has transformed ${stats.totalRooms}+ rooms for children with special needs across greater Atlanta.`;
const breadcrumbs = [
  { name: 'Home', url: 'https://sunshineonaranneyday.com/' },
  { name: 'Our Story', url: pageUrl },
];
const jsonLd = buildSchemaGraph(
  getWebPageSchema({ url: pageUrl, title: 'Our Story', description: aboutDesc }),
  getBreadcrumbSchema(breadcrumbs, pageUrl),
);
---

<PageLayout
  title="Our Story — How It All Started"
  description={aboutDesc}
  jsonLd={jsonLd}
  breadcrumbs={breadcrumbs}
  heroLabel="About"
  heroTitle={'Our <em class="highlight">Story</em>'}
  heroSubtitle="How it all started — and where we're headed"
>

  <!-- ══════ FOUNDERS — The Beginning ══════ -->
  <section class="founders" id="our-story" aria-labelledby="founders-heading">
    <div class="founders-inner">
      <div class="founders-photo">
        <img src={`${CF}/${founderPhotoId}/w=600,q=80`} srcset={`${CF}/${founderPhotoId}/w=400,q=80 400w, ${CF}/${founderPhotoId}/w=600,q=80 600w, ${CF}/${founderPhotoId}/w=800,q=80 800w`} sizes="(max-width:768px) calc(100vw - 48px), 460px" alt="Peter and Holly Ranney, founders of Sunshine on a Ranney Day" width="600" height="450" loading="eager" decoding="async" fetchpriority="high" />
      </div>
      <div class="founders-text" data-reveal>
        <div class="section-label">{page.founders.label}</div>
        <h2 id="founders-heading" set:html={page.founders.heading} />
        {page.founders.paragraphs.map((p: string) => <p set:html={p} />)}
      </div>
    </div>
  </section>

  <!-- ══════ TRIPP — The Turning Point ══════ -->
  <section class="turning-point" aria-labelledby="tripp-heading">
    <div class="turning-point-inner">
      <div class="turning-point-text" data-reveal>
        <div class="section-label">{page.turningPoint.label}</div>
        <h2 id="tripp-heading" set:html={page.turningPoint.heading} />
        {page.turningPoint.paragraphs.map((p: string) => <p set:html={p} />)}
      </div>
      <div class="turning-point-photo" data-reveal data-delay="1">
        <img src={`${CF}/${trippPhotoId}/w=600,q=80`} srcset={`${CF}/${trippPhotoId}/w=400,q=80 400w, ${CF}/${trippPhotoId}/w=600,q=80 600w, ${CF}/${trippPhotoId}/w=800,q=80 800w`} sizes="(max-width:768px) calc(100vw - 48px), 460px" alt="The Halstead family — Tripp's story inspired millions and helped expand SOARD's mission" width="600" height="807" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  <!-- ══════ TIMELINE ══════ -->
  <section class="timeline-section" aria-labelledby="timeline-heading">
    <div class="timeline-header" data-reveal>
      <div class="section-label section-label--yellow">Milestones</div>
      <h2 id="timeline-heading">{stats.years} years of building <em>dreams</em>.</h2>
      <p class="timeline-subtitle">Every room starts with a story. Here's ours.</p>
    </div>
    <div class="timeline" id="timeline">
      <!-- Spine -->
      <div class="tl-track" aria-hidden="true">
        <div class="tl-track-fill"></div>
        <div class="tl-cursor"></div>
      </div>
      {milestones.map((m, i) => (
        <div class={`tl-item ${i % 2 === 0 ? 'tl-item--left' : 'tl-item--right'}`} data-tl-item>
          <div class="tl-dot" aria-hidden="true">
            <span class="tl-dot-ring"></span>
            <span class="tl-dot-core"></span>
          </div>
          <div class="tl-connector" aria-hidden="true"></div>
          <div class="tl-card">
            {m.image && (
              <div class="tl-image">
                <img
                  src={cfUrl(m.image, { w: 480, h: 280, fit: 'cover', gravity: 'face', q: 75 })}
                  srcset={cfSrcset(m.image, [320, 480, 640], { fit: 'cover', gravity: 'face', quality: 75, aspectRatio: 280/480 })}
                  sizes="(max-width:640px) calc(100vw - 72px), (max-width:960px) calc(100vw - 100px), 420px"
                  alt={m.title}
                  width="480"
                  height="280"
                  loading={i < 2 ? 'eager' : 'lazy'}
                  decoding="async"
                  class="lqip-img"
                />
              </div>
            )}
            <div class="tl-content">
              <span class="tl-year">{m.year}</span>
              <h3 class="tl-title">{m.title}</h3>
              <p class="tl-desc">{m.desc}</p>
              {m.detail && <p class="tl-detail">{m.detail}</p>}
            </div>
          </div>
        </div>
      ))}
      <!-- End beacon -->
      <div class="tl-cap" aria-hidden="true">
        <div class="tl-cap-year">{new Date().getFullYear()}+</div>
        <span class="tl-cap-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
        </span>
        <div class="tl-cap-label">And counting</div>
      </div>
    </div>
  </section>

  <!-- ══════ IMPACT RIBBON ══════ -->
  <section class="ribbon" aria-label="Impact numbers">
    <div class="ribbon-inner">
      <div class="ribbon-stat" data-reveal>
        <span class="ribbon-num">{stats.totalRooms}+</span>
        <span class="ribbon-label">Room Makeovers</span>
      </div>
      <div class="ribbon-divider" role="presentation"></div>
      <div class="ribbon-stat" data-reveal data-delay="1">
        <span class="ribbon-num">{stats.totalKids}+</span>
        <span class="ribbon-label">Children Served</span>
      </div>
      <div class="ribbon-divider" role="presentation"></div>
      <div class="ribbon-stat" data-reveal data-delay="2">
        <span class="ribbon-num">{stats.years}</span>
        <span class="ribbon-label">Years of Impact</span>
      </div>
    </div>
  </section>

  <!-- ══════ GRACIE — The Mascot ══════ -->
  <section class="mascot" aria-labelledby="mascot-heading">
    <div class="mascot-inner">
      <div class="mascot-text" data-reveal>
        <div class="section-label">{page.mascot.label}</div>
        <h2 id="mascot-heading" set:html={page.mascot.heading} />
        {page.mascot.paragraphs.map((p: string) => <p set:html={p} />)}
        <p class="mascot-tagline" set:html={page.mascot.tagline} />
      </div>
      <div class="mascot-visual" data-reveal data-delay="1">
        <div class="mascot-photo">
          <img src={`${CF}/${graciePhotoId}/w=600,q=80`} srcset={`${CF}/${graciePhotoId}/w=400,q=80 400w, ${CF}/${graciePhotoId}/w=600,q=80 600w, ${CF}/${graciePhotoId}/w=800,q=80 800w`} sizes="(max-width:768px) calc(100vw - 48px), 460px" alt="Gracie the Pig — the real pot-bellied pig that inspired SOARD's mascot" width="600" height="400" loading="lazy" decoding="async" />
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ SUNNY & RANNEY — The Store ══════ -->
  <section class="store-section" aria-labelledby="store-heading">
    <div class="store-inner">
      <div class="store-photo" data-reveal>
        <img src={`${CF}/${storePhotoId}/w=600,q=80`} srcset={`${CF}/${storePhotoId}/w=400,q=80 400w, ${CF}/${storePhotoId}/w=600,q=80 600w, ${CF}/${storePhotoId}/w=800,q=80 800w`} sizes="(max-width:768px) calc(100vw - 48px), 460px" alt="Sunny & Ranney, a nonprofit home furnishings store in Roswell, Georgia" width="600" height="450" loading="lazy" decoding="async" />
      </div>
      <div class="store-text" data-reveal data-delay="1">
        <div class="section-label">{page.store.label}</div>
        <h2 id="store-heading" set:html={page.store.heading} />
        {page.store.paragraphs.map((p: string) => <p set:html={p} />)}
        <a href="https://sunnyandranney.com" target="_blank" rel="noopener noreferrer" class="btn btn-dark">Shop Sunny & Ranney →</a>
      </div>
    </div>
  </section>

  <!-- ══════ WHERE WE ARE TODAY ══════ -->
  <section class="today-section" aria-labelledby="today-heading">
    <div class="today-inner" data-reveal>
      <div class="section-label">{page.today.label}</div>
      <h2 id="today-heading" set:html={page.today.heading} />
      <p class="today-body" set:html={page.today.body} />
      <div class="today-links">
        <a href="/about/leadership" class="btn btn-dark">Meet Our Team →</a>
        <a href="/about/financials" class="btn btn-outline">View Financials →</a>
      </div>
    </div>
  </section>

  <!-- ══════ FINAL CTA ══════ -->
  <section class="story-finale">
    <div class="story-finale-inner">
      <h2 data-reveal set:html={page.finale.heading} />
      <p data-reveal data-delay="1" set:html={page.finale.body} />
      <div class="story-finale-ctas" data-reveal data-delay="2">
        <a href="/donate" class="btn btn-dark btn-lg">Donate Today</a>
        <a href="/kids" class="btn btn-outline-dark">Meet the Kids</a>
      </div>
      <p class="story-finale-note" data-reveal data-delay="3">501(c)(3) · EIN 45-4773997 · All donations tax-deductible</p>
    </div>
  </section>

</PageLayout>

<style>
  /* ─── Page-specific overrides ──────────── */
  h2 em:not(.highlight) { font-style: italic; color: #8A7200; }

  /* ══════════════════════════════════════════
     FOUNDERS — Split layout
     ══════════════════════════════════════════ */
  .founders {
    background: var(--c-warm-gray);
    padding-block: var(--space-5xl) var(--space-4xl);
  }

  .founders-inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-lg);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
  }

  .founders-photo {
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
  }

  .founders-photo img {
    width: 100%;
    height: auto;
    display: block;
  }

  .founders-text h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    margin-bottom: var(--space-xl);
  }

  .founders-text p {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--c-text);
    margin-bottom: var(--space-md);
  }

  .founders-text p:last-of-type {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--c-text-muted);
  }

  @media (max-width: 768px) {
    .founders { padding-block: var(--space-3xl); }
    .founders-inner {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
  }

  /* ══════════════════════════════════════════
     TURNING POINT — Reversed split
     ══════════════════════════════════════════ */
  .turning-point {
    background: var(--c-warm-gray);
    padding-block: var(--space-4xl);
  }

  .turning-point-inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-lg);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
  }

  .turning-point-text h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    margin-bottom: var(--space-xl);
  }

  .turning-point-text p {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--c-text);
    margin-bottom: var(--space-md);
  }

  .turning-point-photo {
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
  }

  .turning-point-photo img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 768px) {
    .turning-point { padding-block: var(--space-3xl); }
    .turning-point-inner {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
    .turning-point-text { order: 1; }
    .turning-point-photo { order: 2; }
  }

  /* ══════════════════════════════════════════
     TIMELINE — Scroll-driven cinematic
     ══════════════════════════════════════════ */
  .timeline-section {
    --tl-gutter: 60px;
    background: var(--c-dark);
    color: var(--c-white);
    padding-block: var(--space-5xl) 0;
    overflow: hidden;
    position: relative;
  }

  /* Subtle gradient overlay at top for seamless section transition */
  .timeline-section::before {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    height: 120px;
    background: linear-gradient(180deg, rgba(45,46,51,0.6), transparent);
    pointer-events: none;
    z-index: 1;
  }

  .timeline-header {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: var(--space-5xl);
    padding-inline: var(--space-lg);
    position: relative;
    z-index: 2;
  }

  .timeline-header .section-label { justify-content: center; }

  .timeline-header h2 {
    color: var(--c-white);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
  }

  .timeline-subtitle {
    margin-top: var(--space-md);
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.6;
  }

  /* ── Track container ── */
  .timeline {
    position: relative;
    max-width: 1060px;
    margin-inline: auto;
    padding-inline: var(--space-lg);
    padding-bottom: var(--space-5xl);
  }

  /* ── Central spine ── */
  .tl-track {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    transform: translateX(-50%);
    background: rgba(255, 255, 255, 0.05);
    z-index: 0;
  }

  .tl-track-fill {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, var(--c-yellow) 0%, rgba(255, 218, 36, 0.6) 60%, rgba(255, 218, 36, 0.15) 100%);
    transform-origin: top;
  }

  .tl-ready .tl-track-fill {
    transform: scaleY(0);
    will-change: transform;
  }

  /* ── CSS scroll-driven fill — compositor thread, zero JS ──
   * .timeline gets a named view-timeline. Children reference it
   * so animation progress tracks the *timeline section* scrolling
   * through the viewport, not the individual element. */
  @supports (animation-timeline: view()) {
    .timeline.tl-ready {
      view-timeline-name: --tl;
      view-timeline-axis: block;
    }

    @keyframes tl-fill-scroll {
      from { transform: scaleY(0); }
      to   { transform: scaleY(1); }
    }

    .tl-ready .tl-track-fill {
      animation: tl-fill-scroll linear both;
      animation-timeline: --tl;
      animation-range: entry 0% exit 60%;
    }

    @keyframes tl-cursor-scroll {
      0%   { transform: translateY(0%); opacity: 0; }
      5%   { opacity: 1; }
      95%  { opacity: 1; }
      100% { transform: translateY(100%); opacity: 0; }
    }

    .tl-ready .tl-cursor {
      animation: tl-cursor-scroll linear both;
      animation-timeline: --tl;
      animation-range: entry 0% exit 60%;
      transition: none;
    }
  }

  /* ── Scroll cursor — rides the fill line ── */
  /* height: 100% makes translateY(%) parent-relative → compositable */
  .tl-cursor {
    position: absolute;
    left: 50%;
    top: 0;
    width: 0;
    height: 100%;
    transform: translateY(0%);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 3;
    pointer-events: none;
    will-change: transform, opacity;
  }

  .tl-cursor::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--c-yellow);
    transform: translate(-50%, -50%);
    box-shadow: 0 0 12px 4px rgba(255, 218, 36, 0.5), 0 0 40px 8px rgba(255, 218, 36, 0.15);
  }

  .tl-cursor.is-visible {
    opacity: 1;
  }

  /* ── Each milestone item ── */
  .tl-item {
    position: relative;
    display: grid;
    grid-template-columns: 1fr var(--tl-gutter) 1fr;
    gap: 0;
    align-items: start;
    margin-bottom: 72px;
    z-index: 1;
  }

  .tl-item:last-of-type { margin-bottom: 0; }

  /* Alternating sides */
  .tl-item--left .tl-card      { grid-column: 1; grid-row: 1; justify-self: end; }
  .tl-item--left .tl-dot       { grid-column: 2; grid-row: 1; }
  .tl-item--left .tl-connector { grid-column: 2; grid-row: 1; }
  .tl-item--right .tl-card     { grid-column: 3; grid-row: 1; justify-self: start; }
  .tl-item--right .tl-dot      { grid-column: 2; grid-row: 1; }
  .tl-item--right .tl-connector{ grid-column: 2; grid-row: 1; }

  /* ── Dot ── */
  .tl-dot {
    display: flex;
    align-items: start;
    justify-content: center;
    padding-top: 28px;
    position: relative;
    z-index: 2;
  }

  .tl-dot-ring {
    position: absolute;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid rgba(255, 218, 36, 0.15);
    top: 20px;
    left: 50%;
    transform: translateX(-50%) scale(1);
    opacity: 1;
    transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tl-ready .tl-dot-ring {
    transform: translateX(-50%) scale(0.4);
    opacity: 0;
  }

  .tl-dot-core {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--c-yellow);
    border: 2px solid var(--c-yellow);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    z-index: 1;
  }

  .tl-ready .tl-dot-core {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.12);
  }

  /* Active dot */
  .tl-item.is-active .tl-dot-core {
    background: var(--c-yellow);
    border-color: var(--c-yellow);
    box-shadow: 0 0 20px rgba(255, 218, 36, 0.6), 0 0 60px rgba(255, 218, 36, 0.15);
    transform: scale(1.1);
  }

  .tl-item.is-active .tl-dot-ring {
    opacity: 1;
    transform: translateX(-50%) scale(1);
    border-color: rgba(255, 218, 36, 0.3);
    animation: tl-ring-pulse 3s ease-in-out infinite;
  }

  @keyframes tl-ring-pulse {
    0%, 100% { transform: translateX(-50%) scale(1); opacity: 0.5; }
    50%      { transform: translateX(-50%) scale(1.6); opacity: 0; }
  }

  /* ── Connector ── */
  .tl-connector {
    position: absolute;
    top: 35px;
    height: 2px;
    background: rgba(255, 218, 36, 0.25);
    transition: background 0.5s ease, width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    width: 30px;
  }

  .tl-ready .tl-connector {
    background: rgba(255, 218, 36, 0.12);
    width: 0;
  }

  .tl-item--left .tl-connector  { right: 50%; transform-origin: right; }
  .tl-item--right .tl-connector { left: 50%; transform-origin: left; }

  .tl-item.is-active .tl-connector {
    background: rgba(255, 218, 36, 0.25);
    width: 30px;
  }

  /* ── Card ── */
  .tl-card {
    max-width: 440px;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    overflow: hidden;
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.35s ease,
                box-shadow 0.35s ease,
                background 0.35s ease;
  }

  /* Only hide cards once JS has confirmed it can reveal them */
  .tl-ready .tl-card {
    opacity: 0;
  }
  .tl-ready .tl-item--left .tl-card  { transform: translateY(40px) translateX(30px); }
  .tl-ready .tl-item--right .tl-card { transform: translateY(40px) translateX(-30px); }

  .tl-item.is-active .tl-card {
    opacity: 1;
    transform: translateY(0) translateX(0);
  }

  /* Hover — lift + border glow + shadow */
  .tl-card:hover {
    border-color: rgba(255, 218, 36, 0.25);
    background: rgba(255, 255, 255, 0.06);
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(255, 218, 36, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    transform: translateY(-6px) !important;
  }

  /* ── Card image ── */
  .tl-image {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  /* Gradient overlay on image for text readability / polish */
  .tl-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(45, 46, 51, 0.5) 100%);
    pointer-events: none;
  }

  .tl-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tl-card:hover .tl-image img {
    transform: scale(1.06);
  }

  /* ── Card content ── */
