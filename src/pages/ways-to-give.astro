  }

  .hero-stat-num {
    font-family: var(--font-display);
    font-size: 40px;
    font-weight: 700;
    color: var(--c-yellow);
    line-height: 1;
    display: block;
  }

  .hero-stat-label {
    display: block;
    font-size: 12px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.85);
    margin-top: 4px;
    line-height: 1.4;
  }

  @keyframes heroUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes heroSlide {
    from { transform: translateY(20px); }
    to { transform: translateY(0); }
  }
  @keyframes heroPhotoIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow, .hero-lead, .hero-ctas, .hero-trust,
    .hero-photo-wrap, .hero-stat { opacity: 1; transform: none; animation: none; }
  }

  /* ── Testimonial strip between hero and nav ── */
  .wtg-testimonial {
    background: var(--c-cream);
    padding: var(--space-xl) 0 var(--space-lg);
    border-top: 1px solid var(--c-border);
  }
  .wtg-testimonial-inner {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    flex-direction: column;
  }
  .wtg-testimonial-qm { width: 28px; height: 22px; color: var(--c-yellow); opacity: 0.4; flex-shrink: 0; }
  .wtg-testimonial-quote {
    font-family: var(--font-display);
    font-size: clamp(17px, 1.8vw, 20px);
    font-style: italic;
    line-height: 1.7;
    color: var(--c-text);
    margin: 0;
  }
  .wtg-testimonial-attr { display: flex; gap: 8px; align-items: center; }
  .wtg-testimonial-name { font-size: 13px; font-weight: 600; color: var(--c-dark); }
  .wtg-testimonial-role { font-size: 12px; color: var(--c-text-muted); }

  /* ══════════════════════════════════════════
     ANCHOR NAV
     ══════════════════════════════════════════ */
  .wtg-nav {
    position: sticky;
    top: var(--header-height, 84px);
    z-index: 90;
    background: rgba(255, 253, 247, 0.95);
    -webkit-backdrop-filter: blur(16px) saturate(1.5);
    backdrop-filter: blur(16px) saturate(1.5);
    border-bottom: 1px solid rgba(0,0,0,0.05);
    transition: box-shadow 0.4s ease;
  }
  .wtg-nav.is-stuck {
    box-shadow: 0 1px 24px rgba(0,0,0,0.06);
  }
  .wtg-nav-track {
    position: relative;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 6px var(--space-xl);
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 4px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .wtg-nav-track::-webkit-scrollbar { display: none; }

  /* ── Sliding pill ── */
  .wtg-nav-pill {
    position: absolute;
    top: 50%;
    left: 0;
    height: 36px;
    width: 0;
    transform: translateY(-50%);
    background: var(--c-dark, #2a2a2a);
    border-radius: 100px;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                width 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.2s ease;
    will-change: transform, width;
    pointer-events: none;
    opacity: 0;
  }
  .wtg-nav-pill.is-ready { opacity: 1; }

  .wtg-nav-link {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    padding: 10px 20px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    text-decoration: none;
    white-space: nowrap;
    border-radius: 100px;
    transition: color 0.25s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .wtg-nav-link span { position: relative; z-index: 1; }
  .wtg-nav-link:hover { color: var(--c-dark); }
  .wtg-nav-link.is-active { color: #fff; }

  /* ══════════════════════════════════════════
     SECTIONS — Shared
     ══════════════════════════════════════════ */
  .wtg-section { padding: 100px 0; contain: layout style; scroll-margin-top: calc(var(--header-height, 84px) + 60px); }
  .wtg-section--alt { background: var(--c-warm-gray); }
  .wtg-container { max-width: var(--max-width); margin: 0 auto; padding: 0 var(--space-xl); }
  .wtg-sh { display: flex; align-items: flex-start; gap: 24px; margin-bottom: 56px; position: relative; }
  .wtg-sh[data-num]::before { content: attr(data-num); font-family: var(--font-display); font-size: clamp(56px, 6vw, 80px); font-weight: 700; color: #c8a96e; opacity: 0.38; line-height: 0.85; letter-spacing: -0.04em; flex-shrink: 0; }
  .wtg-sh-text h2 { font-size: clamp(24px, 3vw, 36px); line-height: 1.25; margin-bottom: 6px; }
  .wtg-sh-text p { font-size: 16px; color: var(--c-text); line-height: 1.6; }

  /* ══════════════════════════════════════════
     01 · GIVE TODAY
     ══════════════════════════════════════════ */
  .wtg-give-grid {
    display: grid;
