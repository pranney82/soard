---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Our Kids" description="Meet the incredible children whose lives have been transformed by Sunshine on a Ranney Day. 132+ kids, 106+ rooms, endless stories of joy.">

  <section class="page-hero">
    <div class="container">
      <div class="section-label" style="color:var(--c-yellow)">Our Kids</div>
      <h1>Every room changes a <em>life</em></h1>
      <p class="page-hero-sub">These are the children who trusted us to build their dream spaces. Every story is unique. Every transformation is real.</p>
    </div>
  </section>

  <!-- ══════ FEATURED KID ══════ -->
  <section class="featured">
    <div class="featured-split">
      <div class="featured-photo">
        <div class="photo-placeholder photo-placeholder--warm" style="min-height:500px;">
          <span class="photo-placeholder-icon">👧🏽</span>
          <span>Amari's room reveal photo</span>
        </div>
        <span class="featured-badge">Featured Story</span>
      </div>
      <div class="featured-content" data-reveal>
        <span class="featured-type">Dream Bedroom</span>
        <h2>Amari's Butterfly Room</h2>
        <div class="featured-meta">Age 8 · Cerebral Palsy · Marietta, GA</div>
        <p>Amari dreamed of a purple butterfly room with a reading nook. Our design partners created a sensory-friendly space with adaptive furniture, dimmable lights, and hand-painted butterflies that make her smile every single day.</p>
        <p>The moment Amari saw her room for the first time, she cried tears of joy. Her mom said it was the first time Amari had her own space that felt truly <em>hers</em>.</p>
        <div class="featured-partners">
          <div><span class="fp-label">Design</span><span class="fp-name">Crosby Design Group</span></div>
          <div><span class="fp-label">Build</span><span class="fp-name">CR Construction</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ ALL KIDS GRID ══════ -->
  <section class="kids-section">
    <div class="container">
      <div class="kids-header" data-reveal>
        <div class="section-label">All Projects</div>
        <h2>132+ children. 106+ rooms. <em class="highlight">Every one matters.</em></h2>
      </div>
      <div class="kids-grid">
        <article class="kid-card card" data-reveal>
          <div class="kid-card-photo"><div class="photo-placeholder photo-placeholder--purple"><span class="photo-placeholder-icon">👦🏻</span></div><span class="kid-tag" style="background:#2DBB7F">Therapy Room</span></div>
          <div class="kid-card-body"><h3>Liam's Sensory Space</h3><span class="kid-meta">Age 5 · Autism Spectrum</span><p>Dimmable lights, a swing, textured walls, and a cozy crash pad for decompression.</p></div>
        </article>
        <article class="kid-card card" data-reveal data-delay="1">
          <div class="kid-card-photo"><div class="photo-placeholder photo-placeholder--blue"><span class="photo-placeholder-icon">👧🏾</span></div><span class="kid-tag" style="background:#0099CC">Accessible Bath</span></div>
          <div class="kid-card-body"><h3>Sofia's Independence</h3><span class="kid-meta">Age 11 · Spina Bifida</span><p>Roll-in shower, grab bars, and a lowered vanity — designed so Sofia can get ready on her own.</p></div>
        </article>
        <article class="kid-card card" data-reveal data-delay="2">
          <div class="kid-card-photo"><div class="photo-placeholder photo-placeholder--purple"><span class="photo-placeholder-icon">👦🏽</span></div><span class="kid-tag">Dream Bedroom</span></div>
          <div class="kid-card-body"><h3>Marcus's Space Room</h3><span class="kid-meta">Age 9 · Muscular Dystrophy</span><p>LED star ceiling, motorized blinds, and a wheelchair-friendly desk built for exploration.</p></div>
        </article>
        <article class="kid-card card" data-reveal>
          <div class="kid-card-photo"><div class="photo-placeholder photo-placeholder--green"><span class="photo-placeholder-icon">👧🏻</span></div><span class="kid-tag" style="background:#2DBB7F">Therapy Room</span></div>
          <div class="kid-card-body"><h3>Emma's Creative Studio</h3><span class="kid-meta">Age 7 · Down Syndrome</span><p>A bright art and sensory room with an easel, sensory table, and cozy reading corner.</p></div>
        </article>
        <article class="kid-card card" data-reveal data-delay="1">
          <div class="kid-card-photo"><div class="photo-placeholder photo-placeholder--purple"><span class="photo-placeholder-icon">👦🏿</span></div><span class="kid-tag">Dream Bedroom</span></div>
          <div class="kid-card-body"><h3>Jayden's Sports Den</h3><span class="kid-meta">Age 10 · Traumatic Brain Injury</span><p>Adaptive tech, soft-close drawers, and a mini trophy wall for a sports-obsessed kid.</p></div>
        </article>
        <article class="kid-card card" data-reveal data-delay="2">
          <div class="kid-card-photo"><div class="photo-placeholder photo-placeholder--blue"><span class="photo-placeholder-icon">👧🏽</span></div><span class="kid-tag" style="background:#0099CC">Accessible Bath</span></div>
          <div class="kid-card-body"><h3>Ava's Safe Space</h3><span class="kid-meta">Age 6 · Epilepsy</span><p>Anti-slip surfaces, padded edges, and gentle lighting for safer daily routines.</p></div>
        </article>
      </div>
    </div>
  </section>

  <!-- ══════ APPLY CTA ══════ -->
  <section class="apply-cta">
    <div class="apply-cta-inner">
      <h2 data-reveal>Know a child who needs a <em class="highlight">dream room</em>?</h2>
      <p data-reveal data-delay="1">We serve families of children with special needs in the Greater Atlanta area. Applications are simple and confidential.</p>
      <div data-reveal data-delay="2">
        <a href="/get-involved#apply" class="btn btn-primary">Apply for a Room →</a>
        <a href="/donate" zeffy-form-link="https://www.zeffy.com/embed/donation-form/help-build-a-brighter-home?modal=true" class="btn btn-dark" style="margin-left:12px;">Sponsor a Room ♥</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .featured{background:var(--c-cream);}
  .featured-split{display:grid;grid-template-columns:1.1fr 1fr;min-height:560px;}
  .featured-photo{position:relative;overflow:hidden;}
  .featured-badge{position:absolute;top:24px;left:24px;background:var(--c-yellow);color:var(--c-dark);font-size:12px;font-weight:700;padding:6px 16px;border-radius:50px;}
  .featured-content{padding:72px 64px;display:flex;flex-direction:column;justify-content:center;}
  .featured-type{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--c-purple);margin-bottom:12px;display:block;}
  .featured-content h2{font-size:clamp(26px,3vw,34px);margin-bottom:8px;}
  .featured-meta{font-size:14px;font-weight:600;color:var(--c-purple);margin-bottom:20px;}
  .featured-content p{font-size:16px;line-height:1.75;margin-bottom:12px;}
  .featured-content em{font-style:italic;color:var(--c-dark);}
  .featured-partners{display:flex;gap:32px;padding-top:24px;margin-top:16px;border-top:1px solid rgba(45,46,51,0.06);}
  .fp-label{display:block;font-size:11px;font-weight:700;color:var(--c-text-light);text-transform:uppercase;letter-spacing:0.1em;}
  .fp-name{display:block;font-size:14px;font-weight:600;color:var(--c-dark);margin-top:4px;}

  .kids-section{padding:var(--section-padding);}
  .kids-header{margin-bottom:48px;}
  .kids-header h2 em{font-style:italic;}
  .kids-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;}
  .kid-card-photo{position:relative;aspect-ratio:4/3;overflow:hidden;}
  .kid-card-photo .photo-placeholder{border-radius:20px 20px 0 0;}
  .kid-tag{position:absolute;top:14px;left:14px;background:var(--c-purple);color:#fff;font-size:11px;font-weight:700;padding:5px 14px;border-radius:50px;letter-spacing:0.02em;}
  .kid-card-body{padding:24px;}
  .kid-card-body h3{font-size:19px;margin-bottom:4px;}
  .kid-meta{display:block;font-size:13px;font-weight:600;color:var(--c-purple);margin-bottom:10px;}
  .kid-card-body p{font-size:15px;line-height:1.6;}

  .apply-cta{padding:100px 0;background:var(--c-yellow);text-align:center;}
  .apply-cta-inner{max-width:600px;margin:0 auto;padding:0 var(--page-padding);}
  .apply-cta h2{margin-bottom:16px;}
  .apply-cta h2 em{font-style:italic;}
  .apply-cta p{font-size:17px;color:rgba(45,46,51,0.65);margin-bottom:32px;}

  [data-reveal]{opacity:0;transform:translateY(32px);transition:opacity 0.7s cubic-bezier(0.16,1,0.3,1),transform 0.7s cubic-bezier(0.16,1,0.3,1);}
  [data-reveal].is-visible{opacity:1;transform:translateY(0);}
  [data-delay="1"]{transition-delay:0.1s;}[data-delay="2"]{transition-delay:0.2s;}

  @media(max-width:768px){
    .featured-split{grid-template-columns:1fr;}
    .featured-content{padding:48px var(--page-padding);}
    .kids-grid{grid-template-columns:1fr;}
  }
</style>
<script>const obs=new IntersectionObserver(e=>e.forEach(n=>{if(n.isIntersecting)n.target.classList.add('is-visible')}),{threshold:0.15,rootMargin:'0px 0px -40px 0px'});document.querySelectorAll('[data-reveal]').forEach(e=>obs.observe(e));</script>
