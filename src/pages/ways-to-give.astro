<script>
  /* ── Anchor nav — highlight active section on scroll ── */
  let _navObs: IntersectionObserver | null = null;

  document.addEventListener('astro:page-load', () => {
    _navObs?.disconnect();

    const links = document.querySelectorAll<HTMLAnchorElement>('.wtg-nav-link');
    const targets = document.querySelectorAll<HTMLElement>('.wtg-section');
    if (!links.length || !targets.length) return;

    _navObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting && e.target.id) {
          links.forEach(l => l.classList.toggle('is-active', l.hash === `#${e.target.id}`));
        }
      });
    }, { rootMargin: '-40% 0px -55% 0px' });

    targets.forEach(t => { if (t.id) _navObs!.observe(t); });
  });

  document.addEventListener('astro:before-swap', () => {
    _navObs?.disconnect();
    _navObs = null;
  });
</script>
