---
/**
 * LqipReveal.astro — LQIP blur-up reveal (progressive enhancement)
 *
 * Include once in BaseLayout. Images are visible by default.
 * JS opts into the blur→sharp fade only for images it can manage.
 * Uses astro:page-load for View Transition compatibility.
 */
---

<script>
  function initLqip() {
    document.querySelectorAll<HTMLImageElement>('.lqip-img:not(.loaded)').forEach(img => {
      if (img.complete && img.naturalWidth > 0) {
        img.classList.add('loaded');
        return;
      }
      // Not yet loaded — opt into the fade
      img.classList.add('lqip-pending');
      img.addEventListener('load', () => {
        img.classList.remove('lqip-pending');
        img.classList.add('loaded');
      }, { once: true });
      img.addEventListener('error', () => {
        // Keep lqip-pending (LQIP blur is the fallback), mark loaded to skip future runs
        img.classList.add('loaded');
      }, { once: true });
    });
  }
  document.addEventListener('astro:page-load', initLqip);
</script>
