---
/**
 * Home Page — Sunshine on a Ranney Day
 * Cinematic hero, editorial layout, scroll reveals
 * Performance: real CF Images, optimized animations, contain
 * SEO: JSON-LD NonprofitOrganization + WebSite, semantic HTML5
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import MediaLogos from '../components/ui/MediaLogos.astro';
import PartnerShowcase from '../components/ui/PartnerShowcase.astro';
import { getCollection } from 'astro:content';
import { getSiteStats } from '../utils/stats';
import { getPublishedKids } from '../utils/collections';

import { CF_BASE as CF, cfId as extractCfId, cfRaw, cfSrcset, cfLqip } from '../utils/cf-image';

/* ── Site settings (all editable from admin) ── */
import siteSettings from '../content/site/settings.json';
import financialSnapshot from '../content/site/financial-snapshot.json';

/* ── Auto-computed stats from content collections ── */
const computed = await getSiteStats();
const stats = {
  totalKids: computed.totalKids,
  totalRooms: computed.totalRooms,
  years: computed.years,
};

/* ── Hero (from site settings) ── */
const heroEyebrow = siteSettings.homeHero?.eyebrow || '501(c)(3) Nonprofit · Atlanta, GA · Since 2012';
const heroLine1 = siteSettings.homeHero?.headlineLine1 || 'Building <em>dreams</em>,';
const heroLine2 = siteSettings.homeHero?.headlineLine2 || 'one room at a time';
const heroHeadline = `${heroLine1}<br>${heroLine2}`;
const heroSub = siteSettings.homeHero?.lead || 'Dream bedrooms, accessible bathrooms, and therapy rooms for children with special needs — at no cost to families.';
const heroCta1Label = siteSettings.homeHero?.cta1Label || 'Give Today';
const heroCta1Link = siteSettings.homeHero?.cta1Link || '/donate';
const heroCta2Label = siteSettings.homeHero?.cta2Label || 'See Our Work';
const heroCta2Link = siteSettings.homeHero?.cta2Link || '#stories';

/* ── Hero Kid + Featured Story Kid (independent) ── */
const allKids = await getPublishedKids();

const heroSlug = siteSettings.heroKidSlug || siteSettings.featuredKidSlug || 'zyah';
const heroKid = allKids.find(k => k.id === heroSlug);
const hd = heroKid?.data;

const featuredSlug = siteSettings.featuredKidSlug || 'zyah';
const featuredKid = allKids.find(k => k.id === featuredSlug);
const fd = featuredKid?.data;

/* ── Kids Strip (from settings) ── */
const kidShowcaseData = siteSettings.kidShowcase || [
  { slug: 'liam', cfId: 'kids/liam/hero' },
  { slug: 'sophia', cfId: 'kids/sophia/hero' },
  { slug: 'jackson', cfId: 'kids/jackson/hero' },
  { slug: 'griffin', cfId: 'kids/griffin/hero' },
  { slug: 'madison', cfId: 'kids/madison/hero' },
  { slug: 'harper', cfId: 'kids/harper/hero' },
  { slug: 'noah', cfId: 'kids/noah/hero' },
  { slug: 'summer', cfId: 'kids/summer/hero' },
];
const kidShowcase = kidShowcaseData.map(item => {
  const kid = allKids.find(k => k.id === item.slug);
  const heroId = kid?.data?.heroImage ? extractCfId(kid.data.heroImage) : null;
  return {
    ...item,
    cfId: heroId || item.cfId || `kids/${item.slug}/hero`,
    name: kid?.data?.name || item.slug,
    age: kid?.data?.age,
    roomLabel: kid?.data?.roomTypes?.[0] || 'Dream Bedroom',
  };
});

/* ── Section photos (from settings) ── */
const sp = siteSettings.sectionPhotos || {};
const missionMainId = sp.missionMain || 'kids/eli/photo-01';
const missionAccentId = sp.missionAccent || 'kids/georgia/photo-01';
const heroPhotoId = siteSettings.heroKidPhotoId || `kids/${heroSlug}/hero`;
const storyPhotoId = siteSettings.featuredStoryImage || (fd?.heroImage ? extractCfId(fd.heroImage) : `kids/${featuredSlug}/hero`);
const processPhotoId = sp.process || `kids/${featuredSlug}/hero`;
const roomPhotos = {
  bedroom: sp.roomBedroom || 'kids/griffin/hero',
  bath: sp.roomBath || 'kids/zyah/hero',
  therapy: sp.roomTherapy || 'kids/jackson/hero',
};
/* ── Partners (dynamic count from collection + featured logos from settings) ── */
const partnerCollection = await getCollection('partners');
const totalPartners = partnerCollection.length;

const signaturePartners = partnerCollection
  .filter((p) => p.data.level === 'signature' && p.data.logo)
  .map((p) => ({ id: extractCfId(p.data.logo), name: p.data.name }));

const partnerLogos = signaturePartners;

/* ── Hero image URLs (DRY — preload + img must be byte-identical) ── */
/* Hero srcset: 4:5 aspect, gravity=face for kid photos, q=70 balances sharpness vs weight.
   CF Images auto-negotiates AVIF/WebP via Accept header — no format= needed.
   Preload <link> + <img> must use byte-identical srcset/sizes strings. */
const heroTransforms = 'fit=cover,gravity=face,q=70';
const heroImg320  = `${CF}/${heroPhotoId}/w=320,h=400,${heroTransforms}`;
const heroImg480  = `${CF}/${heroPhotoId}/w=480,h=600,${heroTransforms}`;
const heroImg640  = `${CF}/${heroPhotoId}/w=640,h=800,${heroTransforms}`;
const heroImg960  = `${CF}/${heroPhotoId}/w=960,h=1200,${heroTransforms}`;
const heroImg1280 = `${CF}/${heroPhotoId}/w=1280,h=1600,${heroTransforms}`;
const heroSrcset = `${heroImg320} 320w, ${heroImg480} 480w, ${heroImg640} 640w, ${heroImg960} 960w, ${heroImg1280} 1280w`;
/* Photo column: 0.85fr of 1400px grid ≈ 530px. 2× retina → 1060px. 1280w covers 2.4× comfortably. */
const heroSizes = '(max-width:480px) 80vw, (max-width:768px) 60vw, 530px';

import { getWebSiteSchema, getSiteNavigationSchema } from '../utils/schema';
const jsonLd = [getWebSiteSchema(), ...getSiteNavigationSchema()];
---

<BaseLayout
  title="Home"
  description="We build free dream bedrooms, accessible bathrooms, and therapy rooms for children with special needs in Atlanta. 501(c)(3) nonprofit — donate or apply today."
  ogImage="/og/home.png"
  jsonLd={jsonLd}
>
  <!-- Preload hero LCP image — imagesrcset/imagesizes must match the <img> -->
  <link slot="head" rel="preload" as="image" imagesrcset={heroSrcset} imagesizes={heroSizes} fetchpriority="high" />

  <!-- ══════ HERO — Editorial ══════ -->
  <section class="hero" aria-label="Introduction">
    <div class="hero-inner">
      <div class="hero-text">
        <p class="hero-eyebrow">{heroEyebrow}</p>
        <h1 class="hero-headline" set:html={heroHeadline} />
        <p class="hero-sub" set:html={heroSub} />
        <div class="hero-ctas">
          <a href={heroCta1Link} class="btn btn-primary btn-hero-glow">{heroCta1Label}</a>
          <a href={heroCta2Link} class="btn btn-dark">{heroCta2Label} <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" style="margin-left:2px"><path d="M8 3v10M3 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
      </div>
      <div class="hero-photo-wrap">
        <a href={`/kids/${heroSlug}`} class="hero-photo">
          <img
            src={heroImg960}
            srcset={heroSrcset}
            sizes={heroSizes}
            alt={`${hd?.name || 'Zyah'}'s room reveal — a life-changing moment`}
            width="960" height="1200"
            loading="eager" fetchpriority="high" decoding="auto"
          />
          <span class="hero-photo-name">{hd?.name || 'Zyah'}, {Array.isArray(hd?.age) ? `ages ${hd.age.join(', ')}` : `age ${hd?.age || 7}`}</span>
        </a>
        <div class="hero-photo-accent" aria-hidden="true"></div>
      </div>
    </div>

  </section>

  <!-- ══════ IMPACT RIBBON ══════ -->
  <section class="ribbon" aria-label="Impact numbers">
    <div class="ribbon-inner">
      <div class="ribbon-stat" data-reveal>
        <span class="ribbon-num">{stats.totalRooms}+</span>
        <span class="ribbon-label">Room Makeovers</span>
      </div>
      <div class="ribbon-divider" role="presentation"></div>
      <div class="ribbon-stat" data-reveal data-delay="1">
        <span class="ribbon-num">{stats.totalKids}+</span>
        <span class="ribbon-label">Children Served</span>
      </div>
      <div class="ribbon-divider" role="presentation"></div>
      <div class="ribbon-stat" data-reveal data-delay="2">
        <span class="ribbon-num">{stats.years}</span>
        <span class="ribbon-label">Years of Impact</span>
      </div>
    </div>
  </section>

  <MediaLogos theme="dark" linked={true} />

  <!-- ══════ MISSION ══════ -->
  <section class="mission" aria-labelledby="mission-heading">
    <div class="mission-inner">
      <div class="mission-text" data-reveal>
        <div class="section-label">Our Mission</div>
        <h2 id="mission-heading">Every child deserves a space that makes them feel <em class="highlight">safe</em>, <em class="highlight">seen</em>, and <em class="highlight">loved</em>.</h2>
        <p class="mission-body">A bedroom that feels like theirs. A bathroom that works for them. A therapy room built around who they are. For children with special needs, the right space changes everything — unlocking independence, comfort, and confidence that transforms daily life for the entire family.</p>
        <p class="mission-body">Since 2012, we've partnered with designers, contractors, and families across Greater Atlanta to create over {stats.totalRooms} life-changing spaces. Every project is unique because every child is unique.</p>
      </div>
      <div class="mission-visual" role="presentation">
        <div class="mission-photo mission-photo--main" data-reveal style={`background-image:url('${cfLqip(missionMainId)}')`}>
          <img src={`${CF}/${missionMainId}/w=600,q=65`} srcset={`${CF}/${missionMainId}/w=360,q=65 360w, ${CF}/${missionMainId}/w=480,q=65 480w, ${CF}/${missionMainId}/w=600,q=65 600w`} sizes="(max-width:768px) 65vw, 30vw" alt={`A completed SOARD room makeover — one of ${stats.totalRooms}+ spaces built for children with special needs`} width="800" height="600" loading="lazy" decoding="async" class="lqip-img" />
        </div>
        <div class="mission-photo mission-photo--accent" data-reveal data-delay="1" style={`background-image:url('${cfLqip(missionAccentId)}')`}>
          <img src={`${CF}/${missionAccentId}/w=600,q=65`} srcset={`${CF}/${missionAccentId}/w=280,q=65 280w, ${CF}/${missionAccentId}/w=400,q=65 400w, ${CF}/${missionAccentId}/w=600,q=65 600w, ${CF}/${missionAccentId}/w=800,q=65 800w`} sizes="(max-width:768px) 52vw, 24vw" alt="A child smiling in their newly designed dream bedroom by Sunshine on a Ranney Day" width="600" height="450" loading="lazy" decoding="async" class="lqip-img" />
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ FEATURED STORY ══════ -->
  <section class="story" id="stories" aria-labelledby="story-heading">
    <div class="story-inner">
      <div class="story-split">
        <figure class="story-photo" style={`background-image:url('${cfLqip(storyPhotoId)}')`}>
          <img src={`${CF}/${storyPhotoId}/w=700,q=65`} srcset={`${CF}/${storyPhotoId}/w=400,q=65 400w, ${CF}/${storyPhotoId}/w=600,q=65 600w, ${CF}/${storyPhotoId}/w=700,q=65 700w`} sizes="(max-width:768px) 100vw, 40vw" alt={`${fd?.name || 'Zyah'}'s room reveal`} width="900" height="600" loading="lazy" decoding="async" class="story-photo-img lqip-img" />
          <div class="story-photo-tag">Featured</div>
        </figure>
        <div class="story-content" data-reveal>
          <div class="section-label">Featured Story</div>
          <span class="story-type">{fd?.roomTypes?.[0] || 'Dream Bedroom'}</span>
          <h2 id="story-heading">{siteSettings.featuredStoryHeadline || `${fd?.name || 'Zyah'}'s new space gave them independence — and their family peace of mind.`}</h2>
          <p>{siteSettings.featuredStoryDescription || `${fd?.name || 'Zyah'}, ${Array.isArray(fd?.age) ? `ages ${fd.age.join(', ')}` : `age ${fd?.age || 7}`}, lives with ${fd?.diagnosis || 'Spinal Muscular Atrophy'}. Our team transformed their space into an accessible, joyful haven — with custom features designed around their unique needs and personality.`}</p>
          <a href={`/kids/${featuredSlug}`} class="btn btn-dark btn-lg story-cta">Read {fd?.name || 'Zyah'}'s Full Story →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ MORE KIDS ══════ -->
  <section class="kids-strip" aria-labelledby="kids-heading">
    <div class="kids-strip-header" data-reveal>
      <div>
        <div class="section-label">More Stories</div>
        <h2 id="kids-heading">Every room changes a <em class="highlight">life</em></h2>
      </div>
      <a href="/kids/" class="kids-strip-all">See all {stats.totalKids}+ kids →</a>
    </div>
    <div class="kids-scroll-wrap">
      <ul class="kids-scroll">
        {kidShowcase.map(kid => (
          <li class="kid-thumb-item">
            <a href={`/kids/${kid.slug}`} class="kid-thumb">
              <div class="kid-thumb-photo" style={`background-image:url('${cfLqip(kid.cfId)}')`}>
                <img src={`${CF}/${kid.cfId}/w=440,h=440,fit=cover,q=65`} alt={`${kid.name}'s room reveal`} width="220" height="220" loading="lazy" decoding="async" class="lqip-img" />
              </div>
              <h3 class="kid-thumb-name">{kid.name}</h3>
              <p>{kid.roomLabel}{kid.age ? ` · ${Array.isArray(kid.age) && kid.age.length > 1 ? `Ages ${kid.age.join(', ')}` : `Age ${Array.isArray(kid.age) ? kid.age[0] : kid.age}`}` : ''}</p>
            </a>
          </li>
        ))}
      </ul>
      <button class="kids-scroll-btn kids-scroll-btn--prev" aria-label="Scroll left" type="button">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <button class="kids-scroll-btn kids-scroll-btn--next" aria-label="Scroll right" type="button">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>
  </section>

  <!-- ══════ PROCESS ══════ -->
  <section class="process" aria-labelledby="process-heading">
    <div class="process-inner">
      <div class="process-header" data-reveal>
        <div class="section-label">The Process</div>
        <h2 id="process-heading">From first call to <em class="highlight">big reveal</em></h2>
      </div>

      <div class="process-split">
        <div class="process-photo" data-reveal style={`background-image:url('${cfLqip(processPhotoId)}')`}>
          <img src={`${CF}/${processPhotoId}/w=960,fit=scale-down,gravity=face,q=70`} alt={`${fd?.name || 'A child'} sees their new room for the first time`} width="960" height="640" loading="lazy" decoding="async" class="lqip-img" />
        </div>

        <div class="process-content">
          <ol class="process-timeline" role="list">
            <li class="process-step" data-reveal data-delay="1">
              <span class="process-num" aria-hidden="true">01</span>
              <h3>Family Applies</h3>
              <p>Families tell us about their child, their needs, and their dreams for a new space.</p>
            </li>
            <li class="process-step" data-reveal data-delay="2">
              <span class="process-num" aria-hidden="true">02</span>
              <h3>Design & Plan</h3>
              <p>Our designer partners create a one-of-a-kind room concept tailored to the child's personality and needs.</p>
            </li>
            <li class="process-step" data-reveal data-delay="3">
              <span class="process-num" aria-hidden="true">03</span>
              <h3>Build & Transform</h3>
              <p>Construction partners bring the design to life.</p>
            </li>
            <li class="process-step process-step--highlight" data-reveal data-delay="4">
              <span class="process-num" aria-hidden="true">04</span>
              <span class="process-badge">The best part</span>
              <h3>The Big Reveal</h3>
              <p>The child walks in and sees a room designed just for them. Everything changes in that moment.</p>
            </li>
          </ol>
          <div class="process-cta" data-reveal>
            <a href="/partners/" class="btn btn-primary">Become a Partner →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ ROOM TYPES — Editorial magazine ══════ -->
  <section class="rooms" aria-labelledby="rooms-heading">
    <div class="rooms-inner">
      <div class="rooms-header" data-reveal>
        <div class="section-label">What We Build</div>
        <h2 id="rooms-heading">Three types of spaces,<br/>one purpose: <em class="highlight">empowering kids</em></h2>
      </div>

      <!-- Three room-type cards -->
      <div class="rm-trio">
        <article class="rm-card" data-reveal>
          <a href="/kids?type=type-accessible-bathroom" class="rm-card-link" aria-label="Accessible bathrooms — see our work">
            <div class="rm-card-img rm-parallax" style={`background-image:url('${cfLqip(roomPhotos.bath)}')`}>
              <img
                src={`${CF}/${roomPhotos.bath}/w=700,h=875,fit=cover,q=80`}
                srcset={cfSrcset(roomPhotos.bath, [360, 500, 700, 1000, 1400], { fit: 'cover', aspectRatio: 5/4, quality: 80 })}
                sizes="(max-width:600px) 82vw, (max-width:900px) 46vw, 30vw"
                alt="An accessible bathroom built by SOARD with roll-in shower, grab bars, and lowered vanity" width="700" height="875"
                loading="lazy" decoding="async" class="lqip-img"
              />
            </div>
            <div class="rm-card-text">
              <span class="rm-num" aria-hidden="true">01</span>
              <h3>Accessible Bathrooms</h3>
              <div class="rm-rule"></div>
              <p>Roll-in showers, grab bars, and lowered vanities — giving children independence and giving families relief from daily struggles.</p>
              <span class="rm-cta">See our work <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            </div>
          </a>
        </article>
        <article class="rm-card" data-reveal data-delay="1">
          <a href="/kids?type=type-dream-bedroom" class="rm-card-link" aria-label="Dream bedrooms — see our work">
            <div class="rm-card-img rm-parallax" style={`background-image:url('${cfLqip(roomPhotos.bedroom)}')`}>
              <img
                src={`${CF}/${roomPhotos.bedroom}/w=700,h=875,fit=cover,q=80`}
                srcset={cfSrcset(roomPhotos.bedroom, [360, 500, 700, 1000, 1400], { fit: 'cover', aspectRatio: 5/4, quality: 80 })}
                sizes="(max-width:600px) 82vw, (max-width:900px) 46vw, 30vw"
                alt="A personalized dream bedroom designed around a child's interests and needs" width="700" height="875"
                loading="lazy" decoding="async" class="lqip-img"
              />
            </div>
            <div class="rm-card-text">
              <span class="rm-num" aria-hidden="true">02</span>
              <h3>Dream Bedrooms</h3>
              <div class="rm-rule"></div>
              <p>Personalized sanctuaries where children can escape, imagine, and simply be kids — designed around their unique interests and needs.</p>
              <span class="rm-cta">See our work <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            </div>
          </a>
        </article>
        <article class="rm-card" data-reveal data-delay="2">
          <a href="/kids?type=type-therapy-room" class="rm-card-link" aria-label="Therapy rooms — see our work">
            <div class="rm-card-img rm-parallax" style={`background-image:url('${cfLqip(roomPhotos.therapy)}')`}>
              <img
                src={`${CF}/${roomPhotos.therapy}/w=700,h=875,fit=cover,q=80`}
                srcset={cfSrcset(roomPhotos.therapy, [360, 500, 700, 1000, 1400], { fit: 'cover', aspectRatio: 5/4, quality: 80 })}
                sizes="(max-width:600px) 82vw, (max-width:900px) 46vw, 30vw"
                alt="A calming sensory therapy room with dimmable lights, swing, and textured walls" width="700" height="875"
                loading="lazy" decoding="async" class="lqip-img"
              />
            </div>
            <div class="rm-card-text">
              <span class="rm-num" aria-hidden="true">03</span>
              <h3>Therapy Rooms</h3>
              <div class="rm-rule"></div>
              <p>Calming retreats with dimmable lights, swings, crash pads, and textured walls — spaces where children can decompress and develop.</p>
              <span class="rm-cta">See our work <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            </div>
          </a>
        </article>
      </div>
    </div>
  </section>

  <!-- ══════ TRUST ══════ -->
  <section class="trust" aria-labelledby="trust-heading">
    <div class="trust-inner">
      <div class="trust-header" data-reveal>
        <div class="section-label" style="color:var(--c-yellow)">Trust & Transparency</div>
        <h2 id="trust-heading">We're an open book. <em>Always.</em></h2>
        <p class="trust-subtitle">We believe you should know exactly where every dollar goes. Our financials are public, our mission is clear, and our track record speaks for itself.</p>
      </div>
      <div class="trust-grid">
        <div class="trust-card" data-reveal>
          <div class="trust-card-top"><span class="trust-big">{financialSnapshot.programPct}%</span><span class="trust-card-label">Program Services</span></div>
          <p>The vast majority of every dollar funds room materials, labor, and design for children's spaces.</p>
        </div>
        <div class="trust-card" data-reveal data-delay="1">
          <div class="trust-card-top"><span class="trust-big trust-big--icon"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"/><path d="M14 2v5a1 1 0 0 0 1 1h5"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg></span><span class="trust-card-label">990 Public</span></div>
          <p>Our IRS Form 990 tax returns are available for anyone to review, anytime.</p>
        </div>
        <div class="trust-card" data-reveal data-delay="2">
          <div class="trust-card-top"><span class="trust-big trust-big--icon"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg></span><span class="trust-card-label">501(c)(3)</span></div>
          <p>Registered nonprofit. EIN 45-4773997. All donations are fully tax-deductible.</p>
        </div>
      </div>
      <div class="trust-cta" data-reveal><a href="/about/financials/" class="btn btn-ghost-light">View Our Financials →</a></div>
    </div>
  </section>

  <!-- ══════ PARTNERS ══════ -->
