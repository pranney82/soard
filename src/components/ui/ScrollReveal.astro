---
/**
 * ScrollReveal.astro — Shared scroll-reveal observer
 *
 * Include once in BaseLayout. Handles all [data-reveal] elements
 * site-wide with proper View Transition lifecycle:
 *   - astro:page-load  → set up observer on every navigation
 *   - astro:before-swap → disconnect observer before DOM swap
 *   - 3s safety timeout → force-reveal if observer somehow fails
 *   - <noscript>        → all content visible if JS is blocked
 *
 * Pages provide their own scoped CSS for [data-reveal] base state
 * and [data-reveal].is-visible reveal state. This component only
 * manages the class toggle.
 */
---

<noscript>
  <style>
    [data-reveal] { opacity: 1 !important; transform: none !important; transition: none !important; }
  </style>
</noscript>

<script>
  let _revealObserver: IntersectionObserver | null = null;
  let _revealSafety: ReturnType<typeof setTimeout> | null = null;

  function cleanupReveal() {
    _revealObserver?.disconnect();
    _revealObserver = null;
    if (_revealSafety) { clearTimeout(_revealSafety); _revealSafety = null; }
  }

  function initReveal() {
    cleanupReveal();

    const els = document.querySelectorAll('[data-reveal]');
    if (!els.length) return;

    _revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          _revealObserver?.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

    els.forEach(el => _revealObserver!.observe(el));

    // Safety net: force-reveal any still-hidden elements after 3s
    _revealSafety = setTimeout(() => {
      document.querySelectorAll('[data-reveal]:not(.is-visible)').forEach(el => {
        el.classList.add('is-visible');
      });
    }, 3000);
  }

  document.addEventListener('astro:page-load', initReveal);
  document.addEventListener('astro:before-swap', cleanupReveal);
</script>
