  }

  .detail-chip__value {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--c-dark);
    line-height: 1.2;
  }

  .hero__intro {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--c-text);
    margin-bottom: var(--space-xl);
    max-width: 480px;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
  }

  .hero__donate-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: var(--c-yellow);
    color: var(--c-dark);
    font-weight: 700;
    font-size: 0.9rem;
    border-radius: 100px;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .hero__donate-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(255, 218, 36, 0.35);
  }

  .hero__share-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 12px 20px;
    background: transparent;
    border: 1px solid var(--c-border);
    border-radius: 100px;
    color: var(--c-text-muted);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: border-color var(--transition-fast), color var(--transition-fast), background var(--transition-fast);
  }

  .hero__share-btn:hover {
    border-color: var(--c-dark);
    color: var(--c-dark);
    background: var(--c-white);
  }

  .hero__share-btn.shared {
    border-color: rgba(255, 218, 36, 0.5);
    color: var(--c-dark);
    background: rgba(255, 218, 36, 0.1);
  }

  /* ═══ Story Section ════════════════════════ */
  .story {
    padding-block: var(--space-3xl);
    background: var(--c-white);
    content-visibility: auto;
    contain-intrinsic-size: auto 600px;
  }

  .story__body {
    font-size: 1.1rem;
    line-height: 1.85;
    color: var(--c-text);
    max-width: 680px;
  }

  .story__body p + p {
