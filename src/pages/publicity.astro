---
/**
 * Publicity Page — Sunshine on a Ranney Day
 * Top-1% press page: stats → logos → celebrity → video → featured → archive → CTA
 *
 * Architecture:
 * - JSON-LD CollectionPage + NewsArticle structured data
 * - OG image for social sharing
 * - Animated stat counters (IntersectionObserver)
 * - Category filter tabs on archive (client JS, no page reload)
 * - Progressive disclosure: archive groups collapse with show-more
 * - YouTube click-to-load facade with preconnect warming
 * - All images via CF Images with proper srcset + sizes
 * - prefers-reduced-motion fully respected
 */
import PageLayout from '../layouts/PageLayout.astro';
import MediaLogos from '../components/ui/MediaLogos.astro';
import CFImage from '../components/ui/CFImage.astro';
import { CF_BASE as CF } from '../utils/cf-image';
import { getCollection } from 'astro:content';

const allPress = await getCollection('press');
const press = allPress.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const featured = press.filter(p => p.data.featured);

const years = [...new Set(press.map(p => new Date(p.data.date).getFullYear()))].sort((a, b) => b - a);
const pressByYear: Record<number, typeof press> = {};
years.forEach(y => { pressByYear[y] = press.filter(p => new Date(p.data.date).getFullYear() === y); });

const categories = ['all', 'national-tv', 'local-tv', 'print', 'magazine', 'entertainment'] as const;
const categoryLabels: Record<string, string> = {
  'all': 'All',
  'national-tv': 'National TV', 'local-tv': 'Local TV',
  'print': 'Print & Online', 'magazine': 'Magazine', 'entertainment': 'Entertainment',
};

function formatDate(dateStr: string): string {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
}

function formatShortDate(dateStr: string): string {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

const celebrities = [
  { name: 'Atlanta Braves', desc: 'Holly & Peter honored as Community Heroes. Players Dansby Swanson, Max Fried, Charlie Culberson & Ender Inciarte surprised them at a makeover with a $5,000 donation.', imageId: 'press-braves-community-heroes', type: 'Community Heroes' },
  { name: 'Coach Nick Saban', desc: 'University of Alabama Coach Nick Saban surprised makeover recipient and cancer survivor Ally with a meeting with her favorite coach.', imageId: 'press-nick-saban-ally', type: 'Celebrity Surprise' },
  { name: 'Atlanta Hawks', desc: 'Hall of Famer Dominique Wilkins, Tim Hardaway Jr., Kris Humphries & Malcolm Delaney surprised Kalen with his Hawks-themed dream bedroom.', imageId: 'press-hawks-kalen-wilkins', type: 'Celebrity Surprise' },
  { name: 'Coach Kirby Smart', desc: 'Honored to be supported by the UGA community as well as their football coach and family.', imageId: 'press-kirby-smart-uga', type: 'Community Partner' },
  { name: 'Atlanta Falcons', desc: 'Peter & Holly honored as Everyday Heroes by the Atlanta Falcons and cheerleaders.', imageId: 'press-falcons-everyday-heroes', type: 'Everyday Heroes' },
  { name: "TLC's Say Yes to the Dress", desc: "Lori & Monte, along with their Bridals by Lori team, helped with multiple room makeovers fit for princesses.", imageId: 'press-tlc-lori-monte', type: 'Celebrity Partner' },
  { name: 'Coy Bowles — Zac Brown Band', desc: "Grammy-winning guitarist Coy Bowles surprised Ruby in her new ballet studio room. Book proceeds benefit SOARD.", imageId: 'press-coy-bowles-ruby', type: 'Celebrity Surprise' },
  { name: 'Governor Nathan Deal', desc: 'Former Georgia Governor and Mrs. Deal attended the annual Evening of Sunshine Gala at the College Football Hall of Fame.', imageId: 'press-governor-deal-gala', type: 'Evening of Sunshine Gala' },
];

const totalPress = press.length;
const tvCount = press.filter(p => p.data.category === 'national-tv' || p.data.category === 'local-tv').length;
const uniqueOutlets = new Set(press.map(p => p.data.outlet)).size;
const yearsActive = new Date().getFullYear() - 2012;

/* JSON-LD: CollectionPage with embedded NewsArticle items */
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Publicity & Media Coverage',
  description: `Sunshine on a Ranney Day has been featured on the Today Show, WSB-TV, 11Alive, Fox 5, AJC, K-LOVE, and ${totalPress}+ media outlets.`,
  url: 'https://sunshineonaranneyday.com/publicity',
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: totalPress,
    itemListElement: featured.slice(0, 8).map((item, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'NewsArticle',
        headline: item.data.title,
        publisher: { '@type': 'Organization', name: item.data.outlet },
        datePublished: item.data.date,
        url: item.data.url,
      },
    })),
  },
};

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Publicity', url: '/publicity' },
];
---

<PageLayout
  title="Publicity & Media Coverage"
  description={`Sunshine on a Ranney Day has been featured on the Today Show, WSB-TV, 11Alive, Fox 5, AJC, K-LOVE, and ${totalPress}+ media outlets.`}
  heroLabel="In the Spotlight"
  heroTitle={'Our story, told by <em class="highlight">those who know it best</em>.'}
  heroSubtitle="From the Today Show to Coach Saban, from the Atlanta Braves to K-LOVE — the world is helping us share the mission of building dreams for children with special needs."
  ogImage={`${CF}/press-braves-community-heroes/w=1200,h=630,fit=cover,q=80`}
  ogType="website"
  jsonLd={jsonLd}
  breadcrumbs={breadcrumbs}
>

  <!-- ══════ IMPACT STATS ══════ -->
  <section class="stats-bar" aria-label="Media impact">
    <div class="container">
      <div class="stats-bar__grid" data-reveal>
        <div class="stats-bar__item" data-reveal data-delay="0">
          <span class="stats-bar__num" data-count-to={totalPress} data-suffix="+">0</span>
          <span class="stats-bar__label">Media Features</span>
          <span class="stats-bar__sub">since 2012</span>
        </div>
        <div class="stats-bar__item" data-reveal data-delay="1">
          <span class="stats-bar__num" data-count-to={uniqueOutlets} data-suffix="+">0</span>
          <span class="stats-bar__label">Outlets</span>
          <span class="stats-bar__sub">local & national</span>
        </div>
        <div class="stats-bar__item" data-reveal data-delay="2">
          <span class="stats-bar__num" data-count-to={tvCount}>0</span>
          <span class="stats-bar__label">TV Segments</span>
          <span class="stats-bar__sub">broadcast features</span>
        </div>
        <div class="stats-bar__item" data-reveal data-delay="3">
          <span class="stats-bar__num" data-count-to={yearsActive} data-suffix="+">0</span>
          <span class="stats-bar__label">Years</span>
          <span class="stats-bar__sub">in the spotlight</span>
        </div>
      </div>
    </div>
  </section>

  <MediaLogos theme="dark" linked={false} />

  <!-- ══════ CELEBRITY SUPPORTERS ══════ -->
  <section class="celebs" aria-labelledby="celebs-heading">
    <div class="container">
      <div class="celebs__header" data-reveal>
        <span class="section-label">Notable Supporters</span>
        <h2 id="celebs-heading" class="sec-title">Championed by <em class="highlight">Atlanta's best</em></h2>
        <p class="celebs__sub">From coaches and athletes to TV personalities and Georgia's governor, the people who meet our families become our biggest advocates.</p>
      </div>

      <!-- Marquee row: top 4 in large cards -->
      <div class="celebs__marquee">
        {celebrities.slice(0, 4).map((c, i) => (
          <article class="cc cc--large" data-reveal data-delay={String(i)}>
            <div class="cc__img-wrap">
              <CFImage
                src={`${CF}/${c.imageId}/public`}
                alt={c.name}
                width={640}
                height={480}
                sizes="(max-width: 480px) 100vw, (max-width: 768px) 50vw, (max-width: 1200px) 33vw, 280px"
                widths={[280, 400, 560, 640]}
                fit="cover"
                gravity="face"
                class="cc__img"
              />
              <div class="cc__overlay">
                <span class="cc__type">{c.type}</span>
              </div>
            </div>
            <div class="cc__body">
              <h3 class="cc__name">{c.name}</h3>
              <p class="cc__desc">{c.desc}</p>
            </div>
          </article>
        ))}
      </div>

      <!-- Second row: remaining 4 in compact cards -->
      <div class="celebs__grid">
        {celebrities.slice(4).map((c, i) => (
          <article class="cc" data-reveal data-delay={String(i)}>
            <div class="cc__img-wrap">
              <CFImage
                src={`${CF}/${c.imageId}/public`}
                alt={c.name}
                width={600}
                height={500}
                sizes="(max-width: 480px) 100vw, (max-width: 768px) 50vw, 260px"
                widths={[260, 400, 520]}
                fit="cover"
                gravity="face"
                class="cc__img"
              />
              <div class="cc__overlay">
                <span class="cc__type">{c.type}</span>
              </div>
            </div>
            <div class="cc__body">
              <h3 class="cc__name">{c.name}</h3>
              <p class="cc__desc">{c.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════ VIDEO HIGHLIGHTS ══════ -->
  <section class="videos" aria-labelledby="vid-heading">
    <div class="container">
      <div class="videos__header" data-reveal>
        <span class="section-label section-label--on-dark">Watch</span>
        <h2 id="vid-heading" class="sec-title sec-title--on-dark">See the <em class="highlight">moments</em> that matter</h2>
      </div>
      <div class="videos__grid">
        <!-- Today Show — click-to-load facade -->
        <div class="vc vc--hero" data-reveal>
          <div class="vc__wrap" id="yt-today-show">
            <img
              src="https://i.ytimg.com/vi/Tej9V0MPQbY/maxresdefault.jpg"
              alt="Today Show — Sunshine on a Ranney Day"
              width="1280" height="720"
              loading="lazy" decoding="async"
              class="vc__poster"
            />
            <button class="vc__play-btn" aria-label="Play Today Show video" data-yt-id="Tej9V0MPQbY">
              <svg width="68" height="48" viewBox="0 0 68 48"><path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="#FFDA24"/><path d="M45 24L27 14v20" fill="#373A36"/></svg>
            </button>
          </div>
          <div class="vc__info">
            <span class="vc__badge">Featured</span>
            <h3 class="vc__title">NBC Today Show Feature</h3>
            <p class="vc__desc">Peter & Holly renovate parent sleep rooms at Children's Healthcare of Atlanta as part of NBC's #ShareKindness campaign.</p>
          </div>
        </div>
        <!-- Braves Community Heroes -->
        <div class="vc" data-reveal data-delay="1">
          <div class="vc__wrap">
            <CFImage
              src={`${CF}/press-braves-community-heroes/public`}
              alt="Atlanta Braves Community Heroes — Sunshine on a Ranney Day"
              width={960}
              height={540}
              sizes="(max-width: 768px) 100vw, 480px"
              widths={[480, 640, 960]}
              class="vc__poster"
            />
            <a href="https://www.mlb.com/video/2018-community-heroes-week/c-2525462483" target="_blank" rel="noopener noreferrer" class="vc__play-btn" aria-label="Watch Braves Community Heroes on MLB.com">
              <svg width="68" height="48" viewBox="0 0 68 48"><path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="#CE1141"/><path d="M45 24L27 14v20" fill="white"/></svg>
            </a>
          </div>
          <div class="vc__info">
            <h3 class="vc__title">Atlanta Braves Community Heroes</h3>
            <p class="vc__desc">Braves players surprise the Ranneys at a makeover and honor them on-field during Community Heroes Week.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ FEATURED COVERAGE ══════ -->
  <section class="pub-featured" aria-labelledby="feat-heading">
    <div class="container">
      <div data-reveal>
        <span class="section-label">Featured Stories</span>
        <h2 id="feat-heading" class="sec-title">Highlighted <em class="highlight">coverage</em></h2>
      </div>
      <div class="feat-grid">
        {featured.map((item, i) => (
          <article class="fc" data-reveal data-delay={i < 3 ? String(i) : undefined}>
            <div class="fc__accent" aria-hidden="true"></div>
            <div class="fc__body">
              <div class="fc__top">
                <span class="fc__cat">{categoryLabels[item.data.category]}</span>
                <time class="fc__date" datetime={item.data.date}>{formatShortDate(item.data.date)}</time>
              </div>
              <h3 class="fc__title">{item.data.title}</h3>
              <p class="fc__outlet">
                <svg class="fc__outlet-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                {item.data.outlet}
              </p>
              <p class="fc__excerpt">{item.data.excerpt}</p>
              <div class="fc__foot">
                {item.data.url && (
                  <a href={item.data.url} class="fc__link" target="_blank" rel="noopener noreferrer">
                    Read article <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
                  </a>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════ PRESS ARCHIVE ══════ -->
  <section class="pub-archive" aria-labelledby="arch-heading" id="archive">
    <div class="container">
      <div class="archive__header" data-reveal>
        <div class="archive__header-text">
          <span class="section-label">Press Archive</span>
          <h2 id="arch-heading" class="sec-title">All <em class="highlight">{totalPress} stories</em></h2>
        </div>
        <!-- Category filter tabs -->
        <nav class="archive__filters" aria-label="Filter press by category">
          {categories.map(cat => (
            <button
              class={`filter-tab ${cat === 'all' ? 'filter-tab--active' : ''}`}
              data-filter={cat}
              aria-pressed={cat === 'all' ? 'true' : 'false'}
            >
              {categoryLabels[cat]}
              <span class="filter-tab__count">
                {cat === 'all' ? totalPress : press.filter(p => p.data.category === cat).length}
              </span>
            </button>
          ))}
        </nav>
      </div>

      <!-- Filtered results count (live region for a11y) -->
      <p class="archive__results" aria-live="polite" aria-atomic="true"></p>

      <div class="archive__body">
        {years.map(year => (
          <div class="yg" data-reveal data-year={year}>
            <div class="yg__label">
              <span class="yg__year">{year}</span>
              <span class="yg__ct">{pressByYear[year].length} stories</span>
              <div class="yg__line" aria-hidden="true"></div>
            </div>
            <div class="cl">
              {pressByYear[year].map(item => (
                <article class="ci" data-category={item.data.category}>
                  <div class="ci__indicator" aria-hidden="true"></div>
                  <div class="ci__content">
                    <div class="ci__meta">
                      <span class="ci__outlet">{item.data.outlet}</span>
                      <span class="ci__sep" aria-hidden="true">&middot;</span>
                      <time datetime={item.data.date}>{formatDate(item.data.date)}</time>
                      <span class="ci__tag">{categoryLabels[item.data.category]}</span>
                    </div>
                    <h3 class="ci__title">
                      {item.data.url ? <a href={item.data.url} target="_blank" rel="noopener noreferrer">{item.data.title}</a> : <span>{item.data.title}</span>}
                    </h3>
                    <p class="ci__excerpt">{item.data.excerpt}</p>
                  </div>
                  {item.data.url && (
                    <a href={item.data.url} class="ci__arrow" target="_blank" rel="noopener noreferrer" aria-label={`Read: ${item.data.title}`}>
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
                    </a>
                  )}
                </article>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════ CTA ══════ -->
  <section class="pub-cta" data-reveal>
    <div class="container">
      <div class="pub-cta__inner">
        <div class="pub-cta__content">
          <span class="section-label section-label--on-dark">Media</span>
          <h2 class="pub-cta__title">Tell our story with us</h2>
          <p class="pub-cta__desc">Interested in covering Sunshine on a Ranney Day? We provide press-ready assets, high-resolution photography, and direct access to founders Peter & Holly Ranney.</p>
        </div>
        <div class="pub-cta__actions">
          <a href="mailto:info@soardcharity.com?subject=Media%20Inquiry" class="btn btn-primary btn-lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg>
            Media Inquiry
          </a>
          <a href="/branding" class="btn btn-outline-light">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Brand & Media Kit
          </a>
        </div>
      </div>
    </div>
  </section>

</PageLayout>

<!-- ══════ CLIENT JS ══════ -->

<!-- Counter animation + YouTube facade + Archive filters -->
<script>
  document.addEventListener('astro:page-load', () => {

    /* ── Animated stat counters ── */
    const counters = document.querySelectorAll<HTMLElement>('[data-count-to]');
    if (counters.length) {
      const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          const target = parseInt(el.dataset.countTo || '0', 10);
          const suffix = el.dataset.suffix || '';
          if (!target) return;
          counterObserver.unobserve(el);

          const duration = 1600;
          const start = performance.now();
          const easeOutQuart = (t: number) => 1 - Math.pow(1 - t, 4);

          function tick(now: number) {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            const value = Math.round(easeOutQuart(progress) * target);
            el.textContent = value.toLocaleString() + suffix;
            if (progress < 1) requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
        });
      }, { threshold: 0.3 });
      counters.forEach(c => counterObserver.observe(c));
    }

    /* ── YouTube click-to-load facade ── */
    let warmed = false;
    function warmConnections() {
      if (warmed) return;
      warmed = true;
      ['https://www.youtube-nocookie.com', 'https://i.ytimg.com'].forEach(origin => {
        const link = document.createElement('link');
        link.rel = 'preconnect';
        link.href = origin;
        document.head.appendChild(link);
      });
    }

    document.querySelectorAll<HTMLButtonElement>('[data-yt-id]').forEach(btn => {
      btn.addEventListener('pointerover', warmConnections, { once: true });
      btn.addEventListener('focus', warmConnections, { once: true });
      btn.addEventListener('click', () => {
        const id = btn.dataset.ytId;
        const wrap = btn.closest('.vc__wrap');
        if (!wrap || !id) return;
        const iframe = document.createElement('iframe');
        iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1`;
        iframe.title = btn.getAttribute('aria-label') || '';
        iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
        iframe.allowFullscreen = true;
        iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;';
        wrap.innerHTML = '';
        wrap.appendChild(iframe);
      });
    });

    /* ── Archive category filters ── */
    const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
    const archiveItems = document.querySelectorAll<HTMLElement>('.ci[data-category]');
    const yearGroups = document.querySelectorAll<HTMLElement>('.yg[data-year]');
    const resultsEl = document.querySelector<HTMLElement>('.archive__results');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const cat = tab.dataset.filter || 'all';

        // Update active state
        tabs.forEach(t => {
          t.classList.remove('filter-tab--active');
          t.setAttribute('aria-pressed', 'false');
        });
        tab.classList.add('filter-tab--active');
        tab.setAttribute('aria-pressed', 'true');

        let visibleCount = 0;

        // Filter items
        archiveItems.forEach(item => {
          const matches = cat === 'all' || item.dataset.category === cat;
          item.style.display = matches ? '' : 'none';
          if (matches) visibleCount++;
        });

        // Hide year groups with no visible items
        yearGroups.forEach(yg => {
          const visibleInGroup = yg.querySelectorAll<HTMLElement>('.ci[data-category]');
          let anyVisible = false;
          visibleInGroup.forEach(ci => {
            if (ci.style.display !== 'none') anyVisible = true;
          });
          yg.style.display = anyVisible ? '' : 'none';
        });

        // Update results count
        if (resultsEl) {
          resultsEl.textContent = cat === 'all'
            ? ''
            : `Showing ${visibleCount} ${visibleCount === 1 ? 'story' : 'stories'}`;
        }
      });
    });
  });
</script>

<style>
  .container { max-width: var(--max-width); margin: 0 auto; padding-inline: var(--page-padding); }
  .container--narrow { max-width: var(--max-width-narrow); }

  /* ── Section labels (matching site design system) ── */
  .section-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-accent, #373A36);
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }
  .section-label::before {
    content: '';
    width: 28px;
    height: 2px;
    background: currentColor;
    flex-shrink: 0;
  }
