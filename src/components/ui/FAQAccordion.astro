---
/**
 * FAQAccordion — production-grade FAQ disclosure list.
 *
 * Pattern:
 *  • Native <details>/<summary> for free a11y semantics (keyboard, screen reader, focus).
 *  • Each question wrapped in a heading element for screen-reader heading navigation
 *    (per W3C WAI-ARIA APG).
 *  • Height animation uses the Radix pattern: JS measures the natural content height
 *    in pixels, then transitions height from explicit 0px → target px (and back).
 *    Browsers optimize concrete pixel transitions far better than max-height or
 *    grid-template-rows because the end value is known up-front.
 *  • Single CSS transition (height only). No opacity stacking, no grid track tricks.
 *  • Reduced-motion: instant open/close, no transition.
 *  • Deep-linkable: each item has a stable id, opening syncs hash, page load reads hash.
 *  • Single-open-at-a-time, with mid-flight transitions cancelled cleanly.
 *  • FAQ schema JSON-LD for Google rich results.
 *
 * References (verified, not guessed):
 *  • Radix Accordion docs — animation pattern using measured CSS variable
 *  • W3C WAI-ARIA APG — accordion header heading wrapping
 *  • NN/G — line-height 1.5–1.6 for answer body, visual weight on questions
 *  • Aditus — warns against max-height animation, recommends measured-pixel approach
 */

export interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
  eyebrow?: string;
  heading?: string;
  subtitle?: string;
  /** Brand accent color used for active state, links, focus ring. */
  accent?: string;
  /** Tinted background for the eyebrow chip and the open item. */
  accentTint?: string;
  /** ID prefix for deep-linking. Each item id = `${idPrefix}-${question-slug}` */
  idPrefix?: string;
  footerLabel?: string;
  footerCta?: string;
  footerHref?: string;
  /** Emit FAQPage JSON-LD for Google rich results. */
  generateSchema?: boolean;
  /**
   * Heading level for each question. Per W3C WAI-ARIA APG, each accordion
   * header should be wrapped in a heading so screen-reader users can navigate
   * the list by heading level. Default h3 — pick the level appropriate to
   * the page's heading hierarchy.
   */
  questionHeadingLevel?: 'h2' | 'h3' | 'h4' | 'h5';
}

const {
  items,
  eyebrow,
  heading,
  subtitle,
  accent = '#2e7d32',
  accentTint = 'rgba(46, 125, 50, 0.1)',
  idPrefix = 'faq',
  footerLabel,
  footerCta,
  footerHref,
  generateSchema = true,
  questionHeadingLevel = 'h3',
} = Astro.props;
const QHeading = questionHeadingLevel;

function slugify(s: string): string {
  return s
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '')
    .slice(0, 60);
}

/* Pre-compute item ids with collision dedupe (-2, -3, ...) so that two
   questions sharing their first 60 slugified chars still get unique anchors
   for deep-linking. */
const itemIds: string[] = [];
const seen = new Map<string, number>();
for (const faq of items) {
  const base = `${idPrefix}-${slugify(faq.question)}`;
  const n = (seen.get(base) ?? 0) + 1;
  seen.set(base, n);
  itemIds.push(n === 1 ? base : `${base}-${n}`);
}

const hostStyle = [`--faq-accent: ${accent}`, `--faq-accent-tint: ${accentTint}`].join('; ');
---

<faq-accordion class="faqacc" style={hostStyle}>
  {(eyebrow || heading || subtitle) && (
    <div class="faqacc__header">
      {eyebrow && <span class="faqacc__label" data-reveal>{eyebrow}</span>}
      {heading && <h2 class="faqacc__heading" data-reveal>{heading}</h2>}
      {subtitle && <p class="faqacc__sub" data-reveal>{subtitle}</p>}
    </div>
  )}

  <div class="faqacc__list">
    {items.map((faq, i) => {
      const itemId = itemIds[i];
      return (
        <details class="faqacc__item" id={itemId}>
          <summary class="faqacc__question">
            <QHeading class="faqacc__q-text">{faq.question}</QHeading>
            <span class="faqacc__chevron" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </span>
          </summary>
          <div class="faqacc__body">
            <div class="faqacc__answer" set:html={faq.answer} />
          </div>
        </details>
      );
    })}
  </div>

  {footerHref && footerCta && (
    <p class="faqacc__footer" data-reveal>
      {footerLabel || 'Still have a question?'}
      <a href={footerHref}>{footerCta}</a>.
    </p>
  )}

  {generateSchema && (
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: items.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: { '@type': 'Answer', text: faq.answer },
      })),
    })} />
  )}
</faq-accordion>

<style>
  faq-accordion {
    display: block;
    max-width: 820px;
    margin: 0 auto;
  }

  .faqacc__header {
    text-align: center;
    margin-bottom: var(--space-2xl, 3rem);
  }
  .faqacc__label {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--faq-accent);
    background: var(--faq-accent-tint);
    padding: 0.35rem 0.85rem;
    border-radius: 100px;
    margin-bottom: 0.75rem;
  }
  .faqacc__heading {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4vw, 2.6rem);
    color: var(--c-dark);
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }
  .faqacc__sub {
    font-size: 0.95rem;
    color: var(--c-text-muted);
    line-height: 1.6;
    margin: 0 auto;
    max-width: 48ch;
  }

  /* Hairline-divider list */
  .faqacc__list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }
  .faqacc__item {
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    transition: background-color 0.18s ease;
    /* Isolates paint of the open body's height transition to this item.
       Without this, every frame repaints the entire region below the FAQ. */
    contain: paint;
  }
  .faqacc__item[open] {
    background-color: color-mix(in srgb, var(--faq-accent) 4%, transparent);
  }
  @supports not (background-color: color-mix(in srgb, red, blue)) {
    .faqacc__item[open] { background-color: var(--faq-accent-tint); opacity: 0.97; }
  }

  .faqacc__question {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md, 1rem);
    padding: 1.5rem 0.5rem 1.5rem 0.25rem;
    color: var(--c-dark);
    transition: color 0.18s ease;
    -webkit-tap-highlight-color: transparent;
    /* Belt-and-suspenders against the historical 300ms iOS tap delay.
       Viewport meta already eliminates it on modern iOS, but this makes
       the contract explicit at the element level. */
    touch-action: manipulation;
  }
  .faqacc__question::-webkit-details-marker { display: none; }
  .faqacc__question::marker { content: ''; }
  .faqacc__question:focus-visible {
    outline: 2px solid var(--faq-accent);
    outline-offset: 4px;
    border-radius: 6px;
  }
  .faqacc__item:hover .faqacc__question,
  .faqacc__item[open] .faqacc__question { color: var(--faq-accent); }

  .faqacc__q-text {
    /* Reset heading element defaults */
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 1.6vw, 1.2rem);
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: -0.005em;
    color: inherit;
    flex: 1;
    text-wrap: balance;
  }

  .faqacc__chevron {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    color: rgba(0, 0, 0, 0.38);
    /* Chevron uses transform — runs on the compositor, no layout cost */
    transition: transform 220ms cubic-bezier(0.4, 0, 0.2, 1),
                color 0.18s ease;
    will-change: transform;
  }
  .faqacc__item:hover .faqacc__chevron { color: var(--faq-accent); }
  .faqacc__item[open] .faqacc__chevron {
    transform: rotate(-180deg);
    color: var(--faq-accent);
  }

  /* Body: always rendered (overrides UA closed-state hiding) so we can measure */
  .faqacc__body {
    display: block;
    height: 0;
    overflow: hidden;
    /* Single transition — no opacity stacking. No will-change here:
       height isn't a compositor property, so will-change: height costs a
       layer without speeding up the transition. */
    transition: height 220ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  /* When open with no inline override, fall through to natural height so content
     can grow/shrink with viewport changes after the animation finishes. */
  .faqacc__item[open] .faqacc__body {
    height: auto;
  }

  .faqacc__answer {
    padding: 0 3rem 1.6rem 0.25rem;
    font-size: 1rem;
    /* NN/G: 1.5–1.6 line-height for readable answer text */
    line-height: 1.6;
    color: var(--c-text-muted);
    max-width: 64ch;
  }
  .faqacc__answer p { margin: 0 0 0.75rem; }
  .faqacc__answer p:last-child { margin-bottom: 0; }
  .faqacc__answer a {
    color: var(--faq-accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--faq-accent) 40%, transparent);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.18s ease;
  }
  .faqacc__answer a:hover { text-decoration-color: var(--faq-accent); }

  .faqacc__footer {
    margin-top: var(--space-2xl, 3rem);
    text-align: center;
    font-size: 0.92rem;
    color: var(--c-text-muted);
  }
  .faqacc__footer a {
    color: var(--faq-accent);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--faq-accent) 40%, transparent);
    text-underline-offset: 3px;
    margin-left: 4px;
    transition: text-decoration-color 0.18s ease;
  }
  .faqacc__footer a:hover { text-decoration-color: var(--faq-accent); }

  @media (max-width: 640px) {
    .faqacc__question { padding: 1.25rem 0.25rem; }
    .faqacc__answer { padding: 0 1rem 1.25rem 0.25rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .faqacc__item,
    .faqacc__question,
    .faqacc__chevron,
    .faqacc__body {
      transition: none;
    }
  }
</style>

<script>
  /**
   * FAQ behavior — Radix-style measured-pixel height animation.
   * Each <faq-accordion> instance owns its items; opens sync URL hash;
   * load reads hash and opens matching item; one open at a time.
   */
  class FAQAccordion extends HTMLElement {
    private items: HTMLDetailsElement[] = [];
    private prefersReduced = false;
    private hashListener?: () => void;
    private boundClick?: (e: Event) => void;
    /**
     * Per-body AbortController for transitionend listeners. Lets us cancel a
     * pending listener cleanly when the user toggles mid-animation, so the
     * old listener doesn't fire on the new transition's completion.
     */
    private listenerCtrls = new WeakMap<HTMLElement, AbortController>();

    connectedCallback() {
      this.items = Array.from(this.querySelectorAll<HTMLDetailsElement>('.faqacc__item'));
      if (!this.items.length) return;

      this.prefersReduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

      this.boundClick = this.handleClick.bind(this);
      this.addEventListener('click', this.boundClick);

      this.openFromHash();
      this.hashListener = () => this.openFromHash();
      window.addEventListener('hashchange', this.hashListener);
    }

    disconnectedCallback() {
      if (this.hashListener) window.removeEventListener('hashchange', this.hashListener);
      if (this.boundClick) this.removeEventListener('click', this.boundClick);
    }

    private handleClick(e: Event) {
      const path = e.composedPath();
      const summary = path.find(
        (n): n is HTMLElement =>
          n instanceof HTMLElement && n.matches('.faqacc__question'),
      );
      if (!summary) return;
      const detail = summary.closest<HTMLDetailsElement>('.faqacc__item');
      if (!detail || !this.items.includes(detail)) return;

      e.preventDefault();

      if (detail.open) {
        this.close(detail);
        if (location.hash === '#' + detail.id) {
          history.replaceState(null, '', location.pathname + location.search);
        }
      } else {
        // Close other open items. If they sit ABOVE the clicked item, their
        // close animation would slide the clicked item upward under the user's
        // finger — so anchor the scroll position to keep the click target steady.
        const detailTop = detail.getBoundingClientRect().top;
        this.items.forEach((other) => {
          if (other === detail || !other.open) return;
          const otherTop = other.getBoundingClientRect().top;
          if (otherTop < detailTop) {
            this.closeAndAnchor(other, detail);
          } else {
            this.close(other);
          }
        });
        this.open(detail);
        if (detail.id) {
          history.replaceState(null, '', '#' + detail.id);
        }
      }
    }

    /**
     * Close `closingItem` while keeping `anchorItem` visually fixed in the
     * viewport. Each animation frame we measure how much the closing item has
     * shrunk and scroll the page upward by that delta — net visual effect:
     * the item the user clicked stays under their finger.
     */
    private closeAndAnchor(closingItem: HTMLDetailsElement, anchorItem: HTMLDetailsElement) {
      if (this.prefersReduced) {
        // No animation → no shift to compensate.
        this.close(closingItem);
        return;
      }
      const anchorBefore = anchorItem.getBoundingClientRect().top;
      this.close(closingItem);

      let lastTop = anchorBefore;
      let raf = 0;
      const tick = () => {
        const nowTop = anchorItem.getBoundingClientRect().top;
        const delta = nowTop - lastTop;
        if (delta !== 0) {
          // scrollBy with no behavior is instant — exactly what we want.
          window.scrollBy(0, delta);
          lastTop = anchorItem.getBoundingClientRect().top;
        }
        if (closingItem.open) {
          raf = requestAnimationFrame(tick);
        }
      };
      raf = requestAnimationFrame(tick);
      // Safety stop: if transitionend never fires (e.g. mid-cancel), bail.
      setTimeout(() => cancelAnimationFrame(raf), 400);
    }

    /**
     * Attach a transitionend listener tied to a fresh AbortController so any
     * previously-pending listener on this body is cancelled cleanly. Without
     * this, a mid-animation toggle would leave the old listener attached and
     * it would still fire when the NEW transition completes.
     */
    private listenForHeightTransition(body: HTMLElement, onComplete: () => void) {
      const prev = this.listenerCtrls.get(body);
      if (prev) prev.abort();
      const ctrl = new AbortController();
      this.listenerCtrls.set(body, ctrl);
      body.addEventListener(
        'transitionend',
        (ev) => {
          const te = ev as TransitionEvent;
          if (te.target !== body || te.propertyName !== 'height') return;
          ctrl.abort(); // we got the event we wanted; stop listening
          onComplete();
        },
        { signal: ctrl.signal },
      );
    }

    /**
     * Open an item: capture the body's current rendered height as the
     * transition's starting pixel value (which correctly handles being called
     * mid-close), measure the natural content height as the target, and
     * transition between them. After the transition, clear the inline height
     * so the body flexes with content/viewport changes.
     */
    private open(detail: HTMLDetailsElement) {
      const body = detail.querySelector<HTMLElement>('.faqacc__body');
      if (!body) return;

      if (this.prefersReduced) {
        detail.open = true;
        return;
      }

      // 1) Capture current rendered height (handles mid-animation correctly)
      const start = body.getBoundingClientRect().height;

      // 2) Mark [open] so the CSS [open] rule applies (height: auto), then
      //    immediately override with the explicit start pixel so transition
      //    has a defined origin. (Same JS turn — no paint between them.)
      detail.open = true;
      body.style.height = start + 'px';

      // 3) Force reflow so the explicit start commits before we measure
      //    scrollHeight (which reflects natural content height) and set target.
      // eslint-disable-next-line @typescript-eslint/no-unused-expressions
      body.offsetHeight;

      const target = body.scrollHeight;
      body.style.height = target + 'px';

      this.listenForHeightTransition(body, () => {
        // Clear inline so CSS [open] body { height: auto } takes over —
        // the body now tracks natural content size from here on.
        body.style.height = '';
      });
    }

    /**
     * Close an item: capture current rendered height (the rect, not
     * scrollHeight — scrollHeight returns the natural content height which
     * causes a visible "snap up" if you close mid-open). Then transition to 0.
     */
    private close(detail: HTMLDetailsElement) {
      const body = detail.querySelector<HTMLElement>('.faqacc__body');
      if (!body) return;

      if (this.prefersReduced) {
        detail.open = false;
        return;
      }

      const start = body.getBoundingClientRect().height;
      body.style.height = start + 'px';
      // eslint-disable-next-line @typescript-eslint/no-unused-expressions
      body.offsetHeight;
      body.style.height = '0px';

      this.listenForHeightTransition(body, () => {
        detail.open = false;
        body.style.height = '';
      });
    }

    private openFromHash() {
      const hash = location.hash.slice(1);
      if (!hash) return;
      const target = this.items.find((d) => d.id === hash);
      if (!target || target.open) return;

      this.items.forEach((other) => {
        if (other !== target && other.open) this.close(other);
      });
      this.open(target);
      // Scroll deep-linked item into view (item has scroll-margin-top via [id])
      requestAnimationFrame(() => {
        target.scrollIntoView({
          behavior: this.prefersReduced ? 'auto' : 'smooth',
          block: 'start',
        });
      });
    }
  }

  if (!customElements.get('faq-accordion')) {
    customElements.define('faq-accordion', FAQAccordion);
  }
</script>
