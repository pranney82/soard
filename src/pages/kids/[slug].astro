---
/**
 * [slug].astro — Individual kid profile page
 *
 * Guided Journey — immersive editorial storytelling with interactive chapters:
 *   1. Meet [Name]: Editorial split hero with hook, pills, stats
 *   2. The Story: Editorial photo/text pairs with alternating layouts
 *   3. The Design: Side-by-side as-built vs proposed plans
 *   4. Before & After: Interactive comparison sliders
 *   5. The Reveal: Video climax (Cloudflare Stream / YouTube)
 *   6. The Gallery: Masonry grid with hero treatment + cascade reveal
 *   + Sticky chapter nav (desktop right rail, mobile bottom bar)
 *
 * PERF: CF Images w/ srcset + gravity:face, LQIP blur-up, lazy loading,
 *       video facade, content-visibility, inline CSS (build config)
 * SEO:  Article + Person schema, breadcrumbs, rich meta, OG image
 * A11Y: Heading hierarchy, ARIA, focus trap lightbox, keyboard nav,
 *       prefers-reduced-motion respected
 * UX:   View Transitions, staggered scroll-reveals, no full-bleed images
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import { getCollection } from 'astro:content';
import { getPublishedKids } from '../../utils/collections';
import { getKidProfileSchema } from '../../utils/schema';

export async function getStaticPaths() {
  const kids = await getPublishedKids();
  const sorted = kids.sort((a, b) => (b.data.year || 0) - (a.data.year || 0));
  const seedHash = (str: string) => {
    let h = 0;
    for (let i = 0; i < str.length; i++) {
      h = ((h << 5) - h + str.charCodeAt(i)) | 0;
    }
    return h;
  };
  const seededShuffle = (arr: typeof kids, seed: string) => {
    const a = [...arr];
    let s = seedHash(seed);
    for (let j = a.length - 1; j > 0; j--) {
      s = (s * 1664525 + 1013904223) | 0;
      const r = ((s >>> 0) % (j + 1));
      [a[j], a[r]] = [a[r], a[j]];
    }
    return a;
  };
  return sorted.map((kid, i) => {
    const others = sorted.filter((k, j) => j !== i);
    const sameType = others.filter(k =>
      k.data.roomTypes?.some(t => kid.data.roomTypes?.includes(t))
    );
    const sameYear = others.filter(k => k.data.year === kid.data.year);
    const seen = new Set();
    const slug = kid.data.slug;
    const deduped = [...seededShuffle(sameType, slug), ...seededShuffle(sameYear, slug + ':year'), ...seededShuffle(others, slug + ':all')]
      .filter(k => {
        if (seen.has(k.data.slug)) return false;
        seen.add(k.data.slug);
        return true;
      });
    const related = deduped
      .filter(k => k.data.heroImage)
      .slice(0, 4)
      .map(k => ({ name: k.data.name, slug: k.data.slug, heroImage: k.data.heroImage, diagnosis: k.data.diagnosis, roomTypes: k.data.roomTypes }));

    return {
      params: { slug: kid.data.slug },
      props: {
        kid: kid.data,
        prevKid: i > 0 ? { name: sorted[i - 1].data.name, slug: sorted[i - 1].data.slug, heroImage: sorted[i - 1].data.heroImage } : null,
        nextKid: i < sorted.length - 1 ? { name: sorted[i + 1].data.name, slug: sorted[i + 1].data.slug, heroImage: sorted[i + 1].data.heroImage } : null,
        relatedKids: related,
      },
    };
  });
}

const { kid, prevKid, nextKid, relatedKids } = Astro.props;
const photos = kid.photos || [];
// ── CF Image helpers ──────────────────────
import { cfUrl as _cfUrl, cfSrcset as _cfSrcset, cfRaw, CF_BASE, cfId } from '../../utils/cf-image';
import lqipManifest from '../../data/lqip-kids.json';
import dimsManifest from '../../data/dimensions-kids.json';
const _lqipMap: Record<string, string> = lqipManifest;
const _dimsMap: Record<string, [number, number]> = dimsManifest;

function cfUrl(src: string, opts: string) { return cfRaw(src, opts); }
function cfSrcset(src: string, widths: number[]) {
  return _cfSrcset(src, widths);
}
function lqip(src: string): string {
  const id = cfId(src);
  return _lqipMap[id] || cfRaw(src, 'w=30,q=30,blur=20');
}
function dims(src: string): [number, number] {
  const id = cfId(src);
  return _dimsMap[id] || [4, 3];
}

// ── YouTube ID extraction ─────────────────
function getYouTubeId(url: string): string | null {
  if (!url) return null;
  const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([a-zA-Z0-9_-]{11})/);
  return match ? match[1] : null;
}
const ytId = kid.videoUrl ? getYouTubeId(kid.videoUrl) : null;
const streamId = kid.streamVideoId || null;
const hasVideo = streamId || ytId;

// ── SEO ───────────────────────────────────
const SITE = 'https://sunshineonaranneyday.com';
const kidSchemas = getKidProfileSchema({
  ...kid,
  videoUrl: kid.videoUrl,
  streamVideoId: kid.streamVideoId,
  photos: kid.photos,
  photographer: kid.photographer,
  status: kid.status,
});
const breadcrumbs = [
  { name: 'Home', url: SITE },
  { name: 'Meet the Kids', url: `${SITE}/kids/` },
  { name: kid.name, url: `${SITE}/kids/${kid.slug}/` },
];

const metaDesc = kid.metaDescription
  || kid.shortDescription
  || `Meet ${kid.name}${kid.diagnosis ? `, diagnosed with ${kid.diagnosis}` : ''}. Learn how Sunshine on a Ranney Day transformed their space${kid.roomTypes?.length ? ` with a ${kid.roomTypes.join(' & ')}` : ''}.`;

const dateModified = kid.year ? `${kid.year}-01-01` : undefined;

// ── LCP preload for hero image ────────────
const heroSrcset = kid.heroImage ? _cfSrcset(kid.heroImage, [600, 900, 1200, 1600, 2400], { fit: 'cover', gravity: 'face' }) : '';
const heroSizes = '(max-width: 768px) 92vw, (max-width: 1100px) 55vw, 640px';

// ── Bio paragraphs + pull quote ───────────
function splitBio(bio: string): string[] {
  if (!bio) return [];
  if (bio.includes('<p>')) {
    return [...bio.matchAll(/<p>([\s\S]*?)<\/p>/gi)]
      .map(m => m[1].replace(/<br\s*\/?>/gi, '').trim())
      .filter(Boolean);
  }
  return bio.split('\n\n').filter(p => p.trim());
}
const bioParas = splitBio(kid.bio || '');
const introPara = bioParas.length > 0 ? bioParas[0] : '';
const remainingParas = bioParas.slice(1);

let pullQuote: string | null = null;
if (kid.quote && kid.quote !== kid.bio && kid.quote !== introPara) {
  pullQuote = kid.quote;
}

const galleryPhotos = photos.slice(0, 30);

// ── Accent photo for hero (must be explicitly set by admin) ────────────────
const accentPhoto = kid.accentImage || null;

// ── Hero image — use real dimensions for native aspect ratio ──
const heroDims = kid.heroImage ? dims(kid.heroImage) : [3, 4];
const heroAR = `${heroDims[0]} / ${heroDims[1]}`;

// ── Hero: art-directed mobile ─────────────
const heroMobileSrcset = kid.heroImage ? _cfSrcset(kid.heroImage, [600, 900, 1200], { fit: 'cover', gravity: 'face' }) : '';
const heroMobileSizes = '(max-width: 480px) 92vw, 92vw';


// ── Minimal data detection ────────────────
const hasDetails = kid.age || (kid.roomTypes && kid.roomTypes.length > 0) || kid.year;
const hasRichContent = kid.bio || galleryPhotos.length > 1 || hasVideo;

// ── Plans — proposed vs as-built ──────────
const plans = kid.plans || [];
const hasPlans = plans.length > 0;
const proposedPlans = plans.filter((p: any) => p.type === 'proposed');
const asBuiltPlans = plans.filter((p: any) => p.type === 'as-built');
// Filter out unhelpful labels (pure numbers, system-generated IDs)
const isDisplayableLabel = (label: string | undefined): boolean => {
  if (!label) return false;
  const trimmed = label.trim();
  if (!trimmed) return false;
  // Skip pure numbers
  if (/^\d+$/.test(trimmed)) return false;
  // Skip system-generated names (CompanyCam, etc)
  if (/^CompanyCam/i.test(trimmed)) return false;
  return true;
};

// ── Before/After photos ───────────────────
const beforeAfterPhotos = kid.beforeAfterPhotos || [];
const hasBeforeAfter = beforeAfterPhotos.length > 0;

// ── Gallery — masonry with hero treatment ──
const galleryFeatured = kid.galleryFeatured || [];
const heroGalleryPhotos = galleryPhotos.slice(0, 2);
const supportingPhotos = galleryPhotos.slice(2, 8);
const overflowGalleryPhotos = galleryPhotos.slice(8);
const showExpandButton = galleryPhotos.length > 8;

// ── Partner count for hero stats ──────────
const partnerCount = kid.partnerLogos?.length || 0;

// ── Hero hook — fuller version for premium feel ─────────────────────────────
const _rawHook = kid.heroSummary
  || (introPara ? introPara.replace(/<[^>]+>/g, '') : '');
const heroHook = (() => {
  if (!_rawHook) return '';
  // Try to get first two sentences for richer context
  const sentences = _rawHook.match(/[^.!?]+[.!?]+/g) || [_rawHook];
  const twoSentences = sentences.slice(0, 2).join(' ').trim();
  if (twoSentences.length <= 220) return twoSentences;
  // Fall back to first sentence if two is too long
  const firstSentence = sentences[0]?.trim() || _rawHook;
  if (firstSentence.length <= 180) return firstSentence;
  // Smart truncation at clause boundary
  const truncated = firstSentence.slice(0, 170);
  const clauseBreak = truncated.match(/^.{80,}[,;:—–]\s/)?.[0];
  if (clauseBreak) return clauseBreak.trim() + '...';
  return truncated.replace(/\s+\S*$/, '') + '...';
})();

// ── Stats for hero at-a-glance ────────────
const statsItems = [
  kid.age && `Age ${Array.isArray(kid.age) ? kid.age.join(' & ') : kid.age}`,
  kid.roomCount && `${kid.roomCount} Room${kid.roomCount > 1 ? 's' : ''}`,
  partnerCount > 0 && `${partnerCount} Partner${partnerCount > 1 ? 's' : ''}`,
  kid.year,
].filter(Boolean);

// ── Chapter Nav — conditional rendering ───
const chapters = [
  { id: 'chapter-meet', label: 'Meet', icon: 'user', show: true },
  { id: 'chapter-story', label: 'Story', icon: 'book', show: bioParas.length > 0 },
  { id: 'chapter-design', label: 'Design', icon: 'blueprint', show: hasPlans },
  { id: 'chapter-transform', label: 'Transform', icon: 'compare', show: hasBeforeAfter },
  { id: 'chapter-reveal', label: 'Reveal', icon: 'play', show: !!hasVideo },
  { id: 'chapter-gallery', label: 'Gallery', icon: 'camera', show: galleryPhotos.length > 1 },
].filter(c => c.show);

// ── Plans display ─────────────────────────
const displayAsBuilt = asBuiltPlans.slice(0, 1);
const displayProposed = proposedPlans.slice(0, 1);
const hasBothTypes = displayAsBuilt.length > 0 && displayProposed.length > 0;

// Orientation detection for adaptive layout
const heroPlan = displayProposed[0] || displayAsBuilt[0];
const planOrientation = (() => {
  if (!heroPlan) return 'portrait';
  const [w, h] = dims(heroPlan.url);
  if (w > h * 1.3) return 'landscape';
  if (h > w * 1.3) return 'portrait';
  return 'square';
})();
---

<BaseLayout
  title={`${kid.name}'s Story`}
  description={metaDesc}
  ogType="article"
  jsonLd={kidSchemas}
  breadcrumbs={breadcrumbs}
  datePublished={kid.year ? `${kid.year}-01-01` : undefined}
  dateModified={dateModified}
>
  {kid.heroImage && <link slot="head" rel="preload" as="image" imagesrcset={heroMobileSrcset} imagesizes={heroMobileSizes} fetchpriority="high" media="(max-width: 768px)" />}
  {kid.heroImage && <link slot="head" rel="preload" as="image" imagesrcset={heroSrcset} imagesizes={heroSizes} fetchpriority="high" media="(min-width: 769px)" />}

  <!-- Scroll progress indicator -->
  <div class="scroll-progress" aria-hidden="true"></div>

  <article class="kid-profile" itemscope itemtype="https://schema.org/Article">

    <!-- ═══ 1. Meet — Premium Hero ═══ -->
    <section class="hero" id="chapter-meet" data-chapter="Meet">
      <div class="hero__container">
        <!-- Media Column -->
        <div class="hero__media">
          <div class="hero__photo-wrapper">
            {kid.heroImage ? (
              <div class="hero__portrait" style={`--lqip: url('${lqip(kid.heroImage)}'); --hero-ar: ${heroAR}`} transition:name="kid-hero">
                <picture>
                  <source
                    media="(max-width: 768px)"
                    srcset={heroMobileSrcset}
                    sizes={heroMobileSizes}
                    width="300"
                    height="400"
                  />
                  <img
                    src={cfUrl(kid.heroImage, 'w=1200,fit=cover,gravity=face,q=85')}
                    srcset={heroSrcset}
                    sizes={heroSizes}
                    alt={`Photo of ${kid.name}${kid.diagnosis ? ` — ${kid.diagnosis}` : ''}`}
                    class="hero__img lqip-img"
                    width="900"
                    height="1200"
                    loading="eager"
                    decoding="async"
                    fetchpriority="high"
                    itemprop="image"
                  />
                </picture>
                <div class="hero__vignette" aria-hidden="true"></div>
                {kid.status === 'in-progress' && (
                  <span class="hero__badge">In Progress</span>
                )}
              </div>
            ) : (
              <div class="hero__portrait hero__portrait--empty">
                <svg class="hero__placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
                <span class="hero__placeholder-text">{kid.name}</span>
              </div>
            )}
          </div>

          {accentPhoto && kid.heroImage && (
            <picture class="hero__accent" data-reveal="accent">
              <source media="(max-width: 768px)" srcset={_cfSrcset(accentPhoto, [180, 280, 400], { fit: 'cover', gravity: 'face', aspectRatio: 1.15 })} sizes="(max-width: 480px) 32vw, 35vw" />
              <source media="(min-width: 769px)" srcset={_cfSrcset(accentPhoto, [280, 400, 560], { fit: 'cover', gravity: 'face', aspectRatio: 1.15 })} sizes="220px" />
              <img
                src={cfUrl(accentPhoto, 'w=400,h=460,fit=cover,gravity=face,q=80')}
                alt={`${kid.name}'s transformed room`}
                width="400" height="460"
                class="hero__accent-img lqip-img" loading="eager" decoding="async"
                style={`--lqip: url('${lqip(accentPhoto)}')`}
              />
            </picture>
          )}

        </div>

        <!-- Content Column -->
        <div class="hero__content">
          <h1 class="hero__name" itemprop="headline" transition:name="kid-name" data-reveal="name">
            {kid.name}
          </h1>

          {kid.diagnosis && (
            <p class="hero__diagnosis" data-reveal="diagnosis">{kid.diagnosis}</p>
          )}

          {heroHook && (
            <p class="hero__hook" data-reveal="hook">{heroHook}</p>
          )}

          <div class="hero__meta" data-reveal="meta">
            {kid.roomTypes && kid.roomTypes.length > 0 && (
              <span class="hero__meta-item">{kid.roomTypes.join(', ')}</span>
            )}
            {kid.year && <span class="hero__meta-item">{kid.year}</span>}
          </div>

          {kid.fundraisingUrl && (
            <a href={kid.fundraisingUrl} target="_blank" rel="noopener noreferrer" class="hero__cta" data-reveal="actions">
              Support {kid.name}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          )}
        </div>
      </div>
    </section>

    <!-- ═══ Sticky Chapter Nav ═══ -->
    {chapters.length > 1 && (
      <nav class="chapter-nav" id="chapter-nav" aria-label="Page sections">
        <div class="chapter-nav__track">
          <div class="chapter-nav__pill" aria-hidden="true"></div>
          {chapters.map((ch) => (
            <a
              href={`#${ch.id}`}
              class={`chapter-nav__link${ch.id === 'chapter-meet' ? ' is-active' : ''}`}
              data-target={ch.id}
            >
              {ch.id === 'chapter-meet' ? kid.name : ch.label}
            </a>
          ))}
        </div>
      </nav>
    )}

    <!-- ═══ 2. The Story — Premium Progressive Disclosure ═══ -->
    {bioParas.length > 0 && (
      <section class="story" id="chapter-story" data-chapter="Story" itemprop="articleBody">
        <div class="story__inner">
          <div class="story__content" itemprop="description">
            <p class="story__lead" set:html={bioParas[0]} />

            {bioParas.length > 1 && (
              <>
                <button class="story__expand" id="story-expand" type="button" aria-expanded="false" aria-controls="story-more">
                  Continue reading
                </button>

                <div class="story__more" id="story-more" hidden>
                  {bioParas.slice(1).map((para, i) => {
                    const showQuoteAfter = pullQuote && i === Math.floor((bioParas.length - 2) / 2);
                    return (
                      <>
                        <p class="story__para" set:html={para} />
                        {showQuoteAfter && (
                          <blockquote class="story__quote">
                            <p class="story__quote-text">{pullQuote}</p>
                          </blockquote>
                        )}
                      </>
                    );
                  })}
                </div>
              </>
            )}
          </div>
        </div>
      </section>
    )}

    <!-- ═══ 3. The Design ═══ -->
    {hasPlans && (
      <section class="design" id="chapter-design" data-chapter="Design">
        <div class="container">
          <h2 class="design__title">The Design</h2>

          <div class="design__grid">
            {plans.slice(0, 2).map((plan: any, i: number) => {
              const lbIndex = galleryPhotos.length + i;
              return (
                <button
                  class="design__item"
                  data-lb-index={lbIndex}
                  type="button"
                  aria-label={`View ${plan.label || 'design plan'}`}
                  style={`--lqip: url('${lqip(plan.url)}')`}
                >
                  <img
                    src={cfUrl(plan.url, 'w=800,q=85')}
                    srcset={cfSrcset(plan.url, [400, 600, 800, 1200])}
                    sizes="(max-width: 768px) 92vw, 560px"
                    alt={plan.label || 'Design plan'}
                    class="design__img lqip-img"
                    loading="lazy"
                    decoding="async"
                    width={dims(plan.url)[0]}
                    height={dims(plan.url)[1]}
                  />
                </button>
              );
            })}
          </div>

          {plans.length > 2 && (
            <button class="design__more" id="design-view-all" data-first-plan-index={galleryPhotos.length} type="button">
              View all {plans.length} plans
            </button>
          )}

          <div hidden aria-hidden="true">
            {plans.map((plan: any, i: number) => (
              <button
                class="masonry__item"
                data-index={galleryPhotos.length + i}
                data-src={cfUrl(plan.url, 'w=1600,q=85')}
                data-srcset={_cfSrcset(plan.url, [800, 1200, 1600, 2400])}
                data-alt={plan.label || `Plan ${i + 1}`}
                data-plan="true"
                type="button"
                style={`--lqip: url('${lqip(plan.url)}')`}
              />
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ═══ 4. Before & After ═══ -->
    {hasBeforeAfter && (
      <section class="ba-section" id="chapter-transform" data-chapter="Transform">
        <div class="container">
          <h2 class="ba-section__title">The Transformation</h2>

          <div class="ba-section__sliders">
            {beforeAfterPhotos.map((pair: any, i: number) => (
              <div class="ba-slider" data-ba-slider>
                {pair.room && <p class="ba-slider__room">{pair.room}</p>}
                <div class="ba-slider__container" style="--ba-pos: 50%" data-ba-container>
                  <img
                    class="ba-slider__after lqip-img"
                    src={_cfUrl(pair.after, { w: 1200, q: 85 })}
                    srcset={_cfSrcset(pair.after, [600, 900, 1200, 1600, 2400])}
                    sizes="(max-width: 768px) 100vw, 800px"
                    alt={pair.afterAlt || `${kid.name}'s room after`}
                    loading="lazy"
                    decoding="async"
                    width="1200"
                    height="900"
                    style={`--lqip: url('${lqip(pair.after)}')`}
                  />
                  <div class="ba-slider__before-clip">
                    <img
                      class="ba-slider__before lqip-img"
                      src={_cfUrl(pair.before, { w: 1200, q: 85 })}
                      srcset={_cfSrcset(pair.before, [600, 900, 1200, 1600, 2400])}
                      sizes="(max-width: 768px) 100vw, 800px"
                      alt={pair.beforeAlt || `${kid.name}'s room before`}
                      loading="lazy"
                      decoding="async"
                      width="1200"
                      height="900"
                      style={`--lqip: url('${lqip(pair.before)}')`}
                    />
                  </div>
                  <input
                    type="range"
                    min="0"
                    max="100"
                    value="50"
                    class="ba-slider__range"
                    aria-label={`Compare before and after${pair.room ? ` for ${pair.room}` : ''}`}
                  />
                  <div class="ba-slider__handle" aria-hidden="true">
                    <div class="ba-slider__handle-glow"></div>
                    <div class="ba-slider__handle-line"></div>
                    <div class="ba-slider__handle-knob">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="15 18 9 12 15 6"></polyline>
                        <polyline points="9 18 15 12 9 6" transform="translate(6, 0)"></polyline>
                      </svg>
                    </div>
                  </div>
                  <span class="ba-slider__label ba-slider__label--before" data-ba-label="before">Before</span>
                  <span class="ba-slider__label ba-slider__label--after" data-ba-label="after">After</span>
                  <div class="ba-slider__hint" data-ba-hint>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
                      <polyline points="8 4 4 8 8 12"></polyline>
                      <polyline points="16 4 20 8 16 12"></polyline>
                    </svg>
                    <span>Drag to compare</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ═══ 5. The Reveal — Video ═══ -->
    {hasVideo && (
      <section class="reveal" id="chapter-reveal" data-chapter="Reveal">
        <div class="reveal__inner">
          <h2 class="reveal__title">The Reveal</h2>

          <figure class="reveal__figure">
            <div class="reveal__frame">
              {streamId ? (
                <div class="stream-facade" id="stream-facade" data-id={streamId} role="button" tabindex="0" aria-label={`Play ${kid.name}'s video`}>
                  <img
                    src={`https://videodelivery.net/${streamId}/thumbnails/thumbnail.jpg?time=2s&height=720`}
                    alt={`Video thumbnail for ${kid.name}'s story`}
                    class="reveal__thumb"
                    loading="lazy"
                    decoding="async"
                    width="1280"
                    height="720"
                  />
                  <div class="reveal__vignette"></div>
                  <div class="reveal__play" aria-hidden="true">
                    <span class="reveal__play-ring"></span>
                    <svg class="reveal__play-tri" viewBox="0 0 24 28" fill="none">
                      <path d="M2 1.5v25l20-12.5L2 1.5z" fill="currentColor"/>
                    </svg>
                  </div>
                </div>
              ) : ytId ? (
                <div class="yt-facade" id="yt-facade" data-id={ytId} role="button" tabindex="0" aria-label={`Play ${kid.name}'s video`}>
                  <picture>
                    <source type="image/webp" srcset={`https://i.ytimg.com/vi_webp/${ytId}/maxresdefault.webp`} />
                    <img
                      src={`https://i.ytimg.com/vi/${ytId}/maxresdefault.jpg`}
                      alt={`Video thumbnail for ${kid.name}'s story`}
                      class="reveal__thumb"
                      loading="lazy"
                      decoding="async"
                    />
                  </picture>
                  <div class="reveal__vignette"></div>
                  <div class="reveal__play" aria-hidden="true">
                    <span class="reveal__play-ring"></span>
                    <svg class="reveal__play-tri" viewBox="0 0 24 28" fill="none">
                      <path d="M2 1.5v25l20-12.5L2 1.5z" fill="currentColor"/>
                    </svg>
                  </div>
                </div>
              ) : null}
            </div>
          </figure>
        </div>
      </section>
    )}

    <!-- ═══ 6. The Gallery — Photo Showcase ═══ -->
    {galleryPhotos.length > 1 && (
      <section class="gallery" id="chapter-gallery" data-chapter="Gallery">
        <div class="container">
          <header class="gallery__header">
            <h2 class="gallery__title">The Gallery</h2>
            {kid.photographer && (
              <p class="gallery__credit">Photos by {kid.photographer}</p>
            )}
          </header>

          <!-- Hero photos — first 2 large -->
          <div class="gallery__grid" id="gallery">
            {heroGalleryPhotos.map((photo, i) => {
              const altText = photo.alt || `${kid.name}'s room transformation photo ${i + 1}`;
              return (
                <button
                  class="masonry__item gallery__cell gallery__cell--hero"
                  data-index={i}
                  data-src={cfUrl(photo.url, 'w=1600,q=85')}
                  data-srcset={_cfSrcset(photo.url, [800, 1200, 1600, 2400])}
                  data-alt={altText}
                  aria-label={`View photo ${i + 1} of ${galleryPhotos.length}`}
                  type="button"
                  style={`--lqip: url('${lqip(photo.url)}'); --stagger: ${i}`}
                >
                  <img
                    src={cfUrl(photo.url, 'w=1200,q=85')}
                    srcset={cfSrcset(photo.url, [600, 900, 1200, 1600])}
                    sizes={i === 0 ? '(max-width: 768px) 92vw, 60vw' : '(max-width: 768px) 92vw, 40vw'}
                    alt={altText}
                    class="gallery__img lqip-img"
                    loading="lazy"
                    decoding="async"
                    width={dims(photo.url)[0]}
                    height={dims(photo.url)[1]}
                  />
                  <div class="gallery__overlay">
                    <span class="gallery__expand">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
                    </span>
                  </div>
                </button>
              );
            })}

            <!-- Supporting photos -->
            {supportingPhotos.map((photo, i) => {
              const globalIndex = heroGalleryPhotos.length + i;
              const altText = photo.alt || `${kid.name}'s room transformation photo ${globalIndex + 1}`;
              return (
                <button
                  class="masonry__item gallery__cell"
                  data-index={globalIndex}
                  data-src={cfUrl(photo.url, 'w=1600,q=85')}
                  data-srcset={_cfSrcset(photo.url, [800, 1200, 1600, 2400])}
                  data-alt={altText}
                  aria-label={`View photo ${globalIndex + 1} of ${galleryPhotos.length}`}
                  type="button"
                  style={`--lqip: url('${lqip(photo.url)}'); --stagger: ${globalIndex}`}
                >
                  <img
                    src={cfUrl(photo.url, 'w=700,q=85')}
                    srcset={cfSrcset(photo.url, [400, 600, 900])}
                    sizes="(max-width: 768px) 46vw, (max-width: 1100px) 30vw, 280px"
                    alt={altText}
                    class="gallery__img lqip-img"
                    loading="lazy"
                    decoding="async"
                    width={dims(photo.url)[0]}
                    height={dims(photo.url)[1]}
                  />
                  <div class="gallery__overlay">
                    <span class="gallery__expand">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
                    </span>
                    <span class="gallery__counter">{globalIndex + 1}/{galleryPhotos.length}</span>
                  </div>
