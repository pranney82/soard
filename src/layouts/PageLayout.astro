---
/**
 * PageLayout.astro
 * Standard page layout with optional hero section, main content area,
 * and optional bottom CTA. Wraps BaseLayout.
 */
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  heroTitle?: string;
  heroSubtitle?: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: object | object[];
  breadcrumbs?: { name: string; url: string }[];
  datePublished?: string;
  dateModified?: string;
  noindex?: boolean;
}

const { title, description, heroTitle, heroSubtitle, ogImage, ogType, jsonLd, breadcrumbs, datePublished, dateModified, noindex } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage} ogType={ogType} jsonLd={jsonLd} breadcrumbs={breadcrumbs} datePublished={datePublished} dateModified={dateModified} noindex={noindex}>
  {(heroTitle || heroSubtitle) && (
    <section class="page-hero">
      <div class="page-hero__inner container">
        <div class="page-hero__text">
          {heroTitle && <h1 class="page-hero__title">{heroTitle}</h1>}
          {heroSubtitle && <p class="page-hero__subtitle">{heroSubtitle}</p>}
        </div>
      </div>
    </section>
  )}

  <article class="page-content">
    <slot />
  </article>

  <slot name="cta" />
</BaseLayout>

<style>
  .page-hero {
    background: var(--c-dark);
    color: #fff;
    padding-block: var(--space-2xl);
  }

  .page-hero__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xl);
  }

  .page-hero__text {
    min-width: 0;
  }

  .page-hero__title {
    color: #fff;
    font-size: clamp(1.6rem, 3.5vw, 2.25rem);
    letter-spacing: -0.02em;
  }

  .page-hero__subtitle {
    margin-top: var(--space-xs);
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.55);
    max-width: 480px;
  }

  .page-content {
    min-height: 40vh;
  }

  @media (max-width: 768px) {
    .page-hero {
      padding-block: var(--space-xl);
    }
  }
</style>
