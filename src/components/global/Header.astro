---
/**
 * Header.astro — Best-in-class mobile navigation
 *
 * Accessibility:
 *   - Focus trap: Tab cycles within open menu only
 *   - inert: page content behind menu is inert when open
 *   - aria-expanded, aria-controls, aria-label, aria-hidden
 *   - Escape key closes menu
 *   - prefers-reduced-motion: instant transitions
 *   - 44px+ touch targets on every interactive element
 *   - External links visually indicated + target="_blank"
 *
 * UX:
 *   - Swipe right-to-left to close (touch gesture)
 *   - Tap overlay to close
 *   - iOS-safe scroll lock (position: fixed + scroll offset preservation)
 *   - overscroll-behavior: contain (no scroll chaining)
 *   - Auto-close on resize past mobile breakpoint
 *   - Nav link click closes menu before navigation
 *
 * Performance:
 *   - ~60 lines of vanilla JS, no framework
 *   - All transitions on transform/opacity only (GPU composited)
 *   - will-change: transform on panel
 *   - Passive touch listeners
 */
const currentPath = Astro.url.pathname;

interface NavChild {
  label: string;
  href: string;
  external?: boolean;
}

interface NavGroup {
  label: string;
  children: NavChild[];
}

const nav: NavGroup[] = [
  {
    label: 'About',
    children: [
      { label: 'Our Story', href: '/about/' },
      { label: 'Leadership', href: '/about/leadership/' },
      { label: 'Financials', href: '/about/financials/' },
    ],
  },
  {
    label: 'Kids & Projects',
    children: [
      { label: 'Featured Rooms', href: '/rooms/' },
      { label: 'Meet the Kids', href: '/kids/' },
      { label: 'Community Projects', href: '/rooms/community/' },
    ],
  },
  {
    label: 'Our Partners',
    children: [
      { label: 'Our Partners', href: '/partners/' },
      { label: 'Construction Partners', href: '/partners/construction/' },
      { label: 'Design Partners', href: '/partners/design/' },
    ],
  },
  {
    label: 'Get Involved',
    children: [
      { label: 'Events', href: 'https://www.sunnyandranney.com/events', external: true },
      { label: 'Donate', href: '/donate/' },
      { label: '2026 Application', href: '/apply/' },
    ],
  },
  {
    label: 'Shop Our Stores',
    children: [
      { label: 'Sunny & Ranney', href: 'https://www.sunnyandranney.com', external: true },
      { label: 'Partly Sunny', href: 'https://partlysunnystore.com', external: true },
    ],
  },
];

function isActive(href: string) {
  if (href.startsWith('http')) return false;
  return currentPath.startsWith(href);
}
---

<header class="site-header" id="site-header">
  <div class="header-inner container--wide">
    <!-- Logo -->
    <a href="/" class="logo" aria-label="Sunshine on a Ranney Day — Home">
      <img
        src="/images/logos/sunny.png"
        alt=""
        class="logo-icon"
        width="40"
        height="40"
        loading="eager"
      />
      <span class="logo-text">
        <span class="logo-name">Sunshine on a Ranney Day</span>
      </span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="desktop-nav" aria-label="Main navigation">
      <ul class="nav-list" role="menubar">
        {nav.map((item) => (
          <li class="nav-item has-dropdown" role="none">
            <button
              class="nav-link"
              role="menuitem"
              aria-haspopup="true"
              aria-expanded="false"
            >
              {item.label}
              <svg class="chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <ul class="dropdown" role="menu">
              {item.children.map((child) => (
                <li role="none">
                  <a
                    href={child.href}
                    role="menuitem"
                    class:list={['dropdown-link', { active: isActive(child.href) }]}
                    {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  >
                    {child.label}
                    {child.external && (
                      <svg class="external-icon" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                        <path d="M4.5 1.5H1.5V10.5H10.5V7.5M7 1.5H10.5M10.5 1.5V5M10.5 1.5L5.5 6.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Donate CTA (desktop) -->
    <a href="/donate/" class="header-cta">Donate</a>

    <!-- Mobile hamburger — semantic <button> -->
    <button
      type="button"
      class="mobile-toggle"
      id="mobile-toggle-btn"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-nav-panel"
    >
      <span class="hamburger-line" aria-hidden="true"></span>
      <span class="hamburger-line" aria-hidden="true"></span>
      <span class="hamburger-line" aria-hidden="true"></span>
    </button>
  </div>

  <!-- Overlay -->
  <div class="mobile-overlay" id="mobile-overlay" aria-hidden="true"></div>

  <!-- Mobile slide-out panel -->
  <nav
    class="mobile-nav"
    id="mobile-nav-panel"
    role="dialog"
    aria-label="Mobile navigation"
    aria-modal="true"
    aria-hidden="true"
  >
    <ul class="mobile-nav-list">
      {nav.map((item) => (
        <li class="mobile-nav-group">
          <span class="mobile-nav-heading">{item.label}</span>
          <ul>
            {item.children.map((child) => (
              <li>
                <a
                  href={child.href}
                  class:list={['mobile-nav-link', { active: isActive(child.href) }]}
                  {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {child.label}
                  {child.external && (
                    <span class="mobile-external-badge" aria-label="Opens in new tab">
                      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                        <path d="M4.5 1.5H1.5V10.5H10.5V7.5M7 1.5H10.5M10.5 1.5V5M10.5 1.5L5.5 6.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ul>
    <a href="/donate/" class="mobile-donate-btn">Donate</a>
  </nav>
</header>

<script>
  (function () {
    const btn = document.getElementById('mobile-toggle-btn');
    const panel = document.getElementById('mobile-nav-panel');
    const overlay = document.getElementById('mobile-overlay');
    const header = document.getElementById('site-header');
    const main = document.querySelector('main');
    const footer = document.querySelector('footer');
    if (!btn || !panel || !overlay) return;

    let isOpen = false;
    let savedScrollY = 0;

    // All focusable elements inside the panel + the toggle button
    function getFocusable() {
      return [btn, ...panel.querySelectorAll('a, button, [tabindex]:not([tabindex="-1"])')];
    }

    function open() {
      isOpen = true;

      // iOS-safe scroll lock: save position, fix body, offset to prevent jump
      savedScrollY = window.scrollY;
      document.body.style.position = 'fixed';
      document.body.style.top = `-${savedScrollY}px`;
      document.body.style.left = '0';
      document.body.style.right = '0';
      document.body.style.overflow = 'hidden';

      btn.setAttribute('aria-expanded', 'true');
      btn.setAttribute('aria-label', 'Close menu');
      btn.classList.add('is-open');
      panel.classList.add('is-open');
      panel.setAttribute('aria-hidden', 'false');
      overlay.classList.add('is-open');

      // Mark page content as inert (screen readers + tab can't escape)
      if (main) main.setAttribute('inert', '');
      if (footer) footer.setAttribute('inert', '');

      // Focus first link
      const first = panel.querySelector('a');
      if (first) first.focus();
    }

    function close() {
      isOpen = false;

      // Restore scroll position
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.left = '';
      document.body.style.right = '';
      document.body.style.overflow = '';
      window.scrollTo(0, savedScrollY);

      btn.setAttribute('aria-expanded', 'false');
      btn.setAttribute('aria-label', 'Open menu');
      btn.classList.remove('is-open');
      panel.classList.remove('is-open');
      panel.setAttribute('aria-hidden', 'true');
      overlay.classList.remove('is-open');

      if (main) main.removeAttribute('inert');
      if (footer) footer.removeAttribute('inert');

      btn.focus();
    }

    // Toggle
    btn.addEventListener('click', function () { isOpen ? close() : open(); });

    // Close on overlay tap
    overlay.addEventListener('click', close);

    // Close on Escape
    document.addEventListener('keydown', function (e) {
      if (!isOpen) return;
      if (e.key === 'Escape') { close(); return; }

      // Focus trap: cycle Tab within menu
      if (e.key === 'Tab') {
        const focusable = getFocusable();
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey) {
          if (document.activeElement === first) { e.preventDefault(); last.focus(); }
        } else {
          if (document.activeElement === last) { e.preventDefault(); first.focus(); }
        }
      }
    });

    // Auto-close on desktop resize
    window.matchMedia('(min-width: 1024px)').addEventListener('change', function (e) {
      if (e.matches && isOpen) close();
    });

    // Close when nav links clicked
    panel.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', close);
    });

    // Swipe-to-close: swipe right on the panel dismisses it
    let touchStartX = 0;
    let touchStartY = 0;
    let swiping = false;

    panel.addEventListener('touchstart', function (e) {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      swiping = true;
    }, { passive: true });

    panel.addEventListener('touchmove', function (e) {
      if (!swiping) return;
      const dx = e.touches[0].clientX - touchStartX;
      const dy = Math.abs(e.touches[0].clientY - touchStartY);
      // Only trigger if horizontal swipe dominates and moving right
      if (dx > 60 && dy < 40) {
        swiping = false;
        close();
      }
    }, { passive: true });

    panel.addEventListener('touchend', function () {
      swiping = false;
    }, { passive: true });
  })();
</script>

<style>
  /* ─── Header Shell ─────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: var(--c-dark);
    height: var(--header-height);
    border-bottom: 3px solid var(--c-yellow);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding-inline: var(--space-lg);
    max-width: var(--max-width-wide);
    margin-inline: auto;
  }

  /* ─── Logo ─────────────────────────────── */
  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-shrink: 0;
    transition: opacity var(--transition-fast);
  }

  .logo:hover { opacity: 0.9; }

  .logo-icon { width: 40px; height: 40px; flex-shrink: 0; }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .logo-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--c-white);
    letter-spacing: 0.01em;
  }

  /* ─── Desktop Nav ──────────────────────── */
  .desktop-nav { display: none; }
  @media (min-width: 1024px) { .desktop-nav { display: flex; } }

  .nav-list { display: flex; align-items: center; gap: var(--space-xs); }
  .nav-item { position: relative; }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: var(--space-sm) var(--space-md);
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--c-white);
    background: none;
    border: none;
    cursor: pointer;
    border-radius: var(--border-radius);
    transition: background var(--transition-fast), color var(--transition-fast);
    white-space: nowrap;
  }

  .nav-link:hover {
    background: rgba(255, 255, 255, 0.1);
    color: var(--c-yellow);
  }

  .chevron { transition: transform var(--transition-fast); }

  /* ─── Desktop Dropdown ─────────────────── */
  .dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    min-width: 220px;
    background: var(--c-white);
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-lg);
    padding: var(--space-sm) 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--transition-fast), transform var(--transition-fast), visibility var(--transition-fast);
    pointer-events: none;
  }

  .nav-item:hover .dropdown,
  .nav-item:focus-within .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  .nav-item:hover .chevron { transform: rotate(180deg); }

  .dropdown-link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-lg);
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--c-text);
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .dropdown-link:hover { background: var(--c-warm-gray); color: var(--c-purple); }
  .dropdown-link.active { color: var(--c-purple); font-weight: 600; }
  .external-icon { opacity: 0.4; flex-shrink: 0; }

  /* ─── Header CTA ───────────────────────── */
  .header-cta {
    display: none;
    padding: 0.5rem 1.25rem;
    background: var(--c-yellow);
    color: var(--c-dark);
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: 100px;
    transition: background var(--transition-fast), transform var(--transition-fast);
  }

  .header-cta:hover { background: var(--c-yellow-hover); transform: translateY(-1px); }
  @media (min-width: 1024px) { .header-cta { display: inline-flex; } }

  /* ─── Mobile Hamburger ─────────────────── */
  .mobile-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 48px;
    height: 48px;
    padding: 12px;
    cursor: pointer;
    border: none;
    background: none;
    z-index: 1001;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  @media (min-width: 1024px) { .mobile-toggle { display: none; } }

  .hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--c-white);
    border-radius: 2px;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: center;
    pointer-events: none;
  }

  .mobile-toggle.is-open .hamburger-line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .mobile-toggle.is-open .hamburger-line:nth-child(2) { opacity: 0; }
  .mobile-toggle.is-open .hamburger-line:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ─── Mobile Overlay ───────────────────── */
  .mobile-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                visibility 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 999;
    -webkit-tap-highlight-color: transparent;
  }

  .mobile-overlay.is-open { opacity: 1; visibility: visible; }

  /* ─── Mobile Nav Panel ─────────────────── */
  .mobile-nav {
    position: fixed;
    top: 0;
    right: 0;
    width: min(340px, 88vw);
    height: 100vh;
    height: 100dvh;
    background: var(--c-white);
    padding: calc(var(--header-height) + var(--space-xl)) var(--space-lg) var(--space-2xl);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
    transform: translateX(100%);
    will-change: transform;
    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
    z-index: 1000;
    box-shadow: -8px 0 30px rgba(0, 0, 0, 0.15);
  }

  .mobile-nav.is-open { transform: translateX(0); }

  @media (min-width: 1024px) {
    .mobile-nav, .mobile-overlay { display: none !important; }
  }

  /* ─── Mobile Nav Content ───────────────── */
  .mobile-nav-group + .mobile-nav-group {
    margin-top: var(--space-lg);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--c-border);
  }

  .mobile-nav-heading {
    display: block;
    font-weight: 700;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-text-muted);
    margin-bottom: var(--space-xs);
  }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.625rem 0;
    font-size: 1rem;
    font-weight: 450;
    color: var(--c-text);
    transition: color var(--transition-fast);
    min-height: 44px;
  }

  .mobile-nav-link:hover { color: var(--c-purple); }

  .mobile-nav-link.active {
    color: var(--c-purple);
    font-weight: 600;
  }

  .mobile-nav-link.active::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--c-purple);
    margin-right: var(--space-sm);
    flex-shrink: 0;
  }

  .mobile-external-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 6px;
    background: var(--c-warm-gray);
    color: var(--c-text-muted);
    flex-shrink: 0;
    transition: background var(--transition-fast);
  }

  .mobile-nav-link:hover .mobile-external-badge {
    background: var(--c-purple-soft);
    color: var(--c-purple);
  }

  .mobile-donate-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: var(--space-xl);
    padding: var(--space-md) var(--space-xl);
    background: var(--c-yellow);
    color: var(--c-dark);
    font-weight: 700;
    font-size: 1rem;
    border-radius: 100px;
    transition: background var(--transition-fast), transform var(--transition-fast);
    min-height: 48px;
  }

  .mobile-donate-btn:hover {
    background: var(--c-yellow-hover);
    transform: translateY(-1px);
  }

  /* ─── Reduced Motion ───────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .mobile-nav,
    .mobile-overlay,
    .hamburger-line,
    .mobile-toggle,
    .dropdown,
    .chevron,
    .nav-link,
    .dropdown-link,
    .header-cta,
    .logo,
    .mobile-nav-link,
    .mobile-donate-btn,
    .mobile-external-badge {
      transition-duration: 0.01ms !important;
    }
  }
</style>
