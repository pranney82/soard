  /* ─── Reveal animation (uses global ScrollReveal via data-reveal) ───── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
