---
/**
 * PageLayout.astro
 * Standard page layout with editorial hero, main content area,
 * and optional bottom CTA. Wraps BaseLayout.
 */
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  heroTitle?: string;
  heroSubtitle?: string;
  heroLabel?: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: object | object[];
  breadcrumbs?: { name: string; url: string }[];
  datePublished?: string;
  dateModified?: string;
  noindex?: boolean;
}

const { title, description, heroTitle, heroSubtitle, heroLabel, ogImage, ogType, jsonLd, breadcrumbs, datePublished, dateModified, noindex } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage} ogType={ogType} jsonLd={jsonLd} breadcrumbs={breadcrumbs} datePublished={datePublished} dateModified={dateModified} noindex={noindex}>
  {(heroTitle || heroSubtitle) && (
    <section class="page-hero">
      <div class="container">
        {heroLabel && <p class="page-hero__label">{heroLabel}</p>}
        {heroTitle && <h1 class="page-hero__title" set:html={heroTitle} />}
        {heroSubtitle && <p class="page-hero__subtitle">{heroSubtitle}</p>}
        <div class="page-hero__rule" aria-hidden="true">
          <span class="page-hero__rule-accent"></span>
        </div>
      </div>
    </section>
  )}

  <article class="page-content">
    <slot />
  </article>

  <slot name="cta" />
</BaseLayout>

<style>
  .page-hero {
    background: var(--c-cream);
    padding-block: var(--space-2xl) 0;
    text-align: center;
  }

  .page-hero .container {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .page-hero__label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    margin-bottom: var(--space-md);
  }

  .page-hero__title {
    color: var(--c-text);
    font-size: clamp(2rem, 5vw, 3.125rem);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.15;
    max-width: 700px;
    margin-inline: auto;
  }

  .page-hero__subtitle {
    margin-top: var(--space-sm);
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(0.95rem, 1.8vw, 1.065rem);
    line-height: 1.6;
    color: var(--c-text-muted);
    max-width: 500px;
    margin-inline: auto;
  }

  .page-hero__rule {
    position: relative;
    height: 2px;
    background: var(--c-border);
    margin-top: var(--space-lg);
    width: 100%;
  }

  .page-hero__rule-accent {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    top: -1px;
    width: 48px;
    height: 3px;
    background: var(--c-yellow);
    border-radius: 1px;
  }

  .page-content {
    min-height: 40vh;
  }

  @media (max-width: 768px) {
    .page-hero {
      padding-block: var(--space-xl) 0;
    }
  }
</style>
