    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    margin-bottom: 28px;
    opacity: 0;
    animation: heroUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.05s both;
  }

