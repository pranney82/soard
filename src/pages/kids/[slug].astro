---
/**
 * [slug].astro — Individual kid profile page (Top 1%)
 *
 * Premium editorial storytelling with:
 *   - LQIP blur-up image placeholders (tiny CF thumbnail → full res)
 *   - Staggered cascade reveal animations (each element sequences in)
 *   - CSS-only scroll progress indicator
 *   - Asymmetric hero with portrait + typography (never full-width)
 *   - Masonry gallery with face-gravity, hover zoom overlay
 *   - Video facade (CF Stream + YouTube)
 *   - Fundraising CTA, partner logos, related kids
 *   - Graceful empty states for minimal-data kids
 *   - content-visibility: auto for rendering perf
 *
 * PERF: CF Images w/ srcset + gravity:face, LQIP blur-up, lazy loading,
 *       video facade, content-visibility, inline CSS (build config)
 * SEO:  Article + Person schema, breadcrumbs, rich meta, OG image
 * A11Y: Heading hierarchy, ARIA, focus trap lightbox, keyboard nav,
 *       prefers-reduced-motion respected
 * UX:   View Transitions, staggered scroll-reveals, no full-bleed images
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import { getCollection } from 'astro:content';
import { getPublishedKids } from '../../utils/collections';
import { getKidProfileSchema } from '../../utils/schema';

export async function getStaticPaths() {
  const kids = await getPublishedKids();
  const sorted = kids.sort((a, b) => (b.data.year || 0) - (a.data.year || 0));
  // Seeded shuffle — deterministic per slug so builds produce identical HTML
  // when content hasn't changed (preserves CF edge cache for 187+ pages)
  const seedHash = (str: string) => {
    let h = 0;
    for (let i = 0; i < str.length; i++) {
      h = ((h << 5) - h + str.charCodeAt(i)) | 0;
    }
    return h;
  };
  const seededShuffle = (arr: typeof kids, seed: string) => {
    const a = [...arr];
    let s = seedHash(seed);
    for (let j = a.length - 1; j > 0; j--) {
      s = (s * 1664525 + 1013904223) | 0;
      const r = ((s >>> 0) % (j + 1));
      [a[j], a[r]] = [a[r], a[j]];
    }
    return a;
  };
  return sorted.map((kid, i) => {
    const others = sorted.filter((k, j) => j !== i);
    const sameType = others.filter(k =>
      k.data.roomTypes?.some(t => kid.data.roomTypes?.includes(t))
    );
    const sameYear = others.filter(k => k.data.year === kid.data.year);
    // Deduplicate by slug, preserving priority order (sameType > sameYear > others)
    const seen = new Set();
    const slug = kid.data.slug;
    const deduped = [...seededShuffle(sameType, slug), ...seededShuffle(sameYear, slug + ':year'), ...seededShuffle(others, slug + ':all')]
      .filter(k => {
        if (seen.has(k.data.slug)) return false;
        seen.add(k.data.slug);
        return true;
      });
    const related = deduped
      .filter(k => k.data.heroImage)
      .slice(0, 4)
      .map(k => ({ name: k.data.name, slug: k.data.slug, heroImage: k.data.heroImage, diagnosis: k.data.diagnosis, roomTypes: k.data.roomTypes }));

    return {
      params: { slug: kid.data.slug },
      props: {
        kid: kid.data,
        prevKid: i > 0 ? { name: sorted[i - 1].data.name, slug: sorted[i - 1].data.slug, heroImage: sorted[i - 1].data.heroImage } : null,
        nextKid: i < sorted.length - 1 ? { name: sorted[i + 1].data.name, slug: sorted[i + 1].data.slug, heroImage: sorted[i + 1].data.heroImage } : null,
        relatedKids: related,
      },
    };
  });
}

const { kid, prevKid, nextKid, relatedKids } = Astro.props;
const photos = kid.photos || [];
// ── CF Image helpers ──────────────────────
import { cfUrl as _cfUrl, cfSrcset as _cfSrcset, cfRaw, CF_BASE, cfId } from '../../utils/cf-image';
import lqipManifest from '../../data/lqip-kids.json';
import dimsManifest from '../../data/dimensions-kids.json';
const _lqipMap: Record<string, string> = lqipManifest;
const _dimsMap: Record<string, [number, number]> = dimsManifest;

function cfUrl(src: string, opts: string) { return cfRaw(src, opts); }
function cfSrcset(src: string, widths: number[]) {
  return _cfSrcset(src, widths);
}
/** LQIP: Inline base64 from build-time manifest (zero HTTP requests).
 *  Falls back to CF URL only if the image isn't in the manifest. */
function lqip(src: string): string {
  const id = cfId(src);
  return _lqipMap[id] || cfRaw(src, 'w=30,q=30,blur=20');
}

/** Real aspect ratio from build-time manifest. Returns [w, h] at GCD-reduced
 *  scale, or a 4:3 fallback if the image isn't in the manifest. */
function dims(src: string): [number, number] {
  const id = cfId(src);
  return _dimsMap[id] || [4, 3];
}

// ── YouTube ID extraction ─────────────────
function getYouTubeId(url: string): string | null {
  if (!url) return null;
  const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([a-zA-Z0-9_-]{11})/);
  return match ? match[1] : null;
}
const ytId = kid.videoUrl ? getYouTubeId(kid.videoUrl) : null;
const streamId = kid.streamVideoId || null;
const hasVideo = streamId || ytId;

// ── SEO ───────────────────────────────────
const SITE = 'https://sunshineonaranneyday.com';
const kidSchemas = getKidProfileSchema({
  ...kid,
  videoUrl: kid.videoUrl,
  streamVideoId: kid.streamVideoId,
  photos: kid.photos,
  photographer: kid.photographer,
  status: kid.status,
});
const breadcrumbs = [
  { name: 'Home', url: SITE },
  { name: 'Meet the Kids', url: `${SITE}/kids/` },
  { name: kid.name, url: `${SITE}/kids/${kid.slug}/` },
];

const metaDesc = kid.metaDescription
  || kid.shortDescription
  || `Meet ${kid.name}${kid.diagnosis ? `, diagnosed with ${kid.diagnosis}` : ''}. Learn how Sunshine on a Ranney Day transformed their space${kid.roomTypes?.length ? ` with a ${kid.roomTypes.join(' & ')}` : ''}.`;

const dateModified = kid.year ? `${kid.year}-01-01` : undefined;

// ── LCP preload for hero image ────────────
// Large srcset for retina sharpness — gravity:face positions focal point
const heroSrcset = kid.heroImage ? _cfSrcset(kid.heroImage, [600, 900, 1200, 1600, 2400], { fit: 'cover', gravity: 'face' }) : '';
const heroSizes = '(max-width: 768px) 92vw, (max-width: 1100px) 55vw, 640px';

// ── Bio paragraphs + pull quote ───────────
// Handle both \n\n-separated plain text AND <p>-wrapped HTML from rich editor
function splitBio(bio: string): string[] {
  if (!bio) return [];
  // If bio contains <p> tags, extract content between them
  if (bio.includes('<p>')) {
    return [...bio.matchAll(/<p>([\s\S]*?)<\/p>/gi)]
      .map(m => m[1].replace(/<br\s*\/?>/gi, '').trim())
      .filter(Boolean);
  }
  // Plain text: split on double newlines
  return bio.split('\n\n').filter(p => p.trim());
}
const bioParas = splitBio(kid.bio || '');
const introPara = bioParas.length > 0 ? bioParas[0] : '';
const remainingParas = bioParas.slice(1);

// Only use explicit quote from CMS — no auto-extraction from bio
let pullQuote: string | null = null;
if (kid.quote && kid.quote !== kid.bio && kid.quote !== introPara) {
  pullQuote = kid.quote;
}

const galleryPhotos = photos.slice(0, 30);

// ── Bento layout roles: forced visual rhythm ───────
// Repeating 8-photo cycle guarantees variety regardless of photo aspect ratios.
// hero(2x2), std, std, wide(2x1), tall(1x2), std, std, wide(2x1)
const BENTO_ROLES = ['hero', 'std', 'std', 'wide', 'tall', 'std', 'std', 'wide'];
function bentoRole(i: number, total: number): string {
  if (i === 0) return 'hero';
  if (total <= 3) return 'std';
  if (total <= 5) return i === 3 ? 'wide' : 'std';
  return BENTO_ROLES[i % BENTO_ROLES.length];
}

// ── Hero: art-directed mobile — bigger for retina sharpness ───────
const heroMobileSrcset = kid.heroImage ? _cfSrcset(kid.heroImage, [600, 900, 1200], { fit: 'cover', gravity: 'face' }) : '';
const heroMobileSizes = '(max-width: 480px) 92vw, 92vw';

// ── Photo Essay: editorial prose with interwoven photos ──
//
// One continuous text column with photos placed within the flow:
//   breakout  — wide photo breaking out of text column between paragraphs
//   float     — smaller photo floated into text, wrapping prose around it
//   cinematic — near-viewport-width dramatic pause
const storyPhotos = kid.storyPhotos || [];
const hasStoryPhotos = storyPhotos.length > 0;
const usePhotoEssay = hasStoryPhotos
  ? remainingParas.length >= 1
  : remainingParas.length >= 2 && galleryPhotos.length >= 3;

// Essay item types (mapped to placement in template):
//   spread  → breakout (wide photo between paragraphs)
//   reverse → float-right (photo floats into text)
//   moment  → cinematic (near-full-width dramatic pause)
//   accent  → float-left (photo floats into text)
type EssayItem =
  | { type: 'spread'; photo: typeof photos[0]; text: string }
  | { type: 'reverse'; photo: typeof photos[0]; text: string }
  | { type: 'moment'; photo: typeof photos[0]; text?: string }
  | { type: 'accent'; photo: typeof photos[0]; text: string; side: 'left' | 'right' }
  | { type: 'quote'; text: string };

let essayItems: EssayItem[] = [];
let overflowParas: string[] = remainingParas;

if (usePhotoEssay) {
  const srcPhotos = hasStoryPhotos ? storyPhotos : (() => {
    const pairCount = Math.min(remainingParas.length, 4, Math.floor(galleryPhotos.length / 2));
    const step = galleryPhotos.length / pairCount;
    return Array.from({ length: pairCount }, (_, i) =>
      galleryPhotos[Math.min(Math.floor(i * step), galleryPhotos.length - 1)]
    );
  })();
  const n = srcPhotos.length;
  const paras = [...remainingParas];
  let paraIdx = 0;

  if (n >= 4) {
    // spread(1) → reverse(2) → [quote] → moment(3) → accent(4)
    essayItems.push({ type: 'spread', photo: srcPhotos[0], text: paras[paraIdx++] || '' });
    essayItems.push({ type: 'reverse', photo: srcPhotos[1], text: paras[paraIdx++] || '' });
    if (pullQuote) essayItems.push({ type: 'quote', text: pullQuote });
    essayItems.push({ type: 'moment', photo: srcPhotos[2], text: paras[paraIdx++] });
    essayItems.push({ type: 'accent', photo: srcPhotos[3], text: paras[paraIdx++] || '', side: 'right' });
  } else if (n === 3) {
    essayItems.push({ type: 'spread', photo: srcPhotos[0], text: paras[paraIdx++] || '' });
    if (pullQuote) essayItems.push({ type: 'quote', text: pullQuote });
    essayItems.push({ type: 'reverse', photo: srcPhotos[1], text: paras[paraIdx++] || '' });
    essayItems.push({ type: 'moment', photo: srcPhotos[2], text: paras[paraIdx++] });
  } else if (n === 2) {
    essayItems.push({ type: 'spread', photo: srcPhotos[0], text: paras[paraIdx++] || '' });
    if (pullQuote) essayItems.push({ type: 'quote', text: pullQuote });
    essayItems.push({ type: 'moment', photo: srcPhotos[1], text: paras[paraIdx++] });
  } else {
    essayItems.push({ type: 'moment', photo: srcPhotos[0], text: paras[paraIdx++] });
    if (pullQuote) essayItems.push({ type: 'quote', text: pullQuote });
  }
  overflowParas = paras.slice(paraIdx);
}

const quoteWoven = essayItems.some(it => it.type === 'quote');
const remainingQuote = (!quoteWoven && pullQuote) ? pullQuote : null;

// ── Minimal data detection ────────────────
const hasDetails = kid.age || (kid.roomTypes && kid.roomTypes.length > 0) || kid.year;
const hasRichContent = kid.bio || galleryPhotos.length > 1 || hasVideo;
---

<BaseLayout
  title={`${kid.name}'s Story`}
  description={metaDesc}
  ogType="article"
  jsonLd={kidSchemas}
  breadcrumbs={breadcrumbs}
  datePublished={kid.year ? `${kid.year}-01-01` : undefined}
  dateModified={dateModified}
>
  {kid.heroImage && <link slot="head" rel="preload" as="image" imagesrcset={heroMobileSrcset} imagesizes={heroMobileSizes} fetchpriority="high" media="(max-width: 768px)" />}
  {kid.heroImage && <link slot="head" rel="preload" as="image" imagesrcset={heroSrcset} imagesizes={heroSizes} fetchpriority="high" media="(min-width: 769px)" />}

  <!-- Scroll progress indicator -->
  <div class="scroll-progress" aria-hidden="true"></div>

  <article class="kid-profile" itemscope itemtype="https://schema.org/Article">
    <!-- ═══ Hero: Magazine Cover ════════════ -->
    <section class="hero">
      <div class="hero__split">
        {kid.heroImage ? (
          <div class="hero__portrait" style={`--lqip: url('${lqip(kid.heroImage)}')`} transition:name="kid-hero">
            <picture>
              <source
                media="(max-width: 768px)"
                srcset={heroMobileSrcset}
                sizes={heroMobileSizes}
                width="300"
                height="400"
              />
              <img
                src={cfUrl(kid.heroImage, 'w=1200,fit=cover,gravity=face,q=85')}
                srcset={heroSrcset}
                sizes={heroSizes}
                alt={`Photo of ${kid.name}${kid.diagnosis ? ` — ${kid.diagnosis}` : ''}`}
                class="hero__img lqip-img"
                width="900"
                height="1200"
                loading="eager"
                decoding="async"
                fetchpriority="high"
                itemprop="image"
              />
            </picture>
            {kid.status === 'in-progress' && (
              <span class="hero__badge">In Progress</span>
            )}
          </div>
        ) : (
          <div class="hero__portrait hero__portrait--empty">
            <svg class="hero__placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
            <span class="hero__placeholder-text">{kid.name}</span>
          </div>
        )}

        <div class="hero__info">
          <a href="/kids/" class="hero__back stagger" aria-label="Back to Meet the Kids">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            Meet the Kids
          </a>
          <h1 class="hero__name" itemprop="headline" transition:name="kid-name">{kid.name}</h1>

          {kid.diagnosis && (
            <p class="hero__diagnosis stagger">{kid.diagnosis}</p>
          )}

          {hasDetails && (
            <p class="hero__meta stagger">
              {[
                kid.age && `Age ${Array.isArray(kid.age) ? kid.age.join(' & ') : kid.age}`,
                kid.roomTypes?.length && kid.roomTypes.join(' & '),
                kid.year,
              ].filter(Boolean).join(' · ')}
            </p>
          )}

          <div class="hero__actions stagger">
            {kid.fundraisingUrl && (
              <a href={kid.fundraisingUrl} target="_blank" rel="noopener noreferrer" class="hero__donate-btn">
                Donate
              </a>
            )}
            <button class="hero__share-btn" id="share-btn" type="button" aria-label="Share this story">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
              Share
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ Lede: The Opening Statement ═══ -->
    {(kid.heroSummary || introPara) && (
      <section class="lede">
        <div class="container container--narrow">
          <p class="lede__text prose--dropcap" itemprop="description">
            <span set:html={kid.heroSummary || introPara} />
          </p>
        </div>
      </section>
    )}

    <!-- ═══ Editorial Story — Continuous Text with Interwoven Photos ═══
         One continuous prose column. Photos are placed WITHIN the flow:
           - breakout: wide photo between paragraphs (breaks out of text column)
           - float:    smaller photo floated into the text column (wraps text around it)
           - cinematic: near-full-width photo as a visual pause
         The reader never loses their place — photos enhance, not interrupt.
         ═══════════════════════════════════════════════════════════════════ -->
    {essayItems.length > 0 && (
      <section class="essay stagger-section" itemprop="articleBody">
        <div class="essay__flow">
          {essayItems.map((item, i) => {
            if (item.type === 'quote') {
              return (
                <blockquote class="essay__quote">
                  <div class="essay__quote-inner">
                    <svg class="essay__quote-mark" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                      <path d="M14 28c-2.2 0-4-1.8-4-4 0-6.6 5.4-12 12-12v4c-4.4 0-8 3.6-8 8h4c2.2 0 4 1.8 4 4s-1.8 4-4 4h-4zm20 0c-2.2 0-4-1.8-4-4 0-6.6 5.4-12 12-12v4c-4.4 0-8 3.6-8 8h4c2.2 0 4 1.8 4 4s-1.8 4-4 4h-4z" fill="currentColor"/>
                    </svg>
                    <p>{item.text}</p>
                  </div>
                </blockquote>
              );
            }

            // Placement pattern:
            //   1st photo (spread)  → breakout between paragraphs
            //   2nd photo (reverse) → float right within text column
            //   3rd photo (moment)  → cinematic full pause
            //   4th photo (accent)  → float left within text column
            const placement = item.type === 'moment' ? 'cinematic'
                            : item.type === 'reverse' ? 'float-right'
                            : item.type === 'accent' ? 'float-left'
                            : 'breakout';
            const photo = item.photo;
            const text = item.text;
            const [w, h] = dims(photo.url);
            const isFirst = i === 0;
            const caption = photo.alt && photo.alt !== `${kid.name}'s room` ? photo.alt : null;
            const isFloat = placement === 'float-right' || placement === 'float-left';

            const srcWidths = placement === 'cinematic' ? [600, 900, 1400, 2000]
                            : isFloat ? [300, 500, 800]
                            : [600, 900, 1200, 1600];
            const sizes = placement === 'cinematic'
              ? '(max-width: 768px) 100vw, (max-width: 1400px) 85vw, 1200px'
              : isFloat
                ? '(max-width: 768px) 92vw, (max-width: 1200px) 40vw, 340px'
                : '(max-width: 768px) 92vw, (max-width: 1200px) 75vw, 960px';
            const imgW = placement === 'cinematic' ? 1400 : isFloat ? 800 : 1200;

            if (isFloat) {
              // Float: photo + text together in one block — text wraps around the photo
              return (
                <div class="essay__woven">
                  <figure class={`essay__float essay__float--${placement === 'float-right' ? 'right' : 'left'}`}>
                    <div class="essay__img-wrap" style={`--lqip: url('${lqip(photo.url)}')`}>
                      <img
                        src={_cfUrl(photo.url, { w: imgW, q: 85 })}
                        srcset={_cfSrcset(photo.url, srcWidths)}
                        sizes={sizes}
                        alt={photo.alt || `${kid.name}'s room`}
                        class="essay__img lqip-img"
                        loading="lazy"
                        decoding="async"
                        width={w}
                        height={h}
                      />
                    </div>
                    {caption && <figcaption class="essay__caption">{caption}</figcaption>}
                  </figure>
                  {text && <p set:html={text} />}
                </div>
              );
            }

            // Breakout / cinematic: photo breaks out of text column, text below stays narrow
            return (
              <Fragment>
                <figure class={`essay__break essay__break--${placement}`}>
                  <div class="essay__img-wrap" style={`--lqip: url('${lqip(photo.url)}')`}>
                    <img
                      src={_cfUrl(photo.url, { w: imgW, q: 85 })}
                      srcset={_cfSrcset(photo.url, srcWidths)}
                      sizes={sizes}
                      alt={photo.alt || `${kid.name}'s room`}
                      class="essay__img lqip-img"
                      loading={isFirst ? 'eager' : 'lazy'}
                      decoding="async"
                      width={w}
                      height={h}
                    />
                  </div>
                  {caption && <figcaption class="essay__caption">{caption}</figcaption>}
                </figure>
                {text && <p class={isFirst ? 'prose--dropcap' : ''} set:html={text} />}
              </Fragment>
            );
          })}
        </div>
      </section>
    )}

    <!-- ═══ Story Section (overflow + quote) ═══ -->
    {(overflowParas.length > 0 || remainingQuote) && (
      <section class="story">
        <div class="container container--narrow">
          {overflowParas.length > 0 && (
            <div class={`story__body prose stagger-section ${essayItems.length === 0 ? 'prose--dropcap' : ''}`} itemprop="articleBody">
              {overflowParas.map(paragraph => (
                <p set:html={paragraph} />
              ))}
            </div>
          )}

          {remainingQuote && (
            <blockquote class="pullquote stagger-section">
              <svg class="pullquote__mark" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                <path d="M14 28c-2.2 0-4-1.8-4-4 0-6.6 5.4-12 12-12v4c-4.4 0-8 3.6-8 8h4c2.2 0 4 1.8 4 4s-1.8 4-4 4h-4zm20 0c-2.2 0-4-1.8-4-4 0-6.6 5.4-12 12-12v4c-4.4 0-8 3.6-8 8h4c2.2 0 4 1.8 4 4s-1.8 4-4 4h-4z" fill="currentColor"/>
              </svg>
              <p>{remainingQuote}</p>
            </blockquote>
          )}
        </div>
      </section>
    )}

    <!-- ═══ Video ════════════════════════════ -->
    {hasVideo && (
      <section class="video stagger-section">
        <div class="container container--narrow">
          <h2 class="section-label">Watch {kid.name}'s Story</h2>
          {streamId ? (
            <div class="video__frame">
              <div class="stream-facade" id="stream-facade" data-id={streamId} role="button" tabindex="0" aria-label={`Play ${kid.name}'s video`}>
                <img
                  src={`https://videodelivery.net/${streamId}/thumbnails/thumbnail.jpg?time=2s&height=720`}
                  alt={`Video thumbnail for ${kid.name}'s story`}
                  class="video__thumb"
                  loading="lazy"
                  decoding="async"
                  width="1280"
                  height="720"
                />
                <div class="video__play" aria-hidden="true">
                  <svg width="68" height="48" viewBox="0 0 68 48">
                    <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="#FFDA24"/>
                    <path d="M45 24L27 14v20" fill="#373A36"/>
                  </svg>
                </div>
              </div>
            </div>
          ) : ytId ? (
            <div class="video__frame">
              <div class="yt-facade" id="yt-facade" data-id={ytId} role="button" tabindex="0" aria-label={`Play ${kid.name}'s video`}>
                <picture>
                  <source type="image/webp" srcset={`https://i.ytimg.com/vi_webp/${ytId}/maxresdefault.webp`} />
                  <img
                    src={`https://i.ytimg.com/vi/${ytId}/maxresdefault.jpg`}
                    alt={`Video thumbnail for ${kid.name}'s story`}
                    class="video__thumb"
                    loading="lazy"
                    decoding="async"
                  />
                </picture>
                <div class="video__play" aria-hidden="true">
                  <svg width="68" height="48" viewBox="0 0 68 48">
                    <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="#FFDA24"/>
                    <path d="M45 24L27 14v20" fill="#373A36"/>
                  </svg>
                </div>
              </div>
            </div>
          ) : null}
        </div>
      </section>
    )}

    <!-- ═══ Bento Photo Grid ═══════════════════ -->
    {galleryPhotos.length > 1 && (
      <section class="gallery stagger-section">
        <div class="container">
          <div class="gallery__header">
            <h2 class="section-label">Room Transformation</h2>
            {kid.photographer && (
              <p class="gallery__credit">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13.997 4a2 2 0 0 1 1.76 1.05l.486.9A2 2 0 0 0 18.003 7H20a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h1.997a2 2 0 0 0 1.759-1.048l.489-.904A2 2 0 0 1 10.004 4z"/><circle cx="12" cy="13" r="3"/></svg>
                {kid.photographer}
              </p>
            )}
          </div>
          <div class="bento" id="gallery">
            {galleryPhotos.map((photo, i) => {
              const role = bentoRole(i, galleryPhotos.length);
              const isHero = role === 'hero';
              const isTall = role === 'tall';
              const isWide = role === 'wide';
              const bentoClass = isHero ? 'bento__hero' : isTall ? 'bento__tall' : isWide ? 'bento__wide' : '';
              const imgW = isHero ? 1200 : (isTall || isWide) ? 900 : 700;
              const srcsetWidths = isHero ? [600, 900, 1200, 1600] : [400, 600, 900];
              const sizesAttr = isHero
                ? '(max-width: 768px) 92vw, (max-width: 1100px) 60vw, 580px'
                : isTall || isWide
                  ? '(max-width: 768px) 46vw, (max-width: 1100px) 35vw, 380px'
                  : '(max-width: 768px) 46vw, (max-width: 1100px) 28vw, 280px';
              const altText = photo.alt || `${kid.name}'s room transformation photo ${i + 1}`;
              return (
                <button
                  class={`masonry__item bento__cell ${bentoClass}`}
                  data-index={i}
                  data-src={cfUrl(photo.url, 'w=1600,q=85')}
                  data-srcset={_cfSrcset(photo.url, [800, 1200, 1600, 2400])}
                  data-alt={altText}
                  aria-label={`View photo ${i + 1} of ${galleryPhotos.length}`}
                  type="button"
                  style={`--lqip: url('${lqip(photo.url)}'); --idx: ${i}`}
                >
                  <img
                    src={cfUrl(photo.url, `w=${imgW},q=85`)}
                    srcset={cfSrcset(photo.url, srcsetWidths)}
                    sizes={sizesAttr}
                    alt={altText}
                    class="bento__img lqip-img"
                    loading={isHero ? 'eager' : 'lazy'}
                    decoding={isHero ? 'sync' : 'async'}
                    fetchpriority={isHero ? 'high' : undefined}
                    width={dims(photo.url)[0]}
                    height={dims(photo.url)[1]}
                  />
                  <div class="bento__overlay">
                    <span class="bento__expand">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
                      View
                    </span>
                    <span class="bento__counter">{i + 1}/{galleryPhotos.length}</span>
                  </div>
                </button>
              );
            })}
          </div>
        </div>
      </section>
    )}

    <!-- ═══ Fundraising CTA ═══════════════════ -->
    {kid.fundraisingUrl && (
      <section class="fundraise stagger-section">
        <div class="container container--narrow">
          <div class="fundraise__card">
            <div class="fundraise__icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"/></svg>
            </div>
            <div class="fundraise__content">
              <h2 class="fundraise__title">Help fund {kid.name}'s room</h2>
              <p class="fundraise__text">Your donation helps build {kid.name}'s {kid.roomTypes?.length ? kid.roomTypes.join(' & ').toLowerCase() : 'dream room'}. Zeffy charges zero platform fees so more of your gift reaches our mission.</p>
            </div>
            <a href={kid.fundraisingUrl} target="_blank" rel="noopener noreferrer" class="fundraise__btn">
              Donate Now
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </section>
    )}

    <!-- ═══ Partner Logos ═══════════════════ -->
    {kid.partnerLogos && kid.partnerLogos.length > 0 && (
      <section class="partners stagger-section">
        <div class="container">
          <h2 class="section-label" style="text-align: center;">Project Partners</h2>
          <p class="partners__sub">Made possible by the generous support of these partners.</p>
          <div class="partners__grid">
            {kid.partnerLogos.map(logo => (
              <div class="partners__logo">
                <img
                  src={cfUrl(logo.url, 'w=200,q=85')}
                  alt={logo.name || 'Project partner'}
                  loading="lazy"
                  decoding="async"
                  width="160"
                  height="80"
                />
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ═══ Related Kids ═══════════════════ -->
    {relatedKids && relatedKids.length > 0 && (
      <section class="related stagger-section">
        <div class="container">
          <h2 class="section-label" style="text-align: center;">More Sunshine Stories</h2>
          <div class="related__grid">
            {relatedKids.map(rk => {
              const sharedType = rk.roomTypes?.find(t => kid.roomTypes?.includes(t));
              return (
              <a href={`/kids/${rk.slug}/`} class="related__card">
                <div class="related__img-wrap" style={`--lqip: url('${lqip(rk.heroImage)}')`}>
                  <img
                    src={cfUrl(rk.heroImage, 'w=400,h=500,fit=cover,gravity=face,q=85')}
                    srcset={_cfSrcset(rk.heroImage, [300, 400], { fit: 'cover', gravity: 'face', aspectRatio: 1.25 })}
                    sizes="(max-width: 600px) 45vw, 220px"
                    alt={`Photo of ${rk.name}`}
                    class="related__img lqip-img"
                    loading="lazy"
                    decoding="async"
                    width="400"
                    height="500"
                  />
                </div>
                <div class="related__meta">
                  <span class="related__name">{rk.name}</span>
                  {sharedType && (
                    <span class="related__tag">{sharedType}</span>
                  )}
                  {rk.diagnosis && (
                    <span class="related__diagnosis">{rk.diagnosis}</span>
                  )}
                </div>
              </a>
            );
            })}
          </div>
        </div>
      </section>
    )}

    <!-- ═══ Prev / Next Navigation ════════ -->
    <nav class="kid-nav" aria-label="Navigate between kid profiles">
      <div class="container">
        <div class="kid-nav__grid">
          {prevKid ? (
            <a href={`/kids/${prevKid.slug}/`} class="kid-nav__link kid-nav__link--prev">
              {prevKid.heroImage && (
                <img
                  src={cfUrl(prevKid.heroImage, 'w=80,h=80,fit=cover,gravity=face,q=80')}
                  alt=""
                  class="kid-nav__thumb"
                  loading="lazy"
                  decoding="async"
                  width="40"
                  height="40"
                />
              )}
              <div class="kid-nav__text">
                <span class="kid-nav__label">Previous</span>
                <span class="kid-nav__name">{prevKid.name}</span>
              </div>
            </a>
          ) : <div />}
          <a href="/kids/" class="kid-nav__all" aria-label="View all kids">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 12h18"/><path d="M12 3v18"/></svg>
            All Kids
          </a>
          {nextKid ? (
            <a href={`/kids/${nextKid.slug}/`} class="kid-nav__link kid-nav__link--next">
              <div class="kid-nav__text" style="text-align: right;">
                <span class="kid-nav__label">Next</span>
                <span class="kid-nav__name">{nextKid.name}</span>
              </div>
              {nextKid.heroImage && (
                <img
                  src={cfUrl(nextKid.heroImage, 'w=80,h=80,fit=cover,gravity=face,q=80')}
                  alt=""
                  class="kid-nav__thumb"
                  loading="lazy"
                  decoding="async"
                  width="40"
                  height="40"
                />
              )}
            </a>
          ) : <div />}
        </div>
      </div>
    </nav>

    <!-- ═══ CTA ═══════════════════════════ -->
    <section class="cta stagger-section">
      <div class="cta__watermark" aria-hidden="true">Sunshine</div>
      <div class="container container--narrow" style="text-align: center;">
        <h2 class="cta__title">Help kids like {kid.name}</h2>
        <p class="cta__text">Every donation helps transform a child's living space into a place of comfort, safety, and joy.</p>
        <div class="cta__buttons">
          <Button href="/donate/" variant="primary">Donate Now</Button>
          <Button href="/about/" variant="outline">About Our Mission</Button>
        </div>
      </div>
    </section>
  </article>

  <!-- ═══ Lightbox ══════════════════════════ -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer" hidden>
    <div class="lightbox__backdrop" data-close aria-hidden="true"></div>
    <button class="lightbox__close" data-close aria-label="Close photo viewer">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>
    <button class="lightbox__nav lightbox__nav--prev" id="lb-prev" aria-label="Previous photo">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </button>
    <button class="lightbox__nav lightbox__nav--next" id="lb-next" aria-label="Next photo">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>
    <div class="lightbox__stage" id="lb-stage">
      <div class="lightbox__frame" id="lb-frame">
        <img class="lightbox__placeholder" id="lb-placeholder" src="" alt="" aria-hidden="true" />
        <img class="lightbox__img" id="lb-img" src="" alt="" tabindex="0" />
        <div class="lightbox__loader" id="lb-loader" aria-hidden="true">
          <div class="lightbox__loader-ring"></div>
        </div>
      </div>
      <p class="lightbox__counter" id="lb-counter" aria-live="polite"></p>
    </div>
  </div>
</BaseLayout>

<!-- ═══ Client-side JS ═══════════════════════ -->
<script>
  let _kidObserver: IntersectionObserver | null = null;
  let _staggerObserver: IntersectionObserver | null = null;

  function cleanupKidPage() {
    _kidObserver?.disconnect();
    _kidObserver = null;
    _staggerObserver?.disconnect();
    _staggerObserver = null;
  }

  function initKidPage() {
    cleanupKidPage();

    // ── Staggered hero reveals ────────────────
    // astro:page-load fires AFTER the view transition morph finishes,
    // so no artificial delay needed — just cascade immediately.

    const heroStaggers = document.querySelectorAll('.hero .stagger');
    heroStaggers.forEach((el, i) => {
      const htmlEl = el as HTMLElement;
      htmlEl.style.setProperty('--stagger-delay', `${i * 50}ms`);
      requestAnimationFrame(() => htmlEl.classList.add('stagger--visible'));
    });

    // ── Staggered section reveals ─────────────
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      _staggerObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const section = entry.target as HTMLElement;
              section.classList.add('stagger-section--visible');
              _staggerObserver?.unobserve(section);
            }
          });
        },
        { rootMargin: '40px', threshold: 0.08 }
      );
      document.querySelectorAll('.stagger-section').forEach(el => {
        _staggerObserver!.observe(el);
      });
    } else {
      // Reduced motion: just show everything
      document.querySelectorAll('.stagger-section').forEach(el => {
        el.classList.add('stagger-section--visible');
      });
    }

    // Scroll progress is now pure CSS (animation-timeline: scroll())
    // JS fallback for browsers that don't support it yet
    const progressBar = document.querySelector('.scroll-progress') as HTMLElement;
    if (progressBar && !CSS.supports('animation-timeline', 'scroll()')) {
      const updateProgress = () => {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? Math.min(scrollTop / docHeight, 1) : 0;
        progressBar.style.transform = `scaleX(${progress})`;
      };
      progressBar.style.animation = 'none';
      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    }

    // ── YouTube facade ──────────────────────
    const facade = document.getElementById('yt-facade');
    if (facade) {
      const activate = () => {
        const id = facade.dataset.id;
        const wrapper = document.createElement('div');
        wrapper.style.cssText = 'position:relative;aspect-ratio:16/9;border-radius:var(--border-radius-lg);overflow:hidden';
        const iframe = document.createElement('iframe');
        iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
        iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
        iframe.allowFullscreen = true;
        iframe.title = 'Video player';
        iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0';
        wrapper.appendChild(iframe);
        facade.replaceWith(wrapper);
      };
      facade.addEventListener('click', activate);
      facade.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(); }
      });
    }

    // ── Cloudflare Stream facade ────────────
    const streamFacade = document.getElementById('stream-facade');
    if (streamFacade) {
      const activateStream = () => {
        const id = streamFacade.dataset.id;
        const wrapper = document.createElement('div');
        wrapper.style.cssText = 'position:relative;aspect-ratio:16/9;border-radius:var(--border-radius-lg);overflow:hidden';
        const iframe = document.createElement('iframe');
        iframe.src = `https://iframe.videodelivery.net/${id}?autoplay=true&preload=true`;
        iframe.allow = 'accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture';
        iframe.allowFullscreen = true;
        iframe.title = 'Video player';
        iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0';
        wrapper.appendChild(iframe);
        streamFacade.replaceWith(wrapper);
      };
      streamFacade.addEventListener('click', activateStream);
      streamFacade.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activateStream(); }
      });
    }

    // ══════════════════════════════════════════════════
    // ── Lightbox — top 1% gallery engine ─────────────
    // ══════════════════════════════════════════════════
    //
    //  SPEED:  LQIP data-URI → thumbnail promotion → in-memory bitmap cache
    //          → img.decode() off-thread → predictive preload (±3, hover, idle)
    //          → connection-aware radius → navGeneration stale-frame guard
    //  MOTION: directional translateX slide → smooth open/close with backdrop
    //          → loading ring after 180ms → GPU compositing only
    //          → prefers-reduced-motion respected
    //
    const lightbox = document.getElementById('lightbox') as HTMLElement;
    const lbImg = document.getElementById('lb-img') as HTMLImageElement;
    const lbPlaceholder = document.getElementById('lb-placeholder') as HTMLImageElement;
    const lbFrame = document.getElementById('lb-frame') as HTMLElement;
    const lbLoader = document.getElementById('lb-loader') as HTMLElement;
    const lbCounter = document.getElementById('lb-counter') as HTMLElement;
    const lbPrev = document.getElementById('lb-prev') as HTMLButtonElement;
    const lbNext = document.getElementById('lb-next') as HTMLButtonElement;
    const galleryItems = document.querySelectorAll<HTMLButtonElement>('.masonry__item');

    if (lightbox && galleryItems.length > 0) {
      let currentIndex = 0;
      let previousFocus: HTMLElement | null = null;
      let navGeneration = 0;
      let loaderTimer = 0;

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ── Image cache ────────────────────────
      const cache = new Map<number, { img: HTMLImageElement; decoded: boolean; promise: Promise<HTMLImageElement> }>();

      function ensureCached(index: number): { img: HTMLImageElement; decoded: boolean; promise: Promise<HTMLImageElement> } {
        if (cache.has(index)) return cache.get(index)!;
        const item = galleryItems[index];
        if (!item) {
          const dummy = new Image();
          return { img: dummy, decoded: false, promise: Promise.resolve(dummy) };
        }
        const img = new Image();
        img.srcset = item.dataset.srcset || '';
        img.sizes = '90vw';
        img.src = item.dataset.src || '';
        const entry = {
          img,
          decoded: false,
          promise: (img.decode
            ? img.decode().then(() => { entry.decoded = true; return img; }).catch(() => { entry.decoded = true; return img; })
            : new Promise<HTMLImageElement>(r => { img.onload = img.onerror = () => { entry.decoded = true; r(img); }; })
          ),
        };
        cache.set(index, entry);
        return entry;
      }

      // ── Preload logic ─────────────────────
      function getPreloadRadius(): number {
        const conn = (navigator as any).connection;
        if (!conn) return 3;
        const et = conn.effectiveType;
        if (et === '4g') return 3;
        if (et === '3g') return 1;
        return 0;
      }

      function preloadNeighbours(center: number) {
        const r = getPreloadRadius();
        for (let d = 1; d <= r; d++) {
          if (center + d < galleryItems.length) ensureCached(center + d);
          if (center - d >= 0) ensureCached(center - d);
        }
      }

      let idlePreloadStarted = false;
      function startIdlePreload() {
        if (idlePreloadStarted) return;
        idlePreloadStarted = true;
        const ric = (window as any).requestIdleCallback || ((cb: Function) => setTimeout(cb, 200));
        let nextIdx = 0;
        function step(deadline?: { timeRemaining: () => number }) {
          const budget = deadline ? deadline.timeRemaining() : 16;
          while (nextIdx < galleryItems.length && budget > 2) {
            ensureCached(nextIdx);
            nextIdx++;
            if (nextIdx % 4 === 0) break;
          }
          if (nextIdx < galleryItems.length) ric(step);
        }
        ric(step);
      }

      // ── Loading indicator ──────────────────
      function showLoader() {
        clearTimeout(loaderTimer);
        lbLoader.classList.remove('lightbox__loader--visible');
        loaderTimer = window.setTimeout(() => {
          lbLoader.classList.add('lightbox__loader--visible');
        }, 180);
      }
      function hideLoader() {
        clearTimeout(loaderTimer);
        lbLoader.classList.remove('lightbox__loader--visible');
      }

      // ── Directional slide (Web Animations API) ──
      function slideFrame(direction: number) {
        if (prefersReducedMotion || direction === 0) return;
        lbFrame.getAnimations().forEach(a => a.cancel());
        const dist = direction > 0 ? 40 : -40;
        lbFrame.animate([
          { transform: `translateX(${dist}px)`, opacity: 0.7 },
          { transform: 'translateX(0)', opacity: 1 },
        ], {
          duration: 180,
          easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
          fill: 'none',
        });
      }

      // ── Show photo ─────────────────────────
      function showPhoto(index: number, direction: number = 0) {
        const item = galleryItems[index];
        if (!item) return;
        currentIndex = index;
        const gen = ++navGeneration;
        const alt = item.dataset.alt || '';

        slideFrame(direction);

        // 1) Placeholder: LQIP → thumbnail (progressive, both instant)
        const lqipUrl = item.style.getPropertyValue('--lqip');
        const lqipMatch = lqipUrl.match(/url\(['"]?([^'"]+)['"]?\)/);
        if (lqipMatch) lbPlaceholder.src = lqipMatch[1];
        const thumbImg = item.querySelector('img') as HTMLImageElement | null;
        if (thumbImg && thumbImg.currentSrc) lbPlaceholder.src = thumbImg.currentSrc;
        lbPlaceholder.alt = alt;
        lbPlaceholder.style.opacity = '1';

        // 2) Full-res from cache
        const entry = ensureCached(index);

        if (entry.decoded && entry.img.complete && entry.img.naturalWidth > 0) {
          hideLoader();
          lbImg.srcset = entry.img.srcset;
          lbImg.sizes = '90vw';
          lbImg.src = entry.img.src;
          lbImg.alt = alt;
          lbImg.style.opacity = '1';
          lbPlaceholder.style.opacity = '0';
        } else {
          lbImg.style.opacity = '0';
          showLoader();
          entry.promise.then((img) => {
            if (navGeneration !== gen) return;
            hideLoader();
            lbImg.srcset = img.srcset;
            lbImg.sizes = '90vw';
            lbImg.src = img.src;
            lbImg.alt = alt;
            const ready = lbImg.decode ? lbImg.decode().catch(() => {}) : Promise.resolve();
            ready.then(() => {
              if (navGeneration !== gen) return;
              lbImg.style.opacity = '1';
              lbPlaceholder.style.opacity = '0';
            });
          });
        }

        lbCounter.textContent = `${index + 1} / ${galleryItems.length}`;
        lbPrev.style.visibility = index === 0 ? 'hidden' : '';
        lbPrev.style.pointerEvents = index === 0 ? 'none' : '';
        lbNext.style.visibility = index === galleryItems.length - 1 ? 'hidden' : '';
        lbNext.style.pointerEvents = index === galleryItems.length - 1 ? 'none' : '';
        preloadNeighbours(index);
      }

      // ── Open / Close ───────────────────────
      function openLightbox(index: number) {
        previousFocus = document.activeElement as HTMLElement;
        showPhoto(index, 0);
        lightbox.hidden = false;
        document.body.style.overflow = 'hidden';
        if (!prefersReducedMotion) {
          lightbox.classList.remove('lightbox--open');
          // Double-rAF ensures the browser has painted the un-animated state first
          requestAnimationFrame(() => {
            requestAnimationFrame(() => lightbox.classList.add('lightbox--open'));
          });
        } else {
          lightbox.classList.add('lightbox--open');
        }
        lbImg.focus();
        startIdlePreload();
      }

      function closeLightbox() {
        hideLoader();
        if (!prefersReducedMotion) {
          lightbox.classList.remove('lightbox--open');
          const onDone = () => {
            lightbox.hidden = true;
            lightbox.removeEventListener('transitionend', onDone);
          };
          lightbox.addEventListener('transitionend', onDone);
          setTimeout(() => { lightbox.hidden = true; }, 300);
        } else {
          lightbox.classList.remove('lightbox--open');
          lightbox.hidden = true;
        }
        document.body.style.overflow = '';
        previousFocus?.focus();
      }

      // ── Focus trap ─────────────────────────
      function trapFocus(e: KeyboardEvent) {
        if (e.key !== 'Tab') return;
        const focusable = lightbox.querySelectorAll<HTMLElement>(
          'button:not([hidden]), [tabindex="0"]'
        );
        const list = Array.from(focusable).filter(el =>
          el.offsetParent !== null && getComputedStyle(el).visibility !== 'hidden'
        );
        if (list.length === 0) return;
        const first = list[0];
        const last = list[list.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }

      // ── Navigation helpers ─────────────────
      function goNext() { if (currentIndex < galleryItems.length - 1) showPhoto(currentIndex + 1, 1); }
      function goPrev() { if (currentIndex > 0) showPhoto(currentIndex - 1, -1); }

      // ── Event wiring ───────────────────────
      galleryItems.forEach((item, i) => {
        item.addEventListener('click', () => openLightbox(i));
        item.addEventListener('pointerenter', () => ensureCached(i), { passive: true });
      });

      const galleryEl = document.getElementById('gallery');
      if (galleryEl) {
        galleryEl.addEventListener('pointerenter', () => {
          for (let i = 0; i < Math.min(5, galleryItems.length); i++) ensureCached(i);
        }, { once: true, passive: true });
      }

      lbPrev.addEventListener('click', goPrev);
      lbNext.addEventListener('click', goNext);

      lightbox.querySelectorAll('[data-close]').forEach(el => {
        el.addEventListener('click', closeLightbox);
      });

      lightbox.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') goPrev();
        if (e.key === 'ArrowRight') goNext();
        trapFocus(e);
      });

      // ── Touch / swipe ──────────────────────
      let touchStartX = 0;
      let touchStartY = 0;
      lightbox.addEventListener('touchstart', (e: TouchEvent) => {
        touchStartX = e.changedTouches[0].screenX;
        touchStartY = e.changedTouches[0].screenY;
      }, { passive: true });

      lightbox.addEventListener('touchend', (e: TouchEvent) => {
        const dx = e.changedTouches[0].screenX - touchStartX;
        const dy = e.changedTouches[0].screenY - touchStartY;
        if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy) * 1.5) {
          if (dx < 0) goNext();
          if (dx > 0) goPrev();
        }
      }, { passive: true });
    }

    // ── Share button ───────────────────────
    const shareBtn = document.getElementById('share-btn');
    if (shareBtn) {
      shareBtn.addEventListener('click', async () => {
        const shareData = {
          title: document.title,
          url: window.location.href,
        };
        try {
          if (navigator.share) {
            await navigator.share(shareData);
          } else {
            await navigator.clipboard.writeText(shareData.url);
            shareBtn.classList.add('shared');
            shareBtn.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg> Copied!';
            setTimeout(() => {
              shareBtn.classList.remove('shared');
              shareBtn.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg> Share';
            }, 2000);
          }
        } catch { /* user cancelled share */ }
      });
    }

  } // end initKidPage

  document.addEventListener('astro:page-load', initKidPage);
  document.addEventListener('astro:before-swap', cleanupKidPage);
</script>

<style>
