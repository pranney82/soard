          <a href="/donate/" class="ev-btn ev-btn--outline-white">Donate Directly</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ STICKY MOBILE CTA ═══ -->
  <div class="ev-sticky-cta" aria-hidden="true">
    <a href="https://www.zeffy.com/en-US/ticketing/sunshine-on-a-ranney-fairway--2026" target="_blank" rel="noopener" class="ev-sticky-cta__btn">
