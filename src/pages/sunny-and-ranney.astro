---
/**
 * Sunny & Ranney — Store Landing
 *
 * Mirrors sunnyandranney.com's contained layout:
 *   - Max-width container (1280px), never full-bleed images
 *   - Rounded corners (12–20px) on all images
 *   - Teal (#2b7a96) hero section with contained split layout
 *   - Warm cream/white backgrounds, charcoal dark sections
 *   - Pill-style CTAs, restrained type
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { CF_BASE as CF } from '../utils/cf-image';
import { getSiteStats } from '../utils/stats';
import siteSettings from '../content/site/settings.json';
const s = await getSiteStats();

const store = 'about/sunny-ranney-storefront';
const logo = 'logo-tagline-cyan-bg';
const founders = 'about/founders-reunion-2026';

const rooms = (siteSettings as any).sunnyAndRanneyRooms || [
  { cfId: 'kids/griffin/hero', label: 'Dream Bedroom' },
  { cfId: 'kids/jackson/hero', label: 'Therapy Room' },
  { cfId: 'kids/madison/hero', label: 'Sensory Space' },
];

const desc = 'Sunny & Ranney is a nonprofit home furnishings store in Roswell, GA — designer furniture, décor & gifts with 100% of profits building dream rooms for children with special needs.';
---

<BaseLayout title="Sunny & Ranney" description={desc} breadcrumbs={[{name:'Home',url:'https://sunshineonaranneyday.com/'},{name:'Sunny & Ranney',url:'https://sunshineonaranneyday.com/sunny-and-ranney/'}]}>

<div class="sr">

  <!-- ═══ HERO ═══ -->
  <section class="sr-hero">
    <div class="sr-hero-inner">
      <div class="sr-hero-text">
        <img src={`${CF}/${logo}/w=500,q=90`} alt="Sunny & Ranney" class="sr-hero-logo" width="260" height="70" loading="eager" />
        <p class="sr-hero-lead">A nonprofit home furnishings store where <strong>100% of profits</strong> build dream rooms for children with special needs.</p>
        <div class="sr-hero-ctas">
          <a href="https://sunnyandranney.com" target="_blank" rel="noopener noreferrer" class="sr-cta sr-cta--gold">Shop Online</a>
          <a href="#visit" class="sr-cta sr-cta--glass">Visit Us</a>
        </div>
        <div class="sr-hero-trust">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#FFD400"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <span>5.0 on Google · 117 reviews</span>
        </div>
      </div>
      <div class="sr-hero-media">
        <img
          src={`${CF}/${store}/w=800,h=1000,fit=cover,q=75`}
          srcset={`${CF}/${store}/w=500,h=625,fit=cover,q=70 500w, ${CF}/${store}/w=800,h=1000,fit=cover,q=75 800w`}
          sizes="(max-width:768px) 85vw, 440px"
          alt="Inside the Sunny & Ranney showroom"
          width="800" height="1000"
          loading="eager" fetchpriority="high" decoding="async"
          class="sr-hero-img"
        />
      </div>
    </div>
  </section>

  <!-- ═══ PROMISE ═══ -->
  <section class="sr-promise">
    <div class="sr-container">
      <div class="sr-promise-grid" data-reveal>
        <div class="sr-promise-item">
          <h3>100% of Profits</h3>
          <p>Every dollar funds dream rooms for children with special needs.</p>
        </div>
        <div class="sr-promise-div"></div>
        <div class="sr-promise-item">
          <h3>Designer Curated</h3>
          <p>All brand-new furniture, décor, and gifts — hand-selected by our team.</p>
        </div>
        <div class="sr-promise-div"></div>
        <div class="sr-promise-item">
          <h3>Shop with Purpose</h3>
          <p>Every piece you take home helps build a child's dream space.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ OUR STORY ═══ -->
  <section class="sr-story" aria-labelledby="sr-story-h">
    <div class="sr-container">
      <div class="sr-story-inner">
        <div class="sr-story-text" data-reveal>
          <span class="sr-label">Our Story</span>
          <h2 id="sr-story-h">A bold idea to sustain the mission.</h2>
          <p>In 2020, Peter and Holly Ranney opened Sunny &amp; Ranney in Roswell, Georgia — a real home furnishings store with designer pieces at prices people love. The goal: <em>create a self-sustaining engine for the nonprofit, working alongside generous donors and other fundraisers.</em></p>
          <p>Every dollar of profit goes directly to building rooms for kids. What started as a bold idea became a powerful complement to the mission — <strong>funding room makeovers every single day.</strong></p>
          <a href="/about/" class="sr-text-link">Read our full story →</a>
        </div>
        <figure class="sr-story-fig" data-reveal data-delay="1">
          <img
            src={`${CF}/${founders}/w=600,h=450,fit=cover,gravity=face,q=75`}
            srcset={`${CF}/${founders}/w=400,h=300,fit=cover,gravity=face,q=70 400w, ${CF}/${founders}/w=600,h=450,fit=cover,gravity=face,q=75 600w`}
            sizes="(max-width:768px) 90vw, 48%"
            alt="Peter and Holly Ranney, founders"
            width="600" height="450" loading="lazy" decoding="async"
          />
          <figcaption>Peter & Holly Ranney, founders</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ═══ WHAT WE CARRY ═══ -->
  <section class="sr-carry">
    <div class="sr-container">
      <div class="sr-carry-top">
        <div class="sr-carry-header" data-reveal>
          <span class="sr-label">What We Carry</span>
          <h2>Designer pieces, all brand-new, all for a cause.</h2>
          <p>Hand-selected by our design team — beautiful things that look amazing in your home and feel even better knowing their purpose.</p>
        </div>
        <div class="sr-carry-categories" data-reveal data-delay="1">
          <a href="https://sunnyandranney.com/shop/?collection=living" target="_blank" rel="noopener noreferrer" class="sr-cat">
            <span class="sr-cat-name">Living</span>
            <span class="sr-cat-arrow">→</span>
          </a>
          <a href="https://sunnyandranney.com/shop/?collection=dining" target="_blank" rel="noopener noreferrer" class="sr-cat">
            <span class="sr-cat-name">Dining</span>
            <span class="sr-cat-arrow">→</span>
          </a>
          <a href="https://sunnyandranney.com/shop/?collection=bedroom" target="_blank" rel="noopener noreferrer" class="sr-cat">
            <span class="sr-cat-name">Bedroom</span>
            <span class="sr-cat-arrow">→</span>
          </a>
          <a href="https://sunnyandranney.com/shop/?collection=art-mirrors" target="_blank" rel="noopener noreferrer" class="sr-cat">
            <span class="sr-cat-name">Art & Mirrors</span>
            <span class="sr-cat-arrow">→</span>
          </a>
          <a href="https://sunnyandranney.com/shop/?collection=rugs-collection" target="_blank" rel="noopener noreferrer" class="sr-cat">
            <span class="sr-cat-name">Rugs</span>
            <span class="sr-cat-arrow">→</span>
          </a>
          <a href="https://sunnyandranney.com/shop/?collection=outdoor" target="_blank" rel="noopener noreferrer" class="sr-cat">
            <span class="sr-cat-name">Outdoor</span>
            <span class="sr-cat-arrow">→</span>
          </a>
        </div>
      </div>
      <div class="sr-carry-photos" data-reveal>
        <figure class="sr-carry-img sr-carry-img--wide">
          <img src={`${CF}/sunny-ranney-interior/w=900,h=500,fit=cover,q=75`} srcset={`${CF}/sunny-ranney-interior/w=600,h=333,fit=cover,q=70 600w, ${CF}/sunny-ranney-interior/w=900,h=500,fit=cover,q=75 900w`} sizes="(max-width:768px) 90vw, 62%" alt="Inside the Sunny & Ranney showroom" width="900" height="500" loading="lazy" decoding="async" />
        </figure>
        <figure class="sr-carry-img sr-carry-img--tall">
          <img src={`${CF}/showroom-editorial/w=500,h=500,fit=cover,q=75`} srcset={`${CF}/showroom-editorial/w=320,h=320,fit=cover,q=70 320w, ${CF}/showroom-editorial/w=500,h=500,fit=cover,q=75 500w`} sizes="(max-width:768px) 90vw, 34%" alt="Styled showroom vignette" width="500" height="500" loading="lazy" decoding="async" />
        </figure>
      </div>
    </div>
  </section>

  <!-- ═══ IMPACT ═══ -->
  <section class="sr-impact">
    <div class="sr-container">
      <div class="sr-impact-header" data-reveal>
        <span class="sr-label sr-label--light">The Impact</span>
        <h2>Your home gets a new piece.<br>A child gets a new <em>world</em>.</h2>
      </div>
      <div class="sr-impact-stats" data-reveal>
        <div class="sr-stat"><span class="sr-stat-val">100%</span><span class="sr-stat-label">of profits to kids</span></div>
        <div class="sr-stat"><span class="sr-stat-val">{s.totalRooms}+</span><span class="sr-stat-label">rooms built</span></div>
        <div class="sr-stat"><span class="sr-stat-val">{s.totalKids}+</span><span class="sr-stat-label">children served</span></div>
        <div class="sr-stat"><span class="sr-stat-val">{s.years}</span><span class="sr-stat-label">years of impact</span></div>
      </div>
      <div class="sr-impact-rooms" data-reveal>
        {rooms.map((r: any) => (
          <figure class="sr-room-card">
            <img src={`${CF}/${r.cfId}/w=500,h=400,fit=cover,q=70`} alt={r.label} width="500" height="400" loading="lazy" decoding="async" />
            <figcaption>{r.label}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TESTIMONIAL ═══ -->
  <section class="sr-review">
    <div class="sr-container">
      <div class="sr-review-inner" data-reveal>
        <div class="sr-review-stars">
          {[...Array(5)].map(() => (<svg width="18" height="18" viewBox="0 0 24 24" fill="#FFD400"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>))}
        </div>
        <blockquote>"I walked in expecting a charity shop. I walked out with the most beautiful console table I've ever owned — and the best feeling about a purchase I've ever had."</blockquote>
        <cite>— Verified Customer, Google Reviews</cite>
      </div>
    </div>
  </section>

  <!-- ═══ VISIT ═══ -->
  <section class="sr-visit" id="visit">
    <div class="sr-container">
      <div class="sr-visit-inner">
        <div class="sr-visit-gallery" data-reveal>
          <img
            src={`${CF}/sunny-ranney-interior/w=700,h=500,fit=cover,q=75`}
            srcset={`${CF}/sunny-ranney-interior/w=400,h=286,fit=cover,q=70 400w, ${CF}/sunny-ranney-interior/w=700,h=500,fit=cover,q=75 700w`}
            sizes="(max-width:768px) 90vw, 55%"
            alt="Inside the Sunny & Ranney showroom"
            width="700" height="500" loading="lazy" decoding="async"
            class="sr-visit-img-main"
          />
          <img
            src={`${CF}/${store}/w=320,h=320,fit=cover,q=70`}
            alt="Sunny & Ranney storefront"
            width="320" height="320" loading="lazy" decoding="async"
            class="sr-visit-img-inset"
          />
        </div>
        <div class="sr-visit-text" data-reveal data-delay="1">
          <span class="sr-label sr-label--light">Visit Us</span>
          <h2>Come see what shopping for a cause looks like.</h2>
          <address>
            <p>109A Oak Street<br>Roswell, GA 30075</p>
          </address>
          <div class="sr-visit-hours">
            <p>Tue – Thu · 10am – 5pm<br>Fri – Sat · 10am – 6pm</p>
          </div>
          <div class="sr-visit-contact">
            <p><a href="tel:7709902434">770.990.2434</a></p>
          </div>
          <div class="sr-visit-ctas">
            <a href="https://maps.google.com/?q=109A+Oak+Street+Roswell+GA+30075" target="_blank" rel="noopener noreferrer" class="sr-cta sr-cta--dark">Get Directions</a>
            <a href="https://sunnyandranney.com" target="_blank" rel="noopener noreferrer" class="sr-cta sr-cta--outline">Shop Online</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ EMAIL / FINAL CTA ═══ -->
  <section class="sr-final">
    <div class="sr-container">
      <div class="sr-final-card" data-reveal>
        <h2>Every beautiful piece builds a beautiful future.</h2>
        <p>Shop online or visit us in Roswell. Every purchase changes a child's world.</p>
        <div class="sr-final-ctas">
          <a href="https://sunnyandranney.com" target="_blank" rel="noopener noreferrer" class="sr-cta sr-cta--gold">Shop Sunny & Ranney</a>
          <a href="/donate/" class="sr-cta sr-cta--outline">Make a Donation</a>
        </div>
      </div>
    </div>
  </section>

</div>
</BaseLayout>

<style>
  /* ─── Store palette ─── */
  :root {
    --sr-teal: #2b7a96;
    --sr-cyan: #4B95B4;
    --sr-gold: #FFD400;
    --sr-cream: #FAF7F2;
    --sr-warm: #FDFCFA;
    --sr-charcoal: #2C2C2C;
  }

  .sr { background: var(--sr-cream); }

  .sr-container {
    max-width: 1280px;
    margin: 0 auto;
    padding-inline: clamp(1rem, 4vw, 2.5rem);
  }

  /* ─── Shared elements ─── */
  .sr-label {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--sr-teal);
    margin-bottom: 16px;
  }

  .sr-label--light { color: rgba(255, 255, 255, 0.5); }

  .sr-text-link {
    display: inline-block;
    font-size: 14px;
    font-weight: 600;
    color: var(--sr-teal);
    text-decoration: none;
    margin-top: 8px;
    transition: letter-spacing 0.3s ease;
  }

  .sr-text-link:hover { letter-spacing: 0.03em; }

  /* CTA buttons */
  .sr-cta {
    display: inline-flex;
    align-items: center;
    padding: 14px 28px;
    font-size: 14px;
    font-weight: 600;
    border-radius: 100px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .sr-cta--gold {
    background: var(--sr-gold);
    color: var(--sr-charcoal);
  }
  .sr-cta--gold:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(255, 212, 0, 0.35);
  }

  .sr-cta--glass {
    background: rgba(0, 0, 0, 0.45);
    color: #fff;
    border: 1.5px solid rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .sr-cta--glass:hover {
    background: rgba(0, 0, 0, 0.55);
    border-color: rgba(255, 255, 255, 0.5);
    transform: translateY(-2px);
  }

  .sr-cta--dark {
    background: var(--sr-charcoal);
    color: #fff;
  }
  .sr-cta--dark:hover {
    background: #3a3a3a;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
  }

  .sr-cta--outline {
    background: transparent;
    color: #fff;
    border: 1.5px solid rgba(255, 255, 255, 0.3);
  }
  .sr-cta--outline:hover {
    border-color: #fff;
    transform: translateY(-2px);
  }

  .sr-cta--outline-dark {
    background: transparent;
    color: var(--sr-charcoal);
    border: 1.5px solid rgba(44, 44, 44, 0.25);
  }
  .sr-cta--outline-dark:hover {
    border-color: var(--sr-charcoal);
    transform: translateY(-2px);
  }

  /* ══════════════════════════════
     HERO
     ══════════════════════════════ */
  .sr-hero {
    background: var(--sr-teal);
    padding: clamp(2rem, 5vh, 3rem) 0 0;
  }

  .sr-hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 2.5rem);
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(32px, 5vw, 64px);
    align-items: end;
  }

  .sr-hero-text {
    padding-bottom: clamp(2rem, 5vh, 4rem);
  }

  .sr-hero-logo {
    width: clamp(180px, 22vw, 260px);
    height: auto;
    margin-bottom: 24px;
  }

  .sr-hero-lead {
    font-size: clamp(16px, 1.8vw, 20px);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.95);
    max-width: 420px;
    margin-bottom: 28px;
  }

  .sr-hero-lead strong {
    color: #fff;
    font-weight: 700;
  }

  .sr-hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .sr-hero-trust {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.93);
  }

  .sr-hero-media {
    display: flex;
    justify-content: flex-end;
  }

  .sr-hero-img {
    width: 100%;
    max-width: 440px;
    height: auto;
    border-radius: 20px 20px 0 0;
    display: block;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  /* ══════════════════════════════
     PROMISE
     ══════════════════════════════ */
  .sr-promise {
    padding: clamp(3rem, 6vh, 5rem) 0;
    background: var(--sr-warm);
  }

  .sr-promise-grid {
    display: flex;
    align-items: flex-start;
    gap: 0;
  }

  .sr-promise-item {
    flex: 1;
    text-align: center;
    padding: 0 clamp(16px, 3vw, 32px);
  }

  .sr-promise-item h3 {
    font-size: 16px;
    margin-bottom: 8px;
  }

  .sr-promise-item p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--c-text-muted);
  }

  .sr-promise-div {
    width: 1px;
    height: 56px;
    background: var(--c-border);
    flex-shrink: 0;
    align-self: center;
  }

  /* ══════════════════════════════
     STORY
     ══════════════════════════════ */
  .sr-story {
    padding: clamp(4rem, 8vh, 7rem) 0;
    background: var(--sr-cream);
  }

  .sr-story-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 5vw, 80px);
    align-items: center;
  }

  .sr-story-text h2 {
    font-size: clamp(24px, 3vw, 36px);
    line-height: 1.25;
    margin-bottom: 20px;
  }

  .sr-story-text p {
    font-size: 16px;
    line-height: 1.75;
    color: var(--c-text-muted);
    margin-bottom: 16px;
  }

  .sr-story-text p em { font-style: italic; color: var(--c-dark); }
  .sr-story-text p strong { color: var(--c-dark); }

  .sr-story-fig {
    margin: 0;
  }

  .sr-story-fig img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 12px;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .sr-story-fig figcaption {
    margin-top: 12px;
    font-size: 12px;
    color: var(--c-text-light);
  }

  /* ══════════════════════════════
     WHAT WE CARRY
     ══════════════════════════════ */
  .sr-carry {
    padding: clamp(4rem, 8vh, 7rem) 0;
    background: var(--sr-warm);
  }

  .sr-carry-top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 5vw, 80px);
    align-items: start;
    margin-bottom: clamp(32px, 4vh, 48px);
  }

  .sr-carry-header h2 {
    font-size: clamp(24px, 3vw, 36px);
    line-height: 1.25;
    margin-bottom: 16px;
  }

  .sr-carry-header p {
    font-size: 16px;
    line-height: 1.7;
    color: var(--c-text-muted);
  }

  .sr-carry-categories {
    display: flex;
    flex-direction: column;
  }

  .sr-cat {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 0;
    border-bottom: 1px solid var(--c-border);
    text-decoration: none;
    color: inherit;
    transition: padding-left 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .sr-cat:first-child {
    border-top: 1px solid var(--c-border);
  }

  .sr-cat:hover {
    padding-left: 12px;
  }

  .sr-cat-name {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--c-dark);
  }

  .sr-cat-arrow {
    font-size: 16px;
    color: var(--c-text-light);
    transition: color 0.2s ease, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .sr-cat:hover .sr-cat-arrow {
    color: var(--sr-teal);
    transform: translateX(4px);
  }

  /* Photos row */
  .sr-carry-photos {
    display: grid;
    grid-template-columns: 1.8fr 1fr;
    gap: 20px;
  }

  .sr-carry-img {
    margin: 0;
    border-radius: 12px;
    overflow: hidden;
  }

  .sr-carry-img img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .sr-carry-img:hover img {
    transform: scale(1.03);
  }

  .sr-carry-img--wide img {
    aspect-ratio: 16 / 9;
  }

  .sr-carry-img--tall img {
    aspect-ratio: 1;
  }

  /* ══════════════════════════════
     IMPACT
     ══════════════════════════════ */
  .sr-impact {
    padding: clamp(4rem, 8vh, 7rem) 0;
    background: var(--sr-charcoal);
    color: #fff;
  }

  .sr-impact-header {
    text-align: center;
    max-width: 560px;
    margin: 0 auto clamp(40px, 6vh, 64px);
  }

  .sr-impact-header h2 {
    font-size: clamp(24px, 3.5vw, 40px);
    color: #fff;
    line-height: 1.25;
  }

  .sr-impact-header h2 em {
    font-style: italic;
    color: var(--sr-cyan);
  }

  .sr-impact-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
