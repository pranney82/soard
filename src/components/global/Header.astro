---
/**
 * Header.astro — Best-in-class navigation
 *
 * Accessibility:
 *   - Skip-to-content link (first focusable element)
 *   - Focus trap: Tab cycles within open mobile menu only
 *   - Full arrow-key keyboard nav on desktop dropdowns (WAI-ARIA menubar pattern)
 *   - inert: page content behind menu is inert when open
 *   - aria-expanded, aria-controls, aria-label, aria-hidden
 *   - Escape key closes menu / dropdown
 *   - prefers-reduced-motion: instant transitions
 *   - 44px+ touch targets on every interactive element
 *   - External links visually indicated + target="_blank"
 *   - Parent nav items show active state for child pages
 *
 * UX:
 *   - Hide-on-scroll-down / show-on-scroll-up (reclaims viewport)
 *   - Hover intent with grace delay on desktop dropdowns (safe triangle)
 *   - Swipe right-to-left to close mobile panel (touch gesture)
 *   - Tap overlay to close
 *   - iOS-safe scroll lock (position: fixed + scroll offset preservation)
 *   - overscroll-behavior: contain (no scroll chaining)
 *   - Auto-close on resize past mobile breakpoint
 *   - Nav link click closes menu before navigation
 *   - Enhanced Donate CTA with subtle glow pulse
 *
 * Performance:
 *   - ~120 lines of vanilla JS, no framework
 *   - All transitions on transform/opacity only (GPU composited)
 *   - will-change: transform on panel + header
 *   - Passive touch/scroll listeners
 */
const currentPath = Astro.url.pathname;

interface NavChild {
  label: string;
  href: string;
  external?: boolean;
}

interface NavGroup {
  label: string;
  children: NavChild[];
}

const nav: NavGroup[] = [
  {
    label: 'About',
    children: [
      { label: 'Our Story', href: '/about/' },
      { label: 'Leadership', href: '/about/leadership/' },
      { label: 'Financials', href: '/about/financials/' },
    ],
  },
  {
    label: 'Kids & Projects',
    children: [
      { label: 'Featured Rooms', href: '/rooms/' },
      { label: 'Meet the Kids', href: '/kids/' },
      { label: 'Community Projects', href: '/rooms/community/' },
    ],
  },
  {
    label: 'Our Partners',
    children: [
      { label: 'Our Partners', href: '/partners/' },
      { label: 'Construction Partners', href: '/partners/construction/' },
      { label: 'Design Partners', href: '/partners/design/' },
    ],
  },
  {
    label: 'Get Involved',
    children: [
      { label: 'Events', href: 'https://www.sunnyandranney.com/events', external: true },
      { label: 'Donate', href: '/donate/' },
      { label: '2026 Application', href: '/apply/' },
    ],
  },
  {
    label: 'Shop Our Stores',
    children: [
      { label: 'Sunny & Ranney', href: 'https://www.sunnyandranney.com', external: true },
      { label: 'Partly Sunny', href: 'https://partlysunnystore.com', external: true },
    ],
  },
];

function isActive(href: string) {
  if (href.startsWith('http')) return false;
  return currentPath === href;
}

/** Check if any child in a nav group is active */
function isGroupActive(group: NavGroup) {
  return group.children.some((child) => isActive(child.href));
}
---

<!-- Skip Navigation Link (first focusable element on page) -->
<a href="#main-content" class="skip-nav">Skip to main content</a>

<header class="site-header" id="site-header">
  <div class="header-inner container--wide">
    <!-- Logo -->
    <a href="/" class="logo" aria-label="Sunshine on a Ranney Day — Home">
      <img
        src="/images/logos/sunny-pig-transparent.png"
        alt=""
        class="logo-icon"
        width="88"
        height="40"
        loading="eager"
      />
      <span class="logo-text">Sunshine on a<br/>Ranney Day</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="desktop-nav" aria-label="Main navigation">
      <ul class="nav-list" role="menubar">
        {nav.map((item, groupIndex) => (
          <li
            class:list={['nav-item', 'has-dropdown', { 'group-active': isGroupActive(item) }]}
            role="none"
            data-nav-group={groupIndex}
          >
            <button
              class:list={['nav-link', { 'parent-active': isGroupActive(item) }]}
              role="menuitem"
              aria-haspopup="true"
              aria-expanded="false"
              tabindex={groupIndex === 0 ? '0' : '-1'}
            >
              {item.label}
              <svg class="chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <ul class="dropdown" role="menu" id={`dropdown-${groupIndex}`}>
              {item.children.map((child, childIndex) => (
                <li role="none">
                  <a
                    href={child.href}
                    role="menuitem"
                    class:list={['dropdown-link', { active: isActive(child.href) }]}
                    tabindex="-1"
                    data-child-index={childIndex}
                    {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  >
                    {child.label}
                    {child.external && (
                      <svg class="external-icon" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                        <path d="M4.5 1.5H1.5V10.5H10.5V7.5M7 1.5H10.5M10.5 1.5V5M10.5 1.5L5.5 6.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Donate CTA (desktop) -->
    <a href="/donate/" class="header-cta">
      <svg class="header-cta-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Donate
    </a>

    <!-- Mobile hamburger — semantic <button> -->
    <button
      type="button"
      class="mobile-toggle"
      id="mobile-toggle-btn"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-nav-panel"
    >
      <span class="hamburger-line" aria-hidden="true"></span>
      <span class="hamburger-line" aria-hidden="true"></span>
      <span class="hamburger-line" aria-hidden="true"></span>
    </button>
  </div>

  <!-- Overlay -->
  <div class="mobile-overlay" id="mobile-overlay" aria-hidden="true"></div>

  <!-- Mobile slide-out panel -->
  <nav
    class="mobile-nav"
    id="mobile-nav-panel"
    role="dialog"
    aria-label="Mobile navigation"
    aria-modal="true"
    aria-hidden="true"
  >
    <!-- Mobile nav header: logo + close -->
    <div class="mobile-nav-header">
      <a href="/" class="mobile-nav-logo" aria-label="Sunshine on a Ranney Day — Home">
        <img
          src="/images/logos/logo-light-bg.webp"
          alt="Sunshine on a Ranney Day"
          width="140"
          height="52"
          loading="eager"
        />
      </a>
      <button
        type="button"
        class="mobile-close-btn"
        id="mobile-close-btn"
        aria-label="Close menu"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M15 5L5 15M5 5L15 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <!-- Scrollable nav body -->
    <div class="mobile-nav-body">
      <ul class="mobile-nav-list">
        {nav.map((item, i) => (
          <li class="mobile-nav-group" style={`--stagger: ${i}`}>
            <span class="mobile-nav-heading">{item.label}</span>
            <ul>
              {item.children.map((child) => (
                <li>
                  <a
                    href={child.href}
                    class:list={['mobile-nav-link', { active: isActive(child.href) }]}
                    {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  >
                    {child.label}
                    {child.external && (
                      <span class="mobile-external-badge" aria-label="Opens in new tab">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                          <path d="M4.5 1.5H1.5V10.5H10.5V7.5M7 1.5H10.5M10.5 1.5V5M10.5 1.5L5.5 6.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ul>
    </div>

    <!-- Sticky bottom CTA -->
    <div class="mobile-nav-footer">
      <a href="/donate/" class="mobile-donate-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="flex-shrink:0;">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Donate
      </a>
    </div>
  </nav>
</header>

<script>
  (function () {
    /* ═══════════════════════════════════════════
       MOBILE NAVIGATION
       ═══════════════════════════════════════════ */
    const btn = document.getElementById('mobile-toggle-btn');
    const panel = document.getElementById('mobile-nav-panel');
    const overlay = document.getElementById('mobile-overlay');
    const header = document.getElementById('site-header');
    const closeBtn = document.getElementById('mobile-close-btn');
    const main = document.querySelector('main');
    const footer = document.querySelector('footer');
    if (!btn || !panel || !overlay || !header) return;

    let isOpen = false;
    let savedScrollY = 0;

    function getFocusable() {
      return [closeBtn, ...panel.querySelectorAll('a, button:not(#mobile-close-btn), [tabindex]:not([tabindex="-1"])')];
    }

    function open() {
      isOpen = true;
      savedScrollY = window.scrollY;
      document.body.style.position = 'fixed';
      document.body.style.top = '-' + savedScrollY + 'px';
      document.body.style.left = '0';
      document.body.style.right = '0';
      document.body.style.overflow = 'hidden';

      btn.setAttribute('aria-expanded', 'true');
      btn.setAttribute('aria-label', 'Close menu');
      btn.classList.add('is-open');
      panel.classList.add('is-open');
      panel.setAttribute('aria-hidden', 'false');
      overlay.classList.add('is-open');

      if (main) main.setAttribute('inert', '');
      if (footer) footer.setAttribute('inert', '');
      if (closeBtn) closeBtn.focus();
    }

    function close() {
      isOpen = false;
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.left = '';
      document.body.style.right = '';
      document.body.style.overflow = '';
      window.scrollTo(0, savedScrollY);

      btn.setAttribute('aria-expanded', 'false');
      btn.setAttribute('aria-label', 'Open menu');
      btn.classList.remove('is-open');
      panel.classList.remove('is-open');
      panel.setAttribute('aria-hidden', 'true');
      overlay.classList.remove('is-open');

      if (main) main.removeAttribute('inert');
      if (footer) footer.removeAttribute('inert');
      btn.focus();
    }

    btn.addEventListener('click', function () { isOpen ? close() : open(); });
    if (closeBtn) closeBtn.addEventListener('click', close);
    overlay.addEventListener('click', close);

    document.addEventListener('keydown', function (e) {
      if (!isOpen) return;
      if (e.key === 'Escape') { close(); return; }
      if (e.key === 'Tab') {
        var focusable = getFocusable();
        var first = focusable[0];
        var last = focusable[focusable.length - 1];
        if (e.shiftKey) {
          if (document.activeElement === first) { e.preventDefault(); last.focus(); }
        } else {
          if (document.activeElement === last) { e.preventDefault(); first.focus(); }
        }
      }
    });

    window.matchMedia('(min-width: 1024px)').addEventListener('change', function (e) {
      if (e.matches && isOpen) close();
    });

    panel.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', close);
    });

    // Swipe-to-close
    var touchStartX = 0;
    var touchStartY = 0;
    var swiping = false;

    panel.addEventListener('touchstart', function (e) {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      swiping = true;
    }, { passive: true });

    panel.addEventListener('touchmove', function (e) {
      if (!swiping) return;
      var dx = e.touches[0].clientX - touchStartX;
      var dy = Math.abs(e.touches[0].clientY - touchStartY);
      if (dx > 60 && dy < 40) { swiping = false; close(); }
    }, { passive: true });

    panel.addEventListener('touchend', function () { swiping = false; }, { passive: true });

    /* ═══════════════════════════════════════════
       HIDE-ON-SCROLL-DOWN / SHOW-ON-SCROLL-UP
       ═══════════════════════════════════════════ */
    var lastScrollY = 0;
    var scrollTicking = false;
    var scrollThreshold = 8;

    function onScroll() {
      scrollTicking = false;
      var currentY = window.scrollY;
      var delta = currentY - lastScrollY;

      // Always show header at top of page
      if (currentY <= 10) {
        header.classList.remove('header--hidden');
        lastScrollY = currentY;
        return;
      }

      // Don't hide when mobile nav is open
      if (isOpen) { lastScrollY = currentY; return; }

      if (delta > scrollThreshold) {
        header.classList.add('header--hidden');
      } else if (delta < -scrollThreshold) {
        header.classList.remove('header--hidden');
      }

      lastScrollY = currentY;
    }

    window.addEventListener('scroll', function () {
      if (!scrollTicking) {
        requestAnimationFrame(onScroll);
        scrollTicking = true;
      }
    }, { passive: true });

    /* ═══════════════════════════════════════════
       DESKTOP DROPDOWN — KEYBOARD NAVIGATION
       (WAI-ARIA Menubar pattern: Arrow keys)
       ═══════════════════════════════════════════ */
    var navItems = document.querySelectorAll('.nav-item[data-nav-group]');
    var navButtons = document.querySelectorAll('.nav-item .nav-link');

    function openDropdown(groupEl) {
      var button = groupEl.querySelector('.nav-link');
      var dropdown = groupEl.querySelector('.dropdown');
      if (!button || !dropdown) return;
      button.setAttribute('aria-expanded', 'true');
      groupEl.classList.add('dropdown-open');
    }

    function closeDropdown(groupEl) {
      var button = groupEl.querySelector('.nav-link');
      if (!button) return;
      button.setAttribute('aria-expanded', 'false');
      groupEl.classList.remove('dropdown-open');
    }

    function closeAllDropdowns() {
      navItems.forEach(function (item) { closeDropdown(item); });
    }

    function getDropdownLinks(groupEl) {
      return Array.from(groupEl.querySelectorAll('.dropdown-link'));
    }

    // Keyboard handling on the menubar
    var navList = document.querySelector('.nav-list');
    if (navList) {
      navList.addEventListener('keydown', function (e) {
        var target = e.target;
        var isButton = target.classList.contains('nav-link');
        var isDropdownLink = target.classList.contains('dropdown-link');
        var parentGroup = target.closest('.nav-item[data-nav-group]');
        if (!parentGroup) return;

        var groupIndex = parseInt(parentGroup.dataset.navGroup);

        if (isButton) {
          switch (e.key) {
            case 'ArrowRight': {
              e.preventDefault();
              closeAllDropdowns();
              var next = navItems[(groupIndex + 1) % navItems.length];
              var nextBtn = next.querySelector('.nav-link');
              navButtons.forEach(function (b) { b.setAttribute('tabindex', '-1'); });
              nextBtn.setAttribute('tabindex', '0');
              nextBtn.focus();
              break;
            }
            case 'ArrowLeft': {
              e.preventDefault();
              closeAllDropdowns();
              var prev = navItems[(groupIndex - 1 + navItems.length) % navItems.length];
              var prevBtn = prev.querySelector('.nav-link');
              navButtons.forEach(function (b) { b.setAttribute('tabindex', '-1'); });
              prevBtn.setAttribute('tabindex', '0');
              prevBtn.focus();
              break;
            }
            case 'ArrowDown':
            case 'Enter':
            case ' ': {
              e.preventDefault();
              openDropdown(parentGroup);
              var links = getDropdownLinks(parentGroup);
              if (links.length) links[0].focus();
              break;
            }
            case 'Escape': {
              e.preventDefault();
              closeAllDropdowns();
              target.focus();
              break;
            }
          }
        } else if (isDropdownLink) {
          var links = getDropdownLinks(parentGroup);
          var idx = links.indexOf(target);

          switch (e.key) {
            case 'ArrowDown': {
              e.preventDefault();
              var nextLink = links[(idx + 1) % links.length];
              nextLink.focus();
              break;
            }
            case 'ArrowUp': {
              e.preventDefault();
              if (idx === 0) {
                closeDropdown(parentGroup);
                parentGroup.querySelector('.nav-link').focus();
              } else {
                links[idx - 1].focus();
              }
              break;
            }
            case 'ArrowRight': {
              e.preventDefault();
              closeDropdown(parentGroup);
              var nextGroup = navItems[(groupIndex + 1) % navItems.length];
              openDropdown(nextGroup);
              var nextLinks = getDropdownLinks(nextGroup);
              navButtons.forEach(function (b) { b.setAttribute('tabindex', '-1'); });
              nextGroup.querySelector('.nav-link').setAttribute('tabindex', '0');
              if (nextLinks.length) nextLinks[0].focus();
              break;
            }
            case 'ArrowLeft': {
              e.preventDefault();
              closeDropdown(parentGroup);
              var prevGroup = navItems[(groupIndex - 1 + navItems.length) % navItems.length];
              openDropdown(prevGroup);
              var prevLinks = getDropdownLinks(prevGroup);
              navButtons.forEach(function (b) { b.setAttribute('tabindex', '-1'); });
              prevGroup.querySelector('.nav-link').setAttribute('tabindex', '0');
              if (prevLinks.length) prevLinks[0].focus();
              break;
            }
            case 'Escape': {
              e.preventDefault();
              closeDropdown(parentGroup);
              parentGroup.querySelector('.nav-link').focus();
              break;
            }
            case 'Home': {
              e.preventDefault();
              if (links.length) links[0].focus();
              break;
            }
            case 'End': {
              e.preventDefault();
              if (links.length) links[links.length - 1].focus();
              break;
            }
            case 'Tab': {
              closeAllDropdowns();
              break;
            }
          }
        }
      });
    }

    // Close dropdowns on click outside
    document.addEventListener('click', function (e) {
      if (!e.target.closest('.nav-item')) closeAllDropdowns();
    });

    /* ═══════════════════════════════════════════
       HOVER INTENT — Grace delay on desktop
       Prevents dropdown from closing when cursor
       moves diagonally from trigger to dropdown
       ═══════════════════════════════════════════ */
    navItems.forEach(function (item) {
      var closeTimer = null;
      var GRACE_DELAY = 180;

      item.addEventListener('mouseenter', function () {
        if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
        navItems.forEach(function (other) {
          if (other !== item) closeDropdown(other);
        });
        openDropdown(item);
      });

      item.addEventListener('mouseleave', function () {
        closeTimer = setTimeout(function () {
          closeDropdown(item);
          closeTimer = null;
        }, GRACE_DELAY);
      });
    });

  })();
</script>

<style>
  /* ─── Skip Navigation ──────────────────── */
  .skip-nav {
    position: fixed;
    top: -100%;
    left: var(--space-md);
    z-index: 10000;
    padding: var(--space-sm) var(--space-lg);
    background: var(--c-yellow);
    color: var(--c-dark);
    font-weight: 700;
    font-size: 0.875rem;
    border-radius: 0 0 var(--border-radius) var(--border-radius);
    text-decoration: none;
    box-shadow: var(--shadow-lg);
    transition: top 0.15s ease;
  }

  .skip-nav:focus {
    top: 0;
    outline: 3px solid var(--c-purple);
    outline-offset: 2px;
  }

  /* ─── Header Shell ─────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: var(--c-dark);
    height: var(--header-height);
    border-bottom: 3px solid var(--c-yellow);
    will-change: transform;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .site-header.header--hidden {
    transform: translateY(-100%);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding-inline: var(--space-lg);
    max-width: var(--max-width-wide);
    margin-inline: auto;
  }

  /* ─── Logo ─────────────────────────────── */
  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-shrink: 0;
    transition: opacity var(--transition-fast);
  }

  .logo:hover { opacity: 0.9; }

  .logo-icon { height: 40px; width: auto; flex-shrink: 0; }

  .logo-text {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    color: var(--c-yellow);
    line-height: 1.2;
    white-space: nowrap;
  }

  @media (max-width: 480px) {
    .logo-text { display: none; }
  }

  /* ─── Desktop Nav ──────────────────────── */
  .desktop-nav { display: none; }
  @media (min-width: 1024px) { .desktop-nav { display: flex; } }

  .nav-list { display: flex; align-items: center; gap: var(--space-xs); }
  .nav-item { position: relative; }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: var(--space-sm) var(--space-md);
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--c-white);
    background: none;
    border: none;
    cursor: pointer;
    border-radius: var(--border-radius);
    transition: background var(--transition-fast), color var(--transition-fast);
    white-space: nowrap;
    position: relative;
  }

  .nav-link:hover {
    background: rgba(255, 255, 255, 0.1);
    color: var(--c-yellow);
  }

  /* ─── Parent Active State ──────────────── */
  .nav-link.parent-active {
    color: var(--c-yellow);
  }

  .nav-link.parent-active::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 50%;
    transform: translateX(-50%);
    width: 20px;
    height: 3px;
    background: var(--c-yellow);
    border-radius: 2px;
  }

  .chevron { transition: transform var(--transition-fast); }

  /* ─── Desktop Dropdown ─────────────────── */
  .dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    min-width: 220px;
    background: var(--c-white);
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-lg);
    padding: var(--space-sm) 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--transition-fast), transform var(--transition-fast), visibility var(--transition-fast);
    pointer-events: none;
  }

  /* Open via JS class (hover intent + keyboard) */
  .nav-item.dropdown-open > .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  .nav-item.dropdown-open > .nav-link .chevron { transform: rotate(180deg); }

  .dropdown-link {
