<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.ev-video-facade').forEach(el => {
      const handler = () => {
        const streamId = el.getAttribute('data-stream-id');
        const ytId = el.getAttribute('data-yt-id');
        const iframe = document.createElement('iframe');
        iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:none;';
        iframe.setAttribute('allow', 'autoplay; fullscreen');
        iframe.setAttribute('allowfullscreen', '');
        if (streamId) {
          iframe.src = `https://iframe.videodelivery.net/${streamId}?autoplay=true`;
        } else if (ytId) {
          iframe.src = `https://www.youtube-nocookie.com/embed/${ytId}?autoplay=1`;
        }
        el.style.position = 'relative';
        el.innerHTML = '';
        el.appendChild(iframe);
        el.removeEventListener('click', handler);
        el.removeEventListener('keydown', keyHandler);
        el.removeAttribute('role');
        el.removeAttribute('tabindex');
      };
      const keyHandler = (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); handler(); } };
      el.addEventListener('click', handler);
      el.addEventListener('keydown', keyHandler);
    });
  });
</script>
