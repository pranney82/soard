<!-- ═══════════════════════════════════════════
     CLIENT-SIDE: Countdown + Smooth Scroll
     ═══════════════════════════════════════════ -->
<script>
  /* ── Live countdown badges ── */
  document.querySelectorAll<HTMLElement>('[data-countdown]').forEach(el => {
    const target = new Date(el.dataset.countdown + 'T00:00:00');
    const now = new Date();
    const diff = target.getTime() - now.getTime();
    const days = Math.ceil(diff / (1000 * 60 * 60 * 24));

    if (days > 1) {
      el.textContent = `${days} days away`;
    } else if (days === 1) {
      el.textContent = 'Tomorrow!';
    } else if (days === 0) {
      el.textContent = 'Today!';
    } else {
      el.textContent = 'Recently passed';
    }
  });

  /* ── Freeze golf logo float animation before view-transition snapshot ── */
  document.addEventListener('astro:before-preparation', () => {
    document.querySelectorAll('.hero-event-card__logo').forEach(el => el.classList.add('vt-freeze'));
  });

  /* ── Smooth scroll for anchor links ── */
  document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(link => {
    link.addEventListener('click', (e) => {
      const id = link.getAttribute('href')?.slice(1);
      if (!id) return;
      const target = document.getElementById(id);
      if (!target) return;
      e.preventDefault();
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      history.pushState(null, '', `#${id}`);
    });
  });
</script>

