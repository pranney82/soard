  @media (max-width: 768px) { .trust { padding: 80px 0; } .trust-grid { grid-template-columns: 1fr; } }


  /* ── FINALE ── */
  .finale { padding: 120px 0; background: var(--c-yellow); text-align: center; position: relative; overflow: hidden; contain: layout style; }
  .finale-inner { max-width: 640px; margin: 0 auto; padding: 0 var(--page-padding); position: relative; z-index: 2; }
  .finale-icon { width: clamp(72px, 9vw, 100px); height: auto; margin: 0 auto clamp(20px, 3vw, 28px); display: block; }
  .finale h2 { font-size: clamp(28px, 4vw, 40px); line-height: 1.25; margin-bottom: 20px; }
