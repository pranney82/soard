---
/**
 * CFImage.astro
 * Responsive image component for Cloudflare Images.
 *
 * CF Images `f=auto` negotiates format (AVIF → WebP → JPEG) server-side
 * via the Accept header, so <picture> with explicit format sources is
 * unnecessary. A single <img> with srcset is the correct approach.
 *
 * Non-CF URLs pass through as plain <img>.
 */
interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
  style?: string;
  /** Override default responsive widths (px) */
  widths?: number[];
  /** Quality 1-100 for CF transforms (default 85) */
  quality?: number;
}

const CF_BASE = 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ';

const {
  src,
  alt,
  width,
  height,
  sizes = '(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw',
  loading = 'lazy',
  fetchpriority,
  class: className = '',
  style = '',
  widths = [400, 640, 800, 1024, 1600],
  quality = 85,
} = Astro.props;

const isCFImage = src.includes('imagedelivery.net');

function getBase(url: string): string {
  const id = url.replace(`${CF_BASE}/`, '').replace('/public', '').split('/')[0];
  return `${CF_BASE}/${id}`;
}

function buildSrcset(): string {
  const base = getBase(src);
  return widths.map(w => `${base}/w=${w},f=auto,q=${quality} ${w}w`).join(', ');
}

function buildSrc(): string {
  const base = getBase(src);
  const fallbackW = widths[widths.length - 2] || widths[widths.length - 1];
  return `${base}/w=${fallbackW},f=auto,q=${quality}`;
}
---

<img
  src={isCFImage ? buildSrc() : src}
  srcset={isCFImage ? buildSrcset() : undefined}
  alt={alt}
  width={width}
  height={height}
  sizes={isCFImage ? sizes : undefined}
  loading={loading}
  decoding="async"
  fetchpriority={fetchpriority}
  class:list={['cf-image', className]}
  style={style}
/>

<style>
  .cf-image {
    display: block;
    max-width: 100%;
    height: auto;
    object-fit: cover;
  }
</style>
