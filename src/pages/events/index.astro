---
/**
 * Events Page — Sunshine on a Ranney Day
 * Hero-driven layout: flagship event gets full visual treatment,
 * remaining events in polished cards + past events timeline.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { CF_BASE as CF_IMAGES, cfRaw, cfSrcset } from '../../utils/cf-image';

const allEvents = await getCollection('events');
const today = new Date().toISOString().split('T')[0];

const events = allEvents.map(e => ({
  ...e,
  data: {
    ...e.data,
    status: e.data.status === 'cancelled' ? 'cancelled' : e.data.date < today ? 'past' : 'upcoming',
  },
}));

const upcoming = events
  .filter(e => e.data.status === 'upcoming')
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());

const past = events
  .filter(e => e.data.status === 'past')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const featured = upcoming.filter(e => e.data.featured);
const regular = upcoming.filter(e => !e.data.featured);

const detailPages: Record<string, string> = {
  'sunshine-on-a-ranney-fairway-2026': '/events/golf/',
};

const catLabel: Record<string, string> = {
  fundraiser: 'Fundraiser', volunteer: 'Volunteer',
  reveal: 'Room Reveal', community: 'Community', other: 'Event',
};
const catColor: Record<string, string> = {
  fundraiser: '#d4a017', volunteer: '#2e7d32',
  reveal: '#6a3de8', community: '#1976d2', other: '#5A5B61',
};

// Category-specific gradient "hero" backgrounds for cards
const catGradient: Record<string, string> = {
  fundraiser: 'linear-gradient(135deg, #7a5a00 0%, #b8860b 40%, #d4a017 80%, #e6b422 100%)',
  volunteer:  'linear-gradient(135deg, #1a472a 0%, #2e7d32 40%, #388e3c 70%, #43a047 100%)',
  reveal:     'linear-gradient(135deg, #2d1b69 0%, #4a2d8a 40%, #6a3de8 70%, #7c4dff 100%)',
  community:  'linear-gradient(135deg, #0d3b66 0%, #1565c0 40%, #1976d2 70%, #2196f3 100%)',
  other:      'linear-gradient(135deg, #2c2c2c 0%, #4a4a4a 40%, #5A5B61 70%, #6D6E74 100%)',
};

// Category SVG icons (large, for card headers)
const catIcon: Record<string, string> = {
  fundraiser: '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>',
  volunteer:  '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 12-8.5 8.5c-.83.83-2.17.83-3 0a2.12 2.12 0 0 1 0-3L12 9"/><path d="M17.64 15 22 10.64"/><path d="m20.91 11.7-1.25-1.25c-.6-.6-.93-1.4-.93-2.25v-.86L16.01 4.6a5.56 5.56 0 0 0-3.94-1.64H9l.92.82A6.18 6.18 0 0 1 12 8.4v1.56l2 2h2.47l2.26 1.91"/></svg>',
  reveal:     '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.912 5.813a2 2 0 0 0 1.275 1.275L21 12l-5.813 1.912a2 2 0 0 0-1.275 1.275L12 21l-1.912-5.813a2 2 0 0 0-1.275-1.275L3 12l5.813-1.912a2 2 0 0 0 1.275-1.275L12 3z"/></svg>',
  community:  '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
  other:      '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
};

function fmtDate(d: string) {
  return new Date(d + 'T00:00:00').toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
function fmtWeekday(d: string) {
  return new Date(d + 'T00:00:00').toLocaleDateString('en-US', { weekday: 'long' });
}
function fmtMonth(d: string) {
  return new Date(d + 'T00:00:00').toLocaleDateString('en-US', { month: 'short' }).toUpperCase();
}
function fmtDay(d: string) {
  return new Date(d + 'T00:00:00').getDate().toString();
}

// Pull golf tournament out as flagship
const golfEvent = featured.find(e => e.data.slug === 'sunshine-on-a-ranney-fairway-2026');
const otherFeatured = featured.filter(e => e.data.slug !== 'sunshine-on-a-ranney-fairway-2026');
const allOther = [...otherFeatured, ...regular];
---

<BaseLayout
  title="Events"
  description="Upcoming events from Sunshine on a Ranney Day — galas, volunteer build days, room reveals, and community gatherings in the greater Atlanta area."
  breadcrumbs={[{ name: 'Events', url: '/events/' }]}
>

  <!-- ═══ HERO (always shown) ═══ -->
  <section class="ev-hero">
    <div class="ev-hero__bg" aria-hidden="true"></div>
    <div class="container ev-hero__inner">
      <span class="ev-hero__eyebrow" data-reveal>Events</span>
      <h1 class="ev-hero__title" data-reveal data-delay="1">Come be a part of<br><em class="ev-hl">something&nbsp;big</em>.</h1>
      <p class="ev-hero__sub" data-reveal data-delay="2">From fundraising galas to hands-on build days, there are so many ways to get involved and help us create dream rooms for incredible kids.</p>
    </div>
  </section>

  <!-- ═══ FEATURED NEXT EVENT (golf spotlight) ═══ -->
  {golfEvent && (
    <section class="ev-next">
      <div class="container">
        <div class="ev-next__card" data-reveal>
          <div class="ev-next__bg" aria-hidden="true">
            <div class="ev-next__gradient"></div>
            <div class="ev-next__pattern"></div>
          </div>
          <div class="ev-next__body">
            <span class="ev-next__eyebrow">Next Event</span>
            <h2 class="ev-next__title">{golfEvent.data.title}</h2>
            <p class="ev-next__desc">{golfEvent.data.description}</p>
            <div class="ev-next__details">
              <div class="ev-next__detail">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <time datetime={golfEvent.data.date}>{fmtWeekday(golfEvent.data.date)}, {fmtDate(golfEvent.data.date)}</time>
              </div>
              <div class="ev-next__detail">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {golfEvent.data.location}
              </div>
              {golfEvent.data.time && (
                <div class="ev-next__detail">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {golfEvent.data.time}
                </div>
              )}
            </div>
            <a href="/events/golf/" class="ev-btn ev-btn--gold ev-btn--lg">
              View Details &amp; Register
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="ev-next__visual">
            <img
              src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/golf-logo-light/w=400,q=85,format=auto"
              srcset="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/golf-logo-light/w=280,q=80,format=auto 280w, https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/golf-logo-light/w=400,q=85,format=auto 400w"
              sizes="(max-width: 767px) 160px, 280px"
              alt="Sunshine on a Ranney Fairway"
              width="400" height="400"
              loading="eager" decoding="async"
              class="ev-next__logo"
            />
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ═══ UPCOMING EVENTS ═══ -->
  {allOther.length > 0 && (
    <section class="ev-upcoming" id="upcoming">
      <div class="container">
        <div class="ev-upcoming__header" data-reveal>
          <h2 class="ev-heading">{golfEvent ? 'More Events' : 'Upcoming Events'}</h2>
          <p class="ev-heading__sub">{allOther.length} event{allOther.length !== 1 ? 's' : ''} coming up</p>
        </div>

        <div class="ev-grid">
          {allOther.map((event, i) => {
            const detailUrl = detailPages[event.data.slug];
            return (
              <article class="ev-card" data-reveal data-delay={String(Math.min(i, 3))}>
                {/* Gradient hero header */}
                <div class="ev-card__hero" style={`background: ${catGradient[event.data.category]}`}>
                  <div class="ev-card__hero-pattern" aria-hidden="true"></div>
                  <div class="ev-card__hero-glow" aria-hidden="true"></div>
                  <div class="ev-card__hero-icon" set:html={catIcon[event.data.category]} />
                  <div class="ev-card__hero-date">
                    <time datetime={event.data.date}>
                      <span class="ev-card__hero-month">{fmtMonth(event.data.date)}</span>
                      <span class="ev-card__hero-day">{fmtDay(event.data.date)}</span>
                    </time>
                  </div>
                  <div class="ev-card__hero-cat">{catLabel[event.data.category]}</div>
                </div>
                <div class="ev-card__inner">
                  <h3 class="ev-card__title">{event.data.title}</h3>
                  <div class="ev-card__meta">
                    <span class="ev-card__meta-item">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                      <time datetime={event.data.date}>{fmtWeekday(event.data.date)}, {fmtDate(event.data.date)}</time>
                    </span>
                    {event.data.time && (
                      <span class="ev-card__meta-item">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        {event.data.time}
                      </span>
                    )}
                    <span class="ev-card__meta-item">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                      {event.data.location}
                    </span>
                  </div>
                  <p class="ev-card__desc">{event.data.description}</p>
                  <div class="ev-card__foot">
                    {detailUrl ? (
                      <a href={detailUrl} class="ev-card__cta">View Details <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
                    ) : event.data.ticketUrl ? (
                      <a href={event.data.ticketUrl} class="ev-card__cta" target="_blank" rel="noopener noreferrer">Get Tickets <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg></a>
                    ) : (
                      <span class="ev-card__soon">Details coming soon</span>
                    )}
                    {event.data.ticketPrice && <span class="ev-card__price">{event.data.ticketPrice}</span>}
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ EMPTY ═══ -->
  {upcoming.length === 0 && !golfEvent && (
    <section class="ev-empty" id="upcoming">
      <div class="container">
        <div class="ev-empty__box" data-reveal>
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <h2>No upcoming events</h2>
          <p>We're planning something special. Follow us on social media to be the first to know!</p>
        </div>
      </div>
    </section>
  )}

  <!-- ═══ PAST EVENTS ═══ -->
  {past.length > 0 && (
    <section class="ev-past" id="past">
      <div class="container">
        <h2 class="ev-heading ev-heading--light" data-reveal>Past Events</h2>
        <div class="ev-tl">
          {past.map((event, i) => (
            <article class="ev-tl__item" data-reveal data-delay={String(Math.min(i, 3))}>
              <div class="ev-tl__marker" aria-hidden="true">
                <div class="ev-tl__dot"></div>
              </div>
              <div class="ev-tl__card">
                <div class="ev-tl__top">
                  <span class="ev-tl__cat" style={`--cat: ${catColor[event.data.category]}`}>{catLabel[event.data.category]}</span>
                  <time class="ev-tl__date" datetime={event.data.date}>{fmtDate(event.data.date)}</time>
                </div>
                <h3 class="ev-tl__title">{event.data.title}</h3>
                <p class="ev-tl__loc">{event.data.location}</p>
                <p class="ev-tl__desc">{event.data.description}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ CTA ═══ -->
  <section class="ev-cta">
    <div class="container">
      <div class="ev-cta__card" data-reveal>
        <span class="ev-cta__eyebrow">Get Involved</span>
        <h2>Want to host an event?</h2>
        <p>Partner with us to organize a fundraiser, volunteer day, or community event that supports children with special needs.</p>
        <div class="ev-cta__actions">
          <a href="mailto:info@soardcharity.com?subject=Event%20Partnership" class="ev-btn ev-btn--gold ev-btn--lg">Contact Us</a>
          <a href="/donate/" class="ev-btn ev-btn--outline">Donate Instead</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ═══════════════════════════════════════════
     EVENTS PAGE
     Flagship-driven layout with staggered reveals
     ═══════════════════════════════════════════ */

  [id] { scroll-margin-top: calc(var(--header-height, 84px) + 1.5rem); }

  /* ─── Reveal ─── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  [data-reveal].is-visible { opacity: 1; transform: translateY(0); }
  [data-delay="1"] { transition-delay: 0.1s; }
  [data-delay="2"] { transition-delay: 0.2s; }
  [data-delay="3"] { transition-delay: 0.3s; }
  @media (prefers-reduced-motion: reduce) {
    [data-reveal] { transition: none; opacity: 1; transform: none; }
  }

  /* ─── Highlight ─── */
  .ev-hl {
    font-style: normal;
    background-image: linear-gradient(transparent 52%, var(--c-yellow-soft) 52%);
    padding: 0 0.1em;
  }

  /* ─── Buttons ─── */
  .ev-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0.75rem 1.6rem;
    border-radius: 100px;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    border: 1.5px solid transparent;
    cursor: pointer;
    transition: background 200ms, color 200ms, transform 200ms, box-shadow 200ms;
  }
  .ev-btn:active { transform: scale(0.97); }
  .ev-btn--gold {
    background: var(--c-yellow);
    color: var(--c-dark);
    border-color: var(--c-yellow);
  }
  .ev-btn--gold:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px var(--c-yellow-glow);
  }
  .ev-btn--outline {
    background: transparent;
    color: rgba(255, 255, 255, 0.85);
    border-color: rgba(255, 255, 255, 0.25);
  }
  .ev-btn--outline:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.5);
  }
  .ev-btn--lg { padding: 0.85rem 2.2rem; font-size: 0.95rem; }

  /* ═══ HERO ═══ */
  .ev-hero {
    position: relative;
    padding: var(--space-5xl) 0 var(--space-3xl);
    overflow: hidden;
  }
  .ev-hero__bg {
    position: absolute;
    inset: 0;
    background: var(--c-dark-deep);
  }
  .ev-hero__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 12% 85%, var(--c-yellow-glow) 0%, transparent 55%),
      radial-gradient(ellipse 40% 40% at 90% 15%, rgba(255, 255, 255, 0.035) 0%, transparent 50%);
  }
  .ev-hero__inner {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }
  .ev-hero__eyebrow {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--c-yellow);
    margin-bottom: var(--space-md);
  }
  .ev-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5.5vw, 3.8rem);
    color: #fff;
    line-height: 1.1;
    letter-spacing: -0.01em;
    text-wrap: balance;
    margin-bottom: var(--space-lg);
  }
  .ev-hero__sub {
    font-size: clamp(0.95rem, 1.4vw, 1.1rem);
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.75;
    text-wrap: pretty;
    max-width: 580px;
    margin: 0 auto;
  }

  /* ═══ FEATURED NEXT EVENT CARD ═══ */
  .ev-next {
    padding: var(--space-4xl) 0;
    background: var(--c-cream);
  }
  .ev-next__card {
    position: relative;
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr;
    transition: box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .ev-next__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 56px rgba(0, 0, 0, 0.18);
  }
  @media (min-width: 768px) {
    .ev-next__card { grid-template-columns: 1fr auto; }
  }
  .ev-next__bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #1a472a 0%, #2e7d32 40%, #388e3c 70%, #43a047 100%);
  }
  .ev-next__gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 55% at 15% 85%, rgba(255, 218, 36, 0.14) 0%, transparent 60%),
      radial-gradient(ellipse 50% 50% at 85% 15%, rgba(255, 255, 255, 0.06) 0%, transparent 50%);
  }
  .ev-next__pattern {
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: radial-gradient(circle, #fff 1px, transparent 1px);
    background-size: 32px 32px;
  }
  .ev-next__body {
    position: relative;
    z-index: 1;
    padding: var(--space-2xl);
  }
  @media (min-width: 768px) {
    .ev-next__body { padding: var(--space-3xl); }
  }
  .ev-next__eyebrow {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--c-yellow);
    background: rgba(255, 218, 36, 0.12);
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    margin-bottom: var(--space-lg);
  }
  .ev-next__title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    color: #fff;
    line-height: 1.12;
    text-wrap: balance;
    margin-bottom: var(--space-md);
  }
  .ev-next__desc {
    font-size: clamp(0.9rem, 1.3vw, 1rem);
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.75;
    max-width: 480px;
    text-wrap: pretty;
    margin-bottom: var(--space-xl);
  }
  .ev-next__details {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
  }
  .ev-next__detail {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.85);
  }
  .ev-next__detail svg {
    color: var(--c-yellow);
    flex-shrink: 0;
  }
  .ev-next__visual {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl);
  }
  @media (min-width: 768px) {
    .ev-next__visual { padding: var(--space-2xl) var(--space-3xl); }
  }
  .ev-next__logo {
    width: 160px;
    height: auto;
    filter: drop-shadow(0 8px 32px rgba(0, 0, 0, 0.25));
    animation: ev-float 6s ease-in-out infinite;
  }
  @media (min-width: 768px) {
    .ev-next__logo { width: 280px; }
