---
/**
 * Spring Gala — Hand-crafted event detail page
 * Premium editorial layout: dark hero, event details, ticket tiers,
 * what-to-expect timeline, testimonial, CTA.
 *
 * PERF: CF Images w/ srcset, LQIP blur-up, LCP preload, scoped CSS
 * SEO:  Event JSON-LD, breadcrumbs, OG image
 * A11Y: Heading hierarchy, ARIA, prefers-reduced-motion
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { cfRaw, cfSrcset, cfLqip } from '../../utils/cf-image';

/* ── Ticket tiers ── */
interface Tier {
  name: string;
  price: string;
  detail?: string;
  badge?: string;
  highlight?: boolean;
}

const tiers: Tier[] = [
  { name: 'Individual Ticket', price: '$150', detail: 'Dinner, drinks, live entertainment, and silent auction access' },
  { name: 'Couple', price: '$275', detail: 'Two seats, preferred seating, welcome champagne', badge: 'Most Popular', highlight: true },
  { name: 'Table of 8', price: '$1,100', detail: 'Reserved table, signage, recognition in program' },
  { name: 'VIP Table of 8', price: '$2,500', detail: 'Premium table, private reception, meet & greet with families, logo in all event materials', badge: 'VIP' },
];

/* ── Event content — edit these for each year ── */
const eventYear = '2026';
const eventDate = '2026-04-18';
const eventTime = '6:00 PM – 10:00 PM';
const venueName = 'The Estate at River Run';
const venueAddress = '1050 River Run Blvd, Roswell, GA 30076';
const ticketUrl = 'https://www.sunnyandranney.com/events/spring-gala-2026';
const heroPhotoId = 'kids/eli/photo-01'; /* Replace with gala-specific photo when available */

/* ── JSON-LD ── */
const eventJsonLd = {
  "@type": "Event",
  "@id": `https://sunshineonaranneyday.com/events/gala/#event`,
  "name": `Spring Gala ${eventYear}`,
  "description": `An unforgettable evening celebrating the children and families served by Sunshine on a Ranney Day — dinner, live entertainment, silent auction, and room reveals.`,
  "startDate": `${eventDate}T18:00:00-04:00`,
  "endDate": `${eventDate}T22:00:00-04:00`,
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  "eventStatus": "https://schema.org/EventScheduled",
  "location": {
    "@type": "Place",
    "name": venueName,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "1050 River Run Blvd",
      "addressLocality": "Roswell",
      "addressRegion": "GA",
      "postalCode": "30076",
      "addressCountry": "US",
    },
  },
  "organizer": { "@id": "https://sunshineonaranneyday.com/#organization" },
  "offers": {
    "@type": "Offer",
    "url": ticketUrl,
    "price": "150",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
  },
};

/* ── LCP preload ── */
const heroSrcset = cfSrcset(heroPhotoId, [400, 640, 900], { fit: 'cover', gravity: 'face' });
const heroSizes = '(max-width: 768px) 85vw, 420px';

function fmtDate(d: string) {
  return new Date(d + 'T00:00:00').toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout
  title={`Spring Gala ${eventYear} — Sunshine on a Ranney Day`}
  description={`Join us for the Spring Gala ${eventYear} — an unforgettable evening of dinner, live entertainment, a silent auction, and room reveals celebrating the families we serve.`}
  jsonLd={eventJsonLd}
  breadcrumbs={[
    { name: 'Events', url: '/events/' },
    { name: `Spring Gala ${eventYear}`, url: '/events/gala/' },
  ]}
>
  <link slot="head" rel="preload" as="image" imagesrcset={heroSrcset} imagesizes={heroSizes} fetchpriority="high" />

  <!-- ═══ HERO (editorial split) ═══ -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <span class="hero-eyebrow">Annual Fundraiser</span>
        <h1 class="hero-headline">Spring Gala <em class="highlight">{eventYear}</em></h1>
        <p class="hero-sub">An unforgettable evening of dinner, live entertainment, and a silent auction — all to celebrate and support the children and families we serve.</p>
        <div class="hero-meta">
          <div class="hero-meta__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
            <time datetime={eventDate}>{fmtDate(eventDate)}</time>
          </div>
          <div class="hero-meta__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            {eventTime}
          </div>
          <div class="hero-meta__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
            <a href={`https://maps.google.com/?q=${encodeURIComponent(venueAddress)}`} target="_blank" rel="noopener" class="hero-meta__link">{venueName}</a>
          </div>
        </div>
        <div class="hero-ctas">
          <a href="#tickets" class="btn btn-primary btn-lg">Get Tickets</a>
          <a href="#evening" class="btn btn-dark">What to Expect</a>
        </div>
      </div>
      <div class="hero-frame">
        <div class="hero-accent" aria-hidden="true"></div>
        <div class="hero-photo" style={`background-image:url('${cfLqip(heroPhotoId)}')`}>
          <img
            src={cfRaw(heroPhotoId, 'w=640,h=800,fit=cover,gravity=face,q=82')}
            srcset={heroSrcset}
            sizes={heroSizes}
            alt="Children and families at a Sunshine on a Ranney Day event"
            width="640" height="800"
            loading="eager" decoding="async" fetchpriority="high"
            class="hero-photo__img lqip-img"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ EVENING TIMELINE ═══ -->
  <section class="gala-evening" id="evening">
    <div class="container">
      <div class="gala-evening__header" data-reveal>
        <p class="section-label">The Evening</p>
        <h2 class="section-heading">What to <em class="highlight">Expect</em></h2>
      </div>
      <div class="gala-tl">
        <div class="gala-tl__item" data-reveal>
          <div class="gala-tl__time">6:00 PM</div>
          <div class="gala-tl__content">
            <h3>Cocktail Reception</h3>
            <p>Welcome drinks, silent auction preview, and mingling with sponsors, volunteers, and families.</p>
          </div>
        </div>
        <div class="gala-tl__item" data-reveal>
          <div class="gala-tl__time">7:00 PM</div>
          <div class="gala-tl__content">
            <h3>Dinner & Program</h3>
            <p>A plated dinner paired with our program — hear directly from families whose lives have been transformed by a dream room makeover.</p>
          </div>
        </div>
        <div class="gala-tl__item" data-reveal>
          <div class="gala-tl__time">8:00 PM</div>
          <div class="gala-tl__content">
            <h3>Live Room Reveal</h3>
            <p>The highlight of the evening — watch a child see their new dream room for the very first time, live on stage.</p>
          </div>
        </div>
        <div class="gala-tl__item" data-reveal>
          <div class="gala-tl__time">8:30 PM</div>
          <div class="gala-tl__content">
            <h3>Live Entertainment & Dancing</h3>
            <p>Live music, an open dance floor, and a celebration of community and impact.</p>
          </div>
        </div>
        <div class="gala-tl__item" data-reveal>
          <div class="gala-tl__time">10:00 PM</div>
          <div class="gala-tl__content">
            <h3>Silent Auction Closes</h3>
            <p>Final bids on exclusive packages, experiences, and items — all proceeds fund dream room makeovers.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TICKETS ═══ -->
  <section class="gala-tickets" id="tickets">
    <div class="container">
      <div class="gala-tickets__header" data-reveal>
        <p class="section-label">Reserve Your Seat</p>
        <h2 class="section-heading">Tickets & <em class="highlight">Tables</em></h2>
        <p class="section-sub">Every ticket directly funds dream room makeovers for children with special needs.</p>
      </div>
      <div class="gala-tiers">
        {tiers.map(tier => (
          <div class={`gala-tier ${tier.highlight ? 'gala-tier--highlight' : ''}`} data-reveal>
            {tier.badge && <span class="gala-tier__badge">{tier.badge}</span>}
            <h3 class="gala-tier__name">{tier.name}</h3>
            <span class="gala-tier__price">{tier.price}</span>
            {tier.detail && <p class="gala-tier__detail">{tier.detail}</p>}
          </div>
        ))}
      </div>
      <div class="gala-tickets__cta" data-reveal>
        <a href={ticketUrl} target="_blank" rel="noopener" class="ev-btn ev-btn--gold ev-btn--lg">
          Purchase Tickets
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
        </a>
        <p class="gala-tickets__note">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          100% of proceeds fund dream room makeovers
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="gala-cta">
    <div class="container">
      <div class="gala-cta__card" data-reveal>
        <h2>Can't Make It?<br/>You Can Still Help.</h2>
        <p>Your donation goes directly toward building dream rooms for children with special needs.</p>
        <div class="gala-cta__actions">
          <a href="/donate/" class="ev-btn ev-btn--gold">Donate Directly</a>
          <a href="/events/" class="ev-btn ev-btn--outline-white">All Events</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(link => {
    link.addEventListener('click', (e) => {
      const id = link.getAttribute('href')?.slice(1);
      if (!id) return;
      const target = document.getElementById(id);
      if (!target) return;
      e.preventDefault();
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
</script>

<style>
  [id] { scroll-margin-top: calc(var(--header-height, 84px) + 1.5rem); }

  /* ─── Reveal ─── */
  [data-reveal] {
    opacity: 0; transform: translateY(28px);
    transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1);
  }
  [data-reveal].is-visible { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) { [data-reveal] { transition: none; opacity: 1; transform: none; } }

  /* ─── Shared ─── */
  .ev-btn { display: inline-flex; align-items: center; gap: 8px; padding: 0.75rem 1.6rem; border-radius: 100px; font-size: 0.88rem; font-weight: 600; text-decoration: none; border: 1.5px solid transparent; cursor: pointer; transition: background 200ms, color 200ms, transform 200ms, box-shadow 200ms; }
  .ev-btn:active { transform: scale(0.97); }
  .ev-btn--gold { background: var(--c-yellow); color: var(--c-dark); border-color: var(--c-yellow); }
  .ev-btn--gold:hover { transform: translateY(-2px); box-shadow: 0 6px 24px var(--c-yellow-glow); }
  .ev-btn--lg { padding: 0.85rem 2.2rem; font-size: 0.95rem; }
  .ev-btn--outline-white { background: transparent; color: #fff; border-color: rgba(255,255,255,0.4); }
  .ev-btn--outline-white:hover { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.7); }

  .section-label { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--c-text-muted); margin-bottom: var(--space-sm); }
  .section-heading { font-family: var(--font-display); font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 400; color: var(--c-dark); letter-spacing: -0.02em; line-height: 1.15; text-wrap: balance; }
  .section-sub { font-size: clamp(0.9rem, 1.2vw, 1rem); line-height: 1.7; color: var(--c-text-muted); max-width: 52ch; margin-top: var(--space-sm); }

  /* ═══ HERO ═══ */
  .hero { background: var(--c-cream); padding: var(--space-3xl) 0 var(--space-4xl); overflow: hidden; }
  .hero-inner { max-width: var(--max-width, 1200px); margin: 0 auto; padding: 0 var(--space-xl); display: grid; grid-template-columns: 1fr; gap: var(--space-2xl); align-items: center; }
  @media (min-width: 768px) { .hero-inner { grid-template-columns: 1fr 0.8fr; gap: var(--space-3xl); } }
  .hero-eyebrow { display: block; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.18em; color: var(--c-text-muted); margin-bottom: var(--space-md); }
  .hero-headline { font-family: var(--font-display); font-size: clamp(2rem, 4.5vw + 0.5rem, 3.25rem); font-weight: 400; color: var(--c-dark); line-height: 1.12; letter-spacing: -0.025em; text-wrap: balance; margin-bottom: var(--space-lg); }
  .hero-sub { font-family: var(--font-display); font-style: italic; font-size: clamp(0.95rem, 1.5vw, 1.065rem); line-height: 1.7; color: var(--c-text-muted); max-width: 44ch; margin-bottom: var(--space-lg); }
  .hero-meta { display: flex; flex-direction: column; gap: var(--space-xs); margin-bottom: var(--space-xl); }
  .hero-meta__item { display: flex; align-items: center; gap: 8px; font-size: 0.88rem; color: var(--c-text-muted); }
  .hero-meta__item svg { color: var(--c-text-light); flex-shrink: 0; }
  .hero-meta__link { color: var(--c-text-muted); text-decoration: underline; text-underline-offset: 2px; }
  .hero-meta__link:hover { color: var(--c-dark); }
  .hero-ctas { display: flex; gap: var(--space-md); flex-wrap: wrap; }
  .hero-frame { position: relative; display: flex; justify-content: center; }
  .hero-accent { position: absolute; top: -12px; right: -12px; width: 65%; height: 65%; background: var(--c-yellow); border-radius: var(--border-radius-lg); opacity: 0.15; z-index: 0; }
  .hero-photo { position: relative; z-index: 1; border-radius: var(--border-radius-lg); overflow: hidden; aspect-ratio: 4 / 5; max-width: 420px; width: 100%; background-size: cover; background-position: center; box-shadow: 0 24px 64px rgba(0,0,0,0.12); }
  .hero-photo__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .hero-photo__img.lqip-pending { opacity: 0; }
  .hero-photo__img.loaded { opacity: 1; transition: opacity 0.4s ease; }
  @media (max-width: 767px) {
    .hero { padding: var(--space-xl) 0 var(--space-2xl); }
    .hero-frame { order: -1; }
    .hero-photo { max-width: 280px; aspect-ratio: 3 / 4; }
    .hero-accent { width: 55%; height: 55%; top: -8px; right: -8px; }
    .hero-inner { text-align: center; }
    .hero-meta { align-items: center; }
    .hero-ctas { justify-content: center; }
    .hero-sub { margin-inline: auto; }
  }

  /* ═══ EVENING TIMELINE ═══ */
  .gala-evening { padding: var(--space-4xl) 0; background: var(--c-white); }
  .gala-evening__header { margin-bottom: var(--space-2xl); }
  .gala-tl { position: relative; padding-left: 140px; max-width: 720px; }
  .gala-tl::before { content: ''; position: absolute; left: 120px; top: 8px; bottom: 8px; width: 2px; background: var(--c-border); border-radius: 1px; }
  .gala-tl__item { position: relative; padding-bottom: var(--space-xl); }
  .gala-tl__item:last-child { padding-bottom: 0; }
  .gala-tl__item::before { content: ''; position: absolute; left: -20px; top: 6px; width: 10px; height: 10px; background: var(--c-white); border: 2.5px solid var(--c-border); border-radius: 50%; transition: border-color 0.25s, background 0.25s; z-index: 1; }
  .gala-tl__item:hover::before { border-color: var(--c-yellow); background: var(--c-yellow); }
  .gala-tl__time { position: absolute; left: -140px; top: 0; width: 100px; text-align: right; font-size: 0.82rem; font-weight: 700; color: var(--c-text-muted); letter-spacing: 0.02em; }
  .gala-tl__content h3 { font-family: var(--font-display); font-size: 1.1rem; color: var(--c-dark); margin-bottom: 0.25rem; }
  .gala-tl__content p { font-size: 0.88rem; line-height: 1.65; color: var(--c-text-muted); }
  @media (max-width: 640px) {
    .gala-tl { padding-left: 24px; }
    .gala-tl::before { left: 5px; }
    .gala-tl__item::before { left: -24px; }
    .gala-tl__time { position: static; width: auto; text-align: left; margin-bottom: var(--space-xs); font-size: 0.72rem; color: var(--c-yellow-hover, #b8960b); }
  }

  /* ═══ TICKETS ═══ */
  .gala-tickets { padding: var(--space-4xl) 0; background: var(--c-cream); }
  .gala-tickets__header { margin-bottom: var(--space-2xl); }
  .gala-tiers { display: grid; grid-template-columns: 1fr; gap: var(--space-lg); max-width: 900px; }
  @media (min-width: 640px) { .gala-tiers { grid-template-columns: repeat(2, 1fr); } }
  .gala-tier { position: relative; padding: var(--space-xl); background: var(--c-white); border: 1px solid var(--c-border); border-radius: var(--border-radius-lg); transition: transform 0.35s cubic-bezier(0.16,1,0.3,1), box-shadow 0.35s cubic-bezier(0.16,1,0.3,1); }
  .gala-tier:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(0,0,0,0.08); }
  .gala-tier--highlight { border-color: var(--c-yellow); box-shadow: 0 0 0 1px var(--c-yellow); }
  .gala-tier__badge { position: absolute; top: var(--space-md); right: var(--space-md); font-size: 0.58rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.12em; color: var(--c-dark); background: var(--c-yellow); padding: 0.2rem 0.6rem; border-radius: 100px; }
  .gala-tier__name { font-family: var(--font-display); font-size: 1.1rem; color: var(--c-dark); margin-bottom: var(--space-xs); }
  .gala-tier__price { display: block; font-family: var(--font-display); font-size: 1.8rem; font-weight: 400; color: var(--c-dark); line-height: 1.1; margin-bottom: var(--space-sm); background-image: linear-gradient(transparent 55%, var(--c-yellow-soft) 55%); background-size: auto; background-repeat: no-repeat; display: inline; }
  .gala-tier__detail { font-size: 0.85rem; line-height: 1.6; color: var(--c-text-muted); margin-top: var(--space-sm); }
  .gala-tickets__cta { text-align: center; margin-top: var(--space-2xl); }
  .gala-tickets__note { display: inline-flex; align-items: center; gap: 6px; font-size: 0.78rem; color: var(--c-text-light); margin-top: var(--space-md); }
  @media (prefers-reduced-motion: reduce) { .gala-tier { transition: none; } }

  /* ═══ CTA ═══ */
  .gala-cta { padding: var(--space-3xl) 0 var(--space-4xl); }
  .gala-cta__card { text-align: center; padding: var(--space-3xl) var(--space-xl); background: var(--c-dark-deep, #1E1F25); border-radius: var(--border-radius-lg); max-width: 720px; margin: 0 auto; position: relative; overflow: hidden; }
  .gala-cta__card::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 50% 50% at 10% 90%, var(--c-yellow-glow) 0%, transparent 50%), radial-gradient(ellipse 40% 40% at 90% 10%, rgba(255,255,255,0.03) 0%, transparent 50%); pointer-events: none; }
  .gala-cta__card h2 { font-family: var(--font-display); color: #fff; font-size: clamp(1.5rem, 3vw, 2.2rem); text-wrap: balance; margin-bottom: var(--space-md); position: relative; }
  .gala-cta__card p { color: rgba(255,255,255,0.6); max-width: 480px; margin: 0 auto var(--space-xl); line-height: 1.7; font-size: 0.95rem; text-wrap: pretty; position: relative; }
  .gala-cta__actions { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; position: relative; }

  @media (max-width: 640px) {
    .ev-btn { min-height: 44px; }
    .gala-cta__card { padding: var(--space-2xl) var(--space-md); }
  }
</style>
