---
/**
 * Events Page — Sunshine on a Ranney Day
 * Upcoming and past events — galas, build days, room reveals, and more.
 * Data-driven from src/content/events/ collection
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events');
const today = new Date().toISOString().split('T')[0];

// Auto-set status based on date
const events = allEvents.map(e => ({
  ...e,
  data: {
    ...e.data,
    status: e.data.status === 'cancelled' ? 'cancelled' : e.data.date < today ? 'past' : 'upcoming',
  },
}));

const upcoming = events
  .filter(e => e.data.status === 'upcoming')
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());

const past = events
  .filter(e => e.data.status === 'past')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const featured = upcoming.filter(e => e.data.featured);

const categoryLabels: Record<string, string> = {
  'fundraiser': 'Fundraiser',
  'volunteer': 'Volunteer',
  'reveal': 'Room Reveal',
  'community': 'Community',
  'other': 'Event',
};

const categoryIcons: Record<string, string> = {
  'fundraiser': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>',
  'volunteer': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 12-8.5 8.5c-.83.83-2.17.83-3 0 0 0 0 0 0 0a2.12 2.12 0 0 1 0-3L12 9"/><path d="M17.64 15 22 10.64"/><path d="m20.91 11.7-1.25-1.25c-.6-.6-.93-1.4-.93-2.25v-.86L16.01 4.6a5.56 5.56 0 0 0-3.94-1.64H9l.92.82A6.18 6.18 0 0 1 12 8.4v1.56l2 2h2.47l2.26 1.91"/></svg>',
  'reveal': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.912 5.813a2 2 0 0 0 1.275 1.275L21 12l-5.813 1.912a2 2 0 0 0-1.275 1.275L12 21l-1.912-5.813a2 2 0 0 0-1.275-1.275L3 12l5.813-1.912a2 2 0 0 0 1.275-1.275L12 3z"/></svg>',
  'community': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
  'other': '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
};

function formatDate(dateStr: string): string {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
}

function formatDateShort(dateStr: string): string {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

function formatMonth(dateStr: string): string {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('en-US', { month: 'short' }).toUpperCase();
}

function formatDay(dateStr: string): string {
  const d = new Date(dateStr + 'T00:00:00');
  return d.getDate().toString();
}

import { CF_BASE as CF_IMAGES, cfRaw, cfSrcset } from '../utils/cf-image';
const STREAM_DOMAIN = 'customer-cuav5h47lgfe96ql.cloudflarestream.com';

function getYouTubeId(url: string): string | null {
  const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([a-zA-Z0-9_-]{11})/);
  return match ? match[1] : null;
}
---

<BaseLayout
  title="Events"
  description="Upcoming events from Sunshine on a Ranney Day — galas, volunteer build days, room reveals, and community gatherings in the greater Atlanta area."
>

  <!-- ══════ HERO ══════ -->
  <section class="ev-hero">
    <div class="container">
      <div class="ev-hero__label">Events</div>
      <h1 class="ev-hero__title">Come be a part of <em class="highlight">something&nbsp;big</em>.</h1>
      <p class="ev-hero__sub">From fundraising galas to hands-on build days, there are so many ways to get involved and help us create dream rooms for incredible kids.</p>
    </div>
  </section>

  <!-- ══════ FEATURED / UPCOMING ══════ -->
  {upcoming.length > 0 && (
    <section class="ev-upcoming" aria-labelledby="upcoming-heading">
      <div class="container">
        <h2 id="upcoming-heading" class="ev-section-title">Upcoming Events</h2>

        {/* Featured event cards */}
        {featured.length > 0 && (
          <div class="featured-grid">
            {featured.map(event => (
              <article class="featured-card">
                {event.data.image && (
                  <div class="featured-card__image">
                    <img
                      src={cfRaw(event.data.image, 'w=600,h=340,fit=crop,q=85')}
                      srcset={cfSrcset(event.data.image, [400, 600, 800], { fit: 'crop', aspectRatio: 340/600 })}
                      sizes="(max-width: 768px) 100vw, 600px"
                      alt={event.data.title}
                      loading="lazy"
                      decoding="async"
                      width="600"
                      height="340"
                    />
                    <div class="featured-card__date-badge">
                      <span class="featured-card__month">{formatMonth(event.data.date)}</span>
                      <span class="featured-card__day">{formatDay(event.data.date)}</span>
                    </div>
                  </div>
                )}
                {!event.data.image && (
                  <div class="featured-card__date-strip">
                    <span class="featured-card__month">{formatMonth(event.data.date)}</span>
                    <span class="featured-card__day">{formatDay(event.data.date)}</span>
                  </div>
                )}
                <div class="featured-card__body">
                  <div class="featured-card__top">
                    <div class="featured-card__badge" set:html={categoryIcons[event.data.category]} />
                    <div class="featured-card__cat">{categoryLabels[event.data.category]}</div>
                  </div>
                  <h3 class="featured-card__title">{event.data.title}</h3>
                  <div class="featured-card__details">
                    <p class="featured-card__detail">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                      {event.data.location}
                    </p>
                    {event.data.time && (
                      <p class="featured-card__detail">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        {event.data.time}
                      </p>
                    )}
                    {event.data.ticketPrice && (
                      <p class="featured-card__detail">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                        {event.data.ticketPrice}
                      </p>
                    )}
                  </div>
                  <p class="featured-card__desc">{event.data.description}</p>

                  {/* Video embed */}
                  {(event.data.streamVideoId || event.data.videoUrl) && (() => {
                    const streamId = event.data.streamVideoId;
                    const ytId = event.data.videoUrl ? getYouTubeId(event.data.videoUrl) : null;
                    return (
                      <div class="featured-card__video">
                        {streamId ? (
                          <div class="ev-video-facade" data-stream-id={streamId} role="button" tabindex="0" aria-label={`Play ${event.data.title} video`}>
                            <img
                              src={`https://videodelivery.net/${streamId}/thumbnails/thumbnail.jpg?time=2s&height=400`}
                              alt={`Video thumbnail for ${event.data.title}`}
                              loading="lazy" decoding="async" width="640" height="360"
                              class="ev-video-facade__thumb"
                            />
                            <div class="ev-video-facade__play" aria-hidden="true">
                              <svg width="56" height="40" viewBox="0 0 68 48">
                                <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="#FFDA24"/>
                                <path d="M45 24L27 14v20" fill="#373A36"/>
                              </svg>
                            </div>
                          </div>
                        ) : ytId ? (
                          <div class="ev-video-facade" data-yt-id={ytId} role="button" tabindex="0" aria-label={`Play ${event.data.title} video`}>
                            <picture>
                              <source type="image/webp" srcset={`https://i.ytimg.com/vi_webp/${ytId}/maxresdefault.webp`} />
                              <img
                                src={`https://i.ytimg.com/vi/${ytId}/maxresdefault.jpg`}
                                alt={`Video thumbnail for ${event.data.title}`}
                                loading="lazy" decoding="async" width="640" height="360"
                                class="ev-video-facade__thumb"
                              />
                            </picture>
                            <div class="ev-video-facade__play" aria-hidden="true">
                              <svg width="56" height="40" viewBox="0 0 68 48">
                                <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="red"/>
                                <path d="M45 24L27 14v20" fill="#fff"/>
                              </svg>
                            </div>
                          </div>
                        ) : null}
                      </div>
                    );
                  })()}

                  {/* Photo gallery */}
                  {event.data.photos && event.data.photos.length > 0 && (
                    <div class="featured-card__gallery">
                      {event.data.photos.slice(0, 6).map((photo: { id: string; alt: string }, i: number) => (
                        <a href={`${CF_IMAGES}/${photo.id}/w=1200`} target="_blank" rel="noopener" class="featured-card__gallery-item">
                          <img
                            src={`${CF_IMAGES}/${photo.id}/w=200,h=150,fit=crop`}
                            alt={photo.alt || `${event.data.title} photo ${i + 1}`}
                            loading="lazy" decoding="async" width="200" height="150"
                          />
                        </a>
                      ))}
                      {event.data.photos.length > 6 && (
                        <div class="featured-card__gallery-more">+{event.data.photos.length - 6} more</div>
                      )}
                    </div>
                  )}

                  <div class="featured-card__foot">
                    {event.data.ticketUrl ? (
                      <a href={event.data.ticketUrl} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
                        Get Tickets
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
                      </a>
                    ) : (
                      <span class="featured-card__coming-soon">Details coming soon</span>
                    )}
                  </div>
                </div>
              </article>
            ))}
          </div>
        )}

        {/* Non-featured upcoming events */}
        {upcoming.filter(e => !e.data.featured).length > 0 && (
          <div class="ev-list">
            {upcoming.filter(e => !e.data.featured).map(event => (
              <article class="ev-item">
                <div class="ev-item__date">
                  <span class="ev-item__month">{formatMonth(event.data.date)}</span>
                  <span class="ev-item__day">{formatDay(event.data.date)}</span>
                </div>
                {event.data.image ? (
                  <div class="ev-item__thumb">
                    <img
                      src={cfRaw(event.data.image, 'w=120,h=80,fit=crop,q=80')}
                      alt={event.data.title}
                      loading="lazy"
                      width="120"
                      height="80"
                    />
                  </div>
                ) : (
                  <div class="ev-item__icon" set:html={categoryIcons[event.data.category]} />
                )}
                <div class="ev-item__content">
                  <div class="ev-item__meta">
                    <span class="ev-item__tag">{categoryLabels[event.data.category]}</span>
                    <span class="ev-item__sep" aria-hidden="true">&middot;</span>
                    <time class="ev-item__time" datetime={event.data.date}>{formatDate(event.data.date)}</time>
                  </div>
                  <h3 class="ev-item__title">{event.data.title}</h3>
                  <p class="ev-item__location">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    {event.data.location}
                    {event.data.time && <span> &middot; {event.data.time}</span>}
                  </p>
                  <p class="ev-item__desc">{event.data.description}</p>
                  {/* Inline gallery for list items */}
                  {event.data.photos && event.data.photos.length > 0 && (
                    <div class="ev-item__gallery">
                      {event.data.photos.slice(0, 4).map((photo: { id: string; alt: string }, i: number) => (
                        <a href={`${CF_IMAGES}/${photo.id}/w=1200`} target="_blank" rel="noopener" class="ev-item__gallery-thumb">
                          <img src={`${CF_IMAGES}/${photo.id}/w=100,h=72,fit=crop`} alt={photo.alt || ''} loading="lazy" width="100" height="72" />
                        </a>
                      ))}
                      {event.data.photos.length > 4 && (
                        <span class="ev-item__gallery-more">+{event.data.photos.length - 4}</span>
                      )}
                    </div>
                  )}
                  {(event.data.streamVideoId || event.data.videoUrl) && (
                    <div class="ev-item__badges">
                      <span class="ev-item__badge-video">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                        Video
                      </span>
                    </div>
                  )}
                </div>
                {event.data.ticketUrl && (
                  <a href={event.data.ticketUrl} class="ev-item__link" target="_blank" rel="noopener noreferrer" aria-label={`Get tickets for ${event.data.title}`}>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
                  </a>
                )}
              </article>
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  {/* Empty state if no upcoming events */}
  {upcoming.length === 0 && (
    <section class="ev-empty">
      <div class="container container--narrow" style="text-align: center;">
        <div class="ev-empty__icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <h2 class="ev-section-title">No upcoming events</h2>
        <p style="color: var(--c-text-muted); max-width: 480px; margin: 0 auto;">We're planning something special. Follow us on social media or sign up for our newsletter to be the first to know!</p>
      </div>
    </section>
  )}

  <!-- ══════ PAST EVENTS ══════ -->
  {past.length > 0 && (
    <section class="ev-past" aria-labelledby="past-heading">
      <div class="container">
        <h2 id="past-heading" class="ev-section-title">Past Events</h2>
        <div class="ev-list">
          {past.map(event => (
            <article class="ev-item ev-item--past">
              <div class="ev-item__date">
                <span class="ev-item__month">{formatMonth(event.data.date)}</span>
                <span class="ev-item__day">{formatDay(event.data.date)}</span>
              </div>
              {event.data.image ? (
                <div class="ev-item__thumb">
                  <img
                    src={cfRaw(event.data.image, 'w=120,h=80,fit=crop,q=80')}
                    alt={event.data.title}
                    loading="lazy"
                    width="120"
                    height="80"
                  />
                </div>
              ) : (
                <div class="ev-item__icon" set:html={categoryIcons[event.data.category]} />
              )}
              <div class="ev-item__content">
                <div class="ev-item__meta">
                  <span class="ev-item__tag">{categoryLabels[event.data.category]}</span>
                  <span class="ev-item__sep" aria-hidden="true">&middot;</span>
                  <time class="ev-item__time" datetime={event.data.date}>{formatDate(event.data.date)}</time>
                </div>
                <h3 class="ev-item__title">{event.data.title}</h3>
                <p class="ev-item__location">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  {event.data.location}
                </p>
                <p class="ev-item__desc">{event.data.description}</p>
                {/* Inline gallery for past events */}
                {event.data.photos && event.data.photos.length > 0 && (
                  <div class="ev-item__gallery">
                    {event.data.photos.slice(0, 4).map((photo: { id: string; alt: string }, i: number) => (
                      <a href={`${CF_IMAGES}/${photo.id}/w=1200`} target="_blank" rel="noopener" class="ev-item__gallery-thumb">
                        <img src={`${CF_IMAGES}/${photo.id}/w=100,h=72,fit=crop`} alt={photo.alt || ''} loading="lazy" width="100" height="72" />
                      </a>
                    ))}
                    {event.data.photos.length > 4 && (
                      <span class="ev-item__gallery-more">+{event.data.photos.length - 4}</span>
                    )}
                  </div>
                )}
                {(event.data.streamVideoId || event.data.videoUrl) && (
                  <div class="ev-item__badges">
                    <span class="ev-item__badge-video">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                      Video
                    </span>
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ══════ CTA ══════ -->
  <section class="ev-cta">
    <div class="container container--narrow">
      <h2>Want to host an event?</h2>
      <p>Partner with us to organize a fundraiser, volunteer day, or community event that supports children with special needs.</p>
      <div class="ev-cta__actions">
        <a href="mailto:info@soardcharity.com?subject=Event%20Partnership" class="btn btn-primary btn-lg">Contact Us</a>
        <a href="/donate/" class="btn btn-outline">Donate Instead</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ══════ HERO ══════ */
  .ev-hero {
    background: var(--c-warm-gray);
    color: var(--c-text);
    padding: var(--space-5xl) 0 var(--space-3xl);
    text-align: center;
    border-bottom: 1px solid var(--c-border);
  }
  .ev-hero__label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--c-accent);
    margin-bottom: var(--space-md);
  }
  .ev-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: var(--c-text);
    line-height: 1.15;
    max-width: 700px;
    margin: 0 auto;
  }
  .ev-hero__sub {
    margin-top: var(--space-lg);
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--c-text-muted);
    max-width: 600px;
    margin-inline: auto;
    line-height: 1.7;
  }
  .highlight {
    font-style: normal;
    background-image: linear-gradient(transparent 55%, var(--c-yellow-soft) 55%);
  }

  /* ══════ SECTION TITLES ══════ */
  .ev-section-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: var(--space-2xl);
  }

  /* ══════ UPCOMING ══════ */
  .ev-upcoming {
    padding: var(--space-4xl) 0;
  }
  .ev-empty {
    padding: var(--space-4xl) 0;
  }
  .ev-empty__icon {
    color: var(--c-text-light);
    margin-bottom: var(--space-lg);
  }

  /* ══════ FEATURED CARDS ══════ */
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(400px, 100%), 1fr));
    gap: var(--space-xl);
    margin-bottom: var(--space-3xl);
  }
  .featured-card {
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }
  .featured-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }
  .featured-card__image {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
  }
  .featured-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .featured-card__image .featured-card__date-badge {
    position: absolute;
    top: var(--space-md);
    left: var(--space-md);
  }
  .featured-card__date-badge {
    background: var(--c-yellow);
