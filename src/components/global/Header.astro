---
/**
 * Header.astro — Best-in-class navigation v2
 *
 * Design:
 *   - Glassmorphism header with backdrop-filter blur
 *   - Animated sliding indicator under active/hovered nav items
 *   - Rich mega-dropdown panels with icons, descriptions, accent borders
 *   - Premium Donate CTA with heartbeat pulse
 *   - Full-screen mobile takeover with editorial typography
 *   - Staggered cascade entry animations
 *
 * Accessibility (preserved from v1):
 *   - Skip-to-content link (first focusable element)
 *   - Focus trap: Tab cycles within open mobile menu only
 *   - Full arrow-key keyboard nav on desktop dropdowns (WAI-ARIA menubar)
 *   - inert: page content behind menu is inert when open
 *   - aria-expanded, aria-controls, aria-label, aria-hidden
 *   - Escape key closes menu / dropdown
 *   - prefers-reduced-motion: instant transitions
 *   - 44px+ touch targets on every interactive element
 *   - External links visually indicated + target="_blank"
 *   - Parent nav items show active state for child pages
 *
 * Performance:
 *   - ~140 lines vanilla JS, no framework
 *   - All transitions on transform/opacity only (GPU composited)
 *   - will-change: transform on panel + header
 *   - Passive touch/scroll listeners
 */
const currentPath = Astro.url.pathname;

interface NavChild {
  label: string;
  href: string;
  external?: boolean;
  desc?: string;
  icon?: string;
}

interface NavGroup {
  label: string;
  children: NavChild[];
}

const nav: NavGroup[] = [
  {
    label: 'About',
    children: [
      { label: 'Our Story', href: '/about/', desc: 'How it all began', icon: '📖' },
      { label: 'Leadership', href: '/about/leadership/', desc: 'Meet the team', icon: '👥' },
      { label: 'Financials', href: '/about/financials/', desc: 'Full transparency', icon: '📊' },
    ],
  },
  {
    label: 'Kids & Projects',
    children: [
      { label: 'Featured Rooms', href: '/rooms/', desc: 'Dream rooms revealed', icon: '✨' },
      { label: 'Meet the Kids', href: '/kids/', desc: 'Stories of joy', icon: '💛' },
      { label: 'Community Projects', href: '/rooms/community/', desc: 'Beyond bedrooms', icon: '🏘️' },
    ],
  },
  {
    label: 'Our Partners',
    children: [
      { label: 'Our Partners', href: '/partners/', desc: 'Who makes it happen', icon: '🤝' },
      { label: 'Construction Partners', href: '/partners/construction/', desc: 'Builders & contractors', icon: '🔨' },
      { label: 'Design Partners', href: '/partners/design/', desc: 'Designers & brands', icon: '🎨' },
    ],
  },
  {
    label: 'Get Involved',
    children: [
      { label: 'Events', href: 'https://www.sunnyandranney.com/events', external: true, desc: 'Upcoming gatherings', icon: '📅' },
      { label: 'Donate', href: '/donate/', desc: 'Change a life today', icon: '❤️' },
      { label: '2026 Application', href: '/apply/', desc: 'Apply for a room', icon: '📝' },
    ],
  },
  {
    label: 'Shop Our Stores',
    children: [
      { label: 'Sunny & Ranney', href: 'https://www.sunnyandranney.com', external: true, desc: 'Home & décor store', icon: '🏠' },
      { label: 'Partly Sunny', href: 'https://partlysunnystore.com', external: true, desc: 'Clothing & gifts', icon: '👕' },
    ],
  },
];

function isActive(href: string) {
  if (href.startsWith('http')) return false;
  return currentPath === href;
}

function isGroupActive(group: NavGroup) {
  return group.children.some((child) => isActive(child.href));
}
---

<!-- Skip Navigation -->
<a href="#main-content" class="skip-nav">Skip to main content</a>

<header class="site-header" id="site-header">
  <div class="header-inner">
    <!-- Logo -->
    <a href="/" class="logo" aria-label="Sunshine on a Ranney Day — Home">
      <picture>
        <source srcset="/images/logos/sunny-pig-transparent.webp" type="image/webp" />
        <img
          src="/images/logos/sunny-pig-transparent.png"
          alt=""
          class="logo-icon"
          width="96"
          height="34"
          loading="eager"
          fetchpriority="high"
        />
      </picture>
      <span class="logo-text">
        <span class="logo-line1">Sunshine on a</span>
        <span class="logo-line2">Ranney Day</span>
      </span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="desktop-nav" aria-label="Main navigation">
      <ul class="nav-list" role="menubar">
        {nav.map((item, groupIndex) => (
          <li
            class:list={['nav-item', 'has-dropdown', { 'group-active': isGroupActive(item) }]}
            role="none"
            data-nav-group={groupIndex}
          >
            <button
              class:list={['nav-link', { 'parent-active': isGroupActive(item) }]}
              role="menuitem"
              aria-haspopup="true"
              aria-expanded="false"
              tabindex={groupIndex === 0 ? '0' : '-1'}
            >
              <span class="nav-link-text">{item.label}</span>
              <svg class="chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="dropdown" role="menu" id={`dropdown-${groupIndex}`}>
              <div class="dropdown-inner">
                {item.children.map((child, childIndex) => (
                  <a
                    href={child.href}
                    role="menuitem"
                    class:list={['dropdown-link', { active: isActive(child.href) }]}
                    tabindex="-1"
                    data-child-index={childIndex}
                    {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  >
                    <span class="dropdown-link-icon" aria-hidden="true">{child.icon}</span>
                    <span class="dropdown-link-content">
                      <span class="dropdown-link-label">
                        {child.label}
                        {child.external && (
                          <svg class="external-icon" width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                            <path d="M4.5 1.5H1.5V10.5H10.5V7.5M7 1.5H10.5M10.5 1.5V5M10.5 1.5L5.5 6.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        )}
                      </span>
                      {child.desc && <span class="dropdown-link-desc">{child.desc}</span>}
                    </span>
                  </a>
                ))}
              </div>
            </div>
          </li>
        ))}
      </ul>
      <!-- Sliding indicator bar -->
      <div class="nav-indicator" id="nav-indicator" aria-hidden="true"></div>
    </nav>

    <!-- Donate CTA (desktop) -->
    <a href="/donate/" class="header-cta">
      <span class="header-cta-heart" aria-hidden="true">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
      </span>
      Donate
    </a>

    <!-- Mobile hamburger -->
    <button
      type="button"
      class="mobile-toggle"
      id="mobile-toggle-btn"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-nav-panel"
    >
      <span class="hamburger" aria-hidden="true">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </span>
    </button>
  </div>
</header>

<!-- Full-screen mobile nav -->
<div
  class="mobile-nav"
  id="mobile-nav-panel"
  role="dialog"
  aria-label="Mobile navigation"
  aria-modal="true"
  aria-hidden="true"
>
  <div class="mobile-nav-header">
    <a href="/" class="mobile-nav-logo" aria-label="Sunshine on a Ranney Day — Home">
      <picture>
        <source srcset="/images/logos/logo-dark-bg.webp" type="image/webp" />
        <img src="/images/logos/logo-dark-bg.png" alt="Sunshine on a Ranney Day" width="80" height="80" loading="eager" />
      </picture>
    </a>
    <button type="button" class="mobile-close-btn" id="mobile-close-btn" aria-label="Close menu">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <path d="M17 5L5 17M5 5L17 17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <div class="mobile-nav-body">
    <ul class="mobile-nav-list">
      {nav.map((item, i) => (
        <li class="mobile-nav-group" style={`--stagger: ${i}`}>
          <span class="mobile-nav-heading">{item.label}</span>
          <ul>
            {item.children.map((child) => (
              <li>
                <a
                  href={child.href}
                  class:list={['mobile-nav-link', { active: isActive(child.href) }]}
                  {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  <span class="mobile-nav-link-icon" aria-hidden="true">{child.icon}</span>
                  <span class="mobile-nav-link-text">{child.label}</span>
                  {child.external && (
                    <svg class="mobile-external-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-label="Opens in new tab">
                      <path d="M5.25 2H2V12H12V8.75M8.5 2H12M12 2V5.5M12 2L6.5 7.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ul>
  </div>

  <div class="mobile-nav-footer">
    <a href="/donate/" class="mobile-donate-btn">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="flex-shrink:0;">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
      Donate Now
    </a>
  </div>
</div>

<script>
  (function () {
    /* ═══════════════════════════════════════════
       MOBILE NAVIGATION — Full-screen takeover
       ═══════════════════════════════════════════ */
    var btn = document.getElementById('mobile-toggle-btn');
    var panel = document.getElementById('mobile-nav-panel');
    var header = document.getElementById('site-header');
    var closeBtn = document.getElementById('mobile-close-btn');
    var mainEl = document.querySelector('main');
    var footerEl = document.querySelector('footer');
    if (!btn || !panel || !header) return;

    var isOpen = false;
    var savedScrollY = 0;

    function getFocusable() {
      return [closeBtn].concat(
        Array.from(panel.querySelectorAll('a, button:not(#mobile-close-btn)'))
      ).filter(Boolean);
    }

    function openMenu() {
      isOpen = true;
      savedScrollY = window.scrollY;
      document.body.style.position = 'fixed';
      document.body.style.top = '-' + savedScrollY + 'px';
      document.body.style.left = '0';
      document.body.style.right = '0';
      document.body.style.overflow = 'hidden';

      btn.setAttribute('aria-expanded', 'true');
      btn.setAttribute('aria-label', 'Close menu');
      panel.classList.add('is-open');
      panel.setAttribute('aria-hidden', 'false');

      if (mainEl) mainEl.setAttribute('inert', '');
      if (footerEl) footerEl.setAttribute('inert', '');
      if (closeBtn) closeBtn.focus();
    }

    function closeMenu() {
      isOpen = false;
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.left = '';
      document.body.style.right = '';
      document.body.style.overflow = '';
      window.scrollTo(0, savedScrollY);

      btn.setAttribute('aria-expanded', 'false');
      btn.setAttribute('aria-label', 'Open menu');
      panel.classList.remove('is-open');
      panel.setAttribute('aria-hidden', 'true');

      if (mainEl) mainEl.removeAttribute('inert');
      if (footerEl) footerEl.removeAttribute('inert');
      btn.focus();
    }

    btn.addEventListener('click', function () { isOpen ? closeMenu() : openMenu(); });
    if (closeBtn) closeBtn.addEventListener('click', closeMenu);

    document.addEventListener('keydown', function (e) {
      if (!isOpen) return;
      if (e.key === 'Escape') { closeMenu(); return; }
      if (e.key === 'Tab') {
        var focusable = getFocusable();
        var first = focusable[0];
        var last = focusable[focusable.length - 1];
        if (e.shiftKey) {
          if (document.activeElement === first) { e.preventDefault(); last.focus(); }
        } else {
          if (document.activeElement === last) { e.preventDefault(); first.focus(); }
        }
      }
    });

    window.matchMedia('(min-width: 1024px)').addEventListener('change', function (e) {
      if (e.matches && isOpen) closeMenu();
    });

    panel.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', closeMenu);
    });

    // Swipe down to close
    var touchStartY = 0;
    var swiping = false;
    panel.addEventListener('touchstart', function (e) {
      touchStartY = e.touches[0].clientY; swiping = true;
    }, { passive: true });
    panel.addEventListener('touchmove', function (e) {
      if (!swiping) return;
      if (e.touches[0].clientY - touchStartY > 80) { swiping = false; closeMenu(); }
    }, { passive: true });
    panel.addEventListener('touchend', function () { swiping = false; }, { passive: true });

    /* ═══════════════════════════════════════════
       HEADER SCROLL BEHAVIOR
       ═══════════════════════════════════════════ */
    var lastScrollY = 0;
    var scrollTicking = false;
    var scrollThreshold = 8;

    function onScroll() {
      scrollTicking = false;
      var currentY = window.scrollY;
      var delta = currentY - lastScrollY;

      if (currentY > 20) {
        header.classList.add('header--scrolled');
      } else {
        header.classList.remove('header--scrolled');
      }

      if (currentY <= 10) {
        header.classList.remove('header--hidden');
        lastScrollY = currentY;
        return;
      }

      if (isOpen) { lastScrollY = currentY; return; }

      if (delta > scrollThreshold) {
        header.classList.add('header--hidden');
      } else if (delta < -scrollThreshold) {
        header.classList.remove('header--hidden');
      }

      lastScrollY = currentY;
    }

    window.addEventListener('scroll', function () {
      if (!scrollTicking) { requestAnimationFrame(onScroll); scrollTicking = true; }
    }, { passive: true });

    /* ═══════════════════════════════════════════
       DESKTOP DROPDOWN — KEYBOARD NAV
       ═══════════════════════════════════════════ */
    var navItems = document.querySelectorAll('.nav-item[data-nav-group]');
    var navButtons = document.querySelectorAll('.nav-item .nav-link');

    function openDropdown(groupEl) {
      var button = groupEl.querySelector('.nav-link');
      if (!button) return;
      button.setAttribute('aria-expanded', 'true');
      groupEl.classList.add('dropdown-open');
    }

    function closeDropdown(groupEl) {
      var button = groupEl.querySelector('.nav-link');
      if (!button) return;
      button.setAttribute('aria-expanded', 'false');
      groupEl.classList.remove('dropdown-open');
    }

    function closeAllDropdowns() {
      navItems.forEach(function (item) { closeDropdown(item); });
    }

    function getDropdownLinks(groupEl) {
      return Array.from(groupEl.querySelectorAll('.dropdown-link'));
    }

    var navList = document.querySelector('.nav-list');
    if (navList) {
      navList.addEventListener('keydown', function (e) {
        var target = e.target;
        var isButton = target.classList.contains('nav-link');
        var isDropdownLink = target.classList.contains('dropdown-link');
        var parentGroup = target.closest('.nav-item[data-nav-group]');
        if (!parentGroup) return;
        var groupIndex = parseInt(parentGroup.dataset.navGroup);

        if (isButton) {
          switch (e.key) {
            case 'ArrowRight': {
              e.preventDefault(); closeAllDropdowns();
              var next = navItems[(groupIndex + 1) % navItems.length];
              var nextBtn = next.querySelector('.nav-link');
              navButtons.forEach(function (b) { b.setAttribute('tabindex', '-1'); });
              nextBtn.setAttribute('tabindex', '0'); nextBtn.focus();
              break;
            }
            case 'ArrowLeft': {
              e.preventDefault(); closeAllDropdowns();
              var prev = navItems[(groupIndex - 1 + navItems.length) % navItems.length];
              var prevBtn = prev.querySelector('.nav-link');
              navButtons.forEach(function (b) { b.setAttribute('tabindex', '-1'); });
              prevBtn.setAttribute('tabindex', '0'); prevBtn.focus();
              break;
            }
            case 'ArrowDown': case 'Enter': case ' ': {
              e.preventDefault(); openDropdown(parentGroup);
              var links = getDropdownLinks(parentGroup);
              if (links.length) links[0].focus();
              break;
            }
            case 'Escape': {
              e.preventDefault(); closeAllDropdowns(); target.focus();
              break;
            }
          }
        } else if (isDropdownLink) {
          var links = getDropdownLinks(parentGroup);
          var idx = links.indexOf(target);
          switch (e.key) {
            case 'ArrowDown': {
              e.preventDefault(); links[(idx + 1) % links.length].focus(); break;
            }
            case 'ArrowUp': {
              e.preventDefault();
              if (idx === 0) { closeDropdown(parentGroup); parentGroup.querySelector('.nav-link').focus(); }
              else { links[idx - 1].focus(); }
              break;
            }
            case 'ArrowRight': {
              e.preventDefault(); closeDropdown(parentGroup);
              var nG = navItems[(groupIndex + 1) % navItems.length];
              openDropdown(nG);
              navButtons.forEach(function (b) { b.setAttribute('tabindex', '-1'); });
              nG.querySelector('.nav-link').setAttribute('tabindex', '0');
              var nL = getDropdownLinks(nG); if (nL.length) nL[0].focus();
              break;
            }
            case 'ArrowLeft': {
              e.preventDefault(); closeDropdown(parentGroup);
              var pG = navItems[(groupIndex - 1 + navItems.length) % navItems.length];
              openDropdown(pG);
              navButtons.forEach(function (b) { b.setAttribute('tabindex', '-1'); });
              pG.querySelector('.nav-link').setAttribute('tabindex', '0');
              var pL = getDropdownLinks(pG); if (pL.length) pL[0].focus();
              break;
            }
            case 'Escape': {
              e.preventDefault(); closeDropdown(parentGroup);
              parentGroup.querySelector('.nav-link').focus();
              break;
            }
            case 'Home': { e.preventDefault(); if (links.length) links[0].focus(); break; }
            case 'End': { e.preventDefault(); if (links.length) links[links.length - 1].focus(); break; }
            case 'Tab': { closeAllDropdowns(); break; }
          }
        }
      });
    }

    document.addEventListener('click', function (e) {
      if (!e.target.closest('.nav-item')) closeAllDropdowns();
    });

    /* ═══════════════════════════════════════════
       HOVER INTENT with grace delay
       ═══════════════════════════════════════════ */
    navItems.forEach(function (item) {
      var closeTimer = null;
      var GRACE_DELAY = 200;

      item.addEventListener('mouseenter', function () {
        if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
        navItems.forEach(function (other) {
          if (other !== item) closeDropdown(other);
        });
        openDropdown(item);
      });

      item.addEventListener('mouseleave', function () {
        closeTimer = setTimeout(function () {
          closeDropdown(item); closeTimer = null;
        }, GRACE_DELAY);
      });
    });

    /* ═══════════════════════════════════════════
       SLIDING NAV INDICATOR
       ═══════════════════════════════════════════ */
    var indicator = document.getElementById('nav-indicator');
    var desktopNav = document.querySelector('.desktop-nav');

    function positionIndicator(el) {
      if (!indicator || !desktopNav) return;
      var navRect = desktopNav.getBoundingClientRect();
      var elRect = el.getBoundingClientRect();
      indicator.style.width = elRect.width + 'px';
      indicator.style.transform = 'translateX(' + (elRect.left - navRect.left) + 'px)';
      indicator.style.opacity = '1';
    }

    function hideIndicator() {
      if (!indicator) return;
      var activeBtn = document.querySelector('.nav-link.parent-active');
      if (activeBtn) { positionIndicator(activeBtn); }
      else { indicator.style.opacity = '0'; }
    }

    navButtons.forEach(function (navBtn) {
      navBtn.addEventListener('mouseenter', function () { positionIndicator(this); });
    });

    if (desktopNav) { desktopNav.addEventListener('mouseleave', hideIndicator); }

    // Set indicator on active item at load
    requestAnimationFrame(function () {
      var activeBtn = document.querySelector('.nav-link.parent-active');
      if (activeBtn && indicator) {
        indicator.style.transition = 'none';
        positionIndicator(activeBtn);
        requestAnimationFrame(function () { indicator.style.transition = ''; });
      }
    });
  })();
</script>

<style>
  /* ─── Skip Navigation ──────────────────── */
  .skip-nav {
    position: fixed;
    top: -100%;
    left: var(--space-md);
    z-index: 10000;
    padding: var(--space-sm) var(--space-lg);
    background: var(--c-yellow);
    color: var(--c-dark);
    font-weight: 700;
    font-size: 0.875rem;
    border-radius: 0 0 var(--border-radius) var(--border-radius);
    text-decoration: none;
    box-shadow: var(--shadow-lg);
    transition: top 0.15s ease;
  }

  .skip-nav:focus {
    top: 0;
    outline: 3px solid var(--c-accent);
    outline-offset: 2px;
  }

  /* ─── Header Shell — Glass effect ──────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: rgba(45, 46, 51, 0.92);
    backdrop-filter: blur(20px) saturate(1.2);
    -webkit-backdrop-filter: blur(20px) saturate(1.2);
    height: var(--header-height);
    border-bottom: 3px solid var(--c-yellow);
    will-change: transform;
    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1),
                background 0.3s ease,
                box-shadow 0.3s ease;
  }

  .site-header.header--scrolled {
    background: rgba(45, 46, 51, 0.97);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);
  }

  .site-header.header--hidden {
    transform: translateY(-100%);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding-inline: var(--space-lg);
    max-width: var(--max-width-wide);
    margin-inline: auto;
  }

  /* ─── Logo ─────────────────────────────── */
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .logo:hover { opacity: 0.88; }

  .logo-icon {
    height: 38px;
    width: auto;
    flex-shrink: 0;
  }

  .logo-text {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--c-yellow);
    line-height: 1.1;
    display: flex;
    flex-direction: column;
  }

  .logo-line1 {
    font-size: 0.6875rem;
    letter-spacing: 0.02em;
  }

  .logo-line2 {
    font-size: 0.875rem;
    letter-spacing: 0.01em;
  }

  @media (min-width: 481px) {
    .logo-icon { height: 42px; }
    .logo-line1 { font-size: 0.75rem; }
    .logo-line2 { font-size: 0.9375rem; }
  }

  @media (min-width: 1024px) {
    .logo-icon { height: 46px; }
    .logo-line1 { font-size: 0.8125rem; }
    .logo-line2 { font-size: 1rem; }
  }

