---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import { CF_BASE as CF } from '../utils/cf-image';
---

<BaseLayout title="Page Not Found" description="This page doesn't exist. Browse our kid stories, donate, or explore what Sunshine on a Ranney Day does for children with special needs." noindex={true}>
  <section class="lost">
    <div class="container">
      <div class="hero-404">
        <span class="digit">4</span>
        <div class="gracie-zone" id="gracie-zone">
          <img
            src={`${CF}/sunny-pig/w=280,h=280,fit=cover`}
            srcset={`${CF}/sunny-pig/w=160,h=160,fit=cover 160w, ${CF}/sunny-pig/w=280,h=280,fit=cover 280w`}
            sizes="(max-width: 600px) 140px, 240px"
            alt="Gracie the Pig — SOARD's golden flying mascot"
            width="280"
            height="280"
            class="gracie"
            id="gracie"
            loading="eager"
            decoding="async"
          />
        </div>
        <span class="digit">4</span>
      </div>

      <h1 class="title" id="title">Gracie flew off&nbsp;course!</h1>

      <p class="subtitle">
        This page hasn't been built yet — but don't worry,
        <br />Gracie always finds her way home.
      </p>

      <div class="actions">
        <Button href="/" size="lg">Fly Home</Button>
        <Button href="/kids/" variant="outline" size="lg">Meet the Kids</Button>
      </div>

      <nav class="explore" aria-label="Quick links">
        <a href="/about/">Our Story</a>
        <a href="/donate/">Donate</a>
        <a href="/apply/">Apply</a>
        <a href="/resources/">Resources</a>
        <a href="/faq/">FAQs</a>
        <a href="/events/">Events</a>
      </nav>
    </div>
  </section>
</BaseLayout>

<script>
  const lines = [
    "Gracie flew off\u00a0course!",
    "Oink! Wrong\u00a0turn!",
    "This room hasn't been built\u00a0yet!",
    "Even flying pigs get\u00a0lost!",
    "Hold my cape, I'll find\u00a0it!",
  ];
  let i = 0, busy = false;

  function init() {
    const pig = document.getElementById('gracie');
    const zone = document.getElementById('gracie-zone');
    const h1 = document.getElementById('title');
    if (!pig || !zone || !h1) return;

    pig.addEventListener('click', () => {
      if (busy) return;
      busy = true;
      zone.classList.add('spin');
      i = (i + 1) % lines.length;
      h1.style.opacity = '0';
      h1.style.transform = 'translateY(6px)';
      setTimeout(() => {
        h1.textContent = lines[i];
        h1.style.opacity = '1';
        h1.style.transform = 'translateY(0)';
      }, 180);
      setTimeout(() => { zone.classList.remove('spin'); busy = false; }, 600);
    });
  }

  document.addEventListener('astro:page-load', init);
  init();
</script>

<style>
  .lost {
    min-height: calc(100vh - var(--header-height));
    min-height: calc(100dvh - var(--header-height));
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2xl) var(--page-padding);
    background: var(--c-cream);
  }

  .container {
    text-align: center;
    max-width: 560px;
  }

  /* ── 4 · Gracie · 4 ─────────────────────── */
  .hero-404 {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(0.25rem, 2vw, 1rem);
    margin-bottom: var(--space-lg);
  }

  .digit {
    font-family: var(--font-display);
    font-size: clamp(7rem, 22vw, 15rem);
    font-weight: 700;
    line-height: 1;
    color: var(--c-dark-deep);
    user-select: none;
  }

  /* ── Gracie ──────────────────────────────── */
  .gracie-zone {
    position: relative;
    flex-shrink: 0;
    cursor: pointer;
  }

  .gracie {
    position: relative;
    width: clamp(110px, 28vw, 240px);
    height: auto;
    display: block;
    border-radius: 50%;
    animation: float 4s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-10px); }
  }

  /* Click spin */
  .gracie-zone.spin .gracie {
    animation: spin 0.55s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes spin {
    0%   { transform: rotate(0deg) scale(1); }
    40%  { transform: rotate(-15deg) scale(1.1); }
    100% { transform: rotate(360deg) scale(1); }
  }

  /* ── Copy ────────────────────────────────── */
  .title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 4vw, 2.1rem);
    font-weight: 700;
    color: var(--c-dark);
    margin-bottom: var(--space-sm);
    transition: opacity 0.18s ease, transform 0.18s ease;
    /* Yellow highlight */
    background-image: linear-gradient(transparent 55%, var(--c-yellow-soft) 55%);
    display: inline;
  }

  .subtitle {
    font-family: var(--font-body);
    font-size: clamp(0.95rem, 2.5vw, 1.08rem);
    color: var(--c-text-muted);
    line-height: 1.7;
    margin: var(--space-md) auto var(--space-xl);
    max-width: 400px;
  }

  /* ── Buttons ─────────────────────────────── */
  .actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-2xl);
  }

  /* ── Quick links ─────────────────────────── */
  .explore {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .explore a {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--c-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .explore a:hover {
    color: var(--c-dark);
  }

  /* ── Reduced motion ──────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .gracie { animation: none; }
  }
</style>
