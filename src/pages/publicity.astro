---
/**
 * Publicity Page — Sunshine on a Ranney Day
 *
 * Editorial magazine-spread. Restraint over decoration.
 *
 * Design ceiling patterns used:
 * - Edge-to-edge split (homepage featured story)
 * - Horizontal scroll carousel with scroll-snap (homepage kids strip)
 * - Sticky photo column (homepage process section)
 * - Overlapping photo composition (homepage mission)
 * - Staggered cascade reveals with cubic-bezier spring
 * - YouTube click-to-load facade with preconnect warming
 * - Native <details> for collapsible year groups (donate FAQ)
 * - JSON-LD CollectionPage + NewsArticle structured data
 */
import PageLayout from '../layouts/PageLayout.astro';
import MediaLogos from '../components/ui/MediaLogos.astro';
import CFImage from '../components/ui/CFImage.astro';
import { CF_BASE as CF } from '../utils/cf-image';
import { getCollection } from 'astro:content';

const allPress = await getCollection('press');
const press = allPress.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const featured = press.filter(p => p.data.featured);
const featuredCards = featured.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
const featuredSlugs = new Set(featured.map(p => p.id));
const archivePress = press.filter(p => !featuredSlugs.has(p.id));

const years = [...new Set(archivePress.map(p => new Date(p.data.date).getFullYear()))].sort((a, b) => b - a);
const pressByYear: Record<number, typeof archivePress> = {};
years.forEach(y => { pressByYear[y] = archivePress.filter(p => new Date(p.data.date).getFullYear() === y); });

const categories = ['all', 'national-tv', 'local-tv', 'print', 'magazine', 'entertainment'] as const;
const categoryLabels: Record<string, string> = {
  'all': 'All', 'national-tv': 'National TV', 'local-tv': 'Local TV',
  'print': 'Print & Online', 'magazine': 'Magazine', 'entertainment': 'Entertainment',
};

function formatDate(dateStr: string): string {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
}
const celebrities = [
  { name: 'Atlanta Braves', desc: 'Holly & Peter honored as Community Heroes with a $5,000 donation from players Dansby Swanson, Max Fried, Charlie Culberson & Ender Inciarte.', imageId: 'press-braves-community-heroes', type: 'Community Heroes' },
  { name: 'Coach Nick Saban', desc: 'Coach Saban surprised cancer survivor Ally with a meeting with her favorite coach.', imageId: 'press-nick-saban-ally', type: 'Celebrity Surprise' },
  { name: 'Atlanta Hawks', desc: 'Dominique Wilkins, Tim Hardaway Jr. & more surprised Kalen with his Hawks-themed dream bedroom.', imageId: 'press-hawks-kalen-wilkins', type: 'Celebrity Surprise' },
  { name: 'Coach Kirby Smart', desc: 'Supported by the UGA community and their football coach and family.', imageId: 'press-kirby-smart-uga', type: 'Community Partner' },
  { name: 'Atlanta Falcons', desc: 'Peter & Holly honored as Everyday Heroes by the Falcons.', imageId: 'press-falcons-everyday-heroes', type: 'Everyday Heroes' },
  { name: "TLC's Say Yes to the Dress", desc: "Lori & Monte helped with makeovers fit for princesses.", imageId: 'press-tlc-lori-monte', type: 'Celebrity Partner' },
  { name: 'Coy Bowles — Zac Brown Band', desc: "Grammy-winning guitarist surprised Ruby in her new ballet studio.", imageId: 'press-coy-bowles-ruby', type: 'Celebrity Surprise' },
  { name: 'Governor Nathan Deal', desc: "Governor & Mrs. Deal attended the Evening of Sunshine Gala.", imageId: 'press-governor-deal-gala', type: 'Evening of Sunshine' },
];

const totalPress = press.length;
const tvCount = press.filter(p => p.data.category === 'national-tv' || p.data.category === 'local-tv').length;
const uniqueOutlets = new Set(press.map(p => p.data.outlet)).size;

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'CollectionPage',
  name: 'Publicity & Media Coverage',
  description: `Featured on the Today Show, WSB-TV, 11Alive, Fox 5, AJC, K-LOVE, and ${totalPress}+ media outlets.`,
  url: 'https://sunshineonaranneyday.com/publicity',
  mainEntity: { '@type': 'ItemList', numberOfItems: totalPress,
    itemListElement: featured.slice(0, 8).map((item, i) => ({
      '@type': 'ListItem', position: i + 1,
      item: { '@type': 'NewsArticle', headline: item.data.title,
        publisher: { '@type': 'Organization', name: item.data.outlet },
        datePublished: item.data.date, url: item.data.url },
    })),
  },
};
const breadcrumbs = [{ name: 'Home', url: '/' }, { name: 'Publicity', url: '/publicity' }];
---

<PageLayout
  title="In the News — Today Show, Atlanta Braves & More"
  description={`Featured on the Today Show, WSB-TV, 11Alive, Fox 5, AJC, K-LOVE, and ${totalPress}+ outlets. See our media coverage and press highlights.`}
  heroLabel="In the Spotlight"
  heroTitle={'Our story, told by <em class="highlight">those who know it best</em>.'}
  heroSubtitle="From the Today Show to Coach Saban, from the Atlanta Braves to K-LOVE — the world is helping us share the mission of building dreams for children with special needs."
  jsonLd={jsonLd}
  breadcrumbs={breadcrumbs}
>

  <!-- ════ STATS ════ -->
  <section class="stats" aria-label="Media impact" data-reveal>
    <div class="container">
      <div class="stats__row">
        <div class="stats__item">
          <span class="stats__num">{totalPress}+</span>
          <span class="stats__label">Media Features</span>
        </div>
        <span class="stats__div" aria-hidden="true"></span>
        <div class="stats__item">
          <span class="stats__num">{uniqueOutlets}+</span>
          <span class="stats__label">Outlets</span>
        </div>
        <span class="stats__div" aria-hidden="true"></span>
        <div class="stats__item">
          <span class="stats__num">{tvCount}</span>
          <span class="stats__label">TV Segments</span>
        </div>
        <span class="stats__div" aria-hidden="true"></span>
        <div class="stats__item">
          <span class="stats__num">2</span>
          <span class="stats__label">National TV</span>
        </div>
      </div>
    </div>
  </section>

  <MediaLogos theme="dark" linked={false} />

  <!-- ════ FEATURED PRESS — HERO (dark cinematic) ════ -->
  {featuredCards[0] && (() => {
    const d = featuredCards[0].data;
    const headline = d.featuredHeadline || d.title;
    const desc = d.featuredDescription || d.excerpt;
    return (
      <section class="fph" aria-labelledby="fph-heading">
        <div class="fph__split">
          <figure class="fph__media">
            {d.videoId ? (
              <div class="fph__frame" data-yt-wrap>
                <img
                  src={`https://i.ytimg.com/vi/${d.videoId}/maxresdefault.jpg`}
                  alt={headline}
                  width="1280" height="720" loading="eager" decoding="async"
                  class="fph__poster"
                />
                <button class="fph__play" aria-label={`Play ${d.outlet} video`} data-yt-id={d.videoId}>
                  <span class="fph__play-ring">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                  </span>
                </button>
              </div>
            ) : d.image ? (
              <img
                src={`${d.image}/w=1200,h=800,fit=cover,q=80`}
                srcset={`${d.image}/w=800,q=70 800w, ${d.image}/w=1200,q=80 1200w`}
                sizes="(max-width:1024px) 100vw, 58vw"
                alt={headline} width="1200" height="800" loading="eager" decoding="async"
                class="fph__img"
              />
            ) : null}
            <span class="fph__badge">Featured</span>
          </figure>
          <div class="fph__body" data-reveal>
            <span class="fph__outlet">{d.outlet}</span>
            <h2 id="fph-heading" class="fph__title">{headline}</h2>
            <p class="fph__desc">{desc}</p>
            <time class="fph__date" datetime={d.date}>{formatDate(d.date)}</time>
            <a href={d.url} class="btn btn-yellow" target="_blank" rel="noopener noreferrer">Read the Story →</a>
          </div>
        </div>
      </section>
    );
  })()}

  <!-- ════ FEATURED PRESS — EDITORIAL ALTERNATING ════ -->
  {featuredCards.length > 1 && (
    <section class="fpe" aria-label="More featured press">
      <div class="fpe__inner">
        {featuredCards.slice(1).map((item, i) => {
          const d = item.data;
          const headline = d.featuredHeadline || d.title;
          const desc = d.featuredDescription || d.excerpt;
          const flipped = i % 2 !== 0;
          return (
            <article class={`fpe__item ${flipped ? 'fpe__item--flip' : ''}`} data-reveal>
              <figure class="fpe__media">
                {d.videoId ? (
                  <div class="fpe__frame" data-yt-wrap>
                    <img
                      src={`https://i.ytimg.com/vi/${d.videoId}/maxresdefault.jpg`}
                      alt={headline}
                      width="1280" height="720" loading="lazy" decoding="async"
                      class="fpe__poster"
                    />
                    <button class="fpe__play-btn" aria-label={`Play ${d.outlet} video`} data-yt-id={d.videoId}>
                      <span class="fph__play-ring">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                      </span>
                    </button>
                  </div>
                ) : d.image ? (
                  <img
                    src={`${d.image}/w=900,h=600,fit=cover,q=75`}
                    srcset={`${d.image}/w=600,q=65 600w, ${d.image}/w=900,q=75 900w`}
                    sizes="(max-width:768px) 100vw, 50vw"
                    alt={headline} width="900" height="600" loading="lazy" decoding="async"
                    class="fpe__img"
                  />
                ) : null}
              </figure>
              <div class="fpe__body">
                <span class="fpe__num" aria-hidden="true">{String(i + 2).padStart(2, '0')}</span>
                <span class="fpe__outlet">{d.outlet}</span>
                <h3 class="fpe__title">{headline}</h3>
                <p class="fpe__desc">{desc}</p>
                <div class="fpe__foot">
                  <time datetime={d.date}>{formatDate(d.date)}</time>
                  <a href={d.url} class="fpe__link" target="_blank" rel="noopener noreferrer">
                    Read the story <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
                  </a>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </section>
  )}

  <!-- ════ CELEBRITY SUPPORTERS — HORIZONTAL SCROLL ════ -->
  <section class="celebs" aria-labelledby="celebs-heading">
    <div class="celebs__header" data-reveal>
      <div>
        <div class="section-label">Notable Supporters</div>
        <h2 id="celebs-heading">Championed by <em class="highlight">Atlanta's best</em></h2>
      </div>
      <p class="celebs__sub">From coaches and athletes to TV personalities and Georgia's governor.</p>
    </div>
    <div class="celebs__scroll-wrap">
      <ul class="celebs__scroll">
        {celebrities.map(c => (
          <li class="celebs__item">
            <div class="celebs__card">
              <div class="celebs__photo">
                <CFImage
                  src={`${CF}/${c.imageId}/public`}
                  alt={c.name}
                  width={440} height={520}
                  sizes="320px"
                  widths={[320, 440, 640]}
                  fit="cover"
                  gravity="face"
                  class="celebs__img"
                />
                <div class="celebs__gradient"></div>
                <span class="celebs__type">{c.type}</span>
              </div>
              <div class="celebs__info">
                <h3 class="celebs__name">{c.name}</h3>
                <p class="celebs__desc">{c.desc}</p>
              </div>
            </div>
          </li>
        ))}
      </ul>
      <button class="celebs__btn celebs__btn--prev" aria-label="Scroll left" type="button">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <button class="celebs__btn celebs__btn--next" aria-label="Scroll right" type="button">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>
  </section>

  <!-- ════ PRESS ARCHIVE ════ -->
  <section class="archive" aria-labelledby="arch-heading" id="archive">
    <div class="container">
      <div class="archive__header" data-reveal>
        <div>
          <div class="section-label">Press Archive</div>
          <h2 id="arch-heading" class="sec-title">All <em class="highlight">{archivePress.length} stories</em></h2>
        </div>
        <nav class="archive__tabs" aria-label="Filter by category">
          {categories.map(cat => (
            <button class={`ftab ${cat === 'all' ? 'ftab--active' : ''}`} data-filter={cat} aria-pressed={cat === 'all' ? 'true' : 'false'}>
              {categoryLabels[cat]}
              <span class="ftab__ct">{cat === 'all' ? archivePress.length : archivePress.filter(p => p.data.category === cat).length}</span>
            </button>
          ))}
        </nav>
      </div>
      <p class="archive__live" aria-live="polite" aria-atomic="true"></p>
      <div class="archive__body">
        {years.map((year, yi) => (
          <details class="yg" data-year={year} open={yi === 0} data-reveal>
            <summary class="yg__sum">
              <span class="yg__year">{year}</span>
              <span class="yg__ct">{pressByYear[year].length}</span>
              <span class="yg__line" aria-hidden="true"></span>
              <span class="yg__chev" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m6 9 6 6 6-6"/></svg></span>
            </summary>
            <div class="cl">
              {pressByYear[year].map(item => (
                <article class="ci" data-category={item.data.category}>
                  <div class="ci__bar" aria-hidden="true"></div>
                  <div class="ci__content">
                    <div class="ci__meta">
                      <span class="ci__outlet">{item.data.outlet}</span>
                      <span class="ci__dot" aria-hidden="true"></span>
                      <time datetime={item.data.date}>{formatDate(item.data.date)}</time>
                      <span class="ci__tag">{categoryLabels[item.data.category]}</span>
                    </div>
                    <h3 class="ci__title">
                      {item.data.url ? <a href={item.data.url} target="_blank" rel="noopener noreferrer">{item.data.title}</a> : <span>{item.data.title}</span>}
                    </h3>
                    <p class="ci__excerpt">{item.data.excerpt}</p>
                  </div>
                  {item.data.url && (
                    <a href={item.data.url} class="ci__arrow" target="_blank" rel="noopener noreferrer" aria-label={`Read: ${item.data.title}`}>
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
                    </a>
                  )}
                </article>
              ))}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ CTA ════ -->
  <section class="cta" data-reveal>
    <div class="cta__split">
      <div class="cta__content">
        <div class="section-label section-label--on-dark">Media</div>
        <h2>Tell our story <em class="highlight">with us</em></h2>
        <p>We provide press-ready assets, high-resolution photography, and direct access to founders Peter & Holly Ranney.</p>
        <div class="cta__actions">
          <a href="mailto:info@soardcharity.com?subject=Media%20Inquiry" class="btn btn-primary btn-lg">Media Inquiry →</a>
          <a href="/branding/" class="btn btn-outline-light">Brand & Media Kit</a>
        </div>
      </div>
    </div>
  </section>

</PageLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    /* ── YouTube facade ── */
    let warmed = false;
    function warm() {
      if (warmed) return; warmed = true;
      ['https://www.youtube-nocookie.com','https://i.ytimg.com'].forEach(o => {
        const l = document.createElement('link'); l.rel='preconnect'; l.href=o; document.head.appendChild(l);
      });
    }
    document.querySelectorAll<HTMLButtonElement>('[data-yt-id]').forEach(btn => {
      btn.addEventListener('pointerover', warm, { once: true });
      btn.addEventListener('focus', warm, { once: true });
      btn.addEventListener('click', () => {
        const id = btn.dataset.ytId, wrap = btn.closest('[data-yt-wrap]');
        if (!wrap || !id) return;
        const f = document.createElement('iframe');
        f.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1`;
        f.title = btn.getAttribute('aria-label') || '';
        f.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
        f.allowFullscreen = true;
        f.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;z-index:4;';
        wrap.appendChild(f);
        wrap.querySelector('.fph__poster, .fpe__poster')?.remove();
        btn.remove();
      });
    });

    /* ── Celebrity carousel (homepage kids strip pattern) ── */
    const scroll = document.querySelector('.celebs__scroll') as HTMLElement|null;
    const prev = document.querySelector('.celebs__btn--prev') as HTMLElement|null;
    const next = document.querySelector('.celebs__btn--next') as HTMLElement|null;
    if (scroll && prev && next) {
      function update() {
        const atStart = scroll!.scrollLeft <= 8;
        const atEnd = scroll!.scrollLeft + scroll!.clientWidth >= scroll!.scrollWidth - 8;
        prev!.classList.toggle('is-active', !atStart);
        next!.classList.toggle('is-active', !atEnd);
      }
      prev.addEventListener('click', () => scroll.scrollBy({ left: -680, behavior: 'smooth' }));
      next.addEventListener('click', () => scroll.scrollBy({ left: 680, behavior: 'smooth' }));
      scroll.addEventListener('scroll', update, { passive: true });
      update();
    }

    /* ── Archive filters ── */
    const tabs = document.querySelectorAll<HTMLButtonElement>('.ftab');
    const items = document.querySelectorAll<HTMLElement>('.ci[data-category]');
    const groups = document.querySelectorAll<HTMLDetailsElement>('.yg[data-year]');
    const live = document.querySelector<HTMLElement>('.archive__live');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const cat = tab.dataset.filter || 'all';
        tabs.forEach(t => { t.classList.remove('ftab--active'); t.setAttribute('aria-pressed','false'); });
        tab.classList.add('ftab--active'); tab.setAttribute('aria-pressed','true');
        let n = 0;
        items.forEach(ci => { const ok = cat==='all'||ci.dataset.category===cat; ci.style.display=ok?'':'none'; if(ok) n++; });
        groups.forEach(g => {
          const any = Array.from(g.querySelectorAll<HTMLElement>('.ci[data-category]')).some(ci=>ci.style.display!=='none');
          g.style.display = any ? '' : 'none';
          if (any && cat!=='all') g.open = true;
        });
        if (live) live.textContent = cat==='all' ? '' : `Showing ${n} ${n===1?'story':'stories'}`;
      });
    });
  });
</script>

<style>
  /* ══════════════════════
     FOUNDATIONS
     ══════════════════════ */
  .container { max-width: var(--max-width); margin: 0 auto; padding-inline: var(--page-padding); }
  .container--narrow { max-width: var(--max-width-narrow); }
  .section-label--on-dark { color: var(--c-yellow); }
  .sec-title { font-family: var(--font-display); font-size: clamp(1.6rem,3.5vw,2.4rem); line-height: 1.2; margin-bottom: var(--space-lg); color: var(--c-text); }
  [data-reveal] { opacity:0; transform: translateY(28px); transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1); }
  [data-reveal].is-visible { opacity:1; transform: translateY(0); }
  [data-delay="1"] { transition-delay: 0.1s; }
  [data-delay="2"] { transition-delay: 0.2s; }
  [data-delay="3"] { transition-delay: 0.3s; }

  /* ══════════════════════
     STATS
     ══════════════════════ */
  .stats { background: var(--c-dark); padding: var(--space-2xl) 0; }
  .stats__row { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; }
  .stats__item { text-align: center; padding: var(--space-md) var(--space-2xl); }
  .stats__num { display: block; font-family: var(--font-display); font-size: clamp(2rem,4vw,2.8rem); font-weight: 700; color: var(--c-yellow); line-height: 1; }
  .stats__label { display: block; font-size: 0.72rem; font-weight: 600; color: rgba(255,255,255,0.7); text-transform: uppercase; letter-spacing: 0.1em; margin-top: 6px; }
  .stats__div { width: 1px; height: 36px; background: rgba(255,255,255,0.1); flex-shrink: 0; }

  /* ══════════════════════
     FEATURED PRESS — HERO (dark cinematic split)
     ══════════════════════ */
  .fph { background: var(--c-dark); contain: layout style; overflow: hidden; }
  .fph__split { display: grid; grid-template-columns: 1.2fr 1fr; min-height: 580px; }
  .fph__media { position: relative; overflow: hidden; margin: 0; }
  .fph__frame { position: absolute; inset: 0; background: #000; cursor: pointer; }
  .fph__poster, .fph__img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 8s cubic-bezier(0.25,0.46,0.45,0.94); }
  .fph:hover .fph__poster, .fph:hover .fph__img { transform: scale(1.05); }
  .fph__badge {
    position: absolute; top: 28px; left: 28px;
    background: var(--c-yellow); color: var(--c-dark);
    font-size: 10px; font-weight: 800; padding: 6px 16px;
    border-radius: 50px; letter-spacing: 0.1em; text-transform: uppercase; z-index: 2;
  }
  .fph__play {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
    background: none; border: none; cursor: pointer; z-index: 3; padding: 0;
    transition: transform 0.3s cubic-bezier(0.16,1,0.3,1);
  }
  .fph__play:hover { transform: translate(-50%,-50%) scale(1.1); }
  .fph__play-ring {
    display: flex; align-items: center; justify-content: center;
    width: 88px; height: 88px; border-radius: 50%;
    background: rgba(255,218,36,0.92); color: var(--c-dark);
    box-shadow: 0 0 0 0 rgba(255,218,36,0.35), 0 4px 24px rgba(0,0,0,0.3);
    animation: fp-pulse 2.8s ease-out infinite;
    backdrop-filter: blur(4px);
  }
  @keyframes fp-pulse {
    0% { box-shadow: 0 0 0 0 rgba(255,218,36,0.3), 0 4px 24px rgba(0,0,0,0.3); }
    70% { box-shadow: 0 0 0 24px rgba(255,218,36,0), 0 4px 24px rgba(0,0,0,0.3); }
    100% { box-shadow: 0 0 0 0 rgba(255,218,36,0), 0 4px 24px rgba(0,0,0,0.3); }
  }
  .fph__body {
    padding: 72px 64px; display: flex; flex-direction: column; justify-content: center;
  }
  .fph__outlet {
    font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--c-yellow); margin-bottom: 20px; display: block;
  }
  .fph__title {
    font-family: var(--font-display); font-size: clamp(26px, 2.8vw, 38px);
    line-height: 1.18; margin: 0 0 24px; color: #fff; letter-spacing: -0.02em;
  }
