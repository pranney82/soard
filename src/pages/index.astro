<!-- Hero-specific no-JS fallback (data-reveal handled by ScrollReveal in BaseLayout) -->
<noscript>
  <style>
    .hero-eyebrow, .hero-lead, .hero-ctas, .hero-proof { opacity: 1 !important; animation: none !important; }
    .hero-line-inner { transform: none !important; animation: none !important; }
    .mosaic-cell { opacity: 1 !important; animation: none !important; }
  </style>
</noscript>

<script>
  /* ── Home page: mosaic parallax on scroll ──
   * Mosaic cell animations are pure CSS (animation-delay via --i).
   * This script only handles subtle parallax and pauses animations
   * when scrolled past the hero for GPU savings.
   *
   * Uses astro:page-load for View Transition compatibility. */

  let _scrollHandler: (() => void) | null = null;

  function cleanup() {
    if (_scrollHandler) window.removeEventListener('scroll', _scrollHandler);
    _scrollHandler = null;
  }

  function initHomePage() {
    const hero = document.querySelector('.hero') as HTMLElement;
    if (!hero) return;

    cleanup();

    /* ── Scroll parallax on mosaic + content ── */
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const mosaic = hero.querySelector('.hero-mosaic') as HTMLElement;
      const inner = hero.querySelector('.hero-inner') as HTMLElement;
      if (mosaic && inner) {
        const heroH = hero.offsetHeight || window.innerHeight;
        let ticking = false;
        let pastHero = false;
        _scrollHandler = function () {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            const scrollY = window.scrollY;
            if (scrollY < heroH) {
              pastHero = false;
              const ratio = scrollY / heroH;
              mosaic.style.transform = `scale(1.05) translate3d(0, ${scrollY * 0.15}px, 0)`;
              inner.style.transform = `translate3d(0, ${scrollY * 0.25}px, 0)`;
              inner.style.opacity = String(1 - ratio * 0.9);
            } else if (!pastHero) {
              pastHero = true;
              inner.style.opacity = '0';
            }
            ticking = false;
          });
        };
        window.addEventListener('scroll', _scrollHandler, { passive: true });
      }
    }
  }

  document.addEventListener('astro:page-load', initHomePage);
  document.addEventListener('astro:before-swap', cleanup);
</script>
