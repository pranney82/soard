  .wtg-nav { position: sticky; top: var(--header-height); z-index: 90; background: var(--c-cream); border-bottom: 1px solid var(--c-border); }
  .wtg-nav-track { max-width: var(--max-width); margin: 0 auto; padding: 0 var(--space-xl); display: flex; overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
  .wtg-nav-track::-webkit-scrollbar { display: none; }
  .wtg-nav-link { flex-shrink: 0; display: flex; align-items: center; gap: 8px; padding: 18px 24px; font-size: 15px; font-weight: 600; color: var(--c-text-muted); text-decoration: none; border-bottom: 2px solid transparent; transition: color 0.2s ease, border-color 0.2s ease; white-space: nowrap; }
  .wtg-nav-ico { width: 16px; height: 16px; flex-shrink: 0; opacity: 0.5; transition: opacity 0.2s ease; }
  .wtg-nav-link:hover, .wtg-nav-link.is-active { color: var(--c-dark); border-bottom-color: var(--c-yellow); }
  .wtg-nav-link:hover .wtg-nav-ico, .wtg-nav-link.is-active .wtg-nav-ico { opacity: 1; }

  /* ══════════════════════════════════════════
