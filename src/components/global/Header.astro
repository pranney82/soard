---
/**
 * Header.astro — v5 — Stripe-style morphing dropdown navigation
 *
 * Architecture:
 *   Shared morphing card that smoothly resizes/repositions between nav items.
 *   Content crossfades while the card bridges the visual gap.
 *   Staggered link entrances for premium feel.
 *
 * Desktop features:
 *   - Glass header (backdrop-filter blur + scroll state)
 *   - Sliding yellow indicator bar follows hover
 *   - Morphing dropdown card (Stripe pattern) — no close/reopen flash
 *   - Sliding arrow tracks active button
 *   - Rich dropdown panels with icons + descriptions
 *   - Staggered link entrance animation
 *   - Nav-level hover tracking — dropdown stays open across items
 *   - Shimmer + heartbeat Donate CTA
 *
 * Mobile features:
 *   - Drop-down panel extending from header (not full-screen overlay)
 *   - Large serif group headings, descriptions on each link
 *   - Staggered cascade animation
 *   - Sticky gradient donate footer
 *
 * Accessibility:
 *   - Skip-to-content, focus trap, inert, WAI-ARIA menubar
 *   - Arrow keys, Home/End, Escape
 *   - prefers-reduced-motion disables all animation
 *   - 44px+ touch targets, external link indication
 *
 * Performance:
 *   - ~150 lines vanilla JS (zero dependencies)
 *   - GPU-composited transitions (transform + opacity only)
 *   - Passive scroll/touch listeners, RAF-debounced scroll
 *   - Morph uses CSS transitions on position/size properties
 */
import { cfRaw, cfSrcset as _cfSrcset } from '../../utils/cf-image';
const currentPath = Astro.url.pathname;

const LOGO_ID = 'brand-logo-nav-circle';

interface NavChild {
  label: string;
  href: string;
  external?: boolean;
  desc?: string;
  icon?: string;
}
interface NavGroup {
  label: string;
  href?: string;
  external?: boolean;
  children?: NavChild[];
}

const icons: Record<string, string> = {
  'book-open': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>',
  'users': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
  'bar-chart': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>',
  'sparkles': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.912 5.813a2 2 0 0 0 1.275 1.275L21 12l-5.813 1.912a2 2 0 0 0-1.275 1.275L12 21l-1.912-5.813a2 2 0 0 0-1.275-1.275L3 12l5.813-1.912a2 2 0 0 0 1.275-1.275L12 3z"/></svg>',
  'heart': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>',
  'buildings': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M8 10h.01"/><path d="M16 10h.01"/><path d="M8 14h.01"/><path d="M16 14h.01"/></svg>',
  'handshake': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M11 17a4 4 0 0 0 6.95-2.75l.15-.45A6 6 0 0 0 13.7 7H11"/><path d="M13 7a4 4 0 0 0-6.95 2.75l-.15.45A6 6 0 0 0 10.3 17H13"/><path d="m7 7-1.5-1.5"/><path d="M17 7l1.5-1.5"/></svg>',
  'hammer': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="m15 12-8.5 8.5c-.83.83-2.17.83-3 0 0 0 0 0 0 0a2.12 2.12 0 0 1 0-3L12 9"/><path d="M17.64 15 22 10.64"/><path d="m20.91 11.7-1.25-1.25c-.6-.6-.93-1.4-.93-2.25v-.86L16.01 4.6a5.56 5.56 0 0 0-3.94-1.64H9l.92.82A6.18 6.18 0 0 1 12 8.4v1.56l2 2h2.47l2.26 1.91"/></svg>',
  'palette': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>',
  'calendar': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
  'clipboard': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/></svg>',
  'store': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"/><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><path d="M15 22v-4a2 2 0 0 0-2-2h-2a2 2 0 0 0-2 2v4"/><path d="M2 7h20"/><path d="M22 7v3a2 2 0 0 1-2 2v0a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 16 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 12 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 8 12a2.7 2.7 0 0 1-1.59-.63.7.7 0 0 0-.82 0A2.7 2.7 0 0 1 4 12v0a2 2 0 0 1-2-2V7"/></svg>',
  'newspaper': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>',
  'shirt': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20.38 3.46L16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.47a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.47a2 2 0 0 0-1.34-2.23z"/></svg>',
};

const nav: NavGroup[] = [
  {
    label: 'About Us',
    children: [
      { label: 'Our Story', href: '/about/', desc: 'How it all began', icon: 'book-open' },
      { label: 'Leadership', href: '/about/leadership/', desc: 'Meet the team', icon: 'users' },
      { label: 'Financials', href: '/about/financials/', desc: 'Full transparency', icon: 'bar-chart' },
      { label: 'Press & Media', href: '/publicity/', desc: 'In the news', icon: 'newspaper' },
    ],
  },
  {
    label: 'Our Kids',
    children: [
      { label: 'Meet the Kids', href: '/kids/', desc: 'Stories of joy', icon: 'heart' },
      { label: 'Community Projects', href: '/rooms/community/', desc: 'Beyond bedrooms', icon: 'buildings' },
    ],
  },
  {
    label: 'Our Partners',
    children: [
      { label: 'All Partners', href: '/partners/', desc: 'Who makes it happen', icon: 'handshake' },
      { label: 'Construction', href: '/partners/construction/', desc: 'Builders & contractors', icon: 'hammer' },
      { label: 'Design', href: '/partners/design/', desc: 'Designers & brands', icon: 'palette' },
    ],
  },
  {
    label: 'Get Involved',
    children: [
      { label: 'Events', href: '/events/', desc: 'Upcoming gatherings', icon: 'calendar' },
      { label: 'Donate', href: '/donate/', desc: 'Change a life today', icon: 'heart' },
      { label: '2026 Application', href: '/apply/', desc: 'Apply for a room', icon: 'clipboard' },
    ],
  },
  {
    label: 'Sunny & Ranney',
    href: '/shop/',
  },
];

function isActive(href: string) {
  if (href.startsWith('http')) return false;
  return currentPath === href;
}
function isGroupActive(group: NavGroup) {
  if (group.href) return isActive(group.href);
  return group.children?.some((child) => isActive(child.href)) ?? false;
}
---

<header class="site-header" id="site-header" transition:persist="site-header">
  <div class="header-inner">
    <!-- Logo — imagedelivery.net auto-negotiates AVIF/WebP via Accept header -->
    <a href="/" class="logo" aria-label="Sunshine on a Ranney Day — Home">
        <img
          src={cfRaw(LOGO_ID, 'w=256,q=85')}
          srcset={_cfSrcset(LOGO_ID, [128, 192, 256, 384])}
          sizes="(min-width: 1024px) 64px, (min-width: 481px) 52px, 52px"
          alt="Sunshine on a Ranney Day"
          class="logo-img"
          width="256" height="256"
          loading="eager" fetchpriority="high"
        />
    </a>

    <!-- Desktop Nav -->
    <nav class="desktop-nav" id="desktop-nav" aria-label="Main navigation">
      <ul class="nav-list" role="menubar">
        {nav.map((item, gi) => (
          <li class:list={['nav-item', { 'group-active': isGroupActive(item) }]} role="none" data-nav-group={gi}>
            {item.children ? (
              <>
                <button
                  class:list={['nav-link', { 'parent-active': isGroupActive(item) }]}
                  role="menuitem" aria-haspopup="true" aria-expanded="false"
                  tabindex={gi === 0 ? '0' : '-1'}
                >
                  {item.label}
                  <svg class="chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                    <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <div class="dropdown" role="menu" id={`dd-${gi}`}>
                  <div class="dropdown-panel">
                    {item.children.map((child, ci) => (
                      <a
                        href={child.href} role="menuitem"
                        class:list={['dd-link', { active: isActive(child.href) }]}
                        tabindex="-1" data-child-index={ci} style={`--di:${ci}`}
                        {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                      >
                        <span class="dd-icon" aria-hidden="true" set:html={icons[child.icon || '']} />
                        <span class="dd-body">
                          <span class="dd-label">
                            {child.label}
                            {child.external && (
                              <svg class="dd-ext" width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                                <path d="M4.5 1.5H1.5V10.5H10.5V7.5M7 1.5H10.5M10.5 1.5V5M10.5 1.5L5.5 6.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                              </svg>
                            )}
                          </span>
                          {child.desc && <span class="dd-desc">{child.desc}</span>}
                        </span>
                      </a>
                    ))}
                  </div>
                </div>
              </>
            ) : (
              <a
                href={item.href}
                class:list={['nav-link', { 'parent-active': isGroupActive(item) }]}
                role="menuitem"
                tabindex={gi === 0 ? '0' : '-1'}
                {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                {item.label}
                {item.external && (
                  <svg class="dd-ext" width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true" style="opacity:0.4;margin-left:2px;">
                    <path d="M4.5 1.5H1.5V10.5H10.5V7.5M7 1.5H10.5M10.5 1.5V5M10.5 1.5L5.5 6.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                )}
              </a>
            )}
          </li>
        ))}
      </ul>
      <div class="dd-morph" id="dd-morph" aria-hidden="true">
        <div class="dd-morph-arrow"></div>
      </div>
      <div class="nav-indicator" id="nav-indicator" aria-hidden="true"></div>
    </nav>

    <!-- Donate CTA -->
    <a href="/donate/" class="header-cta">
      <span class="cta-heart" aria-hidden="true">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
      </span>
      Donate
    </a>

    <!-- Mobile: right-side group (donate + hamburger) -->
    <div class="mobile-actions">
      <a href="/donate/" class="mobile-cta">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
        Donate
      </a>
      <button type="button" class="mobile-toggle" id="mobile-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-panel">
        <span class="hamburger" aria-hidden="true">
          <span class="hamburger-line hamburger-line--top"></span>
          <span class="hamburger-line hamburger-line--mid"></span>
          <span class="hamburger-line hamburger-line--bot"></span>
        </span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile drop-down nav (extends from header) -->
<div class="mobile-nav" id="mobile-panel" role="dialog" aria-label="Mobile navigation" aria-modal="true" aria-hidden="true" transition:persist="mobile-panel">
  <div class="mnav-body">
    {nav.map((item, i) => (
      <div class="mnav-group" style={`--i:${i}`}>
        {item.children ? (
          <>
            <h3 class="mnav-heading">{item.label}</h3>
            <div class="mnav-links">
              {item.children.map((child) => (
                <a href={child.href} class:list={['mnav-link', { active: isActive(child.href) }]}
                  {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
                  <span class="mnav-link-icon" aria-hidden="true" set:html={icons[child.icon || '']} />
                  <span class="mnav-link-inner">
                    <span class="mnav-link-label">{child.label}</span>
                    {child.desc && <span class="mnav-link-desc">{child.desc}</span>}
                  </span>
                  {child.external && (
                    <svg class="mnav-ext" width="14" height="14" viewBox="0 0 14 14" fill="none" role="img" aria-label="Opens in new tab">
                      <path d="M5.25 2H2V12H12V8.75M8.5 2H12M12 2V5.5M12 2L6.5 7.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  )}
                </a>
              ))}
            </div>
          </>
        ) : (
          <div class="mnav-links" style="padding-top:4px;">
            <a href={item.href} class="mnav-link"
              {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
              <span class="mnav-link-icon" aria-hidden="true" set:html={icons['store']} />
              <span class="mnav-link-inner">
                <span class="mnav-link-label">{item.label}</span>
              </span>
              {item.external && (
                <svg class="mnav-ext" width="14" height="14" viewBox="0 0 14 14" fill="none" role="img" aria-label="Opens in new tab">
                  <path d="M5.25 2H2V12H12V8.75M8.5 2H12M12 2V5.5M12 2L6.5 7.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
            </a>
          </div>
        )}
      </div>
    ))}
  </div>
</div>

<script>
document.addEventListener('astro:page-load', function () {
  /* Abort previous listeners to prevent stacking across View Transitions */
  if (window.__headerAC) window.__headerAC.abort();
  var ac = new AbortController();
  window.__headerAC = ac;
  var sig = ac.signal;

  var header = document.getElementById('site-header');
  var desktopNav = document.getElementById('desktop-nav');
  var indicator = document.getElementById('nav-indicator');
  var morphEl = document.getElementById('dd-morph');
  var morphArrow = morphEl ? morphEl.querySelector('.dd-morph-arrow') : null;
  var navItems = document.querySelectorAll('.nav-item[data-nav-group]');
  var navButtons = document.querySelectorAll('.nav-item > button');
  if (!header) return;

  /* ═══════ UPDATE ACTIVE STATES (for transition:persist) ═══════ */
  /* Since the header DOM persists across navigations, build-time
     active classes become stale. Re-compute them from the URL. */
  (function updateActiveStates() {
    var path = window.location.pathname;
    /* Desktop nav */
    navItems.forEach(function (item) {
      var links = item.querySelectorAll('.dd-link');
      var directLink = item.querySelector(':scope > a.nav-link');
      var btn = item.querySelector(':scope > button.nav-link');
      var groupActive = false;

      links.forEach(function (a) {
        var href = a.getAttribute('href');
        var isActive = href === path;
        a.classList.toggle('active', isActive);
        if (isActive) groupActive = true;
      });

      if (directLink) {
        var isActive = directLink.getAttribute('href') === path;
        directLink.classList.toggle('parent-active', isActive);
        item.classList.toggle('group-active', isActive);
      } else {
        item.classList.toggle('group-active', groupActive);
        if (btn) btn.classList.toggle('parent-active', groupActive);
      }
    });

    /* Mobile nav */
    document.querySelectorAll('.mnav-link').forEach(function (a) {
      var href = a.getAttribute('href');
      a.classList.toggle('active', href === path);
    });
  })();

  /* ═══════ DESKTOP DROPDOWNS — Morphing Container ═══════ */
  var activeGroup = -1;
  var morphSeq = 0;
  var closeTimer = null;

  function getDDLinks(item) {
    var dd = item.querySelector('.dropdown');
    return dd ? Array.from(dd.querySelectorAll('.dd-link')) : [];
  }

  function activateItem(item) {
    var btn = item.querySelector('button');
    if (btn) btn.setAttribute('aria-expanded', 'true');
    item.classList.add('dd-open');
  }

  function positionMorph(item, isEntrance) {
    if (!morphEl || !morphArrow || !desktopNav) return;
    var panel = item.querySelector('.dropdown-panel');
    if (!panel) return;
    var navRect = desktopNav.getBoundingClientRect();
    var panelRect = panel.getBoundingClientRect();
    var btn = item.querySelector('button');
    var btnRect = btn.getBoundingClientRect();

    var left = panelRect.left - navRect.left;
    var top = panelRect.top - navRect.top;
    var width = panelRect.width;
    var height = panelRect.height;
    var arrowX = (btnRect.left + btnRect.width / 2) - panelRect.left;

    if (isEntrance) {
      morphEl.style.transition = 'none';
      morphEl.style.left = left + 'px';
      morphEl.style.top = top + 'px';
      morphEl.style.width = width + 'px';
      morphEl.style.height = height + 'px';
      morphArrow.style.transition = 'none';
      morphArrow.style.left = arrowX + 'px';
      morphEl.offsetHeight;
      morphEl.style.transition = '';
      morphArrow.style.transition = '';
      morphEl.classList.add('morph-open');
    } else {
      morphEl.style.left = left + 'px';
      morphEl.style.top = top + 'px';
      morphEl.style.width = width + 'px';
      morphEl.style.height = height + 'px';
      morphArrow.style.left = arrowX + 'px';
    }
  }

  function openDD(item) {
    var gi = parseInt(item.dataset.navGroup);
    if (gi === activeGroup) return;
    var prev = activeGroup;
    activeGroup = gi;
    morphSeq++;
    var seq = morphSeq;

    if (prev >= 0) {
      var prevItem = navItems[prev];
      var prevBtn = prevItem.querySelector('button');
      if (prevBtn) prevBtn.setAttribute('aria-expanded', 'false');
      prevItem.classList.remove('dd-open');
    }

    var isEntrance = prev < 0;
    positionMorph(item, isEntrance);

    var delay = isEntrance ? 0 : 50;
    if (delay === 0) {
      activateItem(item);
    } else {
      setTimeout(function () {
        if (morphSeq !== seq) return;
        activateItem(item);
      }, delay);
    }
  }

  function closeDD(item) {
    var gi = parseInt(item.dataset.navGroup);
    var btn = item.querySelector('button');
    if (btn) btn.setAttribute('aria-expanded', 'false');
    item.classList.remove('dd-open');
    if (gi === activeGroup) {
      activeGroup = -1;
      morphSeq++;
      if (morphEl) morphEl.classList.remove('morph-open');
    }
  }

  function closeAllDD() {
    navItems.forEach(function (item) {
      var btn = item.querySelector('button');
      if (btn) btn.setAttribute('aria-expanded', 'false');
      item.classList.remove('dd-open');
    });
    activeGroup = -1;
    morphSeq++;
    if (morphEl) morphEl.classList.remove('morph-open');
  }

  function cancelClose() { if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; } }
  function scheduleClose() { cancelClose(); closeTimer = setTimeout(closeAllDD, 180); }

  navItems.forEach(function (item) {
    item.addEventListener('mouseenter', function () {
      cancelClose();
      // If item has no dropdown (e.g. "Sunny & Ranney"), close all dropdowns instead
      var hasDropdown = item.querySelector('.dropdown-panel');
      if (hasDropdown) {
        openDD(item);
      } else {
        closeAllDD();
      }
    });
  });
  if (desktopNav) desktopNav.addEventListener('mouseleave', scheduleClose);

  document.addEventListener('click', function (e) {
    /* Close dropdown when clicking a link inside it (navigating away) */
    if (e.target.closest('.dd-link')) { closeAllDD(); return; }
    /* Close dropdown when clicking outside the nav */
    if (!e.target.closest('.nav-item') && !e.target.closest('.dd-morph')) closeAllDD();
  }, { signal: sig });

  window.addEventListener('resize', function () { if (activeGroup >= 0) closeAllDD(); }, { signal: sig });

  /* ═══════ SLIDING INDICATOR ═══════ */
  function posInd(el) {
    if (!indicator || !desktopNav) return;
    var nr = desktopNav.getBoundingClientRect();
    var er = el.getBoundingClientRect();
    indicator.style.width = er.width + 'px';
    indicator.style.transform = 'translateX(' + (er.left - nr.left) + 'px)';
    indicator.style.opacity = '1';
  }
  function resetInd() {
    if (!indicator) return;
    var ab = document.querySelector('.nav-link.parent-active');
    if (ab) posInd(ab); else indicator.style.opacity = '0';
  }
  navButtons.forEach(function (b) { b.addEventListener('mouseenter', function () { posInd(this); }); });
  // Also track direct nav links (like "Sunny & Ranney") for the indicator
  document.querySelectorAll('.nav-item > a.nav-link').forEach(function (a) {
    a.addEventListener('mouseenter', function () { posInd(this); });
  });
  if (desktopNav) desktopNav.addEventListener('mouseleave', resetInd);
  requestAnimationFrame(function () {
    var ab = document.querySelector('.nav-link.parent-active');
    if (ab && indicator) { indicator.style.transition = 'none'; posInd(ab); requestAnimationFrame(function () { indicator.style.transition = ''; }); }
  });

  /* ═══════ KEYBOARD NAV ═══════ */
  var navList = document.querySelector('.nav-list');
  if (navList) {
    navList.addEventListener('keydown', function (e) {
      var t = e.target;
      var isBtn = t.matches('.nav-item > button');
      var parent = t.closest('.nav-item[data-nav-group]');
      if (!parent) return;
      var gi = parseInt(parent.dataset.navGroup);

      if (isBtn) {
        switch (e.key) {
          case 'ArrowRight': { e.preventDefault(); closeAllDD(); var n = navButtons[(gi + 1) % navButtons.length]; navButtons.forEach(function (b) { b.tabIndex = -1; }); n.tabIndex = 0; n.focus(); break; }
          case 'ArrowLeft': { e.preventDefault(); closeAllDD(); var p = navButtons[(gi - 1 + navButtons.length) % navButtons.length]; navButtons.forEach(function (b) { b.tabIndex = -1; }); p.tabIndex = 0; p.focus(); break; }
          case 'ArrowDown': case 'Enter': case ' ': { e.preventDefault(); openDD(parent); var links = getDDLinks(parent); if (links.length) links[0].focus(); break; }
          case 'Escape': { e.preventDefault(); closeAllDD(); t.focus(); break; }
        }
      } else if (t.classList.contains('dd-link')) {
        var links = getDDLinks(parent);
        var idx = links.indexOf(t);
        switch (e.key) {
          case 'ArrowDown': { e.preventDefault(); links[(idx + 1) % links.length].focus(); break; }
          case 'ArrowUp': { e.preventDefault(); if (idx === 0) { closeDD(parent); parent.querySelector('button').focus(); } else links[idx - 1].focus(); break; }
          case 'ArrowRight': { e.preventDefault(); closeDD(parent); var ni = (gi + 1) % navButtons.length; openDD(navItems[ni]); navButtons.forEach(function (b) { b.tabIndex = -1; }); navButtons[ni].tabIndex = 0; var nl = getDDLinks(navItems[ni]); if (nl.length) nl[0].focus(); break; }
          case 'ArrowLeft': { e.preventDefault(); closeDD(parent); var pi = (gi - 1 + navButtons.length) % navButtons.length; openDD(navItems[pi]); navButtons.forEach(function (b) { b.tabIndex = -1; }); navButtons[pi].tabIndex = 0; var pl = getDDLinks(navItems[pi]); if (pl.length) pl[0].focus(); break; }
          case 'Escape': { e.preventDefault(); closeDD(parent); parent.querySelector('button').focus(); break; }
          case 'Home': { e.preventDefault(); if (links.length) links[0].focus(); break; }
          case 'End': { e.preventDefault(); if (links.length) links[links.length - 1].focus(); break; }
          case 'Tab': { closeAllDD(); break; }
        }
      }
    });
  }

  /* ═══════ SCROLL ═══════ */
  var ticking = false, mobileOpen = false;
  function onScroll() {
    ticking = false;
    header.classList.toggle('header--scrolled', window.scrollY > 20);
  }
  window.addEventListener('scroll', function () {
    if (!ticking) { requestAnimationFrame(onScroll); ticking = true; }
  }, { passive: true, signal: sig });

  /* ═══════ MOBILE NAV ═══════ */
  var mBtn = document.getElementById('mobile-toggle');
  var mPanel = document.getElementById('mobile-panel');
  var mainEl = document.querySelector('main');
  var footerEl = document.querySelector('footer');
  var savedY = 0;

  function mGetFocusable() {
    return [mBtn].concat(Array.from(mPanel.querySelectorAll('a, button'))).filter(Boolean);
  }

  function mOpen() {
    mobileOpen = true; savedY = window.scrollY;
    mPanel.style.transition = '';            /* restore in case mHideInstant killed it */
    document.documentElement.classList.add('menu-open');
    document.body.style.top = '-' + savedY + 'px';
    mBtn.setAttribute('aria-expanded', 'true');
    mBtn.classList.add('is-open');
    mPanel.classList.add('is-open'); mPanel.setAttribute('aria-hidden', 'false');
    if (mainEl) mainEl.setAttribute('inert', '');
    if (footerEl) footerEl.setAttribute('inert', '');
    var firstLink = mPanel.querySelector('a');
    if (firstLink) firstLink.focus();
  }

  function mCloseMenu() {
    if (!mobileOpen) return;
    mobileOpen = false;
    document.documentElement.classList.remove('menu-open');
    document.body.style.top = '';
    window.scrollTo(0, savedY);
    mBtn.setAttribute('aria-expanded', 'false');
    mBtn.classList.remove('is-open');
    mPanel.classList.remove('is-open'); mPanel.setAttribute('aria-hidden', 'true');
    if (mainEl) mainEl.removeAttribute('inert');
    if (footerEl) footerEl.removeAttribute('inert');
    mBtn.focus();
  }

  /* Hide instantly (no transition) — used when a link navigates away */
  function mHideInstant() {
    if (!mobileOpen) return;
    mobileOpen = false;
    mPanel.style.transition = 'none';
    mPanel.classList.remove('is-open'); mPanel.setAttribute('aria-hidden', 'true');
    document.documentElement.classList.remove('menu-open');
    document.body.style.top = '';
    mBtn.setAttribute('aria-expanded', 'false');
    mBtn.classList.remove('is-open');
    if (mainEl) mainEl.removeAttribute('inert');
    if (footerEl) footerEl.removeAttribute('inert');
  }

  if (mBtn) mBtn.addEventListener('click', function () { mobileOpen ? mCloseMenu() : mOpen(); });

  document.addEventListener('keydown', function (e) {
    if (!mobileOpen) return;
    if (e.key === 'Escape') { mCloseMenu(); return; }
    if (e.key === 'Tab') {
      var f = mGetFocusable(), first = f[0], last = f[f.length - 1];
      if (e.shiftKey) { if (document.activeElement === first) { e.preventDefault(); last.focus(); } }
      else { if (document.activeElement === last) { e.preventDefault(); first.focus(); } }
    }
  }, { signal: sig });

  window.matchMedia('(min-width: 1024px)').addEventListener('change', function (e) { if (e.matches && mobileOpen) mCloseMenu(); }, { signal: sig });

  if (mPanel) {
    mPanel.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', function () { mHideInstant(); });
    });
  }
});

/* Force-clean menu state before View Transition swaps the DOM.
   Prevents html.menu-open (position:fixed, overflow:hidden) from
   leaking into the new page if mHideInstant() timing races the swap. */
document.addEventListener('astro:before-swap', function () {
  document.documentElement.classList.remove('menu-open');
  document.body.style.top = '';
});
</script>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 1000;
