---
/**
 * ScrollReveal.astro — Shared scroll-reveal observer
 *
 * Include once in BaseLayout. Handles all [data-reveal] elements
 * site-wide with proper View Transition lifecycle:
 *   - astro:after-swap  → instantly reveal above-fold elements BEFORE paint
 *   - astro:page-load   → set up observer for below-fold elements
 *   - astro:before-swap  → disconnect observer before DOM swap
 *   - 3s safety timeout  → force-reveal if observer somehow fails
 *   - <noscript>         → all content visible if JS is blocked
 *
 * The key anti-flicker trick: astro:after-swap fires synchronously
 * after the new DOM is inserted but BEFORE the browser paints. By
 * adding .is-visible to above-fold elements here, users never see
 * the opacity:0 base state on client-side navigation.
 */
---

<noscript>
  <style>
    [data-reveal] { opacity: 1 !important; transform: none !important; transition: none !important; }
  </style>
</noscript>

<script>
  let _revealObserver: IntersectionObserver | null = null;
  let _revealSafety: ReturnType<typeof setTimeout> | null = null;

  function cleanupReveal() {
    _revealObserver?.disconnect();
    _revealObserver = null;
    if (_revealSafety) { clearTimeout(_revealSafety); _revealSafety = null; }
  }

  /**
   * Instantly reveal above-fold [data-reveal] elements.
   * Called from astro:after-swap (before paint) to prevent flicker,
   * and also from initReveal as a fallback for initial page load.
   */
  function revealAboveFold() {
    const viewH = window.innerHeight;
    document.querySelectorAll('[data-reveal]:not(.is-visible)').forEach(el => {
      const rect = el.getBoundingClientRect();
      if (rect.top < viewH * 0.85) {
        (el as HTMLElement).style.transition = 'none';
        el.classList.add('is-visible');
      }
    });
  }

  function initReveal() {
    cleanupReveal();

    const els = document.querySelectorAll('[data-reveal]');
    if (!els.length) return;

    // Reveal above-fold elements instantly (covers initial hard load)
    revealAboveFold();

    // Restore transitions for any elements we force-revealed above
    // (allow future scroll-triggered reveals to animate normally)
    requestAnimationFrame(() => {
      document.querySelectorAll('[data-reveal].is-visible').forEach(el => {
        (el as HTMLElement).style.transition = '';
      });
    });

    // Observe remaining below-fold elements normally
    const remaining = document.querySelectorAll('[data-reveal]:not(.is-visible)');
    if (!remaining.length) return;

    _revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          _revealObserver?.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

    remaining.forEach(el => _revealObserver!.observe(el));

    // Safety net: force-reveal any still-hidden elements after 3s
    _revealSafety = setTimeout(() => {
      document.querySelectorAll('[data-reveal]:not(.is-visible)').forEach(el => {
        el.classList.add('is-visible');
      });
    }, 3000);
  }

  // CRITICAL: after-swap fires synchronously BEFORE paint.
  // Revealing above-fold elements here prevents the opacity:0 flash
  // that otherwise appears for 1-2 frames on client-side navigation.
  document.addEventListener('astro:after-swap', revealAboveFold);
  document.addEventListener('astro:page-load', initReveal);
  document.addEventListener('astro:before-swap', cleanupReveal);
</script>
