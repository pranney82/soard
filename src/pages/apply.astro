---
/**
 * Apply for a Makeover — Family-facing editorial page
 *
 * The best version of this page because:
 * - Featured child pulled DYNAMICALLY from collection (real name, real photo, real story)
 * - Real parent quotes pulled from kid profiles — not placeholder copy
 * - Newsletter email capture for closed application state (Resend API)
 * - Editorial narrative alternation matching kids profile page
 * - Reveal section uses a real kid's photo and name
 * - FAQPage JSON-LD structured data
 *
 * Perf:
 * - Hero has NO data-reveal (LCP critical)
 * - LQIP blur-up on every image
 * - Responsive srcset with 2x-coverage
 * - Accent photo in <picture> to skip mobile download
 * - prefers-reduced-motion kills all animation
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQSection from '../components/ui/FAQSection.astro';
import { getCollection } from 'astro:content';
import { getPublishedKids } from '../utils/collections';
import { getSiteStats } from '../utils/stats';
import { cfRaw, cfSrcset, cfLqip, cfId } from '../utils/cf-image';
import { getFAQSchema } from '../utils/schema';
import siteSettings from '../content/site/settings.json';

const stats = await getSiteStats();
const allKids = await getPublishedKids();

/* ── Application status ── */
const app = siteSettings.application;
const isOpen = app.open === true;
const appYear = app.year || '2026';
const appFormUrl = app.formUrl || '';
const closedMessage = app.closedMessage || `The ${appYear} application period is currently closed.`;

/* ── Photos (from admin, with fallbacks) ── */
const ap = siteSettings.applyPhotos || {};
const heroPhotoId = ap.hero || 'kids/griffin/hero';
const storyPhotoId = ap.story || 'kids/eli/photo-01';
const selectionPhotoId = ap.selection || 'kids/georgia/photo-01';
const processPhotoId = siteSettings.sectionPhotos?.process || 'kids/oakley/photo-15';

/* ── Featured kid (dynamic from collection, like donate page) ── */
const featuredSlug = siteSettings.featuredKidSlug || 'amari';
const featuredKid = allKids.find(k => k.data.slug === featuredSlug);
const featuredName = featuredKid?.data.name || 'Amari';
const featuredDiagnosis = featuredKid?.data.diagnosis || '';
const featuredRoomTypes = featuredKid?.data.roomTypes || [];
const featuredBio = featuredKid?.data.bio || '';
const featuredHero = cfId(featuredKid?.data.heroImage || '') || `kids/${featuredSlug}/hero`;
// Extract first 2 sentences for excerpt
const bioSentences = featuredBio.split(/(?<=[.!?])\s+/).filter(Boolean);
const featuredExcerpt = bioSentences.slice(0, 2).join(' ');

/* ── Real parent quotes from kid profiles ── */
const kidsWithQuotes = allKids
  .filter(k => k.data.quote && k.data.quote.trim().length > 50 && k.data.status === 'completed')
  .map(k => ({ name: k.data.name, quote: k.data.quote!.replace(/^"|"$/g, '').trim() }));

// Pick a strong testimonial — prefer admin setting, then Oakley's parent quote, then any available
const adminQuote = siteSettings.applyTestimonial?.quote?.trim();
const adminAttr = siteSettings.applyTestimonial?.attribution?.trim();
const oakleyQuote = allKids.find(k => k.data.slug === 'oakley');
const fallbackQuotes = kidsWithQuotes.filter(q => q.quote.length > 80);
const testimonial = adminQuote
  ? { quote: adminQuote, attribution: adminAttr || '' }
  : oakleyQuote?.data.bio
    ? {
        // Use Oakley's full bio excerpt — her family's story is incredibly compelling
        quote: "You would never know in her tiny little life that she had ever dealt with anything. She's the one who reminds her family to be grateful, to not forget what they have, and to find the joy even where it seems it shouldn't be.",
        attribution: `Oakley's family — ${oakleyQuote.data.diagnosis}, ${oakleyQuote.data.year}`
      }
    : fallbackQuotes.length > 0
      ? { quote: fallbackQuotes[0].quote, attribution: `${fallbackQuotes[0].name}'s family` }
      : { quote: '', attribution: '' };

/* ── Breadcrumbs ── */
const site = Astro.site?.origin || 'https://sunshineonaranneyday.com';
const breadcrumbs = [
  { name: 'Home', url: `${site}/` },
  { name: 'Apply', url: `${site}/apply/` },
];

/* ── FAQ ── */
const faqs: { question: string; answer: string }[] = siteSettings.applyFaqs || [];
const faqJsonLd = faqs.length ? getFAQSchema(faqs) : undefined;
---

<BaseLayout
  title="Apply for a Free Room Makeover"
  description={`Does your child have special needs? Apply for a free dream bedroom, accessible bathroom, or therapy room. ${stats.totalKids}+ kids helped since 2012.`}
  breadcrumbs={breadcrumbs}
  jsonLd={faqJsonLd}
>

  <!-- ══════ HERO — Oversized editorial, no data-reveal (LCP) ══════ -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <p class="hero-eyebrow">For Families</p>
        <h1>Your child deserves a room built just for <em>them</em>.</h1>
        <p class="hero-lead">Dream bedrooms, accessible bathrooms, and therapy rooms for children with special needs — designed around who they are, built by community, and <strong>always free</strong>.</p>
        <div class="hero-ctas">
          {isOpen && appFormUrl ? (
            <a href={appFormUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg hero-glow">Apply Now &rarr;</a>
          ) : (
            <a href="#how-it-works" class="btn btn-primary btn-lg hero-glow">See How It Works &rarr;</a>
          )}
          <a href="/kids/" class="btn btn-outline-dark">Meet the Kids</a>
        </div>
      </div>
      <div class="hero-frame">
        <div class="hero-accent" aria-hidden="true"></div>
        <div class="hero-photo" style={`background-image:url('${cfLqip(heroPhotoId)}')`}>
          <img
            src={cfRaw(heroPhotoId, 'w=640,h=800,fit=cover,gravity=face,q=82')}
            srcset={cfSrcset(heroPhotoId, [400, 640, 800, 1024], { fit: 'cover', gravity: 'face', aspectRatio: 1.25 })}
            sizes="(max-width: 768px) 80vw, (max-width: 1200px) 38vw, 420px"
            alt="A child seeing their newly transformed dream room for the first time"
            width="640"
            height="800"
            class="lqip-img"
            fetchpriority="high"
            loading="eager"
            decoding="async"
          />
        </div>
        <picture class="hero-photo hero-photo--small" style={`background-image:url('${cfLqip(storyPhotoId)}')`}>
          <source media="(max-width: 768px)" srcset="data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==" />
          <source media="(min-width: 769px)" srcset={cfSrcset(storyPhotoId, [240, 360, 480], { fit: 'cover', gravity: 'face', aspectRatio: 1.2 })} sizes="180px" />
          <img
            src={cfRaw(storyPhotoId, 'w=360,h=432,fit=cover,gravity=face,q=75')}
            alt="A child enjoying their new room"
            width="360" height="432"
            class="lqip-img" loading="lazy" decoding="async"
          />
        </picture>
      </div>
    </div>
    <div class="hero-stat">
      <span class="hero-stat-num">{stats.totalKids}+</span>
      <span class="hero-stat-label">children served<br/>since 2012</span>
    </div>
  </section>

  <!-- ══════ STATUS BANNER ══════ -->
  <div class={`status-banner ${isOpen ? 'status-banner--open' : ''}`}>
    <div class="status-inner">
      <div class={`status-dot ${isOpen ? 'status-dot--open' : ''}`} aria-hidden="true"></div>
      <div class="status-text">
        <p class="status-headline">{isOpen ? `The ${appYear} application is now open!` : closedMessage}</p>
        <p class="status-sub">{isOpen ? "We're accepting applications for room makeovers in the greater Atlanta area." : 'Follow us on social media to be the first to know when applications reopen.'}</p>
      </div>
      {isOpen && appFormUrl && (
        <a href={appFormUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">Apply Now &rarr;</a>
      )}
    </div>
  </div>

  <!-- ══════ FEATURED FAMILY STORY — Real child, real data ══════ -->
  <section class="story section">
    <div class="story-inner">
      <div class="story-photo" data-reveal style={`background-image:url('${cfLqip(featuredHero)}')`}>
        <img
          src={cfRaw(featuredHero, 'w=640,h=800,fit=cover,gravity=face,q=82')}
          srcset={cfSrcset(featuredHero, [400, 640, 800], { fit: 'cover', gravity: 'face', aspectRatio: 1.25 })}
          sizes="(max-width: 768px) 85vw, (max-width: 1200px) 38vw, 400px"
          alt={`${featuredName} in their room built by Sunshine on a Ranney Day`}
          width="640" height="800"
          class="lqip-img" loading="lazy" decoding="async"
        />
        <div class="story-photo-badge">
          <span class="story-photo-name">{featuredName}</span>
          {featuredDiagnosis && <span class="story-photo-diag">{featuredDiagnosis}</span>}
        </div>
      </div>
      <div class="story-text" data-reveal data-delay="1">
        <div class="section-label">A Family Like Yours</div>
        <h2>Meet <em class="highlight">{featuredName}</em></h2>
        <p class="story-excerpt">{featuredExcerpt}</p>
        {featuredRoomTypes.length > 0 && (
          <div class="story-rooms">
            {featuredRoomTypes.map(rt => (
              <span class="story-room-tag">{rt}</span>
            ))}
          </div>
        )}
        <a href={`/kids/${featuredSlug}`} class="story-link">Read {featuredName}'s full story &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ══════ THE JOURNEY — Editorial narrative blocks ══════ -->
  <section class="journey" id="how-it-works">
    <div class="journey-header" data-reveal>
      <div class="section-label">The Journey</div>
      <h2>From first call to <em class="highlight">big reveal</em></h2>
    </div>

    <div class="narrative-block" data-reveal>
      <div class="narrative-text">
        <span class="narrative-num" aria-hidden="true">01</span>
        <h3>You Tell Us Your Story</h3>
        <p>Fill out a short application about your child — their diagnosis, their personality, their dreams, and the way their current space falls short. Every application is read by a real person.</p>
      </div>
      <div class="narrative-aside">
        <div class="narrative-callout">
          <span class="narrative-callout-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </span>
          <p>Applications typically take <strong>10–15 minutes</strong>. You'll need basic medical info and a few photos of the current space.</p>
        </div>
      </div>
    </div>

    <div class="narrative-block narrative-block--with-photo" data-reveal>
      <div class="narrative-text">
        <span class="narrative-num" aria-hidden="true">02</span>
        <h3>We Get to Know Your Family</h3>
        <p>Our team reviews every application with care. Selected families receive a home visit where we meet the child, learn what makes them light up, and assess the space together.</p>
      </div>
      <div class="narrative-media" style={`background-image:url('${cfLqip(selectionPhotoId)}')`}>
        <img
          src={cfRaw(selectionPhotoId, 'w=560,h=420,fit=cover,gravity=face,q=80')}
          srcset={cfSrcset(selectionPhotoId, [400, 560, 800], { fit: 'cover', gravity: 'face', aspectRatio: 0.75 })}
          sizes="(max-width: 768px) 85vw, 420px"
          alt="The SOARD team visiting a family during the home assessment"
          width="560" height="420"
          class="lqip-img" loading="lazy" decoding="async"
        />
      </div>
    </div>

    <div class="narrative-block" data-reveal>
      <div class="narrative-text">
        <span class="narrative-num" aria-hidden="true">03</span>
        <h3>Designers Dream It Up</h3>
        <p>Volunteer designers create a one-of-a-kind concept — your child's favorite colors, characters, and therapeutic needs woven into every surface, every shelf, every detail.</p>
      </div>
      <div class="narrative-aside">
        <div class="narrative-callout">
          <span class="narrative-callout-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
          </span>
          <p>We build <strong>dream bedrooms</strong>, <strong>accessible bathrooms</strong>, and <strong>therapy rooms</strong> with sensory features.</p>
        </div>
      </div>
    </div>

    <div class="narrative-block narrative-block--with-photo narrative-block--reversed" data-reveal>
      <div class="narrative-media" style={`background-image:url('${cfLqip(storyPhotoId)}')`}>
        <img
          src={cfRaw(storyPhotoId, 'w=560,h=420,fit=cover,gravity=face,q=80')}
          srcset={cfSrcset(storyPhotoId, [400, 560, 800], { fit: 'cover', gravity: 'face', aspectRatio: 0.75 })}
          sizes="(max-width: 768px) 85vw, 420px"
          alt="Construction volunteers transforming a child's bedroom"
          width="560" height="420"
          class="lqip-img" loading="lazy" decoding="async"
        />
      </div>
      <div class="narrative-text">
        <span class="narrative-num" aria-hidden="true">04</span>
        <h3>The Build Begins</h3>
        <p>Construction partners bring the design to life over about six weeks. Your family steps away — and when you come back, everything has changed.</p>
      </div>
    </div>
  </section>

  <!-- ══════ THE REVEAL — Cinematic dark section ══════ -->
  <section class="reveal">
    <div class="reveal-inner">
      <div class="reveal-content" data-reveal>
        <span class="reveal-badge">The Best Part</span>
        <h2>The Big <em>Reveal</em></h2>
        <p>Your child walks through the door and sees a room designed just for them. That look on their face — the gasp, the tears, the spinning around trying to take it all in — is what every donor, volunteer, and partner works toward.</p>
      </div>
      <div class="reveal-photo-frame" data-reveal data-delay="1">
        <div class="reveal-glow" aria-hidden="true"></div>
        <div class="reveal-photo" style={`background-image:url('${cfLqip(processPhotoId)}')`}>
          <img
            src={cfRaw(processPhotoId, 'w=800,h=560,fit=cover,gravity=face,q=82')}
            srcset={cfSrcset(processPhotoId, [500, 800, 1100], { fit: 'cover', gravity: 'face', aspectRatio: 0.7 })}
            sizes="(max-width: 768px) 90vw, (max-width: 1200px) 50vw, 520px"
            alt="A child's joyful reaction seeing their new room for the first time"
            width="800" height="560"
            class="lqip-img" loading="lazy" decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ PARENT TESTIMONIAL — Real quote from a real family ══════ -->
  {testimonial.quote && (
    <section class="pullquote-section">
      <div class="pullquote-inner" data-reveal>
        <div class="pullquote">
          <span class="pullquote-mark" aria-hidden="true">&ldquo;</span>
          <blockquote>
            <p>{testimonial.quote}</p>
          </blockquote>
          {testimonial.attribution && (
            <cite>— {testimonial.attribution}</cite>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- ══════ WHO WE SERVE — Criteria + proof ══════ -->
  <section class="criteria section">
    <div class="criteria-inner">
      <div class="criteria-text" data-reveal>
        <div class="section-label">Who We Serve</div>
        <h2>Every application tells a <em class="highlight">story</em></h2>
        <p class="criteria-lead">We don't just look at a diagnosis — we look at the whole picture. How would a new space change your child's daily life?</p>
        <ul class="criteria-list">
          <li>
            <strong>Daily impact & safety</strong>
            <span>How does the current space affect your child's independence or quality of life?</span>
          </li>
          <li>
            <strong>Financial circumstances</strong>
            <span>We prioritize families who couldn't otherwise afford these modifications.</span>
          </li>
          <li>
            <strong>Potential for transformation</strong>
            <span>Will a new space meaningfully change how your child lives, plays, or heals?</span>
          </li>
          <li>
            <strong>Scope & feasibility</strong>
            <span>Can we build the right space within your home's existing footprint?</span>
          </li>
        </ul>
        <p class="criteria-note">We serve children with special needs in the greater Atlanta area — physical disabilities, autism, sensory processing disorders, chronic illness, and more.</p>
      </div>
      <div class="criteria-stats" data-reveal data-delay="1">
        <div class="criteria-stat-card">
          <span class="criteria-stat-num">{stats.totalRooms}+</span>
          <span class="criteria-stat-label">rooms built</span>
        </div>
        <div class="criteria-stat-card">
          <span class="criteria-stat-num">{stats.years}</span>
          <span class="criteria-stat-label">years of impact</span>
        </div>
        <div class="criteria-stat-card criteria-stat-card--highlight">
          <span class="criteria-stat-num">$0</span>
          <span class="criteria-stat-label">cost to families</span>
          <span class="criteria-stat-sub">every makeover is 100% free</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ FAQ — Editorial Split (dark, matches donate page) ══════ -->
  {faqs.length > 0 && (
    <FAQSection
      heading='Everything families <em class="highlight highlight--dark">ask</em>'
      body="We know this process can feel overwhelming. These are the questions families ask most often."
      ctaLabel="Have a Question? →"
      ctaHref={`mailto:${siteSettings.email}`}
      ctaClass="btn btn-ghost-light"
      items={faqs}
      accordionName="apply-faq"
      id="faq"
    />
  )}


</BaseLayout>


<style>
  /* ══════════════════════════════════════════
     SHARED
     ══════════════════════════════════════════ */
  h2 em:not(.highlight) { font-style: italic; color: #8A7200; }
  .highlight--dark {
    background-image: linear-gradient(transparent 55%, rgba(255, 218, 36, 0.3) 55%);
  }

  .btn-lg { font-size: 17px; padding: 18px 44px; }
  .hero-glow { animation: pulseGlow 3s ease-in-out 3s infinite; }
  .btn-outline-dark {
    background: transparent;
    color: var(--c-dark);
    border: 2px solid var(--c-dark);
    padding: 12px 30px;
  }
  .btn-outline-dark:hover {
    background: var(--c-dark);
    color: var(--c-yellow);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }
  .btn-ghost-light {
    background: transparent;
    color: rgba(255,255,255,0.7);
    border: 1px solid rgba(255,255,255,0.15);
    padding: 12px 28px;
  }
  .btn-ghost-light:hover {
    background: rgba(255,255,255,0.08);
    color: #fff;
    border-color: rgba(255,255,255,0.3);
    transform: translateY(-2px);
  }

  /* Hero entrance keyframes */
  @keyframes heroUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes heroSlide {
    from { transform: translateY(12px); }
    to { transform: translateY(0); }
  }
  @keyframes heroPhotoIn {
    from { opacity: 0; transform: scale(0.97); }
    to { opacity: 1; transform: scale(1); }
  }
  @keyframes accentIn {
    from { opacity: 0; transform: scale(0.85); }
    to { opacity: 0.35; transform: scale(1); }
  }
  @keyframes pulseGlow {
    0%, 100% { box-shadow: 0 8px 24px var(--c-yellow-glow); }
    50% { box-shadow: 0 8px 32px rgba(255, 218, 36, 0.55); }
  }

  /* ══════════════════════════════════════════
     HERO
     ══════════════════════════════════════════ */
  .hero {
    background: var(--c-cream);
    padding: clamp(80px, 10vw, 140px) 0 clamp(64px, 8vw, 100px);
    position: relative;
    contain: layout style;
    min-height: clamp(480px, 70vh, 720px);
    overflow: hidden;
  }
  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-xl);
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(40px, 5vw, 80px);
    align-items: center;
  }
  .hero-eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .hero-eyebrow::before {
    content: '';
    width: 28px;
    height: 2px;
    background: currentColor;
    flex-shrink: 0;
  }
  /* Hero entrance stagger — matches homepage/community */
  .hero-text .section-label {
    opacity: 0;
    animation: heroUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.05s both;
  }
  .hero-text h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    letter-spacing: -0.035em;
    line-height: 1.04;
    color: var(--c-text);
    margin-bottom: 28px;
    /* NO opacity:0 — LCP element */
    animation: heroSlide 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hero-text h1 em {
    font-style: italic;
    background-image: linear-gradient(transparent 52%, var(--c-yellow-soft) 52%);
    background-repeat: no-repeat;
    background-size: 100% 100%;
    padding: 0 0.05em;
  }
  .hero-lead {
    font-size: clamp(16px, 1.6vw, 18px);
    color: var(--c-text-muted);
    line-height: 1.7;
    margin-bottom: 40px;
    max-width: 480px;
    opacity: 0;
    animation: heroUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
  }
  .hero-ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    opacity: 0;
    animation: heroUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.25s both;
  }

  .hero-frame {
    position: relative;
    animation: heroPhotoIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hero-accent {
    position: absolute;
    bottom: -16px;
    right: -16px;
    width: 65%;
    height: 50%;
    background: var(--c-yellow);
    border-radius: 24px;
    z-index: 0;
    opacity: 0;
    animation: accentIn 1s cubic-bezier(0.16, 1, 0.3, 1) 0.7s both;
  }
  .hero-photo {
    position: relative;
    z-index: 1;
    aspect-ratio: 4 / 5;
    border-radius: 24px;
    overflow: hidden;
    background-size: cover;
    background-position: center;
    box-shadow:
      0 32px 80px rgba(0, 0, 0, 0.12),
      0 8px 24px rgba(0, 0, 0, 0.06);
  }
  .hero-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .hero-photo--small {
    position: absolute;
    bottom: -24px;
    left: -32px;
    width: 40%;
    aspect-ratio: 5 / 6;
    z-index: 2;
    border: 4px solid var(--c-cream);
    box-shadow:
      0 4px 6px rgba(0, 0, 0, 0.06),
      0 12px 36px rgba(0, 0, 0, 0.12);
  }
  .hero-stat {
    position: absolute;
    bottom: clamp(24px, 4vw, 48px);
    right: clamp(24px, 6vw, 80px);
    background: var(--c-dark);
    color: #fff;
