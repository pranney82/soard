---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';

const CF = 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ';
---

<BaseLayout title="Page Not Found — Sunshine on a Ranney Day">
  <section class="lost" id="scene">
    <!-- Blueprint grid background -->
    <div class="blueprint" aria-hidden="true"></div>

    <!-- Parallax sky layer -->
    <div class="sky" id="sky" aria-hidden="true">
      <div class="cloud cloud--1"></div>
      <div class="cloud cloud--2"></div>
      <div class="cloud cloud--3"></div>
      <div class="cloud cloud--4"></div>
    </div>

    <!-- Floating tool particles -->
    <div class="particles" aria-hidden="true">
      <span class="particle particle--1">🔨</span>
      <span class="particle particle--2">🪚</span>
      <span class="particle particle--3">⭐</span>
      <span class="particle particle--4">💛</span>
      <span class="particle particle--5">🔧</span>
      <span class="particle particle--6">🏠</span>
      <span class="particle particle--7">✨</span>
    </div>

    <!-- Confetti canvas for easter egg -->
    <canvas id="confetti" class="confetti-canvas" aria-hidden="true"></canvas>

    <div class="container">
      <!-- 4 · GRACIE · 4 -->
      <div class="hero-404" id="hero-404">
        <span class="digit digit--left" id="digit-l">4</span>
        <div class="gracie-zone" id="gracie-zone">
          <!-- Sunshine rays behind Gracie -->
          <div class="rays" id="rays" aria-hidden="true">
            <div class="ray"></div><div class="ray"></div><div class="ray"></div>
            <div class="ray"></div><div class="ray"></div><div class="ray"></div>
            <div class="ray"></div><div class="ray"></div><div class="ray"></div>
            <div class="ray"></div><div class="ray"></div><div class="ray"></div>
          </div>
          <!-- Yellow glow ring -->
          <div class="glow-ring" id="glow-ring" aria-hidden="true"></div>
          <div class="gracie-wrap" id="gracie-wrap">
            <img
              src={`${CF}/sunny-pig/w=300,h=300,fit=contain`}
              srcset={`${CF}/sunny-pig/w=180,h=180,fit=contain 180w, ${CF}/sunny-pig/w=300,h=300,fit=contain 300w`}
              sizes="(max-width: 600px) 180px, 300px"
              alt="Gracie the Pig — SOARD's golden flying mascot"
              width="300"
              height="300"
              class="gracie"
              id="gracie"
              loading="eager"
              decoding="async"
            />
            <!-- Click sparkle container -->
            <div class="sparkles" id="sparkles" aria-hidden="true"></div>
          </div>
          <div class="gracie-shadow" id="gracie-shadow" aria-hidden="true"></div>
        </div>
        <span class="digit digit--right" id="digit-r">4</span>
      </div>

      <!-- Click counter badge -->
      <div class="oink-counter" id="oink-counter" aria-hidden="true">
        <span class="oink-counter__icon">🐷</span>
        <span class="oink-counter__num" id="oink-num">0</span>
        <span class="oink-counter__label">oinks</span>
      </div>

      <!-- Speech bubble -->
      <div class="bubble" id="bubble">
        <p class="bubble__text" id="bubble-text">Gracie flew off&nbsp;course!</p>
      </div>

      <p class="subtitle">
        She searched high and low, but this page hasn't been built yet.
        <br />Don't worry — Gracie always finds her way home.
      </p>

      <!-- Click prompt -->
      <p class="tap-hint" id="tap-hint" aria-hidden="true">
        <span class="tap-hint__icon">👆</span> Tap Gracie
      </p>

      <div class="actions">
        <Button href="/" size="lg">
          <span aria-hidden="true" style="margin-right: 0.3rem;">🏠</span> Fly Home
        </Button>
        <Button href="/kids/" variant="outline" size="lg">Meet the Kids</Button>
      </div>

      <div class="fun-links">
        <p class="fun-links__label">Or explore:</p>
        <div class="fun-links__list">
          <a href="/about/">Our Story</a>
          <span class="fun-links__dot" aria-hidden="true"></span>
          <a href="/donate/">Donate</a>
          <span class="fun-links__dot" aria-hidden="true"></span>
          <a href="/partners/">Partners</a>
          <span class="fun-links__dot" aria-hidden="true"></span>
          <a href="/shop/">Shop</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const quotes = [
    "Gracie flew off\u00a0course!",
    "This room hasn't been\u00a0built\u00a0yet!",
    "Oink! Wrong\u00a0turn!",
    "Even flying pigs get\u00a0lost!",
    "Hold my cape, I'll find\u00a0it!",
    "404 dreams — still\u00a0searching!",
    "Sawing through pages\u00a0here\u2026",
    "Let's build this page\u00a0together!",
  ];

  const EASTER_EGG_CLICKS = 7;

  function init() {
    const gracie = document.getElementById('gracie');
    const wrap = document.getElementById('gracie-wrap');
    const bubbleText = document.getElementById('bubble-text');
    const sparkles = document.getElementById('sparkles');
    const hint = document.getElementById('tap-hint');
    const digitL = document.getElementById('digit-l');
    const digitR = document.getElementById('digit-r');
    const scene = document.getElementById('scene');
    const sky = document.getElementById('sky');
    const gracieZone = document.getElementById('gracie-zone');
    const rays = document.getElementById('rays');
    const glowRing = document.getElementById('glow-ring');
    const counter = document.getElementById('oink-counter');
    const counterNum = document.getElementById('oink-num');
    const canvas = document.getElementById('confetti');

    if (!gracie || !wrap || !bubbleText || !sparkles || !scene) return;

    let quoteIdx = 0;
    let clickCount = 0;
    let spinning = false;
    let easterEggTriggered = false;

    // ── Mouse Parallax ──────────────────────
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!prefersReduced && sky && gracieZone && rays) {
      let mx = 0, my = 0, cx = 0, cy = 0;
      let ticking = false;

      scene.addEventListener('mousemove', (e) => {
        const rect = scene.getBoundingClientRect();
        mx = ((e.clientX - rect.left) / rect.width - 0.5) * 2;   // -1 to 1
        my = ((e.clientY - rect.top) / rect.height - 0.5) * 2;
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(applyParallax);
        }
      });

      scene.addEventListener('mouseleave', () => {
        mx = 0; my = 0;
        if (!ticking) { ticking = true; requestAnimationFrame(applyParallax); }
      });

      function applyParallax() {
        // Lerp toward target
        cx += (mx - cx) * 0.08;
        cy += (my - cy) * 0.08;

        // Clouds drift with cursor
        sky.style.transform = `translate(${cx * 20}px, ${cy * 10}px)`;

        // Gracie tilts toward cursor
        gracieZone.style.transform = `translate(${cx * 8}px, ${cy * 5}px)`;
        gracie.style.transform = `rotate(${cx * 4}deg)`;

        // Rays shift opposite for depth
        if (rays) rays.style.setProperty('--parallax-x', `${cx * -12}px`);
        if (glowRing) glowRing.style.setProperty('--parallax-x', `${cx * -6}px`);

        if (Math.abs(mx - cx) > 0.001 || Math.abs(my - cy) > 0.001) {
          requestAnimationFrame(applyParallax);
        } else {
          ticking = false;
        }
      }
    }

    // ── Gracie Click ────────────────────────
    gracie.addEventListener('click', () => {
      if (spinning) return;
      spinning = true;
      clickCount++;

      // Show counter after first click
      if (counter && clickCount === 1) {
        counter.classList.add('visible');
      }
      if (counterNum) {
        counterNum.textContent = clickCount;
        counterNum.classList.remove('bump');
        void counterNum.offsetWidth; // reflow
        counterNum.classList.add('bump');
      }

      // Hide hint
      if (hint && clickCount === 1) hint.style.opacity = '0';

      // Barrel roll
      wrap.classList.add('barrel-roll');

      // Digits react — wobble outward
      if (digitL) { digitL.classList.remove('wobble'); void digitL.offsetWidth; digitL.classList.add('wobble'); }
      if (digitR) { digitR.classList.remove('wobble'); void digitR.offsetWidth; digitR.classList.add('wobble'); }

      // Tiny screen shake
      scene.classList.remove('shake');
      void scene.offsetWidth;
      scene.classList.add('shake');

      // Sparkle burst
      const sparkEmoji = ['✨','⭐','💛','🌟','☀️','🐷'];
      for (let i = 0; i < 14; i++) {
        const s = document.createElement('span');
        s.className = 'spark';
        s.textContent = sparkEmoji[Math.floor(Math.random() * sparkEmoji.length)];
        const angle = (i / 14) * 360;
        const dist = 55 + Math.random() * 60;
        s.style.setProperty('--angle', angle + 'deg');
        s.style.setProperty('--dist', dist + 'px');
        s.style.setProperty('--delay', (Math.random() * 0.12) + 's');
        sparkles.appendChild(s);
      }

      // Rotate quote
      quoteIdx = (quoteIdx + 1) % quotes.length;
      bubbleText.style.opacity = '0';
      bubbleText.style.transform = 'translateY(8px)';
      setTimeout(() => {
        bubbleText.innerHTML = quotes[quoteIdx];
        bubbleText.style.opacity = '1';
        bubbleText.style.transform = 'translateY(0)';
      }, 200);

      // ── Easter Egg at N clicks ──
      if (clickCount === EASTER_EGG_CLICKS && !easterEggTriggered) {
        easterEggTriggered = true;
        setTimeout(() => {
          bubbleText.innerHTML = "You found Gracie's secret\u00a0room! 🎉";
          scene.classList.add('golden-mode');
          fireConfetti(canvas);
        }, 300);
      }

      // Cleanup
      setTimeout(() => {
        wrap.classList.remove('barrel-roll');
        sparkles.innerHTML = '';
        scene.classList.remove('shake');
        spinning = false;
      }, 800);
    });

    // ── Confetti ────────────────────────────
    function fireConfetti(canvasEl) {
      if (!canvasEl) return;
      const ctx = canvasEl.getContext('2d');
      if (!ctx) return;

      canvasEl.width = window.innerWidth;
      canvasEl.height = window.innerHeight;
      canvasEl.style.display = 'block';

      const pieces = [];
      const colors = ['#FFDA24', '#FFE766', '#FFC107', '#FFFFFF', '#373A36', '#FFD700', '#FFA500'];

      for (let i = 0; i < 150; i++) {
        pieces.push({
          x: Math.random() * canvasEl.width,
          y: -20 - Math.random() * canvasEl.height * 0.5,
          w: 4 + Math.random() * 8,
          h: 6 + Math.random() * 10,
          color: colors[Math.floor(Math.random() * colors.length)],
          vx: (Math.random() - 0.5) * 4,
          vy: 2 + Math.random() * 5,
          rot: Math.random() * 360,
          rv: (Math.random() - 0.5) * 12,
          opacity: 1,
        });
      }

      let frame = 0;
      function draw() {
        ctx.clearRect(0, 0, canvasEl.width, canvasEl.height);
        let alive = false;
        for (const p of pieces) {
          p.x += p.vx;
          p.vy += 0.1;
          p.y += p.vy;
          p.rot += p.rv;
          if (frame > 80) p.opacity -= 0.015;
          if (p.opacity <= 0) continue;
          alive = true;
          ctx.save();
          ctx.globalAlpha = Math.max(0, p.opacity);
          ctx.translate(p.x, p.y);
          ctx.rotate((p.rot * Math.PI) / 180);
          ctx.fillStyle = p.color;
          ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
          ctx.restore();
        }
        frame++;
        if (alive && frame < 250) {
          requestAnimationFrame(draw);
        } else {
          ctx.clearRect(0, 0, canvasEl.width, canvasEl.height);
          canvasEl.style.display = 'none';
        }
      }
      requestAnimationFrame(draw);
    }
  }

  document.addEventListener('astro:page-load', init);
  init();
</script>

<style>
  /* ═══ Scene ═══════════════════════════════ */
  .lost {
    position: relative;
    overflow: hidden;
    min-height: calc(100vh - var(--header-height));
    min-height: calc(100dvh - var(--header-height));
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: var(--space-3xl);
    background: var(--c-cream);
    transition: background 0.6s ease;
  }

  /* Golden mode (easter egg) */
  .lost.golden-mode {
    background:
      radial-gradient(ellipse 80% 60% at 50% 40%, rgba(255, 218, 36, 0.15) 0%, transparent 70%),
      var(--c-cream);
  }

  .container {
    text-align: center;
    position: relative;
    z-index: 2;
    max-width: 640px;
    margin-inline: auto;
    padding-inline: var(--page-padding);
  }

  /* ═══ Blueprint Grid ══════════════════════ */
  .blueprint {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(55, 58, 54, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(55, 58, 54, 0.025) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 45%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 45%, black 20%, transparent 70%);
  }

  /* ═══ Screen Shake ════════════════════════ */
  :global(.lost.shake) {
    animation: shake 0.35s ease;
  }
  @keyframes shake {
    0%, 100% { transform: translate(0, 0); }
    15%  { transform: translate(-2px, 1px); }
    30%  { transform: translate(2px, -1px); }
    45%  { transform: translate(-1px, 2px); }
    60%  { transform: translate(1px, -1px); }
    75%  { transform: translate(-1px, 0px); }
  }

  /* ═══ Confetti Canvas ═════════════════════ */
  .confetti-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 100;
    pointer-events: none;
    display: none;
  }

  /* ═══ Sky & Clouds ════════════════════════ */
  .sky {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    transition: transform 0.05s linear;
    will-change: transform;
  }

  .cloud {
    position: absolute;
    background: var(--c-white);
    border-radius: 999px;
  }
  .cloud::before,
  .cloud::after {
    content: '';
    position: absolute;
    background: inherit;
    border-radius: inherit;
  }

  .cloud--1 {
    width: 140px; height: 42px; top: 10%; opacity: 0.45;
    animation: drift 30s linear infinite;
  }
  .cloud--1::before { width: 55px; height: 55px; top: -28px; left: 22px; }
  .cloud--1::after  { width: 75px; height: 58px; top: -32px; left: 55px; }

  .cloud--2 {
    width: 100px; height: 32px; top: 22%; opacity: 0.25;
    animation: drift 38s linear infinite -14s;
  }
  .cloud--2::before { width: 42px; height: 42px; top: -22px; left: 16px; }
  .cloud--2::after  { width: 58px; height: 48px; top: -26px; left: 42px; }

  .cloud--3 {
    width: 110px; height: 36px; top: 6%; opacity: 0.3;
    animation: drift 34s linear infinite -22s;
  }
  .cloud--3::before { width: 48px; height: 48px; top: -24px; left: 20px; }
  .cloud--3::after  { width: 65px; height: 50px; top: -28px; left: 48px; }

  .cloud--4 {
    width: 80px; height: 26px; top: 30%; opacity: 0.2;
    animation: drift 42s linear infinite -8s;
  }
  .cloud--4::before { width: 35px; height: 35px; top: -18px; left: 12px; }
  .cloud--4::after  { width: 48px; height: 38px; top: -20px; left: 35px; }

  @keyframes drift {
    from { transform: translateX(-220px); }
    to   { transform: translateX(calc(100vw + 220px)); }
  }

  /* ═══ Floating Particles ══════════════════ */
  .particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .particle {
    position: absolute;
    font-size: 1.4rem;
    opacity: 0;
    animation: float-up 7s ease-in-out infinite;
  }

  .particle--1 { left: 8%;  bottom: 5%;  animation-delay: 0s; }
  .particle--2 { left: 88%; bottom: 8%;  animation-delay: 1s; }
  .particle--3 { left: 18%; bottom: 12%; animation-delay: 2s; font-size: 1.1rem; }
  .particle--4 { left: 78%; bottom: 6%;  animation-delay: 3s; }
  .particle--5 { left: 45%; bottom: 3%;  animation-delay: 4s; }
  .particle--6 { left: 62%; bottom: 10%; animation-delay: 5s; }
  .particle--7 { left: 32%; bottom: 7%;  animation-delay: 6s; font-size: 1rem; }

  @keyframes float-up {
    0%   { opacity: 0; transform: translateY(0) rotate(0deg) scale(0.7); }
    12%  { opacity: 0.6; }
    88%  { opacity: 0.5; }
    100% { opacity: 0; transform: translateY(-65vh) rotate(30deg) scale(1.05); }
  }

  /* ═══ 4 · GRACIE · 4 ═════════════════════ */
  .hero-404 {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(0rem, 1vw, 0.5rem);
    margin-bottom: var(--space-sm);
  }

  .digit {
    font-family: var(--font-display);
    font-size: clamp(7rem, 20vw, 16rem);
    font-weight: 700;
    line-height: 1;
    color: var(--c-dark);
    opacity: 0;
    animation: digit-in 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    user-select: none;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .digit--left {
    animation-delay: 0.1s;
    transform-origin: right center;
  }
  .digit--right {
    animation-delay: 0.35s;
    transform-origin: left center;
  }

  @keyframes digit-in {
    0%   { opacity: 0; transform: translateY(40px) scale(0.85) rotate(-3deg); }
    100% { opacity: 1; transform: translateY(0) scale(1) rotate(-2deg); }
  }
  .digit--right { animation-name: digit-in-r; }
  @keyframes digit-in-r {
    0%   { opacity: 0; transform: translateY(40px) scale(0.85) rotate(3deg); }
    100% { opacity: 1; transform: translateY(0) scale(1) rotate(2deg); }
  }

  /* Digit wobble on click */
  :global(.digit.wobble) {
    animation: digit-wobble 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  :global(.digit--left.wobble) {
    animation-name: digit-wobble-l;
  }
  @keyframes digit-wobble {
    0%   { transform: scale(1) rotate(2deg); }
    25%  { transform: scale(1.06) rotate(6deg) translateX(6px); }
    50%  { transform: scale(0.97) rotate(0deg); }
    100% { transform: scale(1) rotate(2deg); }
  }
  @keyframes digit-wobble-l {
    0%   { transform: scale(1) rotate(-2deg); }
    25%  { transform: scale(1.06) rotate(-6deg) translateX(-6px); }
    50%  { transform: scale(0.97) rotate(0deg); }
    100% { transform: scale(1) rotate(-2deg); }
  }

  /* ═══ Gracie Zone ═════════════════════════ */
  .gracie-zone {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    transition: transform 0.05s linear;
    will-change: transform;
  }

  /* Sunshine rays */
  .rays {
    position: absolute;
    width: clamp(200px, 38vw, 360px);
    height: clamp(200px, 38vw, 360px);
    top: 50%;
    left: 50%;
    transform: translate(calc(-50% + var(--parallax-x, 0px)), -55%);
    animation: rays-spin 30s linear infinite, rays-enter 1s ease 0.3s both;
    pointer-events: none;
    will-change: transform;
  }

  @keyframes rays-enter {
    from { opacity: 0; transform: translate(calc(-50% + var(--parallax-x, 0px)), -55%) scale(0.5); }
    to   { opacity: 1; transform: translate(calc(-50% + var(--parallax-x, 0px)), -55%) scale(1); }
  }

  @keyframes rays-spin {
    to { transform: translate(calc(-50% + var(--parallax-x, 0px)), -55%) rotate(360deg); }
  }

  .ray {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 3px;
    height: 48%;
    background: linear-gradient(to top, rgba(255, 218, 36, 0.22), transparent);
    transform-origin: bottom center;
    border-radius: 3px;
  }
  .ray:nth-child(1)  { transform: rotate(0deg); }
  .ray:nth-child(2)  { transform: rotate(30deg); }
  .ray:nth-child(3)  { transform: rotate(60deg); }
  .ray:nth-child(4)  { transform: rotate(90deg); }
  .ray:nth-child(5)  { transform: rotate(120deg); }
  .ray:nth-child(6)  { transform: rotate(150deg); }
  .ray:nth-child(7)  { transform: rotate(180deg); }
  .ray:nth-child(8)  { transform: rotate(210deg); }
  .ray:nth-child(9)  { transform: rotate(240deg); }
  .ray:nth-child(10) { transform: rotate(270deg); }
  .ray:nth-child(11) { transform: rotate(300deg); }
  .ray:nth-child(12) { transform: rotate(330deg); }

  /* Golden mode — rays get bigger and brighter */
  :global(.lost.golden-mode) .rays {
    width: clamp(240px, 45vw, 440px);
    height: clamp(240px, 45vw, 440px);
    transition: width 0.8s ease, height 0.8s ease;
  }
  :global(.lost.golden-mode) .ray {
    background: linear-gradient(to top, rgba(255, 218, 36, 0.4), transparent);
    width: 4px;
  }

  /* Soft yellow glow */
  .glow-ring {
    position: absolute;
    width: clamp(140px, 30vw, 260px);
    height: clamp(140px, 30vw, 260px);
    top: 50%;
    left: 50%;
    transform: translate(calc(-50% + var(--parallax-x, 0px)), -55%);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 218, 36, 0.18) 0%, rgba(255, 218, 36, 0.05) 50%, transparent 70%);
    animation: glow-pulse 4s ease-in-out infinite;
    pointer-events: none;
    will-change: transform;
  }

  :global(.lost.golden-mode) .glow-ring {
    background: radial-gradient(circle, rgba(255, 218, 36, 0.35) 0%, rgba(255, 218, 36, 0.12) 50%, transparent 70%);
    width: clamp(180px, 38vw, 340px);
    height: clamp(180px, 38vw, 340px);
    transition: all 0.8s ease;
  }

  @keyframes glow-pulse {
    0%, 100% { opacity: 0.8; scale: 1; }
    50%      { opacity: 1; scale: 1.1; }
  }

  /* ═══ Gracie ══════════════════════════════ */
  .gracie-wrap {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    opacity: 0;
    animation: gracie-enter 0.9s cubic-bezier(0.34, 1.56, 0.64, 1) 0.25s forwards;
  }

  @keyframes gracie-enter {
    from { opacity: 0; transform: translateY(50px) scale(0.6) rotate(-15deg); }
    to   { opacity: 1; transform: translateY(0) scale(1) rotate(0deg); }
  }

