---
/**
 * Room Reveal / Makeover — Hand-crafted event detail page
 * Editorial layout: split hero with before/after feel,
 * the child's story, reveal moment, photo gallery, impact CTA.
 *
 * PERF: CF Images w/ srcset, LQIP blur-up, LCP preload, scoped CSS
 * SEO:  Event JSON-LD, breadcrumbs, OG image
 * A11Y: Heading hierarchy, ARIA, prefers-reduced-motion
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { cfRaw, cfSrcset, cfLqip } from '../../utils/cf-image';

/* ══════════════════════════════════════════════
   EDIT THESE FOR EACH MAKEOVER REVEAL
   ══════════════════════════════════════════════ */

const childName = 'Jackson';
const childAge = '8';
const diagnosis = 'Autism Spectrum Disorder';
const roomType = 'Dream Bedroom';
const revealDate = '2025-11-08';
const revealTime = '2:00 PM – 4:00 PM';
const location = 'Private Residence — Roswell, GA';
const heroPhotoId = 'kids/jackson/hero'; /* CF Image ID for the child */

/* Story content — customize per makeover */
const childStory = `Jackson is an energetic 8-year-old who loves dinosaurs, outer space, and building with LEGOs. Diagnosed with Autism Spectrum Disorder at age 3, Jackson's family has navigated years of therapy and specialized care. His old bedroom was cramped, overstimulating, and didn't have the sensory-friendly features he needed to feel safe and calm.`;
const roomDescription = `Working with our incredible design and build partners, we created a space that's truly Jackson's own — a cosmic-themed bedroom with dimmable LED star lights on the ceiling, a custom loft bed shaped like a rocket ship, a quiet sensory nook with weighted blankets and noise-canceling features, and organized LEGO display shelving.`;
const revealMoment = `When Jackson walked into his new room, he stopped in the doorway and whispered "Is this really mine?" before running to his rocket bed with the biggest smile. His mom cried. The whole team cried. This is why we do what we do.`;

/* Photo gallery — add CF Image IDs + alt text for reveal photos */
const photos: { id: string; alt: string }[] = [
  /* Uncomment and add real photo IDs when available:
  { id: 'kids/jackson/photo-01', alt: 'Jackson seeing his new room for the first time' },
  { id: 'kids/jackson/photo-02', alt: 'The completed rocket ship bed' },
  { id: 'kids/jackson/photo-03', alt: 'Sensory nook with dimmable lights' },
  { id: 'kids/jackson/photo-04', alt: 'Jackson and his family in the new room' },
  */
];

/* ══════════════════════════════════════════════ */

const slug = `room-reveal-${childName.toLowerCase()}-${revealDate.split('-')[0]}`;

/* ── JSON-LD ── */
const eventJsonLd = {
  "@type": "Event",
  "@id": `https://sunshineonaranneyday.com/events/makeover/#event`,
  "name": `Room Reveal: ${childName}'s ${roomType}`,
  "description": `Celebrate with ${childName} and family as we reveal a brand-new ${roomType.toLowerCase()} — built by Sunshine on a Ranney Day.`,
  "startDate": revealDate,
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  "eventStatus": "https://schema.org/EventScheduled",
  "location": { "@type": "Place", "name": location },
  "organizer": { "@id": "https://sunshineonaranneyday.com/#organization" },
  ...(heroPhotoId && { "image": cfRaw(heroPhotoId, 'w=1200,q=85') }),
};

/* ── LCP preload ── */
const heroSrcset = cfSrcset(heroPhotoId, [400, 640, 900], { fit: 'cover', gravity: 'face' });
const heroSizes = '(max-width: 768px) 85vw, 420px';

function fmtDate(d: string) {
  return new Date(d + 'T00:00:00').toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout
  title={`Room Reveal: ${childName}'s ${roomType} — Sunshine on a Ranney Day`}
  description={`Celebrate with ${childName} as we reveal a brand-new ${roomType.toLowerCase()} — designed and built by Sunshine on a Ranney Day for a child with ${diagnosis}.`}
  ogImage={cfRaw(heroPhotoId, 'w=1200,h=630,fit=cover,q=85')}
  jsonLd={eventJsonLd}
  breadcrumbs={[
    { name: 'Events', url: '/events/' },
    { name: `${childName}'s Room Reveal`, url: '/events/makeover/' },
  ]}
>
  <link slot="head" rel="preload" as="image" imagesrcset={heroSrcset} imagesizes={heroSizes} fetchpriority="high" />

  <!-- ═══ HERO (editorial split) ═══ -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <span class="hero-eyebrow">Room Reveal</span>
        <h1 class="hero-headline">Meet <em class="highlight">{childName}</em></h1>
        <p class="hero-sub">{childAge} years old · {diagnosis}</p>
        <div class="hero-meta">
          <div class="hero-meta__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
            <time datetime={revealDate}>{fmtDate(revealDate)}</time>
          </div>
          {revealTime && (
            <div class="hero-meta__item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              {revealTime}
            </div>
          )}
          <div class="hero-meta__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
            {location}
          </div>
        </div>
        <div class="hero-ctas">
          <a href="#story" class="btn btn-primary btn-lg">{childName}'s Story</a>
          <a href="/donate/" class="btn btn-dark">Fund a Room</a>
        </div>
      </div>
      <div class="hero-frame">
        <div class="hero-accent" aria-hidden="true"></div>
        <div class="hero-photo" style={`background-image:url('${cfLqip(heroPhotoId)}')`}>
          <img
            src={cfRaw(heroPhotoId, 'w=640,h=800,fit=cover,gravity=face,q=82')}
            srcset={heroSrcset}
            sizes={heroSizes}
            alt={`${childName} — Sunshine on a Ranney Day`}
            width="640" height="800"
            loading="eager" decoding="async" fetchpriority="high"
            class="hero-photo__img lqip-img"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ THE STORY ═══ -->
  <section class="mk-story" id="story">
    <div class="container">
      <div class="mk-story__inner" data-reveal>
        <p class="section-label">The Story</p>
        <h2 class="section-heading">Why {childName} Needed a <em class="highlight">Dream&nbsp;Room</em></h2>
        <p class="mk-story__body">{childStory}</p>
      </div>
    </div>
  </section>

  <!-- ═══ THE ROOM ═══ -->
  <section class="mk-room">
    <div class="container">
      <div class="mk-room__inner" data-reveal>
        <p class="section-label">The Build</p>
        <h2 class="section-heading">What We <em class="highlight">Created</em></h2>
        <p class="mk-room__body">{roomDescription}</p>
        <div class="mk-room__tag">
          <span class="mk-room__tag-label">Room Type</span>
          <span class="mk-room__tag-value">{roomType}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ THE REVEAL MOMENT ═══ -->
  <section class="mk-reveal">
    <div class="mk-reveal__glow" aria-hidden="true"></div>
    <div class="container">
      <div class="mk-reveal__inner" data-reveal>
        <p class="mk-reveal__label">The Moment</p>
        <div class="mk-reveal__quote-mark" aria-hidden="true">&ldquo;</div>
        <blockquote class="mk-reveal__quote">{revealMoment}</blockquote>
      </div>
    </div>
  </section>

  <!-- ═══ PHOTO GALLERY ═══ -->
  {photos.length > 0 && (
    <section class="mk-gallery" id="photos">
      <div class="container">
        <div class="mk-gallery__header" data-reveal>
          <p class="section-label">The Reveal</p>
          <h2 class="section-heading">See {childName}'s <em class="highlight">Reaction</em></h2>
        </div>
        <div class="mk-gallery__grid">
          {photos.map((photo, i) => (
            <div class="mk-gallery__item" data-reveal data-delay={String(Math.min(i, 3))} style={`background-image:url('${cfLqip(photo.id)}')`}>
              <img
                src={cfRaw(photo.id, 'w=600,fit=cover,q=80')}
                srcset={cfSrcset(photo.id, [400, 600, 900], { fit: 'cover' })}
                sizes="(max-width: 639px) 100vw, (max-width: 959px) 50vw, 33vw"
                alt={photo.alt}
                class="mk-gallery__img lqip-img"
                loading="lazy" decoding="async"
                width="600" height="400"
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ CTA ═══ -->
  <section class="mk-cta">
    <div class="container">
      <div class="mk-cta__card" data-reveal>
        <h2>Every Child Deserves a <em class="highlight-dark">Dream&nbsp;Room</em></h2>
        <p>Your donation or sponsorship directly funds life-changing room makeovers for children with special needs.</p>
        <div class="mk-cta__actions">
          <a href="/donate/" class="ev-btn ev-btn--gold">Donate Now</a>
          <a href="/apply/" class="ev-btn ev-btn--outline-white">Apply for a Room</a>
          <a href="/kids/" class="ev-btn ev-btn--outline-white">Meet More Kids</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(link => {
    link.addEventListener('click', (e) => {
      const id = link.getAttribute('href')?.slice(1);
      if (!id) return;
      const target = document.getElementById(id);
      if (!target) return;
      e.preventDefault();
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
</script>

<style>
  [id] { scroll-margin-top: calc(var(--header-height, 84px) + 1.5rem); }

  /* ─── Reveal ─── */
  [data-reveal] {
    opacity: 0; transform: translateY(28px);
    transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1);
  }
  [data-reveal].is-visible { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) { [data-reveal] { transition: none; opacity: 1; transform: none; } }

  /* ─── Shared ─── */
  .ev-btn { display: inline-flex; align-items: center; gap: 8px; padding: 0.75rem 1.6rem; border-radius: 100px; font-size: 0.88rem; font-weight: 600; text-decoration: none; border: 1.5px solid transparent; cursor: pointer; transition: background 200ms, color 200ms, transform 200ms, box-shadow 200ms; }
  .ev-btn:active { transform: scale(0.97); }
  .ev-btn--gold { background: var(--c-yellow); color: var(--c-dark); border-color: var(--c-yellow); }
  .ev-btn--gold:hover { transform: translateY(-2px); box-shadow: 0 6px 24px var(--c-yellow-glow); }
  .ev-btn--outline-white { background: transparent; color: #fff; border-color: rgba(255,255,255,0.4); }
  .ev-btn--outline-white:hover { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.7); }

  .section-label { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--c-text-muted); margin-bottom: var(--space-sm); }
  .section-heading { font-family: var(--font-display); font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 400; color: var(--c-dark); letter-spacing: -0.02em; line-height: 1.15; text-wrap: balance; }

  /* ═══ HERO ═══ */
  .hero { background: var(--c-cream); padding: var(--space-3xl) 0 var(--space-4xl); overflow: hidden; }
  .hero-inner { max-width: var(--max-width, 1200px); margin: 0 auto; padding: 0 var(--space-xl); display: grid; grid-template-columns: 1fr; gap: var(--space-2xl); align-items: center; }
  @media (min-width: 768px) { .hero-inner { grid-template-columns: 1fr 0.8fr; gap: var(--space-3xl); } }
  .hero-eyebrow { display: block; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.18em; color: var(--c-text-muted); margin-bottom: var(--space-md); }
  .hero-headline { font-family: var(--font-display); font-size: clamp(2rem, 4.5vw + 0.5rem, 3.25rem); font-weight: 400; color: var(--c-dark); line-height: 1.12; letter-spacing: -0.025em; text-wrap: balance; margin-bottom: var(--space-sm); }
  .hero-sub { font-family: var(--font-display); font-style: italic; font-size: clamp(0.92rem, 1.4vw, 1.02rem); line-height: 1.7; color: var(--c-text-muted); max-width: 44ch; margin-bottom: var(--space-lg); }
  .hero-meta { display: flex; flex-direction: column; gap: var(--space-xs); margin-bottom: var(--space-xl); }
  .hero-meta__item { display: flex; align-items: center; gap: 8px; font-size: 0.88rem; color: var(--c-text-muted); }
  .hero-meta__item svg { color: var(--c-text-light); flex-shrink: 0; }
  .hero-ctas { display: flex; gap: var(--space-md); flex-wrap: wrap; }
  .hero-frame { position: relative; display: flex; justify-content: center; }
  .hero-accent { position: absolute; top: -12px; right: -12px; width: 65%; height: 65%; background: var(--c-yellow); border-radius: var(--border-radius-lg); opacity: 0.15; z-index: 0; }
  .hero-photo { position: relative; z-index: 1; border-radius: var(--border-radius-lg); overflow: hidden; aspect-ratio: 4 / 5; max-width: 420px; width: 100%; background-size: cover; background-position: center; box-shadow: 0 24px 64px rgba(0,0,0,0.12); }
  .hero-photo__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .hero-photo__img.lqip-pending { opacity: 0; }
  .hero-photo__img.loaded { opacity: 1; transition: opacity 0.4s ease; }
  @media (max-width: 767px) {
    .hero { padding: var(--space-xl) 0 var(--space-2xl); }
    .hero-frame { order: -1; }
    .hero-photo { max-width: 280px; aspect-ratio: 3 / 4; }
    .hero-accent { width: 55%; height: 55%; top: -8px; right: -8px; }
    .hero-inner { text-align: center; }
    .hero-meta { align-items: center; }
    .hero-ctas { justify-content: center; }
    .hero-sub { margin-inline: auto; }
  }

  /* ═══ STORY SECTION ═══ */
  .mk-story { padding: var(--space-4xl) 0; background: var(--c-white); }
  .mk-story__inner { max-width: 680px; }
  .mk-story__body { font-size: 1rem; line-height: 1.85; color: var(--c-text); margin-top: var(--space-lg); text-wrap: pretty; }

  /* ═══ THE ROOM ═══ */
  .mk-room { padding: var(--space-4xl) 0; background: var(--c-cream); }
  .mk-room__inner { max-width: 680px; }
  .mk-room__body { font-size: 1rem; line-height: 1.85; color: var(--c-text); margin-top: var(--space-lg); text-wrap: pretty; }
  .mk-room__tag { display: inline-flex; align-items: center; gap: var(--space-sm); margin-top: var(--space-xl); padding: var(--space-sm) var(--space-md); background: var(--c-white); border: 1px solid var(--c-border); border-radius: 100px; }
  .mk-room__tag-label { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--c-text-muted); }
  .mk-room__tag-value { font-size: 0.82rem; font-weight: 600; color: var(--c-dark); }

  /* ═══ REVEAL MOMENT (dark section) ═══ */
  .mk-reveal { position: relative; padding: var(--space-5xl) 0; background: var(--c-dark-deep, #1E1F25); overflow: hidden; }
  .mk-reveal__glow { position: absolute; inset: 0; background: radial-gradient(ellipse 60% 50% at 50% 80%, var(--c-yellow-glow) 0%, transparent 55%); pointer-events: none; }
  .mk-reveal__inner { position: relative; z-index: 1; max-width: 680px; margin: 0 auto; text-align: center; }
  .mk-reveal__label { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: var(--space-lg); }
  .mk-reveal__quote-mark { font-family: var(--font-display); font-size: 5rem; line-height: 1; color: var(--c-yellow); opacity: 0.4; margin-bottom: calc(-1 * var(--space-lg)); }
  .mk-reveal__quote { font-family: var(--font-display); font-style: italic; font-size: clamp(1.05rem, 2.2vw, 1.3rem); line-height: 1.75; color: #fff; margin: 0; text-wrap: pretty; }

  /* ═══ PHOTO GALLERY ═══ */
  .mk-gallery { padding: var(--space-4xl) 0; background: var(--c-white); }
  .mk-gallery__header { margin-bottom: var(--space-2xl); }
  .mk-gallery__grid { display: grid; grid-template-columns: 1fr; gap: var(--space-md); }
  @media (min-width: 640px) { .mk-gallery__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 960px) { .mk-gallery__grid { grid-template-columns: repeat(3, 1fr); } }
  .mk-gallery__item { border-radius: var(--border-radius-lg); overflow: hidden; aspect-ratio: 3 / 2; background-size: cover; background-position: center; }
  .mk-gallery__img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s cubic-bezier(0.16,1,0.3,1); }
  .mk-gallery__item:hover .mk-gallery__img { transform: scale(1.04); }
  .mk-gallery__img.lqip-pending { opacity: 0; }
  .mk-gallery__img.loaded { opacity: 1; transition: opacity 0.4s ease; }

  /* ═══ CTA ═══ */
  .mk-cta { padding: var(--space-3xl) 0 var(--space-4xl); background: var(--c-cream); }
  .mk-cta__card { text-align: center; padding: var(--space-3xl) var(--space-xl); background: var(--c-dark-deep, #1E1F25); border-radius: var(--border-radius-lg); max-width: 720px; margin: 0 auto; position: relative; overflow: hidden; }
  .mk-cta__card::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 50% 50% at 10% 90%, var(--c-yellow-glow) 0%, transparent 50%), radial-gradient(ellipse 40% 40% at 90% 10%, rgba(255,255,255,0.03) 0%, transparent 50%); pointer-events: none; }
  .mk-cta__card h2 { font-family: var(--font-display); color: #fff; font-size: clamp(1.5rem, 3vw, 2.2rem); text-wrap: balance; margin-bottom: var(--space-md); position: relative; }
  .mk-cta__card p { color: rgba(255,255,255,0.6); max-width: 480px; margin: 0 auto var(--space-xl); line-height: 1.7; font-size: 0.95rem; text-wrap: pretty; position: relative; }
  .mk-cta__actions { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; position: relative; }

  @media (max-width: 640px) {
    .ev-btn { min-height: 44px; }
    .mk-cta__card { padding: var(--space-2xl) var(--space-md); }
  }
</style>
