---
/**
 * Home Page — Sunshine on a Ranney Day
 * Cinematic hero, editorial layout, scroll reveals
 * Performance: real CF Images, optimized animations, contain
 * SEO: JSON-LD NonprofitOrganization + WebSite, semantic HTML5
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import MediaLogos from '../components/ui/MediaLogos.astro';
import { getCollection } from 'astro:content';

const CF = 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ';
const stats = { totalKids: 132, totalRooms: 106, years: 13 };

/* ── Hero (from site settings) ── */
import siteSettings from '../content/site/settings.json';
const heroImageId = siteSettings.homeHero?.imageId || 'kids/harper/hero-c6a714';
const heroAltText = siteSettings.homeHero?.altText || 'A child seeing their dream room for the first time';

/* ── Featured Story ── */
const allKids = await getCollection('kids');
const featuredSlug = 'zyah';
const featuredKid = allKids.find(k => k.id === featuredSlug);
const fd = featuredKid?.data;

/* ── Kids Strip — 8 diverse kids ── */
const kidShowcase = [
  { slug: 'liam',     cfId: 'kids/liam/hero-7ab7f9' },
  { slug: 'sophia',   cfId: 'kids/sophia/hero-63933e' },
  { slug: 'jackson',  cfId: 'kids/jackson/hero-4b1747' },
  { slug: 'griffin',  cfId: 'kids/griffin/hero-dbeb0f' },
  { slug: 'madison',  cfId: 'kids/madison/hero-2d8210' },
  { slug: 'harper',   cfId: 'kids/harper/hero-c6a714' },
  { slug: 'noah',     cfId: 'kids/noah/hero-1ba6ae' },
  { slug: 'summer',   cfId: 'kids/summer/hero-22c2e2' },
].map(item => {
  const kid = allKids.find(k => k.id === item.slug);
  return {
    ...item,
    name: kid?.data?.name || item.slug,
    age: kid?.data?.age,
    roomLabel: kid?.data?.roomTypes?.[0] || 'Dream Bedroom',
  };
});

/* ── Section photos ── */
const missionMainId = 'kids/eli/photo-001-70ddd7';
const missionAccentId = 'kids/georgia/photo-001-bd7eb4';
const storyPhotoId = 'kids/zyah/hero-2a16fd';
const roomPhotos = {
  bedroom: 'kids/griffin/hero-dbeb0f',
  bath: 'kids/zyah/hero-2a16fd',
  therapy: 'kids/jackson/hero-4b1747',
};

/* ── Partner logos ── */
const partnerLogos = [
  { id: 'logos/logo-gas-south-afb96260',         name: 'Gas South' },
  { id: 'logos/logo-randall-paulson-b01b8322',    name: 'Randall Paulson' },
  { id: 'logos/logo-kids-r-kids-2c18b077',        name: 'Kids R Kids' },
  { id: 'logos/logo-cambria-5af4504f',            name: 'Cambria' },
  { id: 'logos/logo-mohawk-9784da88',             name: 'Mohawk' },
  { id: 'logos/logo-jackson-healthcare-3c0f6126', name: 'Jackson Healthcare' },
  { id: 'logos/logo-crosby-design-group-d6cf63',  name: 'Crosby Design Group' },
  { id: 'logos/logo-msi-e55b3f4c',               name: 'MSI' },
  { id: 'logos/logo-cr-construction-v2-bc7affde', name: 'CR Construction' },
  { id: 'logos/logo-stag-partners-3399d7',        name: 'Stag Partners' },
];

import { getWebSiteSchema } from '../utils/schema';
const jsonLd = getWebSiteSchema();
---

<BaseLayout
  title="Building Dreams, One Room at a Time"
  description="Sunshine on a Ranney Day is a 501(c)(3) nonprofit creating life-changing home makeovers for children with special needs — dream bedrooms, accessible bathrooms, and therapy spaces — all at no cost to families in greater Atlanta."
  jsonLd={jsonLd}
>

  <!-- ══════ HERO ══════ -->
  <section class="hero" aria-label="Introduction">
    <!-- Cinematic background with Ken Burns zoom -->
    <div class="hero-media" data-parallax="bg">
      <picture>
        <source type="image/avif" srcset={`${CF}/${heroImageId}/w=640,f=avif 640w, ${CF}/${heroImageId}/w=1024,f=avif 1024w, ${CF}/${heroImageId}/w=1600,f=avif 1600w, ${CF}/${heroImageId}/w=2400,f=avif 2400w`} sizes="100vw" />
        <source type="image/webp" srcset={`${CF}/${heroImageId}/w=640,f=webp 640w, ${CF}/${heroImageId}/w=1024,f=webp 1024w, ${CF}/${heroImageId}/w=1600,f=webp 1600w, ${CF}/${heroImageId}/w=2400,f=webp 2400w`} sizes="100vw" />
        <img class="hero-img" src={`${CF}/${heroImageId}/w=1600,q=80`} alt={heroAltText} width="1600" height="900" loading="eager" decoding="async" fetchpriority="high" />
      </picture>
      <div class="hero-overlay"></div>
      <!-- Floating golden particles (CSS-only) -->
      <div class="hero-particles" aria-hidden="true">
        <span class="particle"></span><span class="particle"></span><span class="particle"></span>
        <span class="particle"></span><span class="particle"></span><span class="particle"></span>
        <span class="particle"></span><span class="particle"></span>
      </div>
    </div>

    <div class="hero-inner" data-parallax="content">
      <div class="hero-content">
        <div class="hero-eyebrow" data-hero-reveal="eyebrow">
          <span class="hero-eyebrow-line"></span>
          501(c)(3) Nonprofit · Atlanta, GA · Since 2012
        </div>
        <h1 data-hero-reveal="headline">
          <span class="hero-line"><span class="hero-line-inner">Building <em>dreams</em>,</span></span>
          <span class="hero-line"><span class="hero-line-inner">one room at a time</span></span>
        </h1>
        <p class="hero-lead" data-hero-reveal="lead">We create life-changing spaces for children with special needs — dream bedrooms, accessible bathrooms, and therapy rooms — all at <strong>no cost to families</strong>.</p>
        <div class="hero-ctas" data-hero-reveal="ctas">
          <a href="/donate" class="btn btn-primary btn-glow">
            Give Today
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 2.5C6.5 1 4 1 2.75 2.75S2.5 6.5 8 11.5C13.5 6.5 13.75 4.5 13.25 2.75S9.5 1 8 2.5Z" fill="currentColor"/></svg>
          </a>
          <a href="#stories" class="btn btn-ghost-light">See Our Work ↓</a>
        </div>
        <div class="hero-proof" data-hero-reveal="proof">
          <span class="hero-proof-avatars" aria-hidden="true">
            <img class="hero-proof-avatar" src={`${CF}/kids/liam/hero-7ab7f9/w=56,h=56,fit=cover,f=auto`} alt="" width="28" height="28" loading="eager" />
            <img class="hero-proof-avatar" src={`${CF}/kids/sophia/hero-63933e/w=56,h=56,fit=cover,f=auto`} alt="" width="28" height="28" loading="eager" />
            <img class="hero-proof-avatar" src={`${CF}/kids/griffin/hero-dbeb0f/w=56,h=56,fit=cover,f=auto`} alt="" width="28" height="28" loading="eager" />
          </span>
          <span class="hero-proof-text">{stats.totalKids}+ families served across Greater Atlanta since 2012</span>
        </div>
      </div>
      <div class="hero-impact" data-hero-reveal="impact">
        <div class="hero-impact-num" data-count-to={stats.totalKids}>0<span>+</span></div>
        <div class="hero-impact-label">children's lives<br/>transformed</div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="hero-scroll" aria-hidden="true">
      <span class="hero-scroll-text">Scroll</span>
      <div class="hero-scroll-track"><div class="hero-scroll-dot"></div></div>
    </div>
  </section>

  <!-- ══════ IMPACT RIBBON ══════ -->
  <section class="ribbon" aria-label="Impact numbers">
    <div class="ribbon-inner">
      <div class="ribbon-stat" data-reveal>
        <span class="ribbon-num">{stats.totalRooms}+</span>
        <span class="ribbon-label">Room Makeovers</span>
      </div>
      <div class="ribbon-divider" role="presentation"></div>
      <div class="ribbon-stat" data-reveal data-delay="1">
        <span class="ribbon-num">{stats.totalKids}+</span>
        <span class="ribbon-label">Children Served</span>
      </div>
      <div class="ribbon-divider" role="presentation"></div>
      <div class="ribbon-stat" data-reveal data-delay="2">
        <span class="ribbon-num">{stats.years}</span>
        <span class="ribbon-label">Years of Impact</span>
      </div>
      <div class="ribbon-divider" role="presentation"></div>
      <div class="ribbon-stat" data-reveal data-delay="3">
        <span class="ribbon-num">100<span class="ribbon-pct">%</span></span>
        <span class="ribbon-label">Goes to Kids</span>
      </div>
    </div>
  </section>

  <MediaLogos theme="dark" linked={true} />

  <!-- ══════ MISSION ══════ -->
  <section class="mission" aria-labelledby="mission-heading">
    <div class="mission-inner">
      <div class="mission-text" data-reveal>
        <div class="section-label">Our Mission</div>
        <h2 id="mission-heading">A bedroom isn't just a room. It's where a child feels <em class="highlight">safe</em>, <em class="highlight">seen</em>, and <em class="highlight">loved</em>.</h2>
        <p class="mission-body">For children with special needs, a thoughtfully designed room changes everything. Sensory-friendly lighting that calms instead of overwhelms. Adaptive furniture that grants independence. Colors and themes chosen by the child — because this space is <em>theirs</em>.</p>
        <p class="mission-body">Since 2012, we've partnered with designers, contractors, and families across Greater Atlanta to create over {stats.totalRooms} life-changing spaces. Every project is different because every child is different.</p>
      </div>
      <div class="mission-visual" role="presentation">
        <div class="mission-photo mission-photo--main" data-reveal>
          <picture>
            <source type="image/avif" srcset={`${CF}/${missionMainId}/w=500,f=avif 500w, ${CF}/${missionMainId}/w=800,f=avif 800w`} sizes="(max-width:768px) 90vw, 40vw" />
            <source type="image/webp" srcset={`${CF}/${missionMainId}/w=500,f=webp 500w, ${CF}/${missionMainId}/w=800,f=webp 800w`} sizes="(max-width:768px) 90vw, 40vw" />
            <img src={`${CF}/${missionMainId}/w=800,q=80`} alt="A transformed room designed for a child with special needs" width="800" height="600" loading="lazy" decoding="async" />
          </picture>
        </div>
        <div class="mission-photo mission-photo--accent" data-reveal data-delay="1">
          <picture>
            <source type="image/avif" srcset={`${CF}/${missionAccentId}/w=400,f=avif 400w, ${CF}/${missionAccentId}/w=600,f=avif 600w`} sizes="(max-width:768px) 60vw, 30vw" />
            <source type="image/webp" srcset={`${CF}/${missionAccentId}/w=400,f=webp 400w, ${CF}/${missionAccentId}/w=600,f=webp 600w`} sizes="(max-width:768px) 60vw, 30vw" />
            <img src={`${CF}/${missionAccentId}/w=600,q=80`} alt="A happy child in their new dream room" width="600" height="450" loading="lazy" decoding="async" />
          </picture>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ FEATURED STORY ══════ -->
  <section class="story" id="stories" aria-labelledby="story-heading">
    <div class="story-split">
      <figure class="story-photo">
        <picture>
          <source type="image/avif" srcset={`${CF}/${storyPhotoId}/w=600,f=avif 600w, ${CF}/${storyPhotoId}/w=900,f=avif 900w, ${CF}/${storyPhotoId}/w=1200,f=avif 1200w`} sizes="(max-width:768px) 100vw, 55vw" />
          <source type="image/webp" srcset={`${CF}/${storyPhotoId}/w=600,f=webp 600w, ${CF}/${storyPhotoId}/w=900,f=webp 900w, ${CF}/${storyPhotoId}/w=1200,f=webp 1200w`} sizes="(max-width:768px) 100vw, 55vw" />
          <img src={`${CF}/${storyPhotoId}/w=900,q=80`} alt={`${fd?.name || 'Zyah'}'s room reveal`} width="900" height="600" loading="lazy" decoding="async" class="story-photo-img" />
        </picture>
        <div class="story-photo-tag">Latest Reveal</div>
      </figure>
      <div class="story-content" data-reveal>
        <div class="section-label">Featured Story</div>
        <span class="story-type">{fd?.roomTypes?.[0] || 'Dream Bedroom'}</span>
        <h2 id="story-heading">{fd?.name || 'Zyah'}'s new space gave her independence — and her family peace of mind.</h2>
        <p>{fd?.name || 'Zyah'}, age {fd?.age || 7}, lives with {fd?.diagnosis || 'Spinal Muscular Atrophy'}. Our team transformed her space into an accessible, joyful haven — with custom features designed around her unique needs and personality.</p>
        <a href={`/kids/${featuredSlug}`} class="btn btn-dark">Read {fd?.name || 'Zyah'}'s Full Story →</a>
      </div>
    </div>
  </section>

  <!-- ══════ MORE KIDS ══════ -->
  <section class="kids-strip" aria-labelledby="kids-heading">
    <div class="kids-strip-header" data-reveal>
      <div>
        <div class="section-label">More Stories</div>
        <h2 id="kids-heading">Every room changes a <em class="highlight">life</em></h2>
      </div>
      <a href="/kids" class="kids-strip-all">See all {stats.totalKids}+ kids →</a>
    </div>
    <ul class="kids-scroll">
      {kidShowcase.map(kid => (
        <li class="kid-thumb-item">
          <a href={`/kids/${kid.slug}`} class="kid-thumb">
            <div class="kid-thumb-photo">
              <img src={`${CF}/${kid.cfId}/w=440,h=440,fit=cover,f=auto`} alt={`${kid.name}'s room reveal`} width="220" height="220" loading="lazy" decoding="async" />
            </div>
            <h3 class="kid-thumb-name">{kid.name}</h3>
            <p>{kid.roomLabel}{kid.age ? ` · Age ${kid.age}` : ''}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- ══════ PROCESS ══════ -->
  <section class="process" aria-labelledby="process-heading">
    <div class="process-inner">
      <div class="process-header" data-reveal>
        <div class="section-label">The Process</div>
        <h2 id="process-heading">From first call to <em class="highlight">big reveal</em></h2>
      </div>
      <ol class="timeline" role="list">
        <li class="timeline-step" data-reveal>
          <div class="timeline-marker" aria-hidden="true"><span>1</span></div>
          <div class="timeline-body"><h3>Family Applies</h3><p>A simple application — families tell us about their child, their needs, and their dreams for a new space.</p></div>
        </li>
        <li class="timeline-step" data-reveal data-delay="1">
          <div class="timeline-marker" aria-hidden="true"><span>2</span></div>
          <div class="timeline-body"><h3>Design & Plan</h3><p>Our designer partners meet the family, learn the child's personality, and create a custom room concept.</p></div>
        </li>
        <li class="timeline-step" data-reveal data-delay="2">
          <div class="timeline-marker" aria-hidden="true"><span>3</span></div>
          <div class="timeline-body"><h3>Build & Transform</h3><p>Construction partners bring it to life — usually in just a few intense, loving days of work.</p></div>
        </li>
        <li class="timeline-step" data-reveal data-delay="3">
          <div class="timeline-marker" aria-hidden="true"><span>4</span></div>
          <div class="timeline-body"><h3>The Big Reveal ✨</h3><p>The moment. The child walks in, sees their new room, and everything changes. This is why we do it.</p></div>
        </li>
      </ol>
    </div>
  </section>

  <!-- ══════ ROOM TYPES ══════ -->
  <section class="rooms" aria-labelledby="rooms-heading">
    <div class="rooms-inner">
      <div class="rooms-header" data-reveal>
        <div class="section-label">What We Build</div>
        <h2 id="rooms-heading">Three types of spaces, one purpose: <em class="highlight">empowering kids</em></h2>
      </div>
      <div class="rooms-grid">
        <a href="/kids" class="room-tile" data-accent="bedroom" data-reveal>
          <div class="room-tile-photo"><img src={`${CF}/${roomPhotos.bedroom}/w=600,h=375,fit=cover,f=auto`} alt="A custom dream bedroom" width="600" height="375" loading="lazy" decoding="async" /></div>
          <div class="room-tile-content">
            <span class="room-tile-tag">Most Popular</span>
            <h3>Dream Bedrooms</h3>
            <p>Personalized sanctuaries where children can escape, imagine, and simply be kids — designed around their unique interests and needs.</p>
            <span class="room-tile-link">See bedrooms →</span>
          </div>
        </a>
        <a href="/kids" class="room-tile" data-accent="bath" data-reveal data-delay="1">
          <div class="room-tile-photo"><img src={`${CF}/${roomPhotos.bath}/w=600,h=375,fit=cover,f=auto`} alt="An accessible bathroom" width="600" height="375" loading="lazy" decoding="async" /></div>
          <div class="room-tile-content">
            <span class="room-tile-tag">Life-Changing</span>
            <h3>Accessible Bathrooms</h3>
            <p>Roll-in showers, grab bars, and lowered vanities — giving children independence and giving families relief from daily struggles.</p>
            <span class="room-tile-link">See bathrooms →</span>
          </div>
        </a>
        <a href="/kids" class="room-tile" data-accent="therapy" data-reveal data-delay="2">
          <div class="room-tile-photo"><img src={`${CF}/${roomPhotos.therapy}/w=600,h=375,fit=cover,f=auto`} alt="A sensory therapy room" width="600" height="375" loading="lazy" decoding="async" /></div>
          <div class="room-tile-content">
            <span class="room-tile-tag">Therapeutic</span>
            <h3>Sensory & Therapy Rooms</h3>
            <p>Calming retreats with dimmable lights, swings, crash pads, and textured walls — spaces where children can decompress and develop.</p>
            <span class="room-tile-link">See therapy rooms →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ══════ TRUST ══════ -->
  <section class="trust" aria-labelledby="trust-heading">
    <div class="trust-inner">
      <div class="trust-header" data-reveal>
        <div class="section-label" style="color:var(--c-yellow)">Trust & Transparency</div>
        <h2 id="trust-heading">We're an open book. <em>Always.</em></h2>
        <p class="trust-subtitle">We believe you should know exactly where every dollar goes. Our financials are public, our mission is clear, and our track record speaks for itself.</p>
      </div>
      <div class="trust-grid">
        <div class="trust-card" data-reveal>
          <div class="trust-card-top"><span class="trust-big">87%</span><span class="trust-card-label">Program Services</span></div>
          <p>The vast majority of every dollar funds room materials, labor, and design for children's spaces.</p>
        </div>
        <div class="trust-card" data-reveal data-delay="1">
          <div class="trust-card-top"><span class="trust-big trust-big--icon"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg></span><span class="trust-card-label">990 Public</span></div>
          <p>Our IRS Form 990 tax returns are available for anyone to review, anytime.</p>
        </div>
        <div class="trust-card" data-reveal data-delay="2">
          <div class="trust-card-top"><span class="trust-big trust-big--icon"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/></svg></span><span class="trust-card-label">501(c)(3)</span></div>
          <p>Registered nonprofit. EIN 45-4773997. All donations are fully tax-deductible.</p>
        </div>
      </div>
      <div class="trust-cta" data-reveal><a href="/about/financials" class="btn btn-ghost-light">View Our Financials →</a></div>
    </div>
  </section>

  <!-- ══════ PARTNERS MARQUEE ══════ -->
  <section class="marquee" aria-label="Our partners">
    <div class="marquee-label">Trusted Partners Who Make It Possible</div>
    <div class="marquee-track" aria-hidden="true">
      {[...partnerLogos, ...partnerLogos, ...partnerLogos].map(p => (
        <div class="marquee-logo">
          <img src={`${CF}/${p.id}/w=280,h=80,fit=contain,f=auto`} alt={p.name} width="140" height="40" loading="lazy" decoding="async" />
        </div>
      ))}
    </div>
  </section>

  <!-- ══════ FINAL CTA ══════ -->
  <section class="finale" aria-labelledby="cta-heading">
    <div class="finale-inner">
      <img src={`${CF}/sunny-pig/w=80,h=80,fit=contain,f=auto`} alt="" class="finale-pig" width="80" height="80" aria-hidden="true" loading="lazy" />
      <h2 id="cta-heading" data-reveal>A room can change a child's life.<br/><em>You</em> can make it happen.</h2>
      <p data-reveal data-delay="1">Every donation — every dollar — goes directly to building dream spaces for children with special needs in the Atlanta area. No middlemen. No overhead bloat. Just kids, rooms, and community.</p>
      <div class="finale-ctas" data-reveal data-delay="2">
        <a href="/donate" class="btn btn-dark btn-lg">Donate Today</a>
        <a href="/get-involved/apply" class="btn btn-outline-dark">Apply for a Room</a>
      </div>
      <p class="finale-note" data-reveal data-delay="3">All donations tax-deductible · 501(c)(3) · EIN 45-4773997</p>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── HERO ── */
  .hero { position: relative; min-height: 100vh; min-height: 100dvh; display: flex; align-items: flex-end; padding-bottom: 80px; overflow: hidden; contain: layout style; }

  /* Ken Burns cinematic zoom — runs on the img, not the media container (parallax uses the container) */
  .hero-media { position: absolute; inset: 0; z-index: 0; }
  .hero-img { width: 100%; height: 100%; object-fit: cover; object-position: center 30%; animation: kenBurns 20s ease-in-out infinite alternate; will-change: transform; }
  @keyframes kenBurns { 0% { transform: scale(1) translate(0, 0); } 100% { transform: scale(1.08) translate(-0.5%, -1%); } }

  /* Rich cinematic overlay with vignette */
  .hero-overlay { position: absolute; inset: 0; background:
    radial-gradient(ellipse at 50% 0%, transparent 50%, rgba(0,0,0,0.35) 100%),
    linear-gradient(to top, rgba(26,27,31,0.95) 0%, rgba(26,27,31,0.6) 30%, rgba(26,27,31,0.2) 55%, rgba(26,27,31,0.1) 100%);
  }

  /* Floating golden particles */
  .hero-particles { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
  .particle { position: absolute; width: 3px; height: 3px; border-radius: 50%; background: var(--c-yellow); opacity: 0; animation: particleFloat linear infinite; }
  .particle:nth-child(1) { left: 10%; animation-duration: 8s; animation-delay: 0s; }
  .particle:nth-child(2) { left: 25%; animation-duration: 11s; animation-delay: 2s; width: 2px; height: 2px; }
  .particle:nth-child(3) { left: 40%; animation-duration: 9s; animation-delay: 4s; }
  .particle:nth-child(4) { left: 55%; animation-duration: 13s; animation-delay: 1s; width: 4px; height: 4px; }
  .particle:nth-child(5) { left: 70%; animation-duration: 10s; animation-delay: 3s; width: 2px; height: 2px; }
  .particle:nth-child(6) { left: 82%; animation-duration: 12s; animation-delay: 5s; }
