---
/**
 * Golf Tournament — Sunshine on a Ranney Fairway 2026
 * Ported from sunnyandranney.com/events/ and adapted for SOARD design system
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQAccordion from '../../components/ui/FAQAccordion.astro';
import { cfRaw, cfSrcset, cfLqip, cfAbsolute } from '../../utils/cf-image';
import { getEntry } from 'astro:content';

/* ── CMS data (admin-editable via golf.json) ── */
const golfData = await getEntry('site', 'golf');
const cms = golfData?.data ?? {};

/* ── Sponsorship tiers (from CMS) ── */
interface Tier {
  name: string;
  price: string;
  detail?: string;
  perk?: string;
  badge?: string;
  badgeStyle?: 'gold' | 'green';
  highlight?: 'featured' | 'popular';
  status?: 'available' | 'few-left' | 'sold-out';
}

const mainTiers: Tier[] = cms.tiers?.main ?? [];
const addOnTiers: Tier[] = cms.tiers?.addons ?? [];

/* ── CMS content ── */
const testimonial = cms.testimonial ?? { quote: '', name: '', title: '' };
const faqs = cms.faqs ?? [];
const galleryPhotos: { id: string; alt: string }[] = cms.galleryPhotos ?? [];
interface SponsorEntry { name: string; logo?: string; website?: string }
interface SponsorTierGroup { tier: string; size: 'xl' | 'lg' | 'md' | 'sm'; names: SponsorEntry[] }
const sponsorTiers: SponsorTierGroup[] = cms.sponsors ?? [];
const majorTiers = sponsorTiers.filter(t => t.size !== 'sm');
const activityTiers = sponsorTiers.filter(t => t.size === 'sm');

const eventJsonLd = {
  "@type": "Event",
  "@id": "https://sunshineonaranneyday.com/events/golf/#event",
  "name": "Sunshine on a Ranney Fairway 2026",
  "description": "Charity golf tournament funding dream room makeovers for children with special needs.",
  "startDate": "2026-05-18T07:00:00-04:00",
  "endDate": "2026-05-18T18:00:00-04:00",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  "eventStatus": "https://schema.org/EventScheduled",
  "location": {
    "@type": "Place",
    "name": "Indian Hills Country Club",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "4001 Clubland Dr.",
      "addressLocality": "Marietta",
      "addressRegion": "GA",
      "postalCode": "30068",
      "addressCountry": "US",
    },
  },
  "organizer": { "@id": "https://sunshineonaranneyday.com/#organization" },
  "image": cfAbsolute("golf-logo-dark"),
  "offers": [
    {
      "@type": "Offer",
      "name": "Foursome",
      "price": "1500",
      "priceCurrency": "USD",
      "url": "https://www.zeffy.com/en-US/ticketing/sunshine-on-a-ranney-fairway--2026",
      "availability": "https://schema.org/InStock",
      "validFrom": "2026-01-01",
    },
    {
      "@type": "Offer",
      "name": "Gold Sponsor",
      "price": "5000",
      "priceCurrency": "USD",
      "url": "https://www.zeffy.com/en-US/ticketing/sunshine-on-a-ranney-fairway--2026",
      "availability": "https://schema.org/InStock",
      "validFrom": "2026-01-01",
    },
    {
      "@type": "Offer",
      "name": "Presenting Sponsor",
      "price": "20000",
      "priceCurrency": "USD",
      "url": "https://www.zeffy.com/en-US/ticketing/sunshine-on-a-ranney-fairway--2026",
      "availability": "https://schema.org/InStock",
      "validFrom": "2026-01-01",
    },
  ],
};

/* ── LCP preload — hero logo (must be byte-identical to <img>) ── */
const heroLogoSrcset = cfSrcset('golf-logo-dark', [280, 400]);
const heroLogoSizes = '(max-width: 767px) 200px, 320px';
---

<BaseLayout
  title="Sunshine on a Ranney Fairway 2026 — Charity Golf Tournament"
  description="Join us for Sunshine on a Ranney Fairway 2026 — a charity golf tournament where every swing supports life-changing room makeovers for children with special needs."
  ogImage="/og/golf.png"
  jsonLd={eventJsonLd}
  breadcrumbs={[
    { name: 'Events', url: '/events/' },
    { name: 'Golf Tournament', url: '/events/golf/' },
  ]}
>
  <!-- Preload hero LCP image — imagesrcset/imagesizes must match the <img> -->
  <link slot="head" rel="preload" as="image" imagesrcset={heroLogoSrcset} imagesizes={heroLogoSizes} fetchpriority="high" />

  <!-- ═══ HERO ═══ -->
  <section class="ev-hero">
    <div class="ev-hero__bg" aria-hidden="true">
      <div class="ev-hero__gradient"></div>
    </div>
    <div class="container ev-hero__inner">
      <div class="ev-hero__content">
        <span class="ev-hero__eyebrow" data-reveal>Charity Golf Tournament</span>
        <h1 class="ev-hero__title" data-reveal transition:name="event-title">
          Sunshine on a<br/>Ranney <span class="ev-hero__accent">Fairway</span>
        </h1>
        <p class="ev-hero__subtitle" data-reveal>
          Tee up for a cause. Every swing supports life-changing room makeovers for children with special needs through <a href="https://sunshineonaranneyday.com" target="_blank" rel="noopener" class="ev-hero__link">Sunshine on a Ranney Day</a>.
        </p>
        <div class="ev-hero__actions" data-reveal>
          <a href="#tickets" class="ev-btn ev-btn--gold ev-btn--hero">Register</a>
          <a href="#details" class="ev-hero__scroll-link">
            Learn More
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
          </a>
        </div>
        <!-- Countdown -->
        <div class="ev-countdown" data-reveal data-event-date="2026-05-18T07:00:00-04:00">
          <div class="ev-countdown__unit">
            <span class="ev-countdown__num" data-days>--</span>
            <span class="ev-countdown__label">Days</span>
          </div>
          <span class="ev-countdown__sep" aria-hidden="true">:</span>
          <div class="ev-countdown__unit">
            <span class="ev-countdown__num" data-hours>--</span>
            <span class="ev-countdown__label">Hours</span>
          </div>
          <span class="ev-countdown__sep" aria-hidden="true">:</span>
          <div class="ev-countdown__unit">
            <span class="ev-countdown__num" data-mins>--</span>
            <span class="ev-countdown__label">Min</span>
          </div>
        </div>
      </div>
      <div class="ev-hero__visual" data-reveal>
        <img
          src={cfRaw('golf-logo-dark', 'w=400,q=85')}
          srcset={heroLogoSrcset}
          sizes={heroLogoSizes}
          alt="Sunshine on a Ranney Fairway Golf Tournament logo"
          class="ev-hero__logo"
          width="400"
          height="400"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          transition:name="event-hero"
        />
      </div>
    </div>
    <div class="ev-hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" fill="var(--c-cream)"><path d="M0,40 C360,80 720,0 1080,40 C1260,60 1380,50 1440,40 L1440,80 L0,80 Z"/></svg>
    </div>
  </section>

  <!-- ═══ EVENT DETAILS ═══ -->
  <section class="ev-details" id="details">
    <div class="container ev-details__inner">
      <div class="ev-details__grid">
        <div class="ev-details__card" data-reveal>
          <div class="ev-details__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
          </div>
          <h2 class="ev-details__card-title">When</h2>
          <p class="ev-details__card-date"><time datetime="2026-05-18">Monday, May 18th, 2026</time></p>
          <p class="ev-details__card-text">
            <strong><time datetime="2026-05-18T07:00:00-04:00">7:00 AM</time></strong> &mdash; Registration<br/>
            <strong><time datetime="2026-05-18T10:00:00-04:00">10:00 AM</time></strong> &mdash; Tee Off<br/>
            <strong>TBA</strong> &mdash; Banquet
          </p>
        </div>
        <div class="ev-details__card" data-reveal>
          <div class="ev-details__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h2 class="ev-details__card-title">Where</h2>
          <p class="ev-details__card-text">
            <strong>Indian Hills Country Club</strong><br/>
            <a href="https://maps.google.com/?q=4001+Clubland+Dr+Marietta+GA+30068" target="_blank" rel="noopener" class="ev-details__map-link">
              4001 Clubland Dr.<br/>Marietta, GA 30068
            </a>
          </p>
        </div>
        <div class="ev-details__card" data-reveal>
          <div class="ev-details__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"/></svg>
          </div>
          <h2 class="ev-details__card-title">The Cause</h2>
          <p class="ev-details__card-text">Proceeds fund dream room makeovers for children with special needs.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ DEDICATED TO ═══ -->
  <section class="ev-chair">
    <div class="container ev-chair__inner" data-reveal>
      <div class="ev-chair__photo-wrap" style={`background-image:url('${cfLqip('golf-brent-aronson')}')`}>
        <img
          src={cfRaw('golf-brent-aronson', 'w=500,q=80')}
          srcset={cfSrcset('golf-brent-aronson', [340, 500], { fit: 'cover', gravity: 'face' })}
          sizes="(max-width: 639px) 220px, 260px"
          alt="Brent Aronson"
          class="ev-chair__photo lqip-img"
          width="500"
          height="500"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="ev-chair__text">
        <span class="ev-chair__label">Dedicated To</span>
        <h2 class="ev-chair__name">Brent Aronson</h2>
        <div class="ev-chair__quote">
          <p>This year's tournament is dedicated to Brent Aronson, whose vision and commitment helped build SOARD. Join us as we celebrate his legacy and see the impact firsthand. Many of the kids you support will be out on the course!</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PHOTO GALLERY ═══ -->
  {galleryPhotos.length > 0 && (
    <section class="ev-gallery" aria-label="Past tournament photos">
      <div class="ev-gallery__track">
        {[...galleryPhotos, ...galleryPhotos].map((photo, i) => (
          <div class="ev-gallery__item">
            <img
              src={cfRaw(photo.id, 'w=400,h=280,fit=cover,q=80')}
              srcset={cfSrcset(photo.id, [300, 400], { height: 280, fit: 'cover' })}
              sizes="280px"
              alt={photo.alt || 'Past tournament photo'}
              width="400"
              height="280"
              loading="lazy"
              decoding="async"
            />
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- ═══ HOW IT HELPS ═══ -->
  <section class="ev-impact">
    <div class="container ev-impact__inner">
      <span class="ev-impact__label" data-reveal>Your Impact</span>
      <h2 class="ev-impact__heading" data-reveal>Every Ticket Changes a Life</h2>
      <div class="ev-impact__steps">
        <div class="ev-impact__step" data-reveal>
          <div class="ev-impact__num" aria-hidden="true">
            <span>1</span>
            <div class="ev-impact__num-ring"></div>
          </div>
          <h3>You Play</h3>
          <p>Grab your clubs and enjoy a day on the course with friends, food, and fun.</p>
        </div>
        <div class="ev-impact__connector" aria-hidden="true">
          <div class="ev-impact__connector-line"></div>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--c-yellow)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </div>
        <div class="ev-impact__step" data-reveal>
          <div class="ev-impact__num" aria-hidden="true">
            <span>2</span>
            <div class="ev-impact__num-ring"></div>
          </div>
          <h3>We Give</h3>
          <p>Every dollar goes directly to Sunshine on a Ranney Day to fund room makeovers.</p>
        </div>
        <div class="ev-impact__connector" aria-hidden="true">
          <div class="ev-impact__connector-line"></div>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--c-yellow)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </div>
        <div class="ev-impact__step" data-reveal>
          <div class="ev-impact__num" aria-hidden="true">
            <span>3</span>
            <div class="ev-impact__num-ring"></div>
          </div>
          <h3>Kids Dream</h3>
          <p>A child with special needs gets the room they've always dreamed of.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TESTIMONIAL ═══ -->
  {testimonial.quote && (
    <section class="ev-testimonial">
      <div class="container ev-testimonial__inner" data-reveal>
        <svg class="ev-testimonial__mark" width="40" height="32" viewBox="0 0 40 32" fill="none" aria-hidden="true"><path d="M0 20.8C0 27.2 3.6 32 9.6 32c4.4 0 7.6-3.2 7.6-7.2 0-4.4-3.2-7.2-6.8-7.2-.8 0-1.6.2-2 .4C9.2 12.4 13.6 6 18.4 3.2L14.8 0C6 4.4 0 12.8 0 20.8Zm22 0C22 27.2 25.6 32 31.6 32c4.4 0 7.6-3.2 7.6-7.2 0-4.4-3.2-7.2-6.8-7.2-.8 0-1.6.2-2 .4C31.2 12.4 35.6 6 40.4 3.2L36.8 0C28 4.4 22 12.8 22 20.8Z" fill="currentColor"/></svg>
        <blockquote class="ev-testimonial__quote">{testimonial.quote}</blockquote>
        <cite class="ev-testimonial__cite">
          <span class="ev-testimonial__name">{testimonial.name}</span>
          {testimonial.title && <span class="ev-testimonial__title">{testimonial.title}</span>}
        </cite>
      </div>
    </section>
  )}

  <!-- ═══ TICKETS ═══ -->
  <section class="ev-tickets" id="tickets">
    <div class="container ev-tickets__inner">
      <span class="ev-tickets__label" data-reveal>Reserve Your Spot</span>
      <h2 class="ev-tickets__heading" data-reveal>Sponsorships &amp; Tickets</h2>
      <p class="ev-tickets__sub" data-reveal>Browse sponsorship packages and foursomes, then register on Zeffy to complete your purchase.</p>

      <!-- Sponsor tiers (data-driven) -->
      <div class="ev-tiers" data-reveal>
        {mainTiers.map(tier => (
          <div class={`ev-tier ${tier.highlight === 'featured' ? 'ev-tier--featured' : tier.highlight === 'popular' ? 'ev-tier--popular' : ''} ${tier.status === 'sold-out' ? 'ev-tier--sold-out' : ''}`}>
            {tier.status === 'sold-out' && (
              <span class="ev-tier__badge ev-tier__badge--sold-out">Sold Out</span>
            )}
            {tier.status === 'few-left' && (
              <span class="ev-tier__badge ev-tier__badge--few-left">Few Left</span>
            )}
            {tier.status !== 'sold-out' && tier.status !== 'few-left' && tier.badge && (
              <span class={`ev-tier__badge ${tier.badgeStyle === 'gold' ? 'ev-tier__badge--gold' : ''}`}>{tier.badge}</span>
            )}
            <div class="ev-tier__head">
              <h3 class="ev-tier__name">{tier.name}</h3>
              <span class="ev-tier__price">{tier.price}</span>
            </div>
            <div class="ev-tier__divider" aria-hidden="true"></div>
            <div class="ev-tier__body">
              {tier.detail && <span class="ev-tier__detail">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                {tier.detail}
              </span>}
              {tier.perk && <span class="ev-tier__perk">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                {tier.perk}
              </span>}
            </div>
          </div>
        ))}
      </div>

      <!-- Additional sponsorships (data-driven) -->
      <details class="ev-more" data-reveal>
        <summary class="ev-more__toggle">
          <span>Additional Sponsorships</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </summary>
        <div class="ev-more__grid">
          {addOnTiers.map(tier => (
            <div class={`ev-tier ev-tier--sm ${tier.status === 'sold-out' ? 'ev-tier--sold-out' : ''}`}>
              {tier.status === 'sold-out' && (
                <span class="ev-tier__status-tag ev-tier__status-tag--sold-out">Sold Out</span>
              )}
              {tier.status === 'few-left' && (
                <span class="ev-tier__status-tag ev-tier__status-tag--few-left">Few Left</span>
              )}
              <h3 class="ev-tier__name">{tier.name}</h3>
              <span class="ev-tier__price">{tier.price}</span>
              {tier.perk && <p class="ev-tier__addon-perk">{tier.perk}</p>}
            </div>
          ))}
        </div>
      </details>

      <!-- CTA -->
      <div class="ev-tickets__cta" data-reveal>
        <a href="https://www.zeffy.com/en-US/ticketing/sunshine-on-a-ranney-fairway--2026" target="_blank" rel="noopener" class="ev-btn ev-btn--gold ev-btn--hero">
          Register &amp; Select Your Package
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
        </a>
        <p class="ev-tickets__secure-note">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Secure checkout powered by Zeffy &middot; Zero platform fees
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ SPONSORS ═══ -->
  {sponsorTiers.length > 0 && (
    <section class="ev-sponsors" id="sponsors">
      <div class="container ev-sponsors__inner">
        <span class="ev-sponsors__label" data-reveal>2026 Sponsors</span>
        <h2 class="ev-sponsors__heading" data-reveal>Thank You to Our Sponsors</h2>
        <p class="ev-sponsors__sub" data-reveal>None of this is possible without the incredible generosity of our sponsors.</p>

        {/* ── Major tiers (Title / Presenting / Diamond / Gold) ── */}
        {majorTiers.map((group) => (
          <div class={`ev-sp-tier ev-sp-tier--${group.size}`} data-reveal>
            {/* Title sponsor gets the dark premium banner */}
            {group.size === 'xl' ? (
              <div class="ev-sp-title-wrap">
                <span class="ev-sp-title-wrap__label">{group.tier}</span>
                <div class="ev-sp-title-wrap__inner">
                  {group.names.map(s => (
                    <Fragment>
                      {s.logo ? (
                        <div class="ev-sp-title-wrap__card">
                          <img src={cfRaw(s.logo, 'w=440,h=220,fit=contain,q=90')} alt={s.name} width="440" height="220" loading="lazy" decoding="async" class="ev-sp-title-wrap__logo" />
                        </div>
                      ) : (
                        <span class="ev-sp-title-wrap__name">{s.name}</span>
                      )}
                    </Fragment>
                  ))}
                </div>
              </div>
            ) : (
              <Fragment>
                <div class="ev-sp-tier__header">
                  <span class="ev-sp-tier__line" aria-hidden="true"></span>
                  <h3 class="ev-sp-tier__label">{group.tier}</h3>
                  <span class="ev-sp-tier__line" aria-hidden="true"></span>
                </div>
                <div class={`ev-sp-tier__grid ev-sp-tier__grid--${group.size}`}>
                  {group.names.map(s => {
                    const Tag = s.website ? 'a' : 'div';
                    return (
                      <Tag
                        class={`ev-sp-card ev-sp-card--${group.size}`}
                        {...(s.website ? { href: s.website, target: '_blank', rel: 'noopener noreferrer' } : {})}
                      >
                        {s.logo ? (
                          <img
                            src={cfRaw(s.logo, `w=${group.size === 'lg' ? 260 : 200},h=${group.size === 'lg' ? 130 : 100},fit=contain,q=85`)}
                            alt={s.name}
                            width={group.size === 'lg' ? 260 : 200}
                            height={group.size === 'lg' ? 130 : 100}
                            loading="lazy"
                            decoding="async"
                            class="ev-sp-card__logo"
                          />
                        ) : (
                          <span class="ev-sp-card__name">{s.name}</span>
                        )}
                        {s.website && (
                          <svg class="ev-sp-card__ext" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                        )}
                      </Tag>
                    );
                  })}
                </div>
              </Fragment>
            )}
          </div>
        ))}

        {/* ── Activity sponsors (compact grouped layout) ── */}
        {activityTiers.length > 0 && (
          <div class="ev-sp-activity" data-reveal>
            <div class="ev-sp-activity__header">
              <span class="ev-sp-activity__line" aria-hidden="true"></span>
              <h3 class="ev-sp-activity__title">Event Sponsors</h3>
              <span class="ev-sp-activity__line" aria-hidden="true"></span>
            </div>
            <div class="ev-sp-activity__list">
              {activityTiers.map(group => (
                <div class="ev-sp-activity__row">
                  <span class="ev-sp-activity__label">{group.tier}</span>
                  <div class="ev-sp-activity__names">
                    {group.names.map((s, i) => (
                      <Fragment>
                        {s.website ? (
                          <a href={s.website} target="_blank" rel="noopener noreferrer" class="ev-sp-activity__name ev-sp-activity__name--link">{s.name}</a>
                        ) : (
                          <span class="ev-sp-activity__name">{s.name}</span>
                        )}
                        {i < group.names.length - 1 && <span class="ev-sp-activity__sep" aria-hidden="true">&middot;</span>}
                      </Fragment>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- ═══ FAQ ═══ -->
  {faqs.length > 0 && (
    <section class="ev-faq">
      <div class="container">
        <FAQAccordion
          items={faqs}
          eyebrow="Questions?"
          heading="Frequently Asked"
          subtitle="Everything you need to know about the tournament."
