    margin-top: var(--space-3xl);
    padding: var(--space-2xl) var(--space-2xl) var(--space-2xl) var(--space-3xl);
    background: linear-gradient(135deg, rgba(255, 218, 36, 0.06) 0%, rgba(255, 218, 36, 0.02) 100%);
    border-left: 4px solid var(--c-yellow);
    border-radius: 0 var(--border-radius-lg) var(--border-radius-lg) 0;
    max-width: 680px;
  }

  .pullquote__mark {
    position: absolute;
    top: var(--space-lg);
    left: var(--space-lg);
    width: 32px;
    height: 32px;
    color: var(--c-yellow);
    opacity: 0.5;
  }

  .pullquote p {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.15rem;
    line-height: 1.65;
