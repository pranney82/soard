---
/**
 * Home Page — Sunshine on a Ranney Day
 * Cinematic hero, editorial layout, scroll reveals
 * Performance: real CF Images, optimized animations, contain
 * SEO: JSON-LD NonprofitOrganization + WebSite, semantic HTML5
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import MediaLogos from '../components/ui/MediaLogos.astro';
import { getCollection } from 'astro:content';

const CF = 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ';

/* ── Site settings (all editable from admin) ── */
import siteSettings from '../content/site/settings.json';
const stats = {
  totalKids: siteSettings.stats?.kidsServed || 132,
  totalRooms: siteSettings.stats?.roomsCompleted || 106,
  years: siteSettings.stats?.yearsOfImpact || 13,
};

/* ── Hero (from site settings) ── */
const heroEyebrow = siteSettings.homeHero?.eyebrow || '501(c)(3) Nonprofit · Atlanta, GA · Since 2012';
const heroHeadlineLine1 = siteSettings.homeHero?.headlineLine1 || 'Building <em>dreams</em>,';
const heroHeadlineLine2 = siteSettings.homeHero?.headlineLine2 || 'one room at a time';
const heroLead = siteSettings.homeHero?.lead || 'We create life-changing spaces for children with special needs — dream bedrooms, accessible bathrooms, and therapy rooms — all at <strong>no cost to families</strong>.';
const heroCta1Label = siteSettings.homeHero?.cta1Label || 'Give Today';
const heroCta1Link = siteSettings.homeHero?.cta1Link || '/donate';
const heroCta2Label = siteSettings.homeHero?.cta2Label || 'See Our Work ↓';
const heroCta2Link = siteSettings.homeHero?.cta2Link || '#stories';

/* ── Hero Mosaic — 30 kids, each a ~4KB thumbnail ── */
const mosaicKids = siteSettings.heroMosaic || [
  { slug: 'zyah', name: 'Zyah', cfId: 'b7ae8742-5431-4c85-aa74-a36b173c6200' },
  { slug: 'bryce', name: 'Bryce', cfId: '8c30d105-b021-4a7a-19a7-c247b3531500' },
  { slug: 'alex', name: 'Alex', cfId: '1e6a46a7-c998-4afe-2c0e-24027dc77800' },
  { slug: 'griffin', name: 'Griffin', cfId: 'dfd10b8a-a636-4cb6-f748-c59bbd31a500' },
  { slug: 'ethan-2022', name: 'Ethan', cfId: '5424eb2a-ab4d-4305-aea1-3149b7a7cc00' },
  { slug: 'elizabeth', name: 'Elizabeth', cfId: '8bf4ac37-d5a0-43d0-5e7f-93df38508b00' },
  { slug: 'brianna', name: 'Brianna', cfId: '473ec592-3e39-4a74-af36-a409ab33c500' },
  { slug: 'braxton', name: 'Braxton', cfId: 'c4686f1d-343f-4936-25e7-9118f5093900' },
  { slug: 'samantha', name: 'Samantha', cfId: '31f4acf8-daea-400f-cc98-19d5dcb93a00' },
  { slug: 'leland', name: 'Leland', cfId: '8e7ec97e-f72a-444a-9f51-6c26960cb400' },
  { slug: 'amanda-caleb-and-isaac', name: 'Amanda, Caleb & Isaac', cfId: 'c749d2a0-bf64-459c-9503-f589a70a1800' },
  { slug: 'ally', name: 'Ally', cfId: '1767682f-9806-49a0-bd90-6f3d4e81cd00' },
  { slug: 'breanna', name: 'Breanna', cfId: '3550059b-79ba-47d7-dbd7-9a37be050d00' },
  { slug: 'eli', name: 'Eli', cfId: '85e1c185-6f97-4bcd-a5d7-8cf3cc8dec00' },
  { slug: 'ellie', name: 'Ellie', cfId: '5543acf4-5a16-4a75-2859-12709174e200' },
  { slug: 'monica', name: 'Monica', cfId: 'fd5e6be1-748b-4db4-c182-472321f56100' },
  { slug: 'rachel', name: 'Rachel', cfId: '09d0e72d-677c-4628-5aeb-d0497b746200' },
  { slug: 'devon', name: 'Devon', cfId: '1b41b4ef-d921-4fa3-9080-fcc295318f00' },
  { slug: 'shawn', name: 'Shawn', cfId: '7f02fcda-71e1-4b1a-dfd8-38ba076c9d00' },
  { slug: 'landon', name: 'Landon', cfId: 'b23f46b7-206f-4c96-d9e6-8815bfb2b800' },
  { slug: 'eliavah', name: 'Eliavah', cfId: '50054953-a4b3-4ed7-2e36-5dda71d6da00' },
  { slug: 'lizzie', name: 'Lizzie', cfId: '43476e06-cfeb-4167-622c-aecaa288b400' },
  { slug: 'haleigh', name: 'Haleigh', cfId: '557be3e1-5fc3-4302-e5f8-ee43db474300' },
  { slug: 'adam', name: 'Adam', cfId: '845313dc-e883-435e-0b63-271f7c048500' },
  { slug: 'charlie', name: 'Charlie', cfId: '520c76a8-45e3-4d22-b8e6-51bbc72c0100' },
  { slug: 'samuel', name: 'Samuel', cfId: 'd7c26883-40ed-4be9-cf16-95135d1cc500' },
  { slug: 'john-and-joseph', name: 'John & Joseph', cfId: '95362728-7938-45a8-709d-06cf25403a00' },
  { slug: 'harper', name: 'Harper', cfId: '97e6435d-0d88-44db-20c6-f91c182f0d00' },
  { slug: 'noah', name: 'Noah', cfId: 'f0f1f46b-2180-49ad-d714-c46641ff2d00' },
  { slug: 'karson', name: 'Karson', cfId: '19bad55d-e080-41cc-eb82-d16c3663a800' },
];

/* ── Featured Story ── */
const allKids = await getCollection('kids');
const featuredSlug = siteSettings.featuredKidSlug || 'zyah';
const featuredKid = allKids.find(k => k.id === featuredSlug);
const fd = featuredKid?.data;

/* ── Kids Strip (from settings) ── */
const kidShowcaseData = siteSettings.kidShowcase || [
  { slug: 'liam', cfId: 'kids/liam/hero-7ab7f9' },
  { slug: 'sophia', cfId: 'kids/sophia/hero-63933e' },
  { slug: 'jackson', cfId: 'kids/jackson/hero-4b1747' },
  { slug: 'griffin', cfId: 'kids/griffin/hero-dbeb0f' },
  { slug: 'madison', cfId: 'kids/madison/hero-2d8210' },
  { slug: 'harper', cfId: 'kids/harper/hero-c6a714' },
  { slug: 'noah', cfId: 'kids/noah/hero-1ba6ae' },
  { slug: 'summer', cfId: 'kids/summer/hero-22c2e2' },
];
const kidShowcase = kidShowcaseData.map(item => {
  const kid = allKids.find(k => k.id === item.slug);
  return {
    ...item,
    name: kid?.data?.name || item.slug,
    age: kid?.data?.age,
    roomLabel: kid?.data?.roomTypes?.[0] || 'Dream Bedroom',
  };
});

/* ── Section photos (from settings) ── */
const sp = siteSettings.sectionPhotos || {};
const missionMainId = sp.missionMain || 'kids/eli/photo-001-70ddd7';
const missionAccentId = sp.missionAccent || 'kids/georgia/photo-001-bd7eb4';
const storyPhotoId = sp.storyPhoto || 'kids/zyah/hero-2a16fd';
const roomPhotos = {
  bedroom: sp.roomBedroom || 'kids/griffin/hero-dbeb0f',
  bath: sp.roomBath || 'kids/zyah/hero-2a16fd',
  therapy: sp.roomTherapy || 'kids/jackson/hero-4b1747',
};

/* ── Partner logos (from settings) ── */
const partnerLogos = siteSettings.partnerLogos || [
  { id: 'logos/logo-gas-south-afb96260', name: 'Gas South' },
  { id: 'logos/logo-randall-paulson-b01b8322', name: 'Randall Paulson' },
  { id: 'logos/logo-kids-r-kids-2c18b077', name: 'Kids R Kids' },
  { id: 'logos/logo-cambria-5af4504f', name: 'Cambria' },
  { id: 'logos/logo-mohawk-9784da88', name: 'Mohawk' },
  { id: 'logos/logo-jackson-healthcare-3c0f6126', name: 'Jackson Healthcare' },
  { id: 'logos/logo-crosby-design-group-d6cf63', name: 'Crosby Design Group' },
  { id: 'logos/logo-msi-e55b3f4c', name: 'MSI' },
  { id: 'logos/logo-cr-construction-v2-bc7affde', name: 'CR Construction' },
  { id: 'logos/logo-stag-partners-3399d7', name: 'Stag Partners' },
];

import { getWebSiteSchema } from '../utils/schema';
const jsonLd = getWebSiteSchema();
---

<BaseLayout
  title="Building Dreams, One Room at a Time"
  description="Sunshine on a Ranney Day is a 501(c)(3) nonprofit creating life-changing home makeovers for children with special needs — dream bedrooms, accessible bathrooms, and therapy spaces — all at no cost to families in greater Atlanta."
  jsonLd={jsonLd}
>

  <!-- ══════ HERO — Three Pillars ══════ -->
  <section class="hero" aria-label="Introduction">
    <div class="hero-inner">
      <!-- Headline block -->
      <div class="hero-header">
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
          {heroEyebrow}
        </div>
        <h1>
          <span class="hero-line"><span class="hero-line-inner" set:html={heroHeadlineLine1} /></span>
          <span class="hero-line"><span class="hero-line-inner" set:html={heroHeadlineLine2} /></span>
        </h1>
        <p class="hero-lead" set:html={heroLead} />
      </div>

      <!-- Three pillar cards — each shows a room type -->
      <div class="pillars">
        <a href="/kids/" class="pillar" style="--pi:0">
          <div class="pillar-img">
            <picture>
              <source type="image/avif" srcset={`${CF}/${roomPhotos.bedroom}/w=480,h=600,fit=cover,f=avif`} />
              <source type="image/webp" srcset={`${CF}/${roomPhotos.bedroom}/w=480,h=600,fit=cover,f=webp`} />
              <img src={`${CF}/${roomPhotos.bedroom}/w=480,h=600,fit=cover,q=78`} alt="A completed dream bedroom designed for a child with special needs" width="480" height="600" loading="eager" />
            </picture>
            <div class="pillar-badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 22v-2c0-2.2 1.8-4 4-4h2"/><path d="M9 16c0 2.2 1.8 4 4 4h4c2.2 0 4-1.8 4-4v-6"/><path d="M3 10V6c0-1.1.9-2 2-2h14a2 2 0 0 1 2 2v4"/><path d="M3 10h18"/></svg>
              Dream Bedrooms
            </div>
          </div>
          <div class="pillar-caption">
            <span class="pillar-count">{Math.round(stats.totalRooms * 0.6)}+ built</span>
            <p>Themes chosen by the child. Sensory-friendly lighting. A space that's truly <em>theirs</em>.</p>
          </div>
        </a>

        <a href="/kids/" class="pillar" style="--pi:1">
          <div class="pillar-img">
            <picture>
              <source type="image/avif" srcset={`${CF}/${roomPhotos.bath}/w=480,h=600,fit=cover,f=avif`} />
              <source type="image/webp" srcset={`${CF}/${roomPhotos.bath}/w=480,h=600,fit=cover,f=webp`} />
              <img src={`${CF}/${roomPhotos.bath}/w=480,h=600,fit=cover,q=78`} alt="An accessible bathroom renovation for a child in a wheelchair" width="480" height="600" loading="eager" />
            </picture>
            <div class="pillar-badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12h16a1 1 0 0 1 1 1v3a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4v-3a1 1 0 0 1 1-1z"/><path d="M6 12V4a2 2 0 0 1 2-2h3v2.25a.75.75 0 0 0 1.5 0V2h.5"/></svg>
              Accessible Bathrooms
            </div>
          </div>
          <div class="pillar-caption">
            <span class="pillar-count">Roll-in showers & grab bars</span>
            <p>Adaptive fixtures that grant independence and dignity. Built for every ability.</p>
          </div>
        </a>

        <a href="/kids/" class="pillar" style="--pi:2">
          <div class="pillar-img">
            <picture>
              <source type="image/avif" srcset={`${CF}/${roomPhotos.therapy}/w=480,h=600,fit=cover,f=avif`} />
              <source type="image/webp" srcset={`${CF}/${roomPhotos.therapy}/w=480,h=600,fit=cover,f=webp`} />
              <img src={`${CF}/${roomPhotos.therapy}/w=480,h=600,fit=cover,q=78`} alt="A therapy room designed for a child's sensory and developmental needs" width="480" height="600" loading="eager" />
            </picture>
            <div class="pillar-badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l1.912 5.813a2 2 0 0 0 1.275 1.275L21 12l-5.813 1.912a2 2 0 0 0-1.275 1.275L12 21l-1.912-5.813a2 2 0 0 0-1.275-1.275L3 12l5.813-1.912a2 2 0 0 0 1.275-1.275L12 3z"/></svg>
              Therapy Rooms
            </div>
          </div>
          <div class="pillar-caption">
            <span class="pillar-count">Sensory-designed spaces</span>
            <p>Calming environments for therapy, play, and growth. Custom-built for each child's needs.</p>
          </div>
        </a>
      </div>

      <!-- CTA + Stats row -->
      <div class="hero-bottom">
        <div class="hero-ctas">
          <a href={heroCta1Link} class="btn btn-primary btn-glow">
            {heroCta1Label}
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 2.5C6.5 1 4 1 2.75 2.75S2.5 6.5 8 11.5C13.5 6.5 13.75 4.5 13.25 2.75S9.5 1 8 2.5Z" fill="currentColor"/></svg>
          </a>
          <a href={heroCta2Link} class="btn btn-outline-dark">{heroCta2Label}</a>
        </div>
        <div class="hero-proof">
          <div class="proof-item"><span class="proof-num">{stats.totalKids}+</span> kids served</div>
          <span class="proof-sep">·</span>
          <div class="proof-item"><span class="proof-num">{stats.years}</span> years</div>
          <span class="proof-sep">·</span>
          <div class="proof-item"><span class="proof-num">100%</span> free for families</div>
        </div>
      </div>
    </div>

    <!-- Auto-scrolling filmstrip -->
    <div class="hero-filmstrip" aria-hidden="true">
      <div class="filmstrip-track">
        {[...mosaicKids, ...mosaicKids].map((kid) => (
          <a href={`/kids/${kid.slug}`} class="filmstrip-cell">
            <img
              src={`${CF}/${kid.cfId}/w=96,h=96,fit=cover,f=auto,q=60`}
              alt=""
              width="96" height="96"
              loading="lazy" decoding="async"
            />
            <span class="filmstrip-name">{kid.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════ IMPACT RIBBON ══════ -->
  <section class="ribbon" aria-label="Impact numbers">
    <div class="ribbon-inner">
      <div class="ribbon-stat" data-reveal>
        <span class="ribbon-num">{stats.totalRooms}+</span>
        <span class="ribbon-label">Room Makeovers</span>
      </div>
      <div class="ribbon-divider" role="presentation"></div>
      <div class="ribbon-stat" data-reveal data-delay="1">
        <span class="ribbon-num">{stats.totalKids}+</span>
        <span class="ribbon-label">Children Served</span>
      </div>
      <div class="ribbon-divider" role="presentation"></div>
      <div class="ribbon-stat" data-reveal data-delay="2">
        <span class="ribbon-num">{stats.years}</span>
        <span class="ribbon-label">Years of Impact</span>
      </div>
      <div class="ribbon-divider" role="presentation"></div>
      <div class="ribbon-stat" data-reveal data-delay="3">
        <span class="ribbon-num">100<span class="ribbon-pct">%</span></span>
        <span class="ribbon-label">Goes to Kids</span>
      </div>
    </div>
  </section>

  <MediaLogos theme="dark" linked={true} />

  <!-- ══════ MISSION ══════ -->
  <section class="mission" aria-labelledby="mission-heading">
    <div class="mission-inner">
      <div class="mission-text" data-reveal>
        <div class="section-label">Our Mission</div>
        <h2 id="mission-heading">A bedroom isn't just a room. It's where a child feels <em class="highlight">safe</em>, <em class="highlight">seen</em>, and <em class="highlight">loved</em>.</h2>
        <p class="mission-body">For children with special needs, a thoughtfully designed room changes everything. Sensory-friendly lighting that calms instead of overwhelms. Adaptive furniture that grants independence. Colors and themes chosen by the child — because this space is <em>theirs</em>.</p>
        <p class="mission-body">Since 2012, we've partnered with designers, contractors, and families across Greater Atlanta to create over {stats.totalRooms} life-changing spaces. Every project is different because every child is different.</p>
      </div>
      <div class="mission-visual" role="presentation">
        <div class="mission-photo mission-photo--main" data-reveal>
          <picture>
            <source type="image/avif" srcset={`${CF}/${missionMainId}/w=500,f=avif 500w, ${CF}/${missionMainId}/w=800,f=avif 800w`} sizes="(max-width:768px) 90vw, 40vw" />
            <source type="image/webp" srcset={`${CF}/${missionMainId}/w=500,f=webp 500w, ${CF}/${missionMainId}/w=800,f=webp 800w`} sizes="(max-width:768px) 90vw, 40vw" />
            <img src={`${CF}/${missionMainId}/w=800,q=80`} alt="A transformed room designed for a child with special needs" width="800" height="600" loading="lazy" decoding="async" />
          </picture>
        </div>
        <div class="mission-photo mission-photo--accent" data-reveal data-delay="1">
          <picture>
            <source type="image/avif" srcset={`${CF}/${missionAccentId}/w=400,f=avif 400w, ${CF}/${missionAccentId}/w=600,f=avif 600w`} sizes="(max-width:768px) 60vw, 30vw" />
            <source type="image/webp" srcset={`${CF}/${missionAccentId}/w=400,f=webp 400w, ${CF}/${missionAccentId}/w=600,f=webp 600w`} sizes="(max-width:768px) 60vw, 30vw" />
            <img src={`${CF}/${missionAccentId}/w=600,q=80`} alt="A happy child in their new dream room" width="600" height="450" loading="lazy" decoding="async" />
          </picture>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ FEATURED STORY ══════ -->
  <section class="story" id="stories" aria-labelledby="story-heading">
    <div class="story-split">
      <figure class="story-photo">
        <picture>
          <source type="image/avif" srcset={`${CF}/${storyPhotoId}/w=600,f=avif 600w, ${CF}/${storyPhotoId}/w=900,f=avif 900w, ${CF}/${storyPhotoId}/w=1200,f=avif 1200w`} sizes="(max-width:768px) 100vw, 55vw" />
          <source type="image/webp" srcset={`${CF}/${storyPhotoId}/w=600,f=webp 600w, ${CF}/${storyPhotoId}/w=900,f=webp 900w, ${CF}/${storyPhotoId}/w=1200,f=webp 1200w`} sizes="(max-width:768px) 100vw, 55vw" />
          <img src={`${CF}/${storyPhotoId}/w=900,q=80`} alt={`${fd?.name || 'Zyah'}'s room reveal`} width="900" height="600" loading="lazy" decoding="async" class="story-photo-img" />
        </picture>
        <div class="story-photo-tag">Latest Reveal</div>
      </figure>
      <div class="story-content" data-reveal>
        <div class="section-label">Featured Story</div>
        <span class="story-type">{fd?.roomTypes?.[0] || 'Dream Bedroom'}</span>
        <h2 id="story-heading">{fd?.name || 'Zyah'}'s new space gave her independence — and her family peace of mind.</h2>
        <p>{fd?.name || 'Zyah'}, age {fd?.age || 7}, lives with {fd?.diagnosis || 'Spinal Muscular Atrophy'}. Our team transformed her space into an accessible, joyful haven — with custom features designed around her unique needs and personality.</p>
        <a href={`/kids/${featuredSlug}`} class="btn btn-dark">Read {fd?.name || 'Zyah'}'s Full Story →</a>
      </div>
    </div>
  </section>

  <!-- ══════ MORE KIDS ══════ -->
  <section class="kids-strip" aria-labelledby="kids-heading">
    <div class="kids-strip-header" data-reveal>
      <div>
        <div class="section-label">More Stories</div>
        <h2 id="kids-heading">Every room changes a <em class="highlight">life</em></h2>
      </div>
      <a href="/kids" class="kids-strip-all">See all {stats.totalKids}+ kids →</a>
    </div>
    <ul class="kids-scroll">
      {kidShowcase.map(kid => (
        <li class="kid-thumb-item">
          <a href={`/kids/${kid.slug}`} class="kid-thumb">
            <div class="kid-thumb-photo">
              <img src={`${CF}/${kid.cfId}/w=440,h=440,fit=cover,f=auto`} alt={`${kid.name}'s room reveal`} width="220" height="220" loading="lazy" decoding="async" />
            </div>
            <h3 class="kid-thumb-name">{kid.name}</h3>
            <p>{kid.roomLabel}{kid.age ? ` · Age ${kid.age}` : ''}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- ══════ PROCESS ══════ -->
  <section class="process" aria-labelledby="process-heading">
    <div class="process-inner">
      <div class="process-header" data-reveal>
        <div class="section-label">The Process</div>
        <h2 id="process-heading">From first call to <em class="highlight">big reveal</em></h2>
      </div>
      <ol class="timeline" role="list">
        <li class="timeline-step" data-reveal>
          <div class="timeline-marker" aria-hidden="true"><span>1</span></div>
          <div class="timeline-body"><h3>Family Applies</h3><p>A simple application — families tell us about their child, their needs, and their dreams for a new space.</p></div>
        </li>
        <li class="timeline-step" data-reveal data-delay="1">
          <div class="timeline-marker" aria-hidden="true"><span>2</span></div>
          <div class="timeline-body"><h3>Design & Plan</h3><p>Our designer partners meet the family, learn the child's personality, and create a custom room concept.</p></div>
        </li>
        <li class="timeline-step" data-reveal data-delay="2">
          <div class="timeline-marker" aria-hidden="true"><span>3</span></div>
          <div class="timeline-body"><h3>Build & Transform</h3><p>Construction partners bring it to life — usually in just a few intense, loving days of work.</p></div>
        </li>
        <li class="timeline-step" data-reveal data-delay="3">
          <div class="timeline-marker" aria-hidden="true"><span>4</span></div>
          <div class="timeline-body"><h3>The Big Reveal ✨</h3><p>The moment. The child walks in, sees their new room, and everything changes. This is why we do it.</p></div>
        </li>
      </ol>
    </div>
  </section>

  <!-- ══════ ROOM TYPES ══════ -->
  <section class="rooms" aria-labelledby="rooms-heading">
    <div class="rooms-inner">
      <div class="rooms-header" data-reveal>
        <div class="section-label">What We Build</div>
        <h2 id="rooms-heading">Three types of spaces, one purpose: <em class="highlight">empowering kids</em></h2>
      </div>
      <div class="rooms-grid">
        <a href="/kids" class="room-tile" data-accent="bedroom" data-reveal>
