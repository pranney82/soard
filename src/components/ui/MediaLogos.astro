---
/**
 * MediaLogos.astro
 * "As Featured In" media outlet logo bar using CF Images.
 * Logos are grayscale by default, darken on hover.
 * Used on homepage and publicity page.
 */
interface Props {
  theme?: 'light' | 'dark';
  linked?: boolean;
}

const { theme = 'dark', linked = true } = Astro.props;
const CF = 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ';
const href = linked ? '/publicity' : undefined;

const logos = [
  { id: 'press-logo-today-show',        alt: 'Today Show',                 wide: false },
  { id: 'press-logo-11alive',           alt: '11Alive',                    wide: false },
  { id: 'press-logo-fox5',              alt: 'Fox 5 Atlanta',              wide: false },
  { id: 'press-logo-wsb-tv',            alt: 'WSB-TV',                     wide: false },
  { id: 'press-logo-ajc',               alt: 'Atlanta Journal-Constitution', wide: true },
  { id: 'press-logo-atlanta-magazine',  alt: 'Atlanta Magazine',           wide: false },
  { id: 'press-logo-styleblueprint',    alt: 'StyleBlueprint',             wide: true },
  { id: 'press-logo-41nbc',             alt: '41NBC',                      wide: false },
];
---

<div class="ml" data-theme={theme}>
  <div class="ml__label">As Featured In</div>
  <div class="ml__row">
    {logos.map(logo => href ? (
      <a href={href} class:list={["ml__item", { "ml__item--wide": logo.wide }]} aria-label={`Featured on ${logo.alt}`}>
        <img
          src={`${CF}/${logo.id}/w=400`}
          alt={logo.alt}
          class="ml__logo"
          loading="lazy"
          decoding="async"
          width="200"
          height="60"
        />
      </a>
    ) : (
      <div class:list={["ml__item", { "ml__item--wide": logo.wide }]}>
        <img
          src={`${CF}/${logo.id}/w=400`}
          alt={logo.alt}
          class="ml__logo"
          loading="lazy"
          decoding="async"
          width="200"
          height="60"
        />
      </div>
    ))}
  </div>
</div>

<style>
  .ml {
    padding: 48px 0;
    overflow: hidden;
  }
  .ml[data-theme="dark"] {
    background: var(--c-warm-gray, #F5F4F0);
    border-top: 1px solid var(--c-border, #E5E4E0);
    border-bottom: 1px solid var(--c-border, #E5E4E0);
  }
  .ml[data-theme="light"] {
    background: rgba(255,255,255,0.04);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .ml__label {
    text-align: center;
    margin-bottom: 32px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }
  .ml[data-theme="dark"] .ml__label { color: var(--c-text-light, #9B9CA0); }
  .ml[data-theme="light"] .ml__label { color: rgba(255,255,255,0.35); }

  .ml__row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 20px 48px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 2rem);
  }

  .ml__item {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .ml[data-theme="dark"] .ml__item { opacity: 0.35; }
  .ml[data-theme="light"] .ml__item { opacity: 0.4; }

  .ml__item:hover {
    opacity: 0.8 !important;
    transform: translateY(-1px);
  }

  .ml__logo {
    height: 48px;
    width: auto;
    object-fit: contain;
  }
  /* Light theme: invert the dark logos to white */
  .ml[data-theme="light"] .ml__logo {
    filter: invert(1) brightness(2);
  }

  .ml__item--wide .ml__logo {
    height: 44px;
  }

  /* ── Tablet ── */
  @media (max-width: 900px) {
    .ml__row { gap: 16px 32px; }
    .ml__logo { height: 40px; }
    .ml__item--wide .ml__logo { height: 36px; }
    .ml { padding: 40px 0; }
  }
  /* ── Mobile ── */
  @media (max-width: 600px) {
    .ml__row { gap: 12px 24px; }
    .ml__logo { height: 32px; }
    .ml__item--wide .ml__logo { height: 28px; }
    .ml { padding: 32px 0; }
    .ml__label { margin-bottom: 24px; }
  }
</style>
