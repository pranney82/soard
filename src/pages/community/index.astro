---
/**
 * Community Projects — Sunshine on a Ranney Day
 * Large-scale renovations at schools, camps, and nonprofits
 * serving children with special needs.
 *
 * DESIGN: Modeled after the kids index page — editorial split hero,
 * premium project card grid with same hover system (yellow gradient
 * overlay, inset border glow, CTA arrow, animated name underline),
 * spotlight split, and dark CTA. Clean, focused, no section bloat.
 *
 * PERF NOTES:
 * - Editorial split hero with preloaded LCP image
 * - Hero image: fetchpriority="high", eager loading, LQIP blur-up
 * - All below-fold images: loading="lazy" with LQIP
 * - CFImage component for responsive srcsets
 * - data-reveal on below-fold elements
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import CFImage from '../../components/ui/CFImage.astro';
import { getWebPageSchema, getBreadcrumbSchema, buildSchemaGraph } from '../../utils/schema';
import { getCollection } from 'astro:content';
import { cfRaw, cfSrcset, cfLqip, cfId, cfDensitySrcset } from '../../utils/cf-image';
import { getSiteStats } from '../../utils/stats';
import siteSettings from '../../content/site/settings.json';

/* ── Community Projects from content collection ── */
const allProjects = await getCollection('community');
const projects = allProjects
  .map(p => p.data)
  .sort((a, b) => (a.order || 0) - (b.order || 0) || a.name.localeCompare(b.name));

/* ── Community Partners (nonprofit orgs we serve) ── */
const allCommunityPartners = await getCollection('communityPartners');
const communityPartners = allCommunityPartners
  .map(p => p.data)
  .sort((a, b) => (a.order || 0) - (b.order || 0) || a.name.localeCompare(b.name));
const featuredPartners = communityPartners.filter(p => p.featured);

const { livesImpacted } = await getSiteStats();
const totalImpact = livesImpacted.toLocaleString() + '+';

/* ── Hero photos (editable via admin → Kids on Site → Community) ── */
const heroPhotoId = siteSettings.communityPhotos?.hero || 'kids/camp-twin-lakes/hero';
const heroAccentPhotoId = siteSettings.communityPhotos?.accent || 'kids/summit-counseling-center/hero';

/* ── Spotlight ── */
const spotlightPhoto = 'community/the-drake-house/after-01';

/* ── Schema ── */
const pageUrl = 'https://sunshineonaranneyday.com/community/';
const breadcrumbs = [
  { name: 'Home', url: 'https://sunshineonaranneyday.com/' },
  { name: 'Community Projects', url: pageUrl },
];
const jsonLd = buildSchemaGraph(
  getWebPageSchema({
    url: pageUrl,
    title: 'Community Projects',
    description: 'Sunshine on a Ranney Day partners with nonprofits, schools, and camps to complete large-scale renovation projects that impact thousands of children with special needs each year. Meet our nonprofit partners.',
  }),
  getBreadcrumbSchema(breadcrumbs, pageUrl),
);
---

<BaseLayout
  title="Community Projects — Large-Scale Renovations"
  description="Sunshine on a Ranney Day partners with nonprofits, schools, and camps to complete large-scale renovation projects that impact thousands of children with special needs each year."
  jsonLd={jsonLd}
  breadcrumbs={breadcrumbs}
>
  <!-- Preload hero LCP image -->
  <link slot="head" rel="preload" as="image" imagesrcset={cfSrcset(heroPhotoId, [400, 640, 800, 1024], { fit: 'cover', aspectRatio: 1.25 })} imagesizes="(max-width:768px) 80vw, (max-width:1200px) 38vw, 420px" fetchpriority="high" />

  <!-- ══════ HERO — Editorial Split (matches apply/donate/home) ══════ -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <p class="hero-eyebrow">Community Projects</p>
        <h1>Thinking <em>bigger</em>.</h1>
        <p class="hero-lead">When one room isn't enough, we think bigger. We partner with schools, camps, and nonprofits to transform entire facilities — classrooms, therapy rooms, and gathering spaces that serve thousands of children every year.</p>
        <div class="hero-ctas">
          <a href="#projects" class="btn btn-primary">See Our Projects <span aria-hidden="true">&darr;</span></a>
        </div>
      </div>
      <div class="hero-frame">
        <div class="hero-accent" aria-hidden="true"></div>
        <div class="hero-photo" style={`background-image:url('${cfLqip(heroPhotoId)}')`}>
          <img
            src={cfRaw(heroPhotoId, 'w=640,h=800,fit=cover,q=82')}
            srcset={cfSrcset(heroPhotoId, [400, 640, 800, 1024], { fit: 'cover', aspectRatio: 1.25 })}
            sizes="(max-width:768px) 80vw, (max-width:1200px) 38vw, 420px"
            alt="Camp Twin Lakes facility renovated by SOARD"
            width="640" height="800"
            class="lqip-img"
            fetchpriority="high"
            loading="eager"
            decoding="async"
          />
        </div>
        <picture class="hero-photo hero-photo--small" style={`background-image:url('${cfLqip(heroAccentPhotoId)}')`}>
          <source media="(max-width:768px)" srcset="data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==" />
          <source media="(min-width:769px)" srcset={cfSrcset(heroAccentPhotoId, [240, 360, 480], { fit: 'cover', aspectRatio: 1.2 })} sizes="180px" />
          <img
            src={cfRaw(heroAccentPhotoId, 'w=360,h=432,fit=cover,q=75')}
            alt="Summit Counseling Center renovation by SOARD"
            width="360" height="432"
            class="lqip-img" loading="lazy" decoding="async"
          />
        </picture>
      </div>
    </div>
    <div class="hero-stat">
      <span class="hero-stat-num">{totalImpact}</span>
      <span class="hero-stat-label">children reached<br/>through partnerships</span>
    </div>
  </section>

  <!-- ══════ PROJECTS GRID ══════ -->
  <section class="projects" id="projects">
    <div class="projects-inner">
      <div class="projects-header" data-reveal>
        <p class="projects-label">Our Projects</p>
        <h2>Organizations we've <em class="highlight">transformed</em>.</h2>
        <p class="projects-sub">Each partnership is a story of transformation — facilities redesigned, spaces reimagined, and thousands of lives changed.</p>
      </div>

      <div class="projects-grid">
        {projects.map((project, i) => {
          const hasDetail = !!project.story;
          const detailHref = `/community/${project.slug}/`;
          const hasPhoto = project.imageId || project.heroImage;
          const photoId = project.imageId || project.heroImage || '';
          return (
            <a href={hasDetail ? detailHref : undefined} class={`project-card ${!hasDetail ? 'project-card--static' : ''}`} data-reveal data-delay={String(i % 3)}>
              <div class="project-card__frame" style={hasPhoto && project.imageId ? `background-image:url(${cfLqip(project.imageId)})` : ''}>
                {hasPhoto ? (
                  <CFImage
                    src={photoId}
                    alt={project.imageAlt || `${project.name} project by SOARD`}
                    width={480} height={360}
                    sizes="(max-width:768px) calc(50vw - 24px), (max-width:1100px) calc(33vw - 24px), 260px"
                    widths={[240, 360, 480]}
                    loading={i < 3 ? 'eager' : 'lazy'}
                    fit="cover"
                    class="project-card__img lqip-img"
                  />
                ) : (
                  <div class="project-card__color" style={`background: ${project.color};`}>
                    <span class="project-card__color-num">{project.impact}</span>
                    <span class="project-card__color-label">{project.impactLabel}</span>
                  </div>
                )}
                {hasDetail && (
                  <div class="project-card__hover" aria-hidden="true">
                    <span class="project-card__cta">
                      <span class="sr-only">View project</span>
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                  </div>
                )}
                {project.badge && <span class="project-card__badge">{project.badge}</span>}
              </div>
              <div class="project-card__info">
                <span class="project-card__name">{project.name}</span>
              </div>
              <span class="project-card__meta">
                {project.year} · {project.impact} {project.impactLabel}
              </span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ══════ SPOTLIGHT — Drake House ══════ -->
  <section class="spotlight" aria-labelledby="spotlight-heading">
    <div class="spotlight-inner">
      <div class="spotlight-visual" data-reveal>
        <a href="/community/the-drake-house/" class="spotlight-frame">
          <CFImage
            src={spotlightPhoto}
            alt="The Drake House headquarters renovated by SOARD"
            width={800} height={600}
            sizes="(max-width:768px) 90vw, 50vw"
            widths={[400, 600, 800]}
            loading="lazy"
            fit="cover"
            class="spotlight-img"
          />
        </a>
      </div>
      <div class="spotlight-text" data-reveal data-delay="1">
        <div class="section-label">2022 Spotlight</div>
        <h2 id="spotlight-heading">Transforming The Drake House for families <em class="highlight">starting over</em>.</h2>
        <p>The Drake House provides housing and education for single mothers and their children experiencing homelessness. Over 40% of Atlanta's homeless population are women and children.</p>
        <p>SOARD renovated their headquarters — classrooms, activity spaces, a community kitchen, and teen gathering rooms — creating an environment where families can recover, learn, and rebuild with dignity.</p>
        <a href="/community/the-drake-house/" class="spotlight-link">
          View Full Project
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ══════ NONPROFIT PARTNERS ══════ -->
  {communityPartners.length > 0 && (
    <section class="np-section" id="nonprofit-partners" aria-labelledby="np-heading">
      <div class="np-inner">
        <div class="np-header" data-reveal>
          <p class="np-label">Nonprofit Partners</p>
          <h2 id="np-heading">The organizations we <em class="highlight">serve</em>.</h2>
          <p class="np-sub">These schools, camps, hospitals, and community centers open their doors so we can transform facilities for the children and families who need it most.</p>
        </div>
        <div class="np-grid" data-reveal data-delay="1">
          {communityPartners.map(p => {
            const hasLogo = !!p.logo;
            const hasLink = !!p.website;
            const Tag = hasLink ? 'a' : 'div';
            return (
              <Tag
                class:list={['np-logo-card', { 'np-logo-card--linked': hasLink }]}
                {...(hasLink ? { href: p.website, target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                <div class="np-logo-card__logo">
                  {hasLogo ? (
                    <img
                      src={cfRaw(p.logo, 'w=280,h=80,fit=contain,q=80')}
                      srcset={cfDensitySrcset(cfId(p.logo), 140, 40, { quality: 80, fit: 'contain' })}
                      alt={p.name}
                      width="140" height="40"
                      loading="lazy" decoding="async"
                    />
                  ) : (
                    <span class="np-logo-card__placeholder">{p.name}</span>
                  )}
                </div>
                <span class="np-logo-card__name">{p.name}</span>
                {hasLink && (
                  <svg class="np-logo-card__ext" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
                )}
              </Tag>
            );
          })}
        </div>
        <div class="np-cta" data-reveal>
          <p>Is your organization serving children with special needs?</p>
          <a href="mailto:info@soardcharity.com?subject=Community%20Partnership%20Inquiry" class="spotlight-link">
            Start a Conversation
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- ══════ CTA ══════ -->
  <section class="cta-section">
    <div class="cta-inner">
      <h2 data-reveal>Every child deserves a space to <em>thrive</em></h2>
      <p data-reveal data-delay="1">Your generosity helps us transform facilities at schools, camps, and nonprofits across greater Atlanta.</p>
      <div class="cta-buttons" data-reveal data-delay="2">
        <a href="/donate" class="btn btn-yellow">Donate Now</a>
        <a href="/about" class="btn btn-outline-light">Our Story</a>
      </div>
    </div>
  </section>

</BaseLayout>

<!-- ══════ View Transitions: card ↔ hero morph ══════ -->
<script>
  function initCommunityTransitions() {
    const grid = document.querySelector('.projects-grid');
    if (!grid) return;

    grid.addEventListener('click', (e) => {
      const card = (e.target as HTMLElement).closest('.project-card') as HTMLElement | null;
      if (!card || card.classList.contains('project-card--static')) return;

      document.querySelectorAll('[style*="view-transition-name"]').forEach(el => {
        (el as HTMLElement).style.viewTransitionName = '';
      });

      const frame = card.querySelector('.project-card__frame') as HTMLElement | null;
      const name = card.querySelector('.project-card__name') as HTMLElement | null;
      if (frame) {
        frame.style.viewTransitionName = 'community-hero';
        frame.style.boxShadow = 'none';
        const overlay = frame.querySelector('.project-card__hover') as HTMLElement | null;
        if (overlay) overlay.style.opacity = '0';
        const cta = frame.querySelector('.project-card__cta') as HTMLElement | null;
        if (cta) cta.style.opacity = '0';
        const img = frame.querySelector('.project-card__img') as HTMLElement | null;
        if (img) { img.style.transform = 'none'; img.style.filter = 'none'; }
      }
      if (name) name.style.viewTransitionName = 'community-name';
    });
  }

  function setupCommunityBackTransition(e: any) {
    const fromPath = window.location.pathname;
    const slugMatch = fromPath.match(/^\/community\/([^/]+)\/?$/);
    if (!slugMatch) return;
    const newDoc = e.newDocument as Document;
    if (!newDoc.querySelector('.projects-grid')) return;
    const slug = slugMatch[1];
    const card = newDoc.querySelector(`a.project-card[href="/community/${slug}/"]`) as HTMLElement | null;
    if (!card) return;
    const frame = card.querySelector('.project-card__frame') as HTMLElement | null;
    const name = card.querySelector('.project-card__name') as HTMLElement | null;
    if (frame) frame.style.viewTransitionName = 'community-hero';
    if (name) name.style.viewTransitionName = 'community-name';
  }

  document.addEventListener('astro:page-load', initCommunityTransitions);
  document.addEventListener('astro:before-swap', setupCommunityBackTransition);
</script>

<style>
  /* ── LQIP blur-up ── */
  .lqip-img.lqip-pending { opacity: 0; }
  .lqip-img:not(.lqip-pending) { transition: opacity 0.4s ease; }

  /* ══════════════════════════════════════════
     HERO — Editorial Split (matches apply/donate/home)
     ══════════════════════════════════════════ */
  @keyframes heroUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes heroSlide {
    from { transform: translateY(20px); }
    to { transform: translateY(0); }
  }
  @keyframes heroPhotoIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes accentIn {
    from { opacity: 0; transform: scale(0.85); }
    to { opacity: 1; transform: scale(1); }
  }

  .hero {
    background: var(--c-cream);
    padding: clamp(80px, 10vw, 140px) 0 clamp(64px, 8vw, 100px);
    position: relative;
    contain: layout style;
    min-height: clamp(480px, 70vh, 720px);
    overflow: hidden;
  }

  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-xl);
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(40px, 5vw, 80px);
    align-items: center;
  }

  .hero-eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    opacity: 0;
    animation: heroUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.05s both;
  }

  .hero-eyebrow::before {
    content: '';
    width: 28px;
    height: 2px;
    background: currentColor;
    flex-shrink: 0;
  }

  .hero-text h1 {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    letter-spacing: -0.035em;
    line-height: 1.04;
    color: var(--c-text);
    margin-bottom: 28px;
    animation: heroSlide 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero-text h1 em {
    font-style: italic;
    background-image: linear-gradient(transparent 52%, var(--c-yellow-soft) 52%);
    background-repeat: no-repeat;
    background-size: 100% 100%;
    padding: 0 0.05em;
  }

  .hero-lead {
    font-size: clamp(16px, 1.6vw, 18px);
    color: var(--c-text-muted);
    line-height: 1.7;
    margin-bottom: 40px;
    max-width: 480px;
    opacity: 0;
    animation: heroUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
  }

  .hero-ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    opacity: 0;
    animation: heroUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.25s both;
  }

  .hero-frame {
    position: relative;
    animation: heroPhotoIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero-accent {
    position: absolute;
    bottom: -16px;
    right: -16px;
    width: 65%;
    height: 50%;
    background: var(--c-yellow);
    border-radius: 24px;
    z-index: 0;
    opacity: 0;
    animation: accentIn 1s cubic-bezier(0.16, 1, 0.3, 1) 0.7s both;
  }

  .hero-photo {
    position: relative;
    z-index: 1;
    aspect-ratio: 4 / 5;
    border-radius: 24px;
    overflow: hidden;
    background-size: cover;
    background-position: center;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.12), 0 8px 24px rgba(0, 0, 0, 0.06);
  }

  .hero-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .hero-photo--small {
    position: absolute;
    bottom: -24px;
    left: -32px;
    width: 40%;
    aspect-ratio: 5 / 6;
    z-index: 2;
    border: 4px solid var(--c-cream);
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.06), 0 12px 36px rgba(0, 0, 0, 0.12);
  }

  .hero-stat {
    position: absolute;
    bottom: clamp(24px, 4vw, 48px);
    right: clamp(24px, 6vw, 80px);
    background: var(--c-dark);
    color: #fff;
    padding: 16px 24px;
    border-radius: var(--border-radius-lg);
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.08), 0 16px 48px rgba(0, 0, 0, 0.15);
    z-index: 3;
  }

  .hero-stat-num {
    font-family: var(--font-display);
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 700;
    color: var(--c-yellow);
    line-height: 1;
  }

  .hero-stat-label {
    font-size: 12px;
    font-weight: 600;
    line-height: 1.35;
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; gap: 40px; text-align: center; }
    .hero-lead { margin-inline: auto; }
    .hero-ctas { justify-content: center; }
    .hero-frame { max-width: 380px; margin: 0 auto; }
    .hero-stat { position: relative; bottom: auto; right: auto; margin: -20px auto 0; width: fit-content; }
  }

  @media (max-width: 480px) {
    .hero { padding-top: clamp(48px, 8vw, 80px); padding-bottom: var(--space-xl); min-height: auto; }
    .hero-text h1 { font-size: clamp(2rem, 9vw, 3rem); }
    .hero-photo--small { display: none; }
    .hero-photo { border-radius: 18px; }
    .hero-accent { bottom: -12px; right: -12px; border-radius: 18px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow, .hero-lead, .hero-ctas,
    .hero-frame, .hero-accent { opacity: 1; transform: none; animation: none; }
    .hero-text h1 { animation: none; }
  }

  /* ══════════════════════════════════════════
     PROJECTS GRID — Modeled after kids index
     ══════════════════════════════════════════ */
  .projects {
    background: var(--c-cream);
    padding: var(--space-xl) 0 var(--space-5xl);
    scroll-margin-top: var(--header-height);
  }

  .projects-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-xl);
  }

  .projects-header {
    text-align: center;
    max-width: 580px;
    margin: 0 auto var(--space-xl);
  }

  .projects-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    margin-bottom: var(--space-sm);
  }

  .projects-header h2 {
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--c-dark);
  }

  .projects-header h2 em { font-style: normal; }

  .projects-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(0.95rem, 1.8vw, 1.065rem);
    color: var(--c-text-muted);
    line-height: 1.5;
    margin-top: var(--space-md);
  }


  /* ── Grid ── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 900px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); gap: var(--space-md) 14px; }
  }

  /* ── Card (mirrors kid-card pattern) ── */
  .project-card {
    display: block;
    text-decoration: none;
    outline-offset: 4px;
    transition: opacity 0.25s ease;
  }

  .project-card:focus-visible {
    outline: 2px solid var(--c-dark);
    outline-offset: 4px;
    border-radius: var(--border-radius-lg);
  }

  .project-card:active { opacity: 0.85; transition-duration: 80ms; }

  .project-card--static { cursor: default; }

  /* Frame — image container */
  .project-card__frame {
    position: relative;
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--c-warm-gray);
    box-shadow: inset 0 0 0 0px var(--c-yellow);
    transition: box-shadow 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    background-size: cover;
    background-position: center;
  }

  .project-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
