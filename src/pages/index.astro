    50% { box-shadow: 0 0 0 8px rgba(255,218,36,0.06); }
  }

  .hero h1 {
    font-size: clamp(36px, 5.5vw, 68px);
    color: var(--c-dark); line-height: 1.06;
    margin-bottom: 20px; letter-spacing: -0.035em;
  }
  .hero h1 em {
    font-style: italic;
    background-image: linear-gradient(transparent 52%, var(--c-yellow-soft) 52%);
  }
  .hero-line { display: block; overflow: hidden; padding-bottom: 0.15em; margin-bottom: -0.15em; }
  .hero-line-inner { display: block; transform: translateY(110%); }
  .hero-line:nth-child(1) .hero-line-inner { animation: lineReveal 0.9s cubic-bezier(0.16,1,0.3,1) 0.25s both; }
  .hero-line:nth-child(2) .hero-line-inner { animation: lineReveal 0.9s cubic-bezier(0.16,1,0.3,1) 0.4s both; }
  @keyframes lineReveal { to { transform: translateY(0); } }

  .hero-lead {
    font-size: clamp(15px, 1.6vw, 18px);
