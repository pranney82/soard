---
/**
 * Header.astro — v5 — Stripe-style morphing dropdown navigation
 *
 * Architecture:
 *   Shared morphing card that smoothly resizes/repositions between nav items.
 *   Content crossfades while the card bridges the visual gap.
 *   Staggered link entrances for premium feel.
 *
 * Desktop features:
 *   - Glass header (backdrop-filter blur + scroll state)
 *   - Sliding yellow indicator bar follows hover
 *   - Morphing dropdown card (Stripe pattern) — no close/reopen flash
 *   - Sliding arrow tracks active button
 *   - Rich dropdown panels with icons + descriptions
 *   - Staggered link entrance animation
 *   - Nav-level hover tracking — dropdown stays open across items
 *   - Shimmer + heartbeat Donate CTA
 *
 * Mobile features:
 *   - Drop-down panel extending from header (not full-screen overlay)
 *   - Large serif group headings, descriptions on each link
 *   - Staggered cascade animation
 *   - Sticky gradient donate footer
 *
 * Accessibility:
 *   - Skip-to-content, focus trap, inert, WAI-ARIA menubar
 *   - Arrow keys, Home/End, Escape
 *   - prefers-reduced-motion disables all animation
 *   - 44px+ touch targets, external link indication
 *
 * Performance:
 *   - ~150 lines vanilla JS (zero dependencies)
 *   - GPU-composited transitions (transform + opacity only)
 *   - Passive scroll/touch listeners, RAF-debounced scroll
 *   - Morph uses CSS transitions on position/size properties
 */
import { cfRaw, cfSrcset as _cfSrcset } from '../../utils/cf-image';
const currentPath = Astro.url.pathname;

const LOGO_ID = 'brand-logo-light-bg-display';

interface NavChild {
  label: string;
  href: string;
  external?: boolean;
  desc?: string;
  icon?: string;
}
interface NavGroup {
  label: string;
  href?: string;
  external?: boolean;
  children?: NavChild[];
}

const icons: Record<string, string> = {
  'book-open': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/></svg>',
  'users': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.128a4 4 0 0 1 0 7.744"/></svg>',
  'bar-chart': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12c.552 0 1.005-.449.95-.998a10 10 0 0 0-8.953-8.951c-.55-.055-.998.398-.998.95v8a1 1 0 0 0 1 1z"/><path d="M21.21 15.89A10 10 0 1 1 8 2.83"/></svg>',
  'sparkles': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.912 5.813a2 2 0 0 0 1.275 1.275L21 12l-5.813 1.912a2 2 0 0 0-1.275 1.275L12 21l-1.912-5.813a2 2 0 0 0-1.275-1.275L3 12l5.813-1.912a2 2 0 0 0 1.275-1.275L12 3z"/></svg>',
  'heart': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"/></svg>',
  'buildings': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M19.414 14.414C21 12.828 22 11.5 22 9.5a5.5 5.5 0 0 0-9.591-3.676.6.6 0 0 1-.818.001A5.5 5.5 0 0 0 2 9.5c0 2.3 1.5 4 3 5.5l5.535 5.362a2 2 0 0 0 2.879.052 2.12 2.12 0 0 0-.004-3 2.124 2.124 0 1 0 3-3 2.124 2.124 0 0 0 3.004 0 2 2 0 0 0 0-2.828l-1.881-1.882a2.41 2.41 0 0 0-3.409 0l-1.71 1.71a2 2 0 0 1-2.828 0 2 2 0 0 1 0-2.828l2.823-2.762"/></svg>',
  'handshake': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="m11 17 2 2a1 1 0 1 0 3-3"/><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"/><path d="m21 3 1 11h-2"/><path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"/><path d="M3 4h8"/></svg>',
  'hammer': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="m15 12-9.373 9.373a1 1 0 0 1-3.001-3L12 9"/><path d="m18 15 4-4"/><path d="m21.5 11.5-1.914-1.914A2 2 0 0 1 19 8.172v-.344a2 2 0 0 0-.586-1.414l-1.657-1.657A6 6 0 0 0 12.516 3H9l1.243 1.243A6 6 0 0 1 12 8.485V10l2 2h1.172a2 2 0 0 1 1.414.586L18.5 14.5"/></svg>',
  'palette': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a1 1 0 0 1 0-20 10 9 0 0 1 10 9 5 5 0 0 1-5 5h-2.25a1.75 1.75 0 0 0-1.4 2.8l.3.4a1.75 1.75 0 0 1-1.4 2.8z"/><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/></svg>',
  'party-popper': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M5.8 11.3 2 22l10.7-3.79"/><path d="M4 3h.01"/><path d="M22 8h.01"/><path d="M15 2h.01"/><path d="M22 20h.01"/><path d="m22 2-2.24.75a2.9 2.9 0 0 0-1.96 3.12c.1.86-.57 1.63-1.45 1.63h-.38c-.86 0-1.6.6-1.76 1.44L14 10"/><path d="m22 13-.82-.33c-.86-.34-1.82.2-1.98 1.11c-.11.7-.72 1.22-1.43 1.22H17"/><path d="m11 2 .33.82c.34.86-.2 1.82-1.11 1.98C9.52 4.9 9 5.52 9 6.23V7"/><path d="M11 13c1.93 1.93 2.83 4.17 2 5-.83.83-3.07-.07-5-2-1.93-1.93-2.83-4.17-2-5 .83-.83 3.07.07 5 2Z"/></svg>',
  'clipboard': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v2"/><path d="M21.34 15.664a1 1 0 1 0-3.004-3.004l-5.01 5.012a2 2 0 0 0-.506.854l-.837 2.87a.5.5 0 0 0 .62.62l2.87-.837a2 2 0 0 0 .854-.506z"/><path d="M8 22H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/></svg>',
  'store': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M15 21v-5a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v5"/><path d="M17.774 10.31a1.12 1.12 0 0 0-1.549 0 2.5 2.5 0 0 1-3.451 0 1.12 1.12 0 0 0-1.548 0 2.5 2.5 0 0 1-3.452 0 1.12 1.12 0 0 0-1.549 0 2.5 2.5 0 0 1-3.77-3.248l2.889-4.184A2 2 0 0 1 7 2h10a2 2 0 0 1 1.653.873l2.895 4.192a2.5 2.5 0 0 1-3.774 3.244"/><path d="M4 10.95V19a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8.05"/></svg>',
  'newspaper': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18h-5"/><path d="M18 14h-8"/><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-4 0v-9a2 2 0 0 1 2-2h2"/><rect width="8" height="4" x="10" y="6" rx="1"/></svg>',
  'shirt': '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20.38 3.46L16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.47a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.47a2 2 0 0 0-1.34-2.23z"/></svg>',
};

const nav: NavGroup[] = [
  {
    label: 'About Us',
    children: [
      { label: 'Our Story', href: '/about/', desc: 'How it all began', icon: 'book-open' },
      { label: 'Leadership', href: '/about/leadership/', desc: 'Meet the team', icon: 'users' },
      { label: 'Financials', href: '/about/financials/', desc: 'Full transparency', icon: 'bar-chart' },
      { label: 'Press & Media', href: '/publicity/', desc: 'In the news', icon: 'newspaper' },
    ],
  },
  {
    label: 'Our Kids',
    children: [
      { label: 'Meet the Kids', href: '/kids/', desc: 'Stories of joy', icon: 'heart' },
      { label: 'Community Projects', href: '/community/', desc: 'Beyond bedrooms', icon: 'buildings' },
      { label: 'Apply for Makeover', href: '/apply/', desc: 'Apply for a room', icon: 'clipboard' },
    ],
  },
  {
    label: 'Get Involved',
    children: [
      { label: 'Events', href: '/events/', desc: 'Upcoming gatherings', icon: 'party-popper' },
      { label: 'Partners', href: '/partners/', desc: 'Who makes it happen', icon: 'handshake' },
      { label: 'Ways to Give', href: '/ways-to-give/', desc: 'Tax-smart giving options', icon: 'heart' },
      { label: 'Sunny & Ranney', href: '/sunny-and-ranney/', desc: 'Shop for a cause', icon: 'store' },
    ],
  },
];

function isActive(href: string) {
  if (href.startsWith('http')) return false;
  return currentPath === href;
}
function isGroupActive(group: NavGroup) {
  if (group.href) return isActive(group.href);
  return group.children?.some((child) => isActive(child.href)) ?? false;
}
---

<header class="site-header" id="site-header" transition:persist="site-header">
  <div class="header-inner">
    <!-- Logo — imagedelivery.net auto-negotiates AVIF/WebP via Accept header -->
    <a href="/" class="logo" aria-label="Sunshine on a Ranney Day — Home">
        <img
          src={cfRaw(LOGO_ID, 'w=512,q=85')}
          srcset={_cfSrcset(LOGO_ID, [256, 384, 512, 768])}
          sizes="(min-width: 1024px) 140px, 120px"
          alt="Sunshine on a Ranney Day"
          class="logo-img"
          width="256" height="256"
          loading="eager" fetchpriority="high"
        />
    </a>

    <!-- Desktop Nav -->
    <nav class="desktop-nav" id="desktop-nav" aria-label="Main navigation">
      <ul class="nav-list" role="menubar">
        {nav.map((item, gi) => (
          <li class:list={['nav-item', { 'group-active': isGroupActive(item) }]} role="none" data-nav-group={gi}>
            {item.children ? (
              <>
                <button
                  class:list={['nav-link', { 'parent-active': isGroupActive(item) }]}
                  role="menuitem" aria-haspopup="true" aria-expanded="false"
                  tabindex={gi === 0 ? '0' : '-1'}
                >
                  {item.label}
                  <svg class="chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                    <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <div class="dropdown" role="menu" id={`dd-${gi}`}>
                  <div class="dropdown-panel">
                    {item.children.map((child, ci) => (
                      <a
                        href={child.href} role="menuitem"
                        class:list={['dd-link', { active: isActive(child.href) }]}
                        tabindex="-1" data-child-index={ci} style={`--di:${ci}`}
                        {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                      >
                        <span class="dd-icon" aria-hidden="true" set:html={icons[child.icon || '']} />
                        <span class="dd-body">
                          <span class="dd-label">
                            {child.label}
                            {child.external && (
                              <svg class="dd-ext" width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                                <path d="M4.5 1.5H1.5V10.5H10.5V7.5M7 1.5H10.5M10.5 1.5V5M10.5 1.5L5.5 6.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                              </svg>
                            )}
                          </span>
                          {child.desc && <span class="dd-desc">{child.desc}</span>}
                        </span>
                      </a>
                    ))}
                  </div>
                </div>
              </>
            ) : (
              <a
                href={item.href}
                class:list={['nav-link', { 'parent-active': isGroupActive(item) }]}
                role="menuitem"
                tabindex={gi === 0 ? '0' : '-1'}
                {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                {item.label}
                {item.external && (
                  <svg class="dd-ext" width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true" style="opacity:0.4;margin-left:2px;">
                    <path d="M4.5 1.5H1.5V10.5H10.5V7.5M7 1.5H10.5M10.5 1.5V5M10.5 1.5L5.5 6.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                )}
              </a>
            )}
          </li>
        ))}
      </ul>
      <div class="dd-morph" id="dd-morph" aria-hidden="true">
        <div class="dd-morph-arrow"></div>
      </div>
      <div class="nav-indicator" id="nav-indicator" aria-hidden="true"></div>
    </nav>

    <!-- Donate CTA -->
    <a href="/donate/" class="header-cta">
      <span class="cta-heart" aria-hidden="true">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
      </span>
      Donate
    </a>

    <!-- Mobile: right-side group (donate + hamburger) -->
    <div class="mobile-actions">
      <a href="/donate/" class="mobile-cta">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
        Donate
      </a>
      <button type="button" class="mobile-toggle" id="mobile-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-panel">
        <span class="hamburger" aria-hidden="true">
          <span class="hamburger-line hamburger-line--top"></span>
          <span class="hamburger-line hamburger-line--mid"></span>
          <span class="hamburger-line hamburger-line--bot"></span>
        </span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile drop-down nav (extends from header) -->
<div class="mobile-nav" id="mobile-panel" role="dialog" aria-label="Mobile navigation" aria-modal="true" aria-hidden="true" transition:persist="mobile-panel">
  <div class="mnav-body">
    {nav.map((item, i) => (
      <div class="mnav-group" style={`--i:${i}`}>
        {item.children ? (
          <>
            <h3 class="mnav-heading">{item.label}</h3>
            <div class="mnav-links">
              {item.children.map((child) => (
                <a href={child.href} class:list={['mnav-link', { active: isActive(child.href) }]}
                  {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
                  <span class="mnav-link-icon" aria-hidden="true" set:html={icons[child.icon || '']} />
                  <span class="mnav-link-inner">
                    <span class="mnav-link-label">{child.label}</span>
                    {child.desc && <span class="mnav-link-desc">{child.desc}</span>}
                  </span>
                  {child.external && (
                    <svg class="mnav-ext" width="14" height="14" viewBox="0 0 14 14" fill="none" role="img" aria-label="Opens in new tab">
                      <path d="M5.25 2H2V12H12V8.75M8.5 2H12M12 2V5.5M12 2L6.5 7.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  )}
                </a>
              ))}
            </div>
          </>
        ) : (
          <div class="mnav-links" style="padding-top:4px;">
            <a href={item.href} class="mnav-link"
              {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
              <span class="mnav-link-icon" aria-hidden="true" set:html={icons['store']} />
              <span class="mnav-link-inner">
                <span class="mnav-link-label">{item.label}</span>
              </span>
              {item.external && (
                <svg class="mnav-ext" width="14" height="14" viewBox="0 0 14 14" fill="none" role="img" aria-label="Opens in new tab">
                  <path d="M5.25 2H2V12H12V8.75M8.5 2H12M12 2V5.5M12 2L6.5 7.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
            </a>
          </div>
        )}
      </div>
    ))}
  </div>
</div>

<script>
document.addEventListener('astro:page-load', function () {
  /* Abort previous listeners to prevent stacking across View Transitions */
  if (window.__headerAC) window.__headerAC.abort();
  var ac = new AbortController();
  window.__headerAC = ac;
  var sig = ac.signal;

  var header = document.getElementById('site-header');
  var desktopNav = document.getElementById('desktop-nav');
  var indicator = document.getElementById('nav-indicator');
  var morphEl = document.getElementById('dd-morph');
  var morphArrow = morphEl ? morphEl.querySelector('.dd-morph-arrow') : null;
  var navItems = document.querySelectorAll('.nav-item[data-nav-group]');
  var navButtons = document.querySelectorAll('.nav-item > button');
  if (!header) return;

  /* ═══════ UPDATE ACTIVE STATES (for transition:persist) ═══════ */
  /* Since the header DOM persists across navigations, build-time
     active classes become stale. Re-compute them from the URL. */
  (function updateActiveStates() {
    var path = window.location.pathname;
    /* Desktop nav */
    navItems.forEach(function (item) {
      var links = item.querySelectorAll('.dd-link');
      var directLink = item.querySelector(':scope > a.nav-link');
      var btn = item.querySelector(':scope > button.nav-link');
      var groupActive = false;

      links.forEach(function (a) {
        var href = a.getAttribute('href');
        var isActive = href === path;
        a.classList.toggle('active', isActive);
        if (isActive) groupActive = true;
      });

      if (directLink) {
        var isActive = directLink.getAttribute('href') === path;
        directLink.classList.toggle('parent-active', isActive);
        item.classList.toggle('group-active', isActive);
      } else {
        item.classList.toggle('group-active', groupActive);
        if (btn) btn.classList.toggle('parent-active', groupActive);
      }
    });

    /* Mobile nav */
    document.querySelectorAll('.mnav-link').forEach(function (a) {
      var href = a.getAttribute('href');
      a.classList.toggle('active', href === path);
    });
  })();

  /* ═══════ DESKTOP DROPDOWNS — Morphing Container ═══════ */
  var activeGroup = -1;
  var morphSeq = 0;
  var closeTimer = null;

  function getDDLinks(item) {
    var dd = item.querySelector('.dropdown');
    return dd ? Array.from(dd.querySelectorAll('.dd-link')) : [];
  }

  function activateItem(item) {
    var btn = item.querySelector('button');
    if (btn) btn.setAttribute('aria-expanded', 'true');
    item.classList.add('dd-open');
  }

  function positionMorph(item, isEntrance) {
    if (!morphEl || !morphArrow || !desktopNav) return;
    var panel = item.querySelector('.dropdown-panel');
    if (!panel) return;
    var navRect = desktopNav.getBoundingClientRect();
    var panelRect = panel.getBoundingClientRect();
    var btn = item.querySelector('button');
    var btnRect = btn.getBoundingClientRect();

    var left = panelRect.left - navRect.left;
    var top = panelRect.top - navRect.top;
    var width = panelRect.width;
    var height = panelRect.height;
    var arrowX = (btnRect.left + btnRect.width / 2) - panelRect.left;

    if (isEntrance) {
      morphEl.style.transition = 'none';
      morphEl.style.left = left + 'px';
      morphEl.style.top = top + 'px';
      morphEl.style.width = width + 'px';
      morphEl.style.height = height + 'px';
      morphArrow.style.transition = 'none';
      morphArrow.style.left = arrowX + 'px';
      morphEl.offsetHeight;
      morphEl.style.transition = '';
      morphArrow.style.transition = '';
      morphEl.classList.add('morph-open');
    } else {
      morphEl.style.left = left + 'px';
      morphEl.style.top = top + 'px';
      morphEl.style.width = width + 'px';
      morphEl.style.height = height + 'px';
      morphArrow.style.left = arrowX + 'px';
    }
  }

  function openDD(item) {
    var gi = parseInt(item.dataset.navGroup);
    if (gi === activeGroup) return;
    var prev = activeGroup;
    activeGroup = gi;
    morphSeq++;
    var seq = morphSeq;

    if (prev >= 0) {
      var prevItem = navItems[prev];
      var prevBtn = prevItem.querySelector('button');
      if (prevBtn) prevBtn.setAttribute('aria-expanded', 'false');
      prevItem.classList.remove('dd-open');
    }

    var isEntrance = prev < 0;
    positionMorph(item, isEntrance);

    var delay = isEntrance ? 0 : 50;
    if (delay === 0) {
      activateItem(item);
    } else {
      setTimeout(function () {
        if (morphSeq !== seq) return;
        activateItem(item);
      }, delay);
    }
  }

  function closeDD(item) {
    var gi = parseInt(item.dataset.navGroup);
    var btn = item.querySelector('button');
    if (btn) btn.setAttribute('aria-expanded', 'false');
