          </div>

          <!-- Overflow photos (hidden by default) -->
          {overflowGalleryPhotos.length > 0 && (
            <div class="gallery__overflow" id="gallery-overflow" hidden>
              {overflowGalleryPhotos.map((photo, i) => {
                const globalIndex = 8 + i;
                const altText = photo.alt || `${kid.name}'s room transformation photo ${globalIndex + 1}`;
                return (
                  <button
                    class="masonry__item gallery__cell"
                    data-index={globalIndex}
                    data-src={cfUrl(photo.url, 'w=1600,q=85')}
                    data-srcset={_cfSrcset(photo.url, [800, 1200, 1600, 2400])}
                    data-alt={altText}
                    aria-label={`View photo ${globalIndex + 1} of ${galleryPhotos.length}`}
                    type="button"
                    style={`--lqip: url('${lqip(photo.url)}'); --stagger: ${globalIndex}`}
                  >
                    <img
                      src={cfUrl(photo.url, 'w=700,q=85')}
                      srcset={cfSrcset(photo.url, [400, 600, 900])}
                      sizes="(max-width: 768px) 46vw, (max-width: 1100px) 30vw, 280px"
                      alt={altText}
                      class="gallery__img lqip-img"
                      loading="lazy"
                      decoding="async"
                      width={dims(photo.url)[0]}
                      height={dims(photo.url)[1]}
                    />
                    <div class="gallery__overlay">
                      <span class="gallery__counter">{globalIndex + 1}/{galleryPhotos.length}</span>
                    </div>
                  </button>
                );
              })}
            </div>
          )}

          {showExpandButton && (
            <div class="gallery__expand-wrap">
              <button class="gallery__show-all" id="gallery-expand" type="button">
                Show all {galleryPhotos.length} photos
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
              </button>
            </div>
          )}
        </div>
      </section>
    )}

    <!-- ═══ The Village — Partners ═══ -->
    {kid.partnerLogos && kid.partnerLogos.length > 0 && (
      <section class="village">
        <div class="container container--narrow">
          <div class="village__inner">
            <p class="village__label">Made possible by</p>
            <div class="village__logos">
              {kid.partnerLogos.map(logo => (
                <div class="village__logo">
                  <img
                    src={cfUrl(logo.url, 'w=200,q=85')}
                    alt={logo.name || 'Project partner'}
                    loading="lazy"
                    decoding="async"
                    width="120"
                    height="60"
                  />
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- ═══ More Stories ═══ -->
    {relatedKids && relatedKids.length > 0 && (
      <section class="related">
        <div class="container">
          <h2 class="related__title">More Stories</h2>
          <div class="related__grid">
            {relatedKids.map((rk) => (
              <a href={`/kids/${rk.slug}/`} class="related__card">
                <div class="related__frame" style={`--lqip: url('${lqip(rk.heroImage)}')`}>
                  <img
                    src={cfUrl(rk.heroImage, 'w=340,h=453,fit=cover,gravity=face,q=80')}
                    srcset={_cfSrcset(rk.heroImage, [180, 260, 380], { fit: 'cover', gravity: 'face', aspectRatio: 4/3 })}
                    sizes="(max-width: 600px) calc(50vw - 24px), 240px"
                    alt={`Photo of ${rk.name}`}
                    class="related__img lqip-img"
                    loading="lazy"
                    decoding="async"
                    width="340"
                    height="453"
                  />
                </div>
                <div class="related__info">
                  <span class="related__name">{rk.name}</span>
