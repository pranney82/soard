---
import BaseLayout from '../layouts/BaseLayout.astro';
const partners = {
  construction: [
    { name: 'CR Construction', initials: 'CR', desc: 'General contracting, framing, and finish carpentry for every room build.' },
    { name: 'Randall Paulson', initials: 'RP', desc: 'Electrical, plumbing, and specialty construction for accessible rooms.' },
    { name: 'Stag Partners', initials: 'SP', desc: 'Project management and on-site coordination for complex builds.' },
    { name: 'Real Floors Commercial', initials: 'RF', desc: 'Commercial-grade flooring for accessible and sensory-friendly rooms.' },
  ],
  design: [
    { name: 'Crosby Design Group', initials: 'CD', desc: 'Room concepts, palettes, furniture, and styling for each child\'s dream.' },
    { name: 'WYP', initials: 'WYP', desc: 'Accessibility consulting and adaptive design solutions.' },
  ],
  community: [
    { name: 'Gas South', initials: 'GS', desc: 'Major corporate sponsor providing funding for multiple room projects.' },
    { name: 'Kids R Kids', initials: 'KRK', desc: 'Community fundraising partner supporting children\'s spaces.' },
    { name: 'Jackson Healthcare', initials: 'JH', desc: 'Healthcare industry partner supporting accessible room builds.' },
    { name: 'MSI', initials: 'MSI', desc: 'Materials and surface solutions for beautiful, durable finishes.' },
    { name: 'Cambria', initials: 'C', desc: 'Premium surface materials for bathroom and room projects.' },
    { name: 'Mohawk', initials: 'M', desc: 'Flooring materials for accessible and sensory-friendly builds.' },
  ]
};
---
<BaseLayout title="Partners" description="Meet the construction, design, and community partners who donate time, skills, and materials to build dream rooms for children with special needs.">

  <section class="page-hero">
    <div class="container">
      <div class="section-label" style="color:var(--c-yellow)">Our Partners</div>
      <h1>Built by <em>community</em></h1>
      <p class="page-hero-sub">Every room is a community effort. These incredible partners donate time, expertise, and materials to create spaces that transform lives.</p>
    </div>
  </section>

  <section class="partner-section">
    <div class="container">
      <div class="pgroup">
        <div class="pgroup-header" data-reveal>
          <div class="section-label">Construction Partners</div>
          <h2>The builders behind every <em class="highlight">transformation</em></h2>
        </div>
        <div class="pgrid">{partners.construction.map((p, i) => (
          <div class="pcard card" data-reveal data-delay={String(i % 3)}>
            <div class="pcard-logo"><div class="photo-placeholder photo-placeholder--warm" style="width:64px;height:64px;border-radius:16px;font-size:12px;"><span style="font-size:20px;font-weight:700;opacity:1;">{p.initials}</span></div></div>
            <h3>{p.name}</h3>
            <p>{p.desc}</p>
          </div>
        ))}</div>
      </div>

      <div class="pgroup">
        <div class="pgroup-header" data-reveal>
          <div class="section-label">Design Partners</div>
          <h2>The creatives who make rooms <em class="highlight">magical</em></h2>
        </div>
        <div class="pgrid">{partners.design.map((p, i) => (
          <div class="pcard card" data-reveal data-delay={String(i % 3)}>
            <div class="pcard-logo"><div class="photo-placeholder photo-placeholder--purple" style="width:64px;height:64px;border-radius:16px;font-size:12px;"><span style="font-size:20px;font-weight:700;opacity:1;">{p.initials}</span></div></div>
            <h3>{p.name}</h3>
            <p>{p.desc}</p>
          </div>
        ))}</div>
      </div>

      <div class="pgroup">
        <div class="pgroup-header" data-reveal>
          <div class="section-label">Community & Material Partners</div>
          <h2>The supporters behind <em class="highlight">every room</em></h2>
        </div>
        <div class="pgrid">{partners.community.map((p, i) => (
          <div class="pcard card" data-reveal data-delay={String(i % 3)}>
            <div class="pcard-logo"><div class="photo-placeholder photo-placeholder--cool" style="width:64px;height:64px;border-radius:16px;font-size:12px;"><span style="font-size:20px;font-weight:700;opacity:1;">{p.initials}</span></div></div>
            <h3>{p.name}</h3>
            <p>{p.desc}</p>
          </div>
        ))}</div>
      </div>
    </div>
  </section>

  <section class="become-partner">
    <div class="become-inner">
      <h2 data-reveal>Want to build dreams <em class="highlight">with us</em>?</h2>
      <p data-reveal data-delay="1">We're always looking for skilled professionals and businesses who want to make a tangible difference in children's lives.</p>
      <a href="/get-involved" class="btn btn-primary" data-reveal data-delay="2">Become a Partner →</a>
    </div>
  </section>

</BaseLayout>

<style>
  .partner-section{padding:var(--section-padding);}
  .pgroup{margin-bottom:80px;}
  .pgroup:last-child{margin-bottom:0;}
  .pgroup-header{margin-bottom:40px;}
  .pgroup-header h2 em{font-style:italic;}
  .pgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:24px;}
  .pcard{padding:36px;}
  .pcard-logo{margin-bottom:20px;}
  .pcard h3{font-family:var(--f-body);font-size:17px;margin-bottom:8px;}
  .pcard p{font-size:15px;line-height:1.65;}
  .become-partner{padding:100px 0;background:var(--c-yellow);text-align:center;}
  .become-inner{max-width:560px;margin:0 auto;padding:0 var(--page-padding);}
  .become-partner h2{margin-bottom:16px;}
  .become-partner h2 em{font-style:italic;}
  .become-partner p{font-size:17px;color:rgba(45,46,51,0.65);margin-bottom:32px;}

  [data-reveal]{opacity:0;transform:translateY(32px);transition:opacity 0.7s cubic-bezier(0.16,1,0.3,1),transform 0.7s cubic-bezier(0.16,1,0.3,1);}
  [data-reveal].is-visible{opacity:1;transform:translateY(0);}
  [data-delay="1"]{transition-delay:0.1s;}[data-delay="2"]{transition-delay:0.2s;}
</style>
<script>const obs=new IntersectionObserver(e=>e.forEach(n=>{if(n.isIntersecting)n.target.classList.add('is-visible')}),{threshold:0.15,rootMargin:'0px 0px -40px 0px'});document.querySelectorAll('[data-reveal]').forEach(e=>obs.observe(e));</script>
