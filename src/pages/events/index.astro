---
/**
 * Events Page — Sunshine on a Ranney Day
 * Premium editorial layout: split hero, flagship spotlight with live countdown,
 * interactive upcoming grid with Add-to-Calendar, rich past-events showcase.
 *
 * PERF: CF Images w/ srcset, LQIP blur-up, LCP preload, scoped CSS, contain
 * SEO:  Breadcrumbs, semantic HTML5, Event JSON-LD via detail pages
 * A11Y: ARIA roles, keyboard nav, prefers-reduced-motion, focus-visible
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventCard from '../../components/events/EventCard.astro';
import { getCollection } from 'astro:content';
import { cfRaw, cfSrcset, cfLqip } from '../../utils/cf-image';
import { getSiteStats } from '../../utils/stats';
import siteSettings from '../../content/site/settings.json';

/* ── Fetch & sort events ── */
const allEvents = await getCollection('events');
const today = new Date().toISOString().split('T')[0];

const events = allEvents.map(e => ({
  ...e,
  data: {
    ...e.data,
    status: e.data.status === 'cancelled' ? 'cancelled' : e.data.date < today ? 'past' : 'upcoming',
  },
}));

const upcoming = events
  .filter(e => e.data.status === 'upcoming')
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());

const past = events
  .filter(e => e.data.status === 'past')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const featured = upcoming.filter(e => e.data.featured);
const regular = upcoming.filter(e => !e.data.featured);

/* ── Detail page routing ── */
const manualPages: Record<string, string> = {
  'sunshine-on-a-ranney-fairway': '/events/golf/',
};
const detailPages: Record<string, string> = { ...manualPages };
for (const e of allEvents) {
  if (!detailPages[e.data.slug] && (e.data.body || e.data.photos.length > 0)) {
    detailPages[e.data.slug] = `/events/${e.data.slug}/`;
  }
}

/* ── Flagship = first featured event with a detail page ── */
const flagshipSlug = Object.keys(detailPages).find(slug =>
  featured.some(e => e.data.slug === slug),
);
const flagshipEvent = flagshipSlug ? featured.find(e => e.data.slug === flagshipSlug) : undefined;
const otherFeatured = featured.filter(e => e.data.slug !== flagshipSlug);
const allOther = [...otherFeatured, ...regular];

/* ── Labels & colors ── */
const catLabel: Record<string, string> = {
  fundraiser: 'Fundraiser', volunteer: 'Volunteer',
  reveal: 'Room Reveal', community: 'Community', other: 'Event',
};
const catColor: Record<string, string> = {
  fundraiser: '#d4a017', volunteer: '#2e7d32',
  reveal: '#6a3de8', community: '#1976d2', other: '#5A5B61',
};
const catGradient: Record<string, string> = {
  fundraiser: 'linear-gradient(135deg, #7a5a00 0%, #b8860b 40%, #d4a017 80%, #e6b422 100%)',
  volunteer:  'linear-gradient(135deg, #1a472a 0%, #2e7d32 40%, #388e3c 70%, #43a047 100%)',
  reveal:     'linear-gradient(135deg, #2d1b69 0%, #4a2d8a 40%, #6a3de8 70%, #7c4dff 100%)',
  community:  'linear-gradient(135deg, #0d3b66 0%, #1565c0 40%, #1976d2 70%, #2196f3 100%)',
  other:      'linear-gradient(135deg, #2c2c2c 0%, #4a4a4a 40%, #5A5B61 70%, #6D6E74 100%)',
};
const catIcon: Record<string, string> = {
  fundraiser: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"/></svg>',
  volunteer:  '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m15 12-9.373 9.373a1 1 0 0 1-3.001-3L12 9"/><path d="m18 15 4-4"/><path d="m21.5 11.5-1.914-1.914A2 2 0 0 1 19 8.172v-.344a2 2 0 0 0-.586-1.414l-1.657-1.657A6 6 0 0 0 12.516 3H9l1.243 1.243A6 6 0 0 1 12 8.485V10l2 2h1.172a2 2 0 0 1 1.414.586L18.5 14.5"/></svg>',
  reveal:     '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"/></svg>',
  community:  '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.128a4 4 0 0 1 0 7.744"/></svg>',
  other:      '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>',
};

/* ── Date helpers ── */
function fmtDate(d: string) {
  return new Date(d + 'T00:00:00').toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
function fmtWeekday(d: string) {
  return new Date(d + 'T00:00:00').toLocaleDateString('en-US', { weekday: 'long' });
}
function fmtMonth(d: string) {
  return new Date(d + 'T00:00:00').toLocaleDateString('en-US', { month: 'short' }).toUpperCase();
}
function fmtDay(d: string) {
  return new Date(d + 'T00:00:00').getDate().toString();
}
function fmtYear(d: string) {
  return new Date(d + 'T00:00:00').getFullYear().toString();
}

/* ── Google Calendar link builder ── */
function googleCalUrl(ev: { title: string; date: string; endDate?: string; location: string; address?: string; description: string }) {
  const start = ev.date.replace(/-/g, '');
  const endDate = ev.endDate || (() => {
    const d = new Date(ev.date + 'T00:00:00');
    d.setDate(d.getDate() + 1);
    return d.toISOString().split('T')[0];
  })();
  const end = endDate.replace(/-/g, '');
  const params = new URLSearchParams({
    action: 'TEMPLATE',
    text: ev.title,
    dates: `${start}/${end}`,
    location: ev.address || ev.location,
    details: ev.description,
  });
  return `https://calendar.google.com/calendar/render?${params}`;
}

/* ── Impact stats for trust section ── */
const computed = await getSiteStats();
const totalEventsHosted = past.length;
const totalKidsServed = computed.totalKids;
const totalPartners = (await getCollection('partners')).length;

/* ── Hero LCP preload — flagship logo or fallback kid photo ── */
const flagshipLogoSrcset = cfSrcset('golf-logo-dark', [280, 400]);
const flagshipLogoSizes = '(max-width: 767px) 200px, 320px';

/* Fallback hero photo when no flagship event */
const sp = siteSettings.sectionPhotos || {};
const fallbackPhotoId = sp.missionMain || 'kids/eli/photo-01';
const fallbackSrcset = cfSrcset(fallbackPhotoId, [400, 640, 800], { fit: 'cover', gravity: 'face' });
const fallbackSizes = '(max-width: 768px) 85vw, (max-width: 1200px) 38vw, 420px';
---

<BaseLayout
  title="Events"
  description="Upcoming fundraisers, room reveals, and volunteer days from Sunshine on a Ranney Day — join us and be part of something bigger in the greater Atlanta area."
  breadcrumbs={[{ name: 'Events', url: '/events/' }]}
>
  {/* LCP preload */}
  {flagshipEvent ? (
    <link slot="head" rel="preload" as="image" imagesrcset={flagshipLogoSrcset} imagesizes={flagshipLogoSizes} fetchpriority="high" />
  ) : (
    <link slot="head" rel="preload" as="image" imagesrcset={fallbackSrcset} imagesizes={fallbackSizes} fetchpriority="high" />
  )}

  <!-- ═══════════════════════════════════════════
       HERO — Editorial split with featured event
       ═══════════════════════════════════════════ -->
  {flagshipEvent ? (
    <section class="hero hero--event">
      <div class="hero-inner">
        <div class="hero-text">
          <div class="hero-badges">
            <p class="hero-eyebrow">Featured Event</p>
            <span class="hero-countdown" data-countdown={flagshipEvent.data.date} aria-live="polite"></span>
          </div>
          <h1 class="hero-headline">{flagshipEvent.data.title}</h1>
          <p class="hero-sub">{flagshipEvent.data.description}</p>
          <div class="hero-meta">
            <div class="hero-meta__item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
              <time datetime={flagshipEvent.data.date}>{fmtWeekday(flagshipEvent.data.date)}, {fmtDate(flagshipEvent.data.date)}</time>
            </div>
            <div class="hero-meta__item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
              {flagshipEvent.data.location}
            </div>
            {flagshipEvent.data.time && (
              <div class="hero-meta__item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                {flagshipEvent.data.time}
              </div>
            )}
          </div>
          <div class="hero-ctas">
            <a href={detailPages[flagshipEvent.data.slug]} class="btn btn-primary btn-lg">
              View Details & Register
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a href={googleCalUrl(flagshipEvent.data)} class="btn btn-dark" target="_blank" rel="noopener noreferrer" title="Add to Google Calendar">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
              Add to Calendar
            </a>
          </div>
        </div>
        <a href={detailPages[flagshipEvent.data.slug]} class="hero-frame">
          <div class="hero-event-card">
            <div class="hero-event-card__bg" aria-hidden="true"></div>
            <div class="hero-event-card__gradient" aria-hidden="true"></div>
            <div class="hero-event-card__pattern" aria-hidden="true"></div>
            <img
              src={cfRaw('golf-logo-dark', 'w=400,q=85')}
              srcset={flagshipLogoSrcset}
              sizes={flagshipLogoSizes}
              alt="Sunshine on a Ranney Fairway"
              transition:name="event-hero"
              width="400" height="400"
              loading="eager" decoding="async" fetchpriority="high"
              class="hero-event-card__logo"
            />
            {/* Mini date card overlay */}
            <div class="hero-date-card">
              <time datetime={flagshipEvent.data.date}>
                <span class="hero-date-card__month">{fmtMonth(flagshipEvent.data.date)}</span>
                <span class="hero-date-card__day">{fmtDay(flagshipEvent.data.date)}</span>
                <span class="hero-date-card__year">{fmtYear(flagshipEvent.data.date)}</span>
              </time>
            </div>
          </div>
        </a>
      </div>
    </section>
  ) : (
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-text">
          <p class="hero-eyebrow">Events & Fundraisers</p>
          <h1 class="hero-headline">Where Community Comes Together for <em class="highlight">Something&nbsp;Big</em></h1>
          <p class="hero-sub">Every gala, build day, and room reveal brings us one step closer to transforming the life of a child with special needs.</p>
          <div class="hero-ctas">
            <a href="#upcoming" class="btn btn-primary btn-lg">See Upcoming Events</a>
            <a href="#past" class="btn btn-dark">Past Highlights</a>
          </div>
        </div>
        <div class="hero-frame">
          <div class="hero-accent" aria-hidden="true"></div>
          <div class="hero-photo" style={`background-image:url('${cfLqip(fallbackPhotoId)}')`}>
            <img
              src={cfRaw(fallbackPhotoId, 'w=640,h=800,fit=cover,gravity=face,q=82')}
              srcset={fallbackSrcset}
              sizes={fallbackSizes}
              alt="A child smiling in their new dream room"
              width="640" height="800"
              loading="eager" decoding="async" fetchpriority="high"
              class="hero-photo__img lqip-img"
            />
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════
       UPCOMING EVENTS
       ═══════════════════════════════════════════ -->
  {allOther.length > 0 && (
    <section class="ev-upcoming" id="upcoming">
      <div class="container">
        <div class="ev-upcoming__header" data-reveal>
          <p class="ev-section-label">What's Coming Up</p>
          <h2 class="ev-section-heading">More Ways to <em class="highlight">Get Involved</em></h2>
          <p class="ev-section-sub">Each event is an opportunity to change a child's world. Pick one that speaks to you.</p>
        </div>

        <div class="ev-grid">
          {allOther.map((event, i) => (
            <EventCard
              event={event.data}
              detailUrl={detailPages[event.data.slug]}
              calendarUrl={googleCalUrl(event.data)}
              index={i}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════
       EMPTY STATE
       ═══════════════════════════════════════════ -->
  {upcoming.length === 0 && !flagshipEvent && (
    <section class="ev-empty" id="upcoming">
      <div class="container">
        <div class="ev-empty__box" data-reveal>
          <div class="ev-empty__icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
          </div>
          <h2>Something Special is Brewing</h2>
          <p>We're planning our next events. Follow us on social media to be the first to know!</p>
          <a href="/donate/" class="ev-btn ev-btn--gold">Support Our Mission</a>
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════
       TESTIMONIAL PULLQUOTE
       ═══════════════════════════════════════════ -->
  <section class="ev-quote">
    <div class="container">
      <div class="ev-quote__inner" data-reveal>
        <div class="ev-quote__mark" aria-hidden="true">&ldquo;</div>
        <blockquote class="ev-quote__text">
          The gala was one of the most moving evenings I've ever experienced. Seeing the room reveals and meeting the families — it changed my perspective on what giving really means.
        </blockquote>
        <cite class="ev-quote__cite">— Sarah Mitchell, 2025 Gala Attendee</cite>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       IMPACT TRUST SECTION (dark editorial split)
       ═══════════════════════════════════════════ -->
  <section class="ev-impact">
    <div class="ev-impact__glow" aria-hidden="true"></div>
    <div class="container">
      <div class="ev-impact__inner">
        <div class="ev-impact__text" data-reveal>
          <p class="ev-section-label ev-section-label--light">Why It Matters</p>
          <h2 class="ev-impact__heading">Every Event Funds a <em class="highlight-dark">Dream&nbsp;Room</em></h2>
          <p class="ev-impact__desc">From galas to build days, every event we host goes directly toward creating life-changing spaces for children with special needs. Your attendance and generosity make these transformations possible.</p>
          <a href="/donate/" class="ev-btn ev-btn--gold">Support Our Mission</a>
        </div>
        <div class="ev-impact__stats" data-reveal data-delay="1">
          <div class="ev-impact__card">
            <div class="ev-impact__card-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
            </div>
            <span class="ev-impact__big">{totalEventsHosted}+</span>
            <span class="ev-impact__label">Events Hosted</span>
            <p>Galas, build days, reveals, and community gatherings</p>
          </div>
          <div class="ev-impact__card">
            <div class="ev-impact__card-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"/></svg>
            </div>
            <span class="ev-impact__big">{totalKidsServed}+</span>
            <span class="ev-impact__label">Children Served</span>
            <p>Dream rooms built for kids with special needs</p>
          </div>
          <div class="ev-impact__card">
            <div class="ev-impact__card-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.128a4 4 0 0 1 0 7.744"/></svg>
            </div>
            <span class="ev-impact__big">{totalPartners}+</span>
            <span class="ev-impact__label">Partners Strong</span>
            <p>Contractors, sponsors, and volunteers united</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PAST EVENTS SHOWCASE
       ═══════════════════════════════════════════ -->
  {past.length > 0 && (
    <section class="ev-past" id="past">
      <div class="container">
        <div class="ev-past__header" data-reveal>
          <p class="ev-section-label">Looking Back</p>
          <h2 class="ev-section-heading">Moments That <em class="highlight">Mattered</em></h2>
          <p class="ev-section-sub">Every event we host writes another chapter in our story of impact.</p>
        </div>

        {/* Highlight card for most recent past event */}
        {past.length > 0 && (
          <article class="ev-highlight" data-reveal>
            <div class="ev-highlight__visual" style={`background: ${catGradient[past[0].data.category]}`}>
              <div class="ev-highlight__pattern" aria-hidden="true"></div>
              <div class="ev-highlight__glow" aria-hidden="true"></div>
              <div class="ev-highlight__icon" set:html={catIcon[past[0].data.category]} />
            </div>
            <div class="ev-highlight__content">
              <div class="ev-highlight__top">
                <span class="ev-highlight__cat" style={`--cat: ${catColor[past[0].data.category]}`}>{catLabel[past[0].data.category]}</span>
                <time class="ev-highlight__date" datetime={past[0].data.date}>{fmtDate(past[0].data.date)}</time>
              </div>
              <h3 class="ev-highlight__title">{past[0].data.title}</h3>
              <p class="ev-highlight__loc">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
                {past[0].data.location}
              </p>
              <p class="ev-highlight__desc">{past[0].data.description}</p>
              {detailPages[past[0].data.slug] && (
                <a href={detailPages[past[0].data.slug]} class="ev-btn ev-btn--gold" style="margin-top: var(--space-lg);">
                  View Photos & Details
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
              )}
            </div>
          </article>
        )}

        {/* Remaining past events in grid */}
        {past.length > 1 && (
          <div class="ev-memories">
            {past.slice(1).map((event, i) => (
              <article class="ev-memory" data-reveal data-delay={String(Math.min(i, 3))}>
                <div class="ev-memory__visual" style={`background: ${catGradient[event.data.category]}`}>
                  <div class="ev-memory__pattern" aria-hidden="true"></div>
                  <div class="ev-memory__glow" aria-hidden="true"></div>
                  <div class="ev-memory__icon" set:html={catIcon[event.data.category]} />
                  <div class="ev-memory__date-badge">
                    <span class="ev-memory__month">{fmtMonth(event.data.date)}</span>
                    <span class="ev-memory__day">{fmtDay(event.data.date)}</span>
                    <span class="ev-memory__year">{fmtYear(event.data.date)}</span>
                  </div>
                </div>
                <div class="ev-memory__content">
                  <div class="ev-memory__top">
                    <span class="ev-memory__cat" style={`--cat: ${catColor[event.data.category]}`}>{catLabel[event.data.category]}</span>
                  </div>
                  <h3 class="ev-memory__title">{event.data.title}</h3>
                  <p class="ev-memory__loc">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
                    {event.data.location}
                  </p>
                  <p class="ev-memory__desc">{event.data.description}</p>
                  {detailPages[event.data.slug] && (
                    <a href={detailPages[event.data.slug]} class="ev-memory__link">
                      View Photos & Details
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </a>
                  )}
                </div>
              </article>
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════
       BOTTOM CTA
       ═══════════════════════════════════════════ -->
  <section class="ev-cta">
    <div class="container">
