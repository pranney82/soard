---
/**
 * CFImage.astro
 * Responsive image component with automatic srcset generation.
 * - Cloudflare Images: generates <picture> with AVIF/WebP srcset
 * - Other URLs: renders a plain optimized <img>
 */
interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
  style?: string;
  /** Override default responsive widths (px) */
  widths?: number[];
  /** Quality 1-100 for CF transforms */
  quality?: number;
}

const {
  src,
  alt,
  width,
  height,
  sizes = '(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw',
  loading = 'lazy',
  fetchpriority,
  class: className = '',
  style = '',
  widths = [400, 640, 800, 1024, 1600],
  quality = 80,
} = Astro.props;

const isCFImage = src.includes('imagedelivery.net');

/**
 * For CF Images URLs like:
 *   https://imagedelivery.net/HASH/IMAGE_ID/w=800,q=80
 * We extract the base (everything before the last slash) and generate
 * srcset entries with width + format transforms.
 */
function cfSrcset(format: 'avif' | 'webp'): string {
  // Strip any existing transform suffix to get the base path
  // CF Images URL: https://imagedelivery.net/HASH/IMAGE_ID/transforms
  const lastSlash = src.lastIndexOf('/');
  const base = src.substring(0, lastSlash);
  return widths.map(w => `${base}/w=${w},f=${format},q=${quality} ${w}w`).join(', ');
}

function cfFallbackSrc(): string {
  const lastSlash = src.lastIndexOf('/');
  const base = src.substring(0, lastSlash);
  // Use the second-largest width as default fallback
  const fallbackW = widths[widths.length - 2] || widths[widths.length - 1];
  return `${base}/w=${fallbackW},q=${quality}`;
}
---

{isCFImage ? (
  <picture>
    <source type="image/avif" srcset={cfSrcset('avif')} sizes={sizes} />
    <source type="image/webp" srcset={cfSrcset('webp')} sizes={sizes} />
    <img
      src={cfFallbackSrc()}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      decoding="async"
      fetchpriority={fetchpriority}
      class:list={['cf-image', className]}
      style={style}
    />
  </picture>
) : (
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    sizes={sizes}
    loading={loading}
    decoding="async"
    fetchpriority={fetchpriority}
    class:list={['cf-image', className]}
    style={style}
  />
)}

<style>
  .cf-image {
    display: block;
    max-width: 100%;
    height: auto;
    object-fit: cover;
  }
</style>
