  @keyframes shimmer { 0%,100% { transform: translateX(-30%); } 50% { transform: translateX(30%); } }
  .header-cta:hover { transform: translateY(-1px) scale(1.03); box-shadow: 0 6px 24px var(--c-yellow-glow); }
  .header-cta:active { transform: translateY(0) scale(0.98); }
