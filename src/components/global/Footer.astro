---
/**
 * Footer.astro — Best-in-class nonprofit footer
 *
 * Structure:
 *   1. Newsletter CTA band (warm gray)
 *   2. Main footer: logo + mission, nav columns, social, donate CTA (dark)
 *   3. Trust signals bar: GuideStar, 501(c)(3), EIN (dark-deep)
 *   4. Legal bar: copyright, privacy, terms (dark-deep, bottom)
 *
 * Accessibility: All links have descriptive text, external links marked,
 *   social icons have aria-labels, skip-to-footer landmark
 * SEO: address in <address> tag, tel: and mailto: links, external rels
 * Performance: SVG social icons inline (no external requests)
 */
import site from '../../content/site/settings.json';
import { cfRaw, cfSrcset } from '../../utils/cf-image';

const FOOTER_LOGO_ID = 'brand-logo-dark-bg-tagline-display';
const year = new Date().getFullYear();
const { phone, email, address, social } = site;
const phoneDigits = phone.replace(/\D/g, '');
const fullAddress = `${address.street.replace(', Suite ', ', Ste ')}, ${address.city} ${address.state} ${address.zip}`;
const mapsUrl = `https://maps.google.com/?q=${encodeURIComponent(`${address.street}, ${address.city}, ${address.state} ${address.zip}`)}`;
---

<footer class="site-footer">

  <!-- ─── 1. NEWSLETTER BAND ─────────────────── -->
  <div class="footer-newsletter">
    <div class="footer-container footer-newsletter-inner">
      <div class="footer-newsletter-text">
        <h2><span class="highlight">Brighten your inbox</span> with a little Sunshine.</h2>
        <p>Room reveals, impact stories, and upcoming events — delivered monthly.</p>
      </div>
      <form class="newsletter-form" id="newsletter-form">
        <div class="newsletter-fields">
          <input
            type="email"
            name="email"
            placeholder="Your email address"
            required
            autocomplete="email"
            aria-label="Email address for newsletter"
            class="newsletter-input"
            id="newsletter-email"
          />
          <button type="submit" class="newsletter-btn" id="newsletter-btn">
            <span class="btn-text">Subscribe</span>
            <span class="btn-sending" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
            </span>
            <span class="btn-done" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
          </button>
        </div>
        <!-- Cloudflare Turnstile — invisible bot protection -->
        <div id="newsletter-turnstile" class="cf-turnstile" data-sitekey="0x4AAAAAAACpMJDcIPz2DI536" data-size="flexible" data-theme="dark"></div>
        <p class="newsletter-note" id="newsletter-note">No spam, ever. Unsubscribe anytime.</p>
      </form>
    </div>
  </div>

  <!-- ─── 2. MAIN FOOTER ─────────────────────── -->
  <div class="footer-main">
    <div class="footer-container footer-main-grid">

      <!-- Brand Block -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="Sunshine on a Ranney Day — Home">
          <img
              src={cfRaw(FOOTER_LOGO_ID, 'w=280,q=85')}
              srcset={cfSrcset(FOOTER_LOGO_ID, [140, 280])}
              sizes="140px"
              alt="Sunshine on a Ranney Day logo"
              width="140"
              height="140"
              loading="lazy"
            />
        </a>
        <p class="footer-mission">
          A 501(c)(3) nonprofit creating life-changing home makeovers for children with special needs in the greater Atlanta area.
        </p>

        <!-- Social Icons -->
        <div class="footer-social">
          {social.facebook && <a href={social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="footer-social-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>}
          {social.instagram && <a href={social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="footer-social-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>}
          {social.youtube && <a href={social.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="footer-social-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>}
          {social.tiktok && <a href={social.tiktok} target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="footer-social-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          </a>}
        </div>

        <!-- Donate CTA -->
        <a href="/donate/" class="footer-donate-btn">
          Make a Donation
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 2.5C6.5 1 4 1 2.75 2.75S2.5 6.5 8 11.5C13.5 6.5 13.75 4.5 13.25 2.75S9.5 1 8 2.5Z" fill="currentColor"/></svg>
        </a>
      </div>

      <!-- Nav Columns -->
      <nav class="footer-nav" aria-label="Footer navigation">
        <div class="footer-col">
          <h3 class="footer-heading">About</h3>
          <ul>
            <li><a href="/about/">Our Story</a></li>
            <li><a href="/about/leadership/">Leadership</a></li>
            <li><a href="/about/financials/">Financials</a></li>
            <li><a href="/publicity/">Press & Media</a></li>
            <li><a href="/branding/">Branding</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h3 class="footer-heading">Our Kids</h3>
          <ul>
            <li><a href="/kids/">Meet the Kids</a></li>
            <li><a href="/rooms/community/">Community Projects</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h3 class="footer-heading">Partners</h3>
          <ul>
            <li><a href="/partners/">All Partners</a></li>
            <li><a href="/partners/construction/">Construction</a></li>
            <li><a href="/partners/design/">Design</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h3 class="footer-heading">Get Involved</h3>
          <ul>
            <li><a href="/donate/">Donate</a></li>
            <li><a href="/apply/">Apply for a Room</a></li>
            <li><a href="/events/">Events</a></li>
            <li><a href="/shop/">Shop</a></li>
            <li><a href="/resources/">Resources</a></li>
            <li><a href="/faq/">FAQs</a></li>
          </ul>
        </div>
      </nav>
    </div>
  </div>

  <!-- ─── 3. TRUST SIGNALS BAR ────────────────── -->
  <div class="footer-trust">
    <div class="footer-container footer-trust-inner">
      <div class="footer-trust-badges">
        <a href="https://www.charitynavigator.org/ein/454773997"
           target="_blank" rel="noopener noreferrer" class="trust-badge" aria-label="View our Charity Navigator profile">
          <img
            src="https://cdn.charitynavigator.org/img/badges/three-star.svg"
            alt="Charity Navigator 3-Star Rating"
            width="64"
            height="64"
            loading="lazy"
            onerror="this.parentElement.style.display='none'"
          />
        </a>
        <a href="https://www.guidestar.org/profile/shared/2954b510-8c76-42e4-b589-7e826ca2cc47"
           target="_blank" rel="noopener noreferrer" class="trust-badge" aria-label="View our GuideStar Transparency profile">
          <img
            src="https://widgets.guidestar.org/TransparencySeal/9198660"
            alt="GuideStar Transparency Seal"
            width="64"
            height="64"
            loading="lazy"
            onerror="this.parentElement.style.display='none'"
          />
        </a>
        <div class="trust-badge trust-badge--text">
          <span class="trust-badge-label">Registered 501(c)(3)</span>
          <span class="trust-badge-value">EIN: 45-4773997</span>
        </div>
        <div class="trust-badge trust-badge--text">
          <span class="trust-badge-label">Tax-Deductible</span>
          <span class="trust-badge-value">100% of donations</span>
        </div>
        <a href="/financials/ga-contractor-license.pdf" target="_blank" rel="noopener noreferrer" class="trust-badge trust-badge--text" aria-label="View Georgia Contractor License">
          <span class="trust-badge-label">Licensed Contractor</span>
          <span class="trust-badge-value">State of Georgia</span>
        </a>
      </div>

      <address class="footer-contact">
        <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="footer-contact-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          {fullAddress}
        </a>
        <a href={`tel:+1${phoneDigits}`} class="footer-contact-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          {phone}
        </a>
        <a href={`mailto:${email}`} class="footer-contact-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          {email}
        </a>
      </address>
    </div>
  </div>

  <!-- ─── 4. LEGAL BAR ────────────────────────── -->
  <div class="footer-legal">
    <div class="footer-container footer-legal-inner">
      <p class="footer-copyright">
        &copy; {year} Sunshine on a Ranney Day. All rights reserved.
      </p>
      <div class="footer-legal-links">
        <a href="/privacy-policy/">Privacy Policy</a>
        <span aria-hidden="true">&middot;</span>
        <a href="/terms/">Terms of Use</a>
        <span aria-hidden="true">&middot;</span>
        <a href="/admin/" class="footer-admin-link">Admin</a>
      </div>
    </div>
  </div>
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <script>
    document.addEventListener('astro:page-load', () => {
      const form = document.getElementById('newsletter-form');
      if (!form) return;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('newsletter-btn');
        const input = document.getElementById('newsletter-email');
        const note = document.getElementById('newsletter-note');
        const email = input.value.trim();
        if (!email) return;

        // Get Turnstile token
        const turnstileInput = form.querySelector('[name="cf-turnstile-response"]');
        const turnstileToken = turnstileInput ? turnstileInput.value : '';

        // Sending state
        btn.classList.add('is-sending');
        btn.disabled = true;
        input.disabled = true;

        try {
          const res = await fetch('/api/newsletter', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, turnstileToken }),
          });
          const data = await res.json();

          btn.classList.remove('is-sending');

          if (data.ok) {
            btn.classList.add('is-done');
            input.value = '';
            note.textContent = "You're in! Welcome to the Sunshine family.";
            note.classList.add('newsletter-note--success');
          } else {
            note.textContent = data.error || 'Something went wrong. Please try again.';
            note.classList.add('newsletter-note--error');
            btn.disabled = false;
            input.disabled = false;
            // Reset Turnstile widget for retry
            if (window.turnstile) window.turnstile.reset('#newsletter-turnstile');
          }
        } catch {
          btn.classList.remove('is-sending');
          note.textContent = 'Something went wrong. Please try again.';
          note.classList.add('newsletter-note--error');
          btn.disabled = false;
          input.disabled = false;
          if (window.turnstile) window.turnstile.reset('#newsletter-turnstile');
        }
      });
    });
  </script>
</footer>

<style>
  /* ═══════════════════════════════════════════
     FOOTER — Best-in-class nonprofit
     ═══════════════════════════════════════════ */

  .site-footer { margin-top: auto; }

  .footer-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding-inline: var(--page-padding);
  }

  /* ─── Newsletter Band ──────────────────── */
  .footer-newsletter {
    background: var(--c-warm-gray);
    padding: 72px 0;
  }
  .footer-newsletter-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 48px;
  }
  .footer-newsletter-text {
    max-width: 420px;
    flex-shrink: 0;
  }
  .footer-newsletter-text h2 {
    font-size: clamp(1.4rem, 2.5vw, 1.75rem);
    line-height: 1.3;
    margin-bottom: 8px;
  }
  .footer-newsletter-text p {
    font-size: 15px;
    color: var(--c-text-muted);
  }
  .newsletter-form {
    flex: 1;
    max-width: 480px;
  }
  .newsletter-fields {
    display: flex;
    gap: 8px;
  }
  .newsletter-input {
    flex: 1;
    padding: 14px 20px;
    border: 2px solid var(--c-border);
    border-radius: 60px;
    background: var(--c-white);
    font-family: var(--font-body);
    font-size: 15px;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }
  .newsletter-input:focus {
    outline: none;
    border-color: var(--c-yellow);
    box-shadow: 0 0 0 3px rgba(255, 218, 36, 0.25);
  }
  .newsletter-input:focus-visible {
    outline: 3px solid var(--c-yellow);
    outline-offset: 2px;
    box-shadow: 0 0 0 5px rgba(255, 218, 36, 0.15);
  }
  .newsletter-btn {
    padding: 14px 28px;
    background: var(--c-yellow);
    color: var(--c-dark);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 15px;
    border: none;
    border-radius: 60px;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .newsletter-btn:hover {
    background: var(--c-yellow-hover);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px var(--c-yellow-glow);
  }
  .newsletter-note {
    font-size: 12px;
    color: var(--c-text-light);
    margin-top: 10px;
    padding-left: 20px;
    transition: color 0.3s ease;
  }
  .newsletter-note--success { color: #22c55e; }
  .newsletter-note--error { color: #ef4444; }

  /* Button states */
  .newsletter-btn { position: relative; }
  .btn-sending, .btn-done { display: none; }
  .newsletter-btn.is-sending .btn-text { display: none; }
  .newsletter-btn.is-sending .btn-sending {
    display: inline-flex;
    animation: nl-spin 0.8s linear infinite;
  }
  .newsletter-btn.is-done .btn-text { display: none; }
  .newsletter-btn.is-done .btn-done { display: inline-flex; }
  .newsletter-btn.is-done {
    background: #22c55e;
    color: white;
    pointer-events: none;
  }
  @keyframes nl-spin { to { transform: rotate(360deg); } }

  @media (max-width: 768px) {
    .footer-newsletter { padding: 56px 0; }
    .footer-newsletter-inner { flex-direction: column; gap: 28px; text-align: center; }
    .footer-newsletter-text { max-width: 100%; }
    .newsletter-form { max-width: 100%; width: 100%; }
    .newsletter-fields { flex-direction: column; }
    .newsletter-note { text-align: center; padding-left: 0; }
  }

  /* ─── Main Footer ──────────────────────── */
  .footer-main {
    background: var(--c-dark-deep);
    color: rgba(255, 255, 255, 0.75);
    padding: 72px 0 56px;
  }
  .footer-main-grid {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 64px;
  }

  /* Brand Block */
  .footer-brand { display: flex; flex-direction: column; gap: 20px; }
  .footer-logo {
    display: inline-block;
    transition: opacity var(--transition-fast);
    text-decoration: none;
  }
  .footer-logo:hover { opacity: 0.85; }
  .footer-logo img {
    display: block;
    width: 140px;
    height: auto;
    object-fit: contain;
  }
  .footer-logo-icon { width: 48px; height: 48px; flex-shrink: 0; }
  .footer-mission {
    font-size: 14px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.5);
    max-width: 260px;
  }

  /* Social Links */
  .footer-social {
    display: flex;
    gap: 12px;
  }
  .footer-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.6);
    transition: all 0.3s ease;
  }
  .footer-social-link:hover {
    background: var(--c-yellow);
    color: var(--c-dark);
    transform: translateY(-3px);
  }

  /* Donate Button */
  .footer-donate-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 28px;
    width: 100%;
    max-width: 260px;
    margin-top: 4px;
    background: var(--c-yellow);
    color: var(--c-dark);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 15px;
    border-radius: 60px;
    text-decoration: none;
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .footer-donate-btn:hover {
    background: var(--c-yellow-hover);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px var(--c-yellow-glow);
  }

  /* Nav Columns */
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }
  .footer-heading {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    color: var(--c-white);
    margin-bottom: 16px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-col a {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition: color var(--transition-fast), padding-left var(--transition-fast);
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .footer-col a:hover {
    color: var(--c-yellow);
