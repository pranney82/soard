  @media (max-width: 768px) { .finale { padding: 80px 0; } .finale-ctas .btn { flex: 1; justify-content: center; min-width: 160px; } }

  /* ── SCROLL REVEALS ── */
  [data-reveal] { opacity: 0; transform: translateY(32px); transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1); }
  [data-reveal].is-visible { opacity: 1; transform: translateY(0); }
  [data-delay="1"] { transition-delay: 0.1s; }
  [data-delay="2"] { transition-delay: 0.2s; }
  [data-delay="3"] { transition-delay: 0.3s; }
  [data-delay="4"] { transition-delay: 0.4s; }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] { opacity: 1; transform: none; transition: none; }
    .btn-hero-glow { animation: none; }

    .hero-headline, .hero-photo-wrap { transform: none; animation: none; }
    .hero-eyebrow, .hero-sub, .hero-ctas, .hero-photo-accent { opacity: 1; transform: none; animation: none; }
    .lqip-img:not(.lqip-pending) { transition: none; }
    .lqip-img.lqip-pending { opacity: initial; }
  }
</style>


<!-- Hero-specific no-JS fallback (data-reveal handled by ScrollReveal in BaseLayout) -->
<noscript>
  <style>
    .hero-headline, .hero-photo-wrap { transform: none !important; animation: none !important; }
    .hero-eyebrow, .hero-sub, .hero-ctas, .hero-photo-accent { opacity: 1 !important; animation: none !important; transform: none !important; }
  </style>
</noscript>

<script>
  /* ── Home page: hero photo parallax ──
   * Subtle vertical parallax on the hero photo for depth.
   * Uses astro:page-load for View Transition compatibility. */

  let _scrollHandler: (() => void) | null = null;

  function cleanup() {
    if (_scrollHandler) window.removeEventListener('scroll', _scrollHandler);
    _scrollHandler = null;
  }

  function initHomePage() {
    const hero = document.querySelector('.hero') as HTMLElement;
    if (!hero) return;

    cleanup();

    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const photo = hero.querySelector('.hero-photo img') as HTMLElement;
      if (photo) {
        const heroH = hero.offsetHeight || window.innerHeight;
        let ticking = false;
        _scrollHandler = function () {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            const scrollY = window.scrollY;
            if (scrollY < heroH) {
              photo.style.setProperty('--parallax-y', `${scrollY * 0.06}px`);
            }
            ticking = false;
          });
        };
        window.addEventListener('scroll', _scrollHandler, { passive: true });
      }
    }
  }

  document.addEventListener('astro:page-load', initHomePage);
  document.addEventListener('astro:before-swap', cleanup);
</script>

<!-- Kids strip scroll arrows (desktop only) -->
<script>
  function initKidsScroll() {
    const scroll = document.querySelector('.kids-scroll') as HTMLElement | null;
    const prev = document.querySelector('.kids-scroll-btn--prev') as HTMLElement | null;
    const next = document.querySelector('.kids-scroll-btn--next') as HTMLElement | null;
    if (!scroll || !prev || !next) return;

    function updateArrows() {
      const atStart = scroll!.scrollLeft <= 8;
      const atEnd = scroll!.scrollLeft + scroll!.clientWidth >= scroll!.scrollWidth - 8;
      prev!.classList.toggle('is-active', !atStart);
      next!.classList.toggle('is-active', !atEnd);
    }

    prev.addEventListener('click', () => { scroll.scrollBy({ left: -488, behavior: 'smooth' }); });
    next.addEventListener('click', () => { scroll.scrollBy({ left: 488, behavior: 'smooth' }); });
    scroll.addEventListener('scroll', updateArrows, { passive: true });
    updateArrows();
  }
  document.addEventListener('astro:page-load', initKidsScroll);
</script>

<!-- Room images: scroll-driven parallax (desktop only) -->
<script>
  let _rmObserver: IntersectionObserver | null = null;
  let _rmScroll: (() => void) | null = null;

  function rmCleanup() {
    _rmObserver?.disconnect(); _rmObserver = null;
    if (_rmScroll) { window.removeEventListener('scroll', _rmScroll); _rmScroll = null; }
  }

  function initRoomParallax() {
    rmCleanup();
    // Skip on mobile (no visual payoff, saves battery) and reduced-motion
    if (window.innerWidth < 768) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const imgs = document.querySelectorAll<HTMLElement>('.rm-parallax img');
    if (!imgs.length) return;

    const visible = new Set<HTMLElement>();

    _rmObserver = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) visible.add(e.target as HTMLElement);
        else visible.delete(e.target as HTMLElement);
      });
    }, { rootMargin: '60px 0px' });

    imgs.forEach(img => _rmObserver!.observe(img));

    let ticking = false;
    function onScroll() {
      if (ticking || !visible.size) return;
      ticking = true;
      requestAnimationFrame(() => {
        const vh = window.innerHeight;
        visible.forEach(img => {
          const rect = img.getBoundingClientRect();
          const progress = (rect.top + rect.height / 2 - vh / 2) / vh;
          img.style.transform = `scale(1.06) translateY(${progress * -16}px)`;
        });
        ticking = false;
      });
    }

    _rmScroll = onScroll;
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll(); // initial position
  }

  document.addEventListener('astro:page-load', initRoomParallax);
  document.addEventListener('astro:before-swap', rmCleanup);
</script>

<!-- Shared element morph: kid thumbnail → profile hero -->
<script>
  function initHomeKidTransitions() {
    document.querySelectorAll<HTMLAnchorElement>('.kid-thumb').forEach(thumb => {
      thumb.addEventListener('click', () => {
        const img = thumb.querySelector('img') as HTMLElement | null;
        const name = thumb.querySelector('.kid-thumb-name') as HTMLElement | null;
        if (img) img.style.viewTransitionName = 'kid-hero';
        if (name) name.style.viewTransitionName = 'kid-name';
      });
    });
  }
  document.addEventListener('astro:page-load', initHomeKidTransitions);
</script>
