<script>
/**
 * Shop Page — SSG + Astro ClientRouter compatible
 *
 * All collections/products are STATIC HTML. This script only handles:
 *   - Hash navigation (collection drill-down, back, popstate)
 *   - Product detail modal (gallery, variants)
 *
 * Bundled module (executes once) + astro:page-load (sole entry) +
 * document-level event delegation (survives all VT navigations).
 */
var STORE_URL = 'https://sunnyandranney.com';
var SHOP_SVG = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>';

function fmtPrice(a, c) { return new Intl.NumberFormat('en-US', { style: 'currency', currency: c || 'USD' }).format(parseFloat(a)); }
function esc(s) { var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }
function titleCase(s) { return (s || '').toLowerCase().replace(/(?:^|\s)\S/g, function (a) { return a.toUpperCase(); }); }

var shopState = { productMap: null, previousFocus: null, ac: null };

/* ── Document-level delegation (registered once, survives all VT) ── */
document.addEventListener('click', function (e) {
  var cc = e.target.closest('[data-collection]');
  if (cc && cc.closest('#shop-collections')) { openCollection(cc.dataset.collection); return; }
  var pc = e.target.closest('[data-handle]');
  if (pc && pc.closest('.shop-products-panel')) { openProduct(pc.dataset.handle); return; }
  if (e.target.closest('#pdp-modal-close') || e.target.id === 'pdp-backdrop') closeModal();
});
document.addEventListener('keydown', function (e) {
  if (e.key === 'Escape') {
    var m = document.getElementById('pdp-modal');
    if (m && m.classList.contains('is-open')) closeModal();
    return;
  }
  if (e.key !== 'Enter' && e.key !== ' ') return;
  var cc = e.target.closest('[data-collection]');
  if (cc && cc.closest('#shop-collections')) { e.preventDefault(); openCollection(cc.dataset.collection); return; }
  var pc = e.target.closest('[data-handle]');
  if (pc && pc.closest('.shop-products-panel')) { e.preventDefault(); openProduct(pc.dataset.handle); }
});

/* ── Navigation ── */
function showCollections() {
  var cg = document.getElementById('shop-collections');
  var bb = document.getElementById('shop-back');
  var ct = document.getElementById('shop-collection-title');
  if (!cg) return;
  document.querySelectorAll('.shop-products-panel').forEach(function (p) { p.style.display = 'none'; });
  bb.style.display = 'none';
  ct.style.display = 'none';
  cg.style.display = '';
}

function openCollection(handle) {
  var cg = document.getElementById('shop-collections');
  var panel = document.getElementById('products-' + handle);
  var bb = document.getElementById('shop-back');
  var ct = document.getElementById('shop-collection-title');
  if (!panel) return;
  document.querySelectorAll('.shop-products-panel').forEach(function (p) { p.style.display = 'none'; });
  cg.style.display = 'none';
  panel.style.display = '';
  bb.style.display = '';
  var card = cg.querySelector('[data-collection="' + handle + '"]');
  var title = card ? card.querySelector('.collection-card-title').textContent : titleCase(handle);
  ct.textContent = title;
  ct.style.display = '';
  bb.scrollIntoView({ behavior: 'smooth', block: 'start' });
  history.pushState({ collection: handle }, '', '#' + handle);
}

/* ── Modal ── */
function closeModal() {
  var modal = document.getElementById('pdp-modal');
  var backdrop = document.getElementById('pdp-backdrop');
  if (!modal) return;
  modal.classList.remove('is-open');
  modal.setAttribute('aria-hidden', 'true');
  if (backdrop) backdrop.classList.remove('is-open');
  document.body.style.overflow = '';
  if (shopState.previousFocus) { shopState.previousFocus.focus(); shopState.previousFocus = null; }
}

function getProductMap() {
  if (!shopState.productMap) {
    var el = document.getElementById('shop-product-data');
    try { shopState.productMap = el ? JSON.parse(el.textContent) : {}; }
    catch (_) { shopState.productMap = {}; }
  }
  return shopState.productMap;
}

function openProduct(handle) {
  shopState.previousFocus = document.activeElement;
  var pm = getProductMap();
  var p = pm[handle];
  if (!p) return;

  var modal = document.getElementById('pdp-modal');
  var backdrop = document.getElementById('pdp-backdrop');
  var modalClose = document.getElementById('pdp-modal-close');
  var modalBody = document.getElementById('pdp-modal-body');

  var images = p.images.edges.map(function (e) { return e.node; });
  var variants = p.variants.edges.map(function (e) { return e.node; });
  var fv = variants[0];
  var hasV = variants.length > 1;
  var price = fv.price;
  var cmpAt = fv.compareAtPrice;
  var disc = cmpAt && parseFloat(cmpAt.amount) > parseFloat(price.amount);

  var html = '<div class="pdp-gallery"><div class="pdp-main-img">' +
    (images[0] ? '<img id="pdp-hero" src="' + images[0].url + '&width=900" alt="' + esc(images[0].altText || p.title) + '" />' : '') + '</div>';
  if (images.length > 1) {
    html += '<div class="pdp-thumbs">';
    images.forEach(function (img, i) {
      html += '<button type="button" class="pdp-thumb' + (i === 0 ? ' is-active' : '') + '" data-idx="' + i + '" data-src="' + img.url + '&width=900" data-alt="' + esc(img.altText || p.title) + '" aria-label="View image ' + (i + 1) + '"><img src="' + img.url + '&width=120" alt="" width="64" height="64" loading="lazy" decoding="async" /></button>';
    });
    html += '</div>';
  }
  html += '</div><div class="pdp-info"><h2 class="pdp-title">' + esc(p.title) + '</h2>' +
    '<div class="pdp-price"><span class="pdp-price-amount' + (disc ? ' has-sale' : '') + '" id="pdp-live-price">' + fmtPrice(price.amount, price.currencyCode) + '</span>' +
    (disc ? '<span class="pdp-price-compare" id="pdp-live-compare">' + fmtPrice(cmpAt.amount, cmpAt.currencyCode) + '</span>' : '<span class="pdp-price-compare" id="pdp-live-compare" style="display:none"></span>') + '</div>';

  if (hasV) {
    p.options.forEach(function (opt) {
      html += '<div class="pdp-option" data-option-name="' + esc(opt.name) + '"><label class="pdp-option-label">' + esc(opt.name) + '</label><div class="pdp-option-values">';
      opt.values.forEach(function (v, i) {
        html += '<button type="button" class="pdp-option-btn' + (i === 0 ? ' is-active' : '') + '" data-opt-name="' + esc(opt.name) + '" data-opt-value="' + esc(v) + '">' + esc(v) + '</button>';
      });
      html += '</div></div>';
    });
  }

  html += (p.availableForSale
    ? '<a href="' + STORE_URL + '/products/' + p.handle + '" target="_blank" rel="noopener" class="pdp-atc btn btn-primary" id="pdp-atc-btn">' + SHOP_SVG + ' Buy Now</a>'
    : '<button type="button" class="pdp-atc btn btn-primary" disabled>Sold Out</button>');
  if (p.descriptionHtml) html += '<div class="pdp-desc">' + p.descriptionHtml + '</div>';
  html += '<p class="pdp-mission-note">100% of proceeds fund dream room makeovers for kids with special needs.</p></div>';

  modalBody.innerHTML = html;
  modal.classList.add('is-open');
  modal.setAttribute('aria-hidden', 'false');
  backdrop.classList.add('is-open');
  document.body.style.overflow = 'hidden';
  modalClose.focus();

  /* Thumbnail + variant interactions */
  var heroImg = document.getElementById('pdp-hero');
  var atcBtn = document.getElementById('pdp-atc-btn');
  var priceEl = document.getElementById('pdp-live-price');
  var compareEl = document.getElementById('pdp-live-compare');

  modalBody.querySelectorAll('.pdp-thumb').forEach(function (thumb) {
    thumb.addEventListener('click', function () {
      modalBody.querySelectorAll('.pdp-thumb').forEach(function (t) { t.classList.remove('is-active'); });
      thumb.classList.add('is-active');
      if (heroImg) { heroImg.src = thumb.dataset.src; heroImg.alt = thumb.dataset.alt || ''; }
    });
  });

  var selected = {};
  modalBody.querySelectorAll('.pdp-option').forEach(function (g) {
    var n = g.dataset.optionName;
    var f = g.querySelector('.pdp-option-btn.is-active');
    if (f) selected[n] = f.dataset.optValue;
  });

  modalBody.querySelectorAll('.pdp-option-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      selected[btn.dataset.optName] = btn.dataset.optValue;
      btn.closest('.pdp-option-values').querySelectorAll('.pdp-option-btn').forEach(function (b) { b.classList.toggle('is-active', b === btn); });
      var match = variants.find(function (v) { return v.selectedOptions.every(function (o) { return selected[o.name] === o.value; }); });
      if (match && atcBtn) {
        if (match.availableForSale) {
          atcBtn.href = STORE_URL + '/products/' + p.handle + '?variant=' + match.id.replace(/\D/g, '');
          atcBtn.innerHTML = SHOP_SVG + ' Buy Now';
          atcBtn.classList.remove('is-disabled'); atcBtn.removeAttribute('aria-disabled');
        } else {
          atcBtn.removeAttribute('href'); atcBtn.innerHTML = 'Sold Out';
          atcBtn.classList.add('is-disabled'); atcBtn.setAttribute('aria-disabled', 'true');
        }
        if (priceEl) { priceEl.textContent = fmtPrice(match.price.amount, match.price.currencyCode); priceEl.classList.toggle('has-sale', !!(match.compareAtPrice && parseFloat(match.compareAtPrice.amount) > parseFloat(match.price.amount))); }
        if (compareEl) {
          if (match.compareAtPrice && parseFloat(match.compareAtPrice.amount) > parseFloat(match.price.amount)) { compareEl.textContent = fmtPrice(match.compareAtPrice.amount, match.compareAtPrice.currencyCode); compareEl.style.display = ''; }
          else { compareEl.style.display = 'none'; }
        }
        if (match.image && heroImg) { heroImg.src = match.image.url + '&width=900'; heroImg.alt = match.image.altText || ''; }
      }
    });
  });
}

/* ── astro:page-load — SOLE ENTRY POINT ── */
document.addEventListener('astro:page-load', function () {
  if (!window.location.pathname.startsWith('/shop')) return;
  if (shopState.ac) shopState.ac.abort();
  shopState.ac = new AbortController();
  var sig = shopState.ac.signal;
  shopState.productMap = null;

  var bb = document.getElementById('shop-back');
  if (bb) bb.addEventListener('click', function () { showCollections(); history.pushState(null, '', window.location.pathname); }, { signal: sig });

  window.addEventListener('popstate', function () {
    var hash = window.location.hash.replace('#', '');
    if (hash) openCollection(hash); else showCollections();
  }, { signal: sig });

  var hash = window.location.hash.replace('#', '');
  if (hash && document.getElementById('products-' + hash)) openCollection(hash);
});
</script>
