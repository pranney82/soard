<script>
  function initTimeline() {
    const timeline = document.getElementById('timeline');
    if (!timeline) return;

    const fill = timeline.querySelector<HTMLElement>('.tl-track-fill');
    const cursor = timeline.querySelector<HTMLElement>('.tl-cursor');
    const items = timeline.querySelectorAll<HTMLElement>('[data-tl-item]');
    const cap = timeline.querySelector<HTMLElement>('.tl-cap');
    if (!fill || !items.length) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReduced) {
      items.forEach(el => el.classList.add('is-active'));
      cap?.classList.add('is-active');
      return; /* no .tl-ready — content stays visible as-is */
    }

    /* ── Progressive enhancement gate ──
     * Only hide elements AFTER confirming JS will reveal them.
     * If JS never reaches this point, content stays visible. */
    timeline.classList.add('tl-ready');

    /* ── Track fill + cursor ──
     * CSS animation-timeline handles this on the compositor thread
     * when supported. JS scroll listener is the fallback only. */
    const cssScrollDriven = CSS.supports('animation-timeline', 'view()');
    let onScroll: (() => void) | null = null;

    if (!cssScrollDriven) {
      function updateTrack() {
        const rect = timeline!.getBoundingClientRect();
        const viewH = window.innerHeight;
        const timelineTop = rect.top;
        const timelineH = rect.height;

        if (timelineTop > viewH) {
          fill!.style.transform = 'scaleY(0)';
          if (cursor) { cursor.classList.remove('is-visible'); }
          return;
        }

        const scrolled = viewH * 0.55 - timelineTop;
        const progress = Math.min(Math.max(scrolled / timelineH, 0), 1);
        fill!.style.transform = `scaleY(${progress})`;

        if (cursor) {
          if (progress > 0.01 && progress < 0.99) {
            cursor.classList.add('is-visible');
            cursor.style.transform = `translateY(${progress * 100}%)`;
          } else {
            cursor.classList.remove('is-visible');
          }
        }
      }

      let ticking = false;
      onScroll = () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(() => {
            updateTrack();
            ticking = false;
          });
        }
      };

      window.addEventListener('scroll', onScroll, { passive: true });
      updateTrack();
    }

    /* ── Intersection observer for items ── */
    const isMobile = window.innerWidth <= 640;
    let activatedCount = 0;
    const itemObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !entry.target.classList.contains('is-active')) {
          const el = entry.target as HTMLElement;
          const delay = Math.min(activatedCount * 100, 250);
          setTimeout(() => el.classList.add('is-active'), delay);
          activatedCount++;
          itemObserver.unobserve(el);
        }
      });
    }, {
      threshold: isMobile ? 0.08 : 0.15,
      rootMargin: isMobile ? '0px 0px -30px 0px' : '0px 0px -80px 0px',
    });

    items.forEach(el => itemObserver.observe(el));

    /* ── End cap observer ── */
    let capObserver: IntersectionObserver | null = null;
    if (cap) {
      capObserver = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) {
          cap.classList.add('is-active');
          capObserver!.disconnect();
        }
      }, { threshold: 0.3 });
      capObserver.observe(cap);
    }

    /* ── Safety net — force-reveal if observer misses items ── */
    const safety = setTimeout(() => {
      items.forEach(el => {
        if (!el.classList.contains('is-active')) {
          el.classList.add('is-active');
          itemObserver.unobserve(el);
        }
      });
      if (cap && !cap.classList.contains('is-active')) cap.classList.add('is-active');
    }, 4000);

    /* ── Cleanup for Astro View Transitions ── */
    document.addEventListener('astro:before-swap', () => {
      if (onScroll) window.removeEventListener('scroll', onScroll);
      itemObserver.disconnect();
      capObserver?.disconnect();
      clearTimeout(safety);
    }, { once: true });
  }

  document.addEventListener('astro:page-load', initTimeline);
</script>


