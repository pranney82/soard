---
/**
 * Events Page — Sunshine on a Ranney Day
 * Hero-driven layout: flagship event gets full visual treatment,
 * remaining events in polished cards + past events timeline.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventCard from '../../components/events/EventCard.astro';
import { getCollection } from 'astro:content';
import { cfRaw, cfSrcset, cfLqip } from '../../utils/cf-image';

const allEvents = await getCollection('events');
const today = new Date().toISOString().split('T')[0];

const events = allEvents.map(e => ({
  ...e,
  data: {
    ...e.data,
    status: e.data.status === 'cancelled' ? 'cancelled' : e.data.date < today ? 'past' : 'upcoming',
  },
}));

const upcoming = events
  .filter(e => e.data.status === 'upcoming')
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());

const past = events
  .filter(e => e.data.status === 'past')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const featured = upcoming.filter(e => e.data.featured);
const regular = upcoming.filter(e => !e.data.featured);

/** Hand-crafted detail pages override the dynamic [slug].astro route */
const manualPages: Record<string, string> = {
  'sunshine-on-a-ranney-fairway-2026': '/events/golf/',
};

/** Auto-detect events with body/photos that get dynamic detail pages */
const detailPages: Record<string, string> = { ...manualPages };
for (const e of allEvents) {
  if (!detailPages[e.data.slug] && (e.data.body || e.data.photos.length > 0)) {
    detailPages[e.data.slug] = `/events/${e.data.slug}/`;
  }
}

/** Flagship = first featured event that has a detail page */
const flagshipSlug = Object.keys(detailPages).find(slug =>
  featured.some(e => e.data.slug === slug),
);

const catLabel: Record<string, string> = {
  fundraiser: 'Fundraiser', volunteer: 'Volunteer',
  reveal: 'Room Reveal', community: 'Community', other: 'Event',
};
const catColor: Record<string, string> = {
  fundraiser: '#d4a017', volunteer: '#2e7d32',
  reveal: '#6a3de8', community: '#1976d2', other: '#5A5B61',
};

function fmtDate(d: string) {
  return new Date(d + 'T00:00:00').toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
function fmtWeekday(d: string) {
  return new Date(d + 'T00:00:00').toLocaleDateString('en-US', { weekday: 'long' });
}

// Pull flagship event out of the upcoming grid
const flagshipEvent = flagshipSlug ? featured.find(e => e.data.slug === flagshipSlug) : undefined;
const otherFeatured = featured.filter(e => e.data.slug !== flagshipSlug);
const allOther = [...otherFeatured, ...regular];

/* ── LCP preload — flagship card logo (must be byte-identical to <img>) ── */
const flagshipLogoSrcset = cfSrcset('golf-logo-dark', [280, 400]);
const flagshipLogoSizes = '(max-width: 767px) 160px, 280px';
---

<BaseLayout
  title="Events"
  description="Upcoming events from Sunshine on a Ranney Day — galas, volunteer build days, room reveals, and community gatherings in the greater Atlanta area."
  breadcrumbs={[{ name: 'Events', url: '/events/' }]}
>
  {/* Preload flagship LCP image — imagesrcset/imagesizes must match the <img> */}
  {flagshipEvent && (
    <link slot="head" rel="preload" as="image" imagesrcset={flagshipLogoSrcset} imagesizes={flagshipLogoSizes} fetchpriority="high" />
  )}

  <!-- ═══ HERO (matches site-wide PageLayout pattern) ═══ -->
  <section class="page-hero">
    <div class="container">
      <p class="page-hero__label">Events</p>
      <h1 class="page-hero__title">Come Be a Part of <em class="highlight">Something&nbsp;Big</em></h1>
      <p class="page-hero__subtitle">From fundraising galas to hands-on build days, there are so many ways to get involved</p>
      <div class="page-hero__rule" aria-hidden="true">
        <span class="page-hero__rule-accent"></span>
      </div>
    </div>
  </section>

  <!-- ═══ FEATURED NEXT EVENT (golf spotlight) ═══ -->
  {flagshipEvent && (
    <section class="ev-next">
      <div class="container">
        <div class="ev-next__card" data-reveal>
          <div class="ev-next__bg" aria-hidden="true">
            <div class="ev-next__gradient"></div>
            <div class="ev-next__pattern"></div>
          </div>
          <div class="ev-next__body">
            <span class="ev-next__eyebrow">Next Event</span>
            <h2 class="ev-next__title" transition:name="event-title">{flagshipEvent.data.title}</h2>
            <p class="ev-next__desc">{flagshipEvent.data.description}</p>
            <div class="ev-next__details">
              <div class="ev-next__detail">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <time datetime={flagshipEvent.data.date}>{fmtWeekday(flagshipEvent.data.date)}, {fmtDate(flagshipEvent.data.date)}</time>
              </div>
              <div class="ev-next__detail">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {flagshipEvent.data.location}
              </div>
              {flagshipEvent.data.time && (
                <div class="ev-next__detail">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {flagshipEvent.data.time}
                </div>
              )}
            </div>
            <a href={detailPages[flagshipEvent.data.slug]} class="ev-btn ev-btn--gold ev-btn--lg">
              View Details &amp; Register
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="ev-next__visual">
            <img
              src={cfRaw('golf-logo-dark', 'w=400,q=85')}
              srcset={flagshipLogoSrcset}
              sizes={flagshipLogoSizes}
              alt="Sunshine on a Ranney Fairway"
              transition:name="event-hero"
              width="400" height="400"
              loading="eager" decoding="async"
              class="ev-next__logo"
            />
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ═══ UPCOMING EVENTS ═══ -->
  {allOther.length > 0 && (
    <section class="ev-upcoming" id="upcoming">
      <div class="container">
        <div class="ev-upcoming__header" data-reveal>
          <p class="ev-section-label">What's Coming Up</p>
          <h2 class="ev-section-heading">More Ways to <em class="highlight">Get Involved</em></h2>
        </div>

        <div class="ev-grid">
          {allOther.map((event, i) => (
            <EventCard
              event={event.data}
              detailUrl={detailPages[event.data.slug]}
              index={i}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ EMPTY ═══ -->
  {upcoming.length === 0 && !flagshipEvent && (
    <section class="ev-empty" id="upcoming">
      <div class="container">
        <div class="ev-empty__box" data-reveal>
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <h2>No upcoming events</h2>
          <p>We're planning something special. Follow us on social media to be the first to know!</p>
        </div>
      </div>
    </section>
  )}

  <!-- ═══ PAST EVENTS ═══ -->
  {past.length > 0 && (
    <section class="ev-past" id="past">
      <div class="container">
        <div class="ev-past__header" data-reveal>
          <p class="ev-section-label">Looking Back</p>
          <h2 class="ev-section-heading">Where We've <em class="highlight">Been</em></h2>
        </div>
        <div class="ev-tl">
          {past.map((event, i) => (
            <article class="ev-tl__item" data-reveal data-delay={String(Math.min(i, 3))}>
              <div class="ev-tl__marker" aria-hidden="true">
                <div class="ev-tl__dot"></div>
              </div>
              <div class="ev-tl__card">
                <div class="ev-tl__top">
                  <span class="ev-tl__cat" style={`--cat: ${catColor[event.data.category]}`}>{catLabel[event.data.category]}</span>
                  <time class="ev-tl__date" datetime={event.data.date}>{fmtDate(event.data.date)}</time>
                </div>
                <h3 class="ev-tl__title">{event.data.title}</h3>
                <p class="ev-tl__loc">{event.data.location}</p>
                <p class="ev-tl__desc">{event.data.description}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ CTA ═══ -->
  <section class="ev-cta">
    <div class="container">
      <div class="ev-cta__inner" data-reveal>
        <p class="ev-section-label">Get Involved</p>
        <h2 class="ev-section-heading">There's a Place for <em class="highlight">You</em></h2>
        <div class="ev-cta__grid">
          <a href="mailto:info@soardcharity.com?subject=Event%20Partnership" class="ev-cta__option">
            <div class="ev-cta__icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
            <h3>Host an Event</h3>
            <p>Partner with us to organize a fundraiser, volunteer day, or community event.</p>
            <span class="ev-cta__link">Get in Touch <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></span>
          </a>
          <a href="/donate/" class="ev-cta__option">
            <div class="ev-cta__icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </div>
            <h3>Donate Directly</h3>
            <p>100% of donations go toward building dream rooms for children with special needs.</p>
            <span class="ev-cta__link">Give Today <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></span>
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ═══════════════════════════════════════════
     EVENTS PAGE
     Flagship-driven layout with staggered reveals
     ═══════════════════════════════════════════ */

  [id] { scroll-margin-top: calc(var(--header-height, 84px) + 1.5rem); }

  /* ─── Reveal ─── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  [data-reveal].is-visible { opacity: 1; transform: translateY(0); }
  [data-delay="1"] { transition-delay: 0.1s; }
  [data-delay="2"] { transition-delay: 0.2s; }
  [data-delay="3"] { transition-delay: 0.3s; }
  @media (prefers-reduced-motion: reduce) {
    [data-reveal] { transition: none; opacity: 1; transform: none; }
  }

  /* ─── Buttons ─── */
  .ev-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0.75rem 1.6rem;
    border-radius: 100px;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    border: 1.5px solid transparent;
    cursor: pointer;
    transition: background 200ms, color 200ms, transform 200ms, box-shadow 200ms;
  }
  .ev-btn:active { transform: scale(0.97); }
  .ev-btn--gold {
    background: var(--c-yellow);
    color: var(--c-dark);
    border-color: var(--c-yellow);
  }
  .ev-btn--gold:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px var(--c-yellow-glow);
  }
  .ev-btn--lg { padding: 0.85rem 2.2rem; font-size: 0.95rem; }

  /* ═══ HERO (matches site-wide PageLayout pattern) ═══ */
  .page-hero {
    background: var(--c-cream);
    padding-block: var(--space-2xl) 0;
    text-align: center;
  }
  .page-hero .container {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .page-hero__label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    margin-bottom: var(--space-md);
  }
  .page-hero__title {
    color: var(--c-text);
    font-size: clamp(2rem, 5vw, 3.125rem);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.15;
    max-width: 700px;
    margin-inline: auto;
  }
  .page-hero__subtitle {
    margin-top: var(--space-sm);
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(0.95rem, 1.8vw, 1.065rem);
    line-height: 1.6;
    color: var(--c-text-muted);
    max-width: 500px;
    margin-inline: auto;
  }
  .page-hero__rule {
    position: relative;
    height: 2px;
    background: var(--c-border);
    margin-top: var(--space-lg);
    width: 100%;
  }
  .page-hero__rule-accent {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    top: -1px;
    width: 48px;
    height: 3px;
    background: var(--c-yellow);
    border-radius: 1px;
  }
  @media (max-width: 768px) {
    .page-hero { padding-block: var(--space-xl) 0; }
  }

  /* ═══ FEATURED NEXT EVENT CARD (cream — flows from hero) ═══ */
  .ev-next {
    padding: var(--space-2xl) 0 var(--space-4xl);
    background: var(--c-cream);
  }
  .ev-next__card {
    position: relative;
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr;
    transition: box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .ev-next__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 56px rgba(0, 0, 0, 0.18);
  }
  @media (min-width: 768px) {
    .ev-next__card { grid-template-columns: 1fr auto; }
  }
  .ev-next__bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #1a472a 0%, #2e7d32 40%, #388e3c 70%, #43a047 100%);
  }
  .ev-next__gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 55% at 15% 85%, rgba(255, 218, 36, 0.14) 0%, transparent 60%),
      radial-gradient(ellipse 50% 50% at 85% 15%, rgba(255, 255, 255, 0.06) 0%, transparent 50%);
  }
  .ev-next__pattern {
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: radial-gradient(circle, #fff 1px, transparent 1px);
    background-size: 32px 32px;
  }
  .ev-next__body {
    position: relative;
    z-index: 1;
    padding: var(--space-2xl);
  }
  @media (min-width: 768px) {
    .ev-next__body { padding: var(--space-3xl); }
  }
  .ev-next__eyebrow {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--c-yellow);
    background: rgba(255, 218, 36, 0.12);
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    margin-bottom: var(--space-lg);
  }
  .ev-next__title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    color: #fff;
    line-height: 1.12;
    text-wrap: balance;
    margin-bottom: var(--space-md);
  }
  .ev-next__desc {
    font-size: clamp(0.9rem, 1.3vw, 1rem);
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.75;
    max-width: 480px;
    text-wrap: pretty;
    margin-bottom: var(--space-xl);
  }
  .ev-next__details {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
  }
  .ev-next__detail {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.85);
  }
  .ev-next__detail svg {
    color: var(--c-yellow);
    flex-shrink: 0;
  }
  .ev-next__visual {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl);
  }
  @media (min-width: 768px) {
    .ev-next__visual { padding: var(--space-2xl) var(--space-3xl); }
  }
  .ev-next__logo {
    width: 160px;
    height: auto;
    filter: drop-shadow(0 8px 32px rgba(0, 0, 0, 0.25));
    animation: ev-float 6s ease-in-out infinite;
  }
  @media (min-width: 768px) {
    .ev-next__logo { width: 280px; }
  }
  @keyframes ev-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  /* ═══ SECTION LABELS (matches donate/home pattern) ═══ */
  .ev-section-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    margin-bottom: var(--space-sm);
  }
  .ev-section-heading {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 400;
    color: var(--c-dark);
    letter-spacing: -0.02em;
    line-height: 1.15;
    text-wrap: balance;
  }
  .ev-upcoming__header,
  .ev-past__header {
    margin-bottom: var(--space-2xl);
  }

  /* ═══ UPCOMING (white background — breaks from cream hero) ═══ */
  .ev-upcoming {
    padding: var(--space-4xl) 0;
    background: var(--c-white);
  }
  .ev-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }
  @media (min-width: 640px) {
    .ev-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 960px) {
    .ev-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* Event card styles live in EventCard.astro */

  /* ═══ EMPTY ═══ */
  .ev-empty { padding: var(--space-5xl) 0; }
  .ev-empty__box {
    text-align: center;
    max-width: 420px;
    margin: 0 auto;
    color: var(--c-text-light);
  }
  .ev-empty__box h2 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--c-dark);
    margin: var(--space-lg) 0 var(--space-sm);
  }
  .ev-empty__box p { line-height: 1.7; }

  /* ═══ PAST TIMELINE ═══ */
  .ev-past {
    padding: var(--space-4xl) 0;
    background: var(--c-warm-gray);
  }
  .ev-tl {
    position: relative;
    padding-left: 28px;
    margin-top: var(--space-2xl);
  }
  .ev-tl::before {
    content: '';
    position: absolute;
    left: 5px; top: 8px; bottom: 8px;
    width: 2px;
    background: var(--c-border);
    border-radius: 1px;
  }
  .ev-tl__item {
    position: relative;
    padding-bottom: var(--space-xl);
  }
  .ev-tl__item:last-child { padding-bottom: 0; }
  .ev-tl__marker {
    position: absolute;
    left: -28px; top: 18px;
  }
  .ev-tl__dot {
    width: 12px; height: 12px;
    background: var(--c-warm-gray);
    border: 2.5px solid var(--c-border);
    border-radius: 50%;
    transition: border-color 0.25s cubic-bezier(0.16, 1, 0.3, 1),
                background 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .ev-tl__item:hover .ev-tl__dot {
    border-color: var(--c-yellow);
    background: var(--c-yellow);
  }
  .ev-tl__card {
    padding: var(--space-lg);
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: var(--border-radius-lg);
    transition: box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .ev-tl__item:hover .ev-tl__card {
    box-shadow: var(--shadow-md);
    transform: translateX(4px);
  }
  .ev-tl__top {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }
  .ev-tl__cat {
    font-size: 0.58rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--cat);
  }
  .ev-tl__date {
    font-size: 0.75rem;
    color: var(--c-text-light);
  }
  .ev-tl__title {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--c-dark);
    margin-bottom: 0.2rem;
  }
  .ev-tl__loc {
    font-size: 0.8rem;
    color: var(--c-text-light);
    margin-bottom: var(--space-sm);
  }
  .ev-tl__desc {
    font-size: 0.85rem;
