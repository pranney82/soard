    border-radius: 100px;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.35s cubic-bezier(0.16,1,0.3,1), box-shadow 0.35s cubic-bezier(0.16,1,0.3,1), background 0.25s ease, color 0.25s ease;
    min-height: 48px;
  }
  .btn:hover { transform: translateY(-3px); }
  .btn:active { transform: translateY(0); }
  .btn-lg { font-size: 17px; padding: 18px 44px; }
  .btn-primary { background: var(--c-yellow); color: var(--c-dark); }
  .btn-primary:hover { box-shadow: 0 8px 24px var(--c-yellow-glow); }
  .btn-dark { background: var(--c-dark); color: #fff; }
  .btn-dark:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.2); }
  .btn-ghost-light {
    background: transparent;
    color: rgba(255,255,255,0.85);
    border: 1.5px solid rgba(255,255,255,0.2);
  }
  .btn-ghost-light:hover { background: rgba(255,255,255,0.08); color: #fff; }
  .btn-outline-dark {
    background: transparent;
    color: var(--c-dark);
    border: 2px solid var(--c-dark);
  }
  .btn-outline-dark:hover { background: var(--c-dark); color: var(--c-yellow); }

  @keyframes pulseGlow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255,218,36,0.3); }
    50% { box-shadow: 0 0 0 10px rgba(255,218,36,0); }
  }
  .btn-glow { animation: pulseGlow 3s ease-in-out infinite; }
  .btn-glow:hover { animation: none; box-shadow: 0 8px 24px var(--c-yellow-glow); }

  /* ══════════════════════════════════════════
     HERO — Editorial Split
     Standardized hero-* naming (matches home/apply/donate)
     ══════════════════════════════════════════ */
  .hero {
    position: relative;
    background: var(--c-cream);
    contain: layout style;
    padding: clamp(40px, 8vh, 100px) 0 40px;
    overflow: hidden;
  }

  .hero-inner {
    max-width: var(--max-width-wide, 1400px);
    margin: 0 auto;
    padding: 0 var(--page-padding);
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(32px, 5vw, 80px);
    align-items: center;
    min-height: clamp(480px, 70vh, 720px);
  }

  /* ── Text column ── */
  .hero-eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    margin-bottom: 28px;
    opacity: 0;
    animation: heroUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.05s both;
  }

  .hero-headline {
    font-size: clamp(42px, 6.5vw, 88px);
    line-height: 1.04;
    letter-spacing: -0.035em;
    color: var(--c-dark);
    margin-bottom: 28px;
    /* NO opacity:0 — this is the LCP element, must paint immediately */
    animation: heroSlide 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero-headline em {
    font-style: italic;
    background-image: linear-gradient(transparent 52%, var(--c-yellow-soft) 52%);
