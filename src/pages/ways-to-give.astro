<script>
  const nav = document.querySelector<HTMLElement>('.wtg-nav');
  const links = document.querySelectorAll<HTMLAnchorElement>('.wtg-nav-link');
  const targets = document.querySelectorAll<HTMLElement>('.wtg-section');
  const track = document.querySelector<HTMLElement>('.wtg-nav-track');
  const pill = document.querySelector<HTMLElement>('.wtg-nav-pill');

  if (nav && links.length && targets.length && track && pill) {

    /* ── Move pill behind a link ── */
    function movePill(link: HTMLElement, instant = false) {
      const trackRect = track!.getBoundingClientRect();
      const linkRect = link.getBoundingClientRect();
      const x = linkRect.left - trackRect.left + track!.scrollLeft;
      pill!.style.width = `${linkRect.width}px`;
      pill!.style.transform = `translateX(${x}px) translateY(-50%)`;
      if (instant) {
        pill!.style.transition = 'none';
        pill!.offsetHeight;
        pill!.style.transition = '';
      }
    }

    /* ── Activate a link ── */
    function activate(id: string, instant = false) {
      links.forEach(l => {
        const active = l.hash === `#${id}`;
        l.classList.toggle('is-active', active);
        if (active) {
          movePill(l, instant);
          const sl = l.offsetLeft - track!.offsetWidth / 2 + l.offsetWidth / 2;
          track!.scrollTo({ left: sl, behavior: instant ? 'auto' : 'smooth' });
        }
      });
    }

    /* ── Init: position pill without animation, then fade in ── */
    const firstActive = track.querySelector<HTMLAnchorElement>('.wtg-nav-link.is-active');
    if (firstActive) {
      movePill(firstActive, true);
      requestAnimationFrame(() => pill.classList.add('is-ready'));
    }

    /* ── Stuck shadow ── */
    const sentinel = document.createElement('div');
    sentinel.style.cssText = 'height:1px;width:1px;pointer-events:none;position:absolute;';
    nav.before(sentinel);
    new IntersectionObserver(([e]) => {
      nav.classList.toggle('is-stuck', !e.isIntersecting);
    }, { threshold: 0 }).observe(sentinel);

    /* ── Scroll-spy ── */
    let clickScrolling = false;
    const io = new IntersectionObserver((entries) => {
      if (clickScrolling) return;
      for (const e of entries) {
        if (e.isIntersecting && e.target.id) {
          activate(e.target.id);
          break;
        }
      }
    }, { rootMargin: '-20% 0px -75% 0px' });
    targets.forEach(t => { if (t.id) io.observe(t); });

    /* ── Scroll offset ── */
    function getOffset() {
      const headerH = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--header-height')) || 84;
      return headerH + nav.offsetHeight + 20;
    }

    /* ── Click ── */
    links.forEach(link => {
      link.addEventListener('click', (e) => {
        const hash = link.hash;
        const section = hash && document.querySelector<HTMLElement>(hash);
        if (!section) return;
        e.preventDefault();

        activate(section.id);

        clickScrolling = true;
        const padTop = parseFloat(getComputedStyle(section).paddingTop) || 0;
        const y = section.getBoundingClientRect().top + window.scrollY + padTop - getOffset();
        window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });

        let timer: ReturnType<typeof setTimeout>;
        const done = () => { clickScrolling = false; window.removeEventListener('scroll', onScroll); };
        const onScroll = () => { clearTimeout(timer); timer = setTimeout(done, 100); };
        window.addEventListener('scroll', onScroll, { passive: true });
        timer = setTimeout(done, 800);

        history.pushState(null, '', hash);
      });
    });

    /* ── Resize ── */
    window.addEventListener('resize', () => {
      const active = track.querySelector<HTMLAnchorElement>('.wtg-nav-link.is-active');
      if (active) movePill(active, true);
    });
  }
</script>
