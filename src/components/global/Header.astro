  function cancelClose() { if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; } }
  function scheduleClose() { cancelClose(); closeTimer = setTimeout(closeAllDD, 180); }

  navItems.forEach(function (item) {
    item.addEventListener('mouseenter', function () {
      cancelClose();
      // If item has no dropdown, close all dropdowns instead
      var hasDropdown = item.querySelector('.dropdown-panel');
      if (hasDropdown) {
        openDD(item);
      } else {
        closeAllDD();
      }
    });
  });
