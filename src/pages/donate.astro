---
/**
 * Donate Page — Editorial-first donation experience
 *
 * DESIGN: Editorial split layouts, asymmetric grids, typographic hierarchy
 * STRUCTURE: Hero → Story → Impact Tiers → Trust → Other Ways → FAQ → Finale
 *
 * PERF NOTES:
 * - Hero content has NO data-reveal (prevents LCP penalty from opacity:0)
 * - Hero image: fetchpriority="high", explicit dimensions, eager loading
 * - No Zeffy iframe on page load — iframe loads on-demand in popup modal (saves ~800KB)
 * - All below-fold images: loading="lazy"
 * - FAQ uses native <details name="..."> for exclusive accordion (zero JS in modern browsers)
 * - Scroll observer is tiny (~300 bytes)
 * - preconnect to imagedelivery.net in BaseLayout
 * - Monthly/one-time toggle uses tiny JS (~100 bytes) for grid swap
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import MediaLogos from '../components/ui/MediaLogos.astro';
import FAQSection from '../components/ui/FAQSection.astro';
import { getCollection } from 'astro:content';
import faqData from '../content/site/faq.json';
import siteSettings from '../content/site/settings.json';
import { getDonateSchema } from '../utils/schema';
import { getSiteStats } from '../utils/stats';
import { cfRaw, cfSrcset, CF_BASE, cfLqip } from '../utils/cf-image';

const computed = await getSiteStats();

/* ── Donate page photos (from admin settings, with fallbacks) ── */
const dp = siteSettings.donatePhotos || {};
const donateHeroPhoto = dp.hero || 'kids/oakley/hero';
const donateHeroKidName = dp.heroKidName || 'Oakley';
const donateStoryPhoto = dp.story || 'kids/amari/hero';
const donateStoryKidName = dp.storyKidName || 'Amari';
const donateStoryKidSlug = (dp.storyKidName || 'Amari').toLowerCase().replace(/\s+/g, '-');

/* ── Dynamic story kid data from collection ── */
const allKids = await getCollection('kids');
const storyKid = allKids.find(k => k.data.slug === donateStoryKidSlug);
const storyBio = storyKid?.data.bio || '';
const storyDiagnosis = storyKid?.data.diagnosis || '';
const storyRoomTypes = storyKid?.data.roomTypes || [];
// Build a short 2-sentence excerpt from the bio
const bioSentences = storyBio.split(/(?<=[.!?])\s+/).filter(Boolean);
const storyExcerpt = bioSentences.slice(0, 2).join(' ');

/* ── Zeffy form URLs ── */
const ZEFFY_ONETIME = 'https://www.zeffy.com/en-US/donation-form/help-build-a-brighter-home';
const ZEFFY_MONTHLY = 'https://www.zeffy.com/en-US/donation-form/soard-monthly-builders';

const donateFaqs = faqData.items
  .filter(item => {
    const cat = faqData.categories.find(c => c.id === item.category);
    return cat?.showOnDonatePage;
  })
  .sort((a, b) => (a.order || 0) - (b.order || 0));

const donateJsonLd = getDonateSchema();
const breadcrumbs = [
  { name: 'Home', url: 'https://sunshineonaranneyday.com/' },
  { name: 'Donate', url: 'https://sunshineonaranneyday.com/donate/' },
];
---

<BaseLayout
  title="Donate — Help Build a Brighter Home"
  description="Every dollar builds accessible bathrooms, dream bedrooms, and therapy rooms for children with special needs in Atlanta — all at no cost to families."
  jsonLd={donateJsonLd}
  breadcrumbs={breadcrumbs}
>
  <!-- Preload hero LCP image -->
  <link slot="head" rel="preload" as="image" imagesrcset={cfSrcset(donateHeroPhoto, [400, 640, 1024, 1600])} imagesizes="(max-width:768px) 100vw, 50vw" fetchpriority="high" />

  <!-- ══════ 1. HERO — Editorial Split ══════ -->
  <section class="donate-hero">
    <div class="donate-hero-inner">
      <div class="donate-hero-content">
        <div class="section-label">Give Today</div>
        <h1>A room can change<br/>a child's <em>entire</em> life.</h1>
        <p class="donate-hero-lead">Your gift builds dream bedrooms, accessible bathrooms, and therapy rooms for children with special needs — at <strong>no cost to families</strong>.</p>
        <div class="donate-hero-ctas">
          <a href={ZEFFY_ONETIME} target="_blank" rel="noopener noreferrer" data-zeffy class="btn btn-primary btn-lg btn-hero-glow">Donate Now →</a>
          <a href="#impact" class="btn btn-outline-dark">See Your Impact</a>
        </div>
        <div class="donate-hero-trust">
          <span class="dht-item"><svg class="dht-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Secure & Encrypted</span>
          <span class="dht-item"><svg class="dht-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 8H8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M16 12H8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>Tax-Deductible</span>
          <span class="dht-item"><svg class="dht-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 0 1 0 4H8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M12 18V6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>Zero Platform Fees</span>
        </div>
      </div>
      <div class="donate-hero-visual">
        <div class="donate-hero-frame" style={`background-image:url('${cfLqip(donateHeroPhoto)}')`}>
          <img
            src={cfRaw(donateHeroPhoto, 'w=1600,q=85')}
            srcset={cfSrcset(donateHeroPhoto, [400, 640, 1024, 1600])}
            sizes="(max-width:768px) 100vw, 50vw"
            alt={`${donateHeroKidName} smiling in their new dream bedroom built by Sunshine on a Ranney Day`}
            width="1024"
            height="683"
            fetchpriority="high"
            loading="eager"
            decoding="async"
            class="donate-hero-img lqip-img"
          />
        </div>
        <div class="donate-hero-stat">
          <span class="donate-hero-stat-num">100<span>%</span></span>
          <span class="donate-hero-stat-label">of your gift goes<br/>directly to kids</span>
        </div>
      </div>
    </div>
  </section>

  <MediaLogos theme="dark" linked={true} />

  <!-- ══════ 2. WHY GIVE + TESTIMONIAL ══════ -->
  <section class="why" id="why">
    <div class="why-inner">
      <div class="why-photos" data-reveal>
        <div class="why-photo why-photo--main" style={`background-image:url('${cfLqip(donateStoryPhoto)}')`}>
          <img
            src={cfRaw(donateStoryPhoto, 'w=800,q=85')}
            srcset={cfSrcset(donateStoryPhoto, [500, 800])}
            sizes="(max-width:768px) 90vw, 40vw"
            alt={`${donateStoryKidName} in their new ${storyRoomTypes[0] || 'dream room'} built by Sunshine on a Ranney Day`}
            width="800"
            height="600"
            loading="lazy"
            decoding="async"
            class="lqip-img"
          />
        </div>
      </div>
      <div class="why-text" data-reveal>
        <div class="section-label">Why Your Gift Matters</div>
        <h2>For kids like {donateStoryKidName}, a new room means a <em class="highlight">new beginning</em>.</h2>
        {storyExcerpt ? <p>{storyExcerpt}</p> : <p>{donateStoryKidName} is one of the incredible kids whose life was transformed by a SOARD room makeover.</p>}
        <p>SOARD transformed {donateStoryKidName}'s home{storyRoomTypes.length > 0 ? ` with a ${storyRoomTypes.join(' and ').toLowerCase()}` : ''} — giving them back independence and a space that's truly <em>theirs</em>.</p>
        <p><strong>This is what your donation builds.</strong> Not just rooms — but independence, dignity, and joy for kids who deserve it most.</p>
        <a href={`/kids/${donateStoryKidSlug}`} class="btn btn-dark">{`Read ${donateStoryKidName}'s Full Story →`}</a>
        <blockquote class="why-testimonial">
          <p>"Seeing the look on a child's face when they walk into their new room — there's nothing like it. We've been donating to SOARD for three years and every time, we know our money went exactly where it should."</p>
          <cite>
            <strong>Sarah & Michael T.</strong>
            <span>Monthly donors since 2023</span>
          </cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ══════ 3. IMPACT TIERS ══════ -->
  <section class="tiers" id="impact">
    <div class="tiers-inner">
      <div class="tiers-top" data-reveal>
        <div class="tiers-header">
          <div class="section-label">Your Impact</div>
          <h2>Every dollar has a <em class="highlight">purpose</em></h2>
        </div>
        <div class="freq-toggle" role="group" aria-label="Donation frequency">
          <button type="button" class="freq-btn is-active" data-freq="once" aria-pressed="true">One-Time</button>
          <button type="button" class="freq-btn" data-freq="monthly" aria-pressed="false">Monthly</button>
          <span class="freq-slider" aria-hidden="true"></span>
        </div>
      </div>

      <!-- ONE-TIME TIERS -->
      <div id="tiers-once">
        <div class="tier-feature" data-reveal>
          <div class="tier-feature-badge">Most Popular</div>
          <div class="tier-feature-info">
            <span class="tier-feature-amount">$500</span>
            <span class="tier-feature-what">Furniture & Flooring</span>
          </div>
          <p class="tier-feature-desc">Adaptive furniture or new accessible flooring — the structural pieces that change a child's daily life.</p>
          <a href={`${ZEFFY_ONETIME}?amount=500`} target="_blank" rel="noopener noreferrer" data-zeffy class="btn btn-primary">Give $500 →</a>
        </div>
        <div class="tier-row">
          <div class="tier-item" data-reveal>
            <span class="tier-item-amount">$60</span>
            <strong class="tier-item-what">Paint & Supplies</strong>
            <p>Transforms a child's walls into their dream canvas — paint, primer, and all materials included.</p>
            <a href={`${ZEFFY_ONETIME}?amount=60`} target="_blank" rel="noopener noreferrer" data-zeffy class="tier-item-cta">Give $60 →</a>
          </div>
          <div class="tier-item" data-reveal data-delay="1">
            <span class="tier-item-amount">$125</span>
            <strong class="tier-item-what">Bedding & Decor</strong>
            <p>New bedding, curtains, rugs, and wall art — the details that make a room feel like <em>home</em>.</p>
            <a href={`${ZEFFY_ONETIME}?amount=125`} target="_blank" rel="noopener noreferrer" data-zeffy class="tier-item-cta">Give $125 →</a>
          </div>
          <div class="tier-item" data-reveal data-delay="2">
            <span class="tier-item-amount">$1,000</span>
            <strong class="tier-item-what">Full Room Sponsor</strong>
            <p>Funds a complete room transformation — from design to demolition to the big reveal moment.</p>
            <a href={`${ZEFFY_ONETIME}?amount=1000`} target="_blank" rel="noopener noreferrer" data-zeffy class="tier-item-cta">Give $1,000 →</a>
          </div>
          <div class="tier-item tier-item--custom" data-reveal data-delay="3">
            <span class="tier-item-amount">Any $</span>
            <strong class="tier-item-what">Your Amount</strong>
            <p>Every dollar has a purpose. Give whatever feels right — it all goes directly to building rooms for kids.</p>
            <a href={`${ZEFFY_ONETIME}?amount=50`} target="_blank" rel="noopener noreferrer" data-zeffy class="tier-item-cta">Choose Your Amount →</a>
          </div>
        </div>
      </div>

      <!-- MONTHLY TIERS -->
      <div id="tiers-monthly" style="display:none">
        <div class="tier-feature">
          <div class="tier-feature-badge">Most Impact</div>
          <div class="tier-feature-info">
            <span class="tier-feature-amount">$50<span class="tier-freq">/mo</span></span>
            <span class="tier-feature-what">Room Champion</span>
          </div>
          <p class="tier-feature-desc">$600/year — funds adaptive furniture and flooring that transforms a child's daily life.</p>
          <a href={`${ZEFFY_MONTHLY}?amount=50`} target="_blank" rel="noopener noreferrer" data-zeffy class="btn btn-primary">Give $50/mo →</a>
        </div>
        <div class="tier-row">
          <div class="tier-item">
            <span class="tier-item-amount">$10<span class="tier-freq">/mo</span></span>
            <strong class="tier-item-what">Sunshine Starter</strong>
            <p>Less than 35¢ a day — provides essential supplies for room makeovers all year long.</p>
            <a href={`${ZEFFY_MONTHLY}?amount=10`} target="_blank" rel="noopener noreferrer" data-zeffy class="tier-item-cta">Give $10/mo →</a>
          </div>
          <div class="tier-item">
            <span class="tier-item-amount">$25<span class="tier-freq">/mo</span></span>
            <strong class="tier-item-what">Dream Builder</strong>
            <p>$300/year — enough to furnish a child's entire dream bedroom with new bedding, decor, and rugs.</p>
            <a href={`${ZEFFY_MONTHLY}?amount=25`} target="_blank" rel="noopener noreferrer" data-zeffy class="tier-item-cta">Give $25/mo →</a>
          </div>
          <div class="tier-item">
            <span class="tier-item-amount">$100<span class="tier-freq">/mo</span></span>
            <strong class="tier-item-what">Legacy Builder</strong>
            <p>$1,200/year — you're directly sponsoring a complete room transformation for a child in need.</p>
            <a href={`${ZEFFY_MONTHLY}?amount=100`} target="_blank" rel="noopener noreferrer" data-zeffy class="tier-item-cta">Give $100/mo →</a>
          </div>
          <div class="tier-item tier-item--custom">
            <span class="tier-item-amount">Any $</span>
            <strong class="tier-item-what">Your Amount</strong>
            <p>Set your own monthly amount — every dollar goes directly to building rooms for kids who need them most.</p>
            <a href={`${ZEFFY_MONTHLY}?amount=50`} target="_blank" rel="noopener noreferrer" data-zeffy class="tier-item-cta">Choose Your Amount →</a>
          </div>
        </div>
      </div>

      <div class="tiers-footer" data-reveal>
        <p class="tiers-note">Every amount makes a difference. <a href={ZEFFY_ONETIME} target="_blank" rel="noopener noreferrer" data-zeffy class="tiers-note-link">Give any custom amount →</a></p>
        <p class="tiers-note tiers-note--sub">Right now, families are on our waitlist hoping for a room makeover. Every donation brings us closer to saying <em>yes</em> to the next child.</p>
        <div class="tiers-match">
          <svg class="tiers-match-icon" viewBox="0 0 24 24" fill="none"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <p><strong>Double your impact</strong> — many employers match charitable gifts. Check with your HR department to see if your company participates.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ 4. TRUST & TRANSPARENCY ══════ -->
  <section class="donate-trust">
    <div class="donate-trust-inner">
      <div class="donate-trust-left" data-reveal>
        <div class="section-label">Trust & Transparency</div>
        <h2>We're an open book. <em class="highlight">Always.</em></h2>
        <p class="donate-trust-body">You should know exactly where every dollar goes. Our financials are public, our mission is clear, and our track record speaks for itself.</p>
        <div class="donate-trust-links">
          <a href="/about/financials" class="btn btn-dark">View Our Financials →</a>
          <a href="/ways-to-give" class="donate-trust-link">More ways to give →</a>
        </div>
      </div>
      <div class="donate-trust-right">
        <div class="dt-card" data-reveal>
          <span class="dt-big">501(c)(3)</span>
          <span class="dt-label">Tax-Exempt Status</span>
          <p>Registered nonprofit. EIN 45-4773997. All donations are fully tax-deductible.</p>
        </div>
        <div class="dt-card" data-reveal data-delay="1">
          <span class="dt-big">{computed.totalRooms}+</span>
          <span class="dt-label">Rooms Completed</span>
          <p>Over {computed.totalKids} children served across the greater Atlanta area since 2012.</p>
        </div>
        <div class="dt-card" data-reveal data-delay="2">
          <span class="dt-big">990</span>
          <span class="dt-label">On File</span>
          <p>Our IRS Form 990 tax returns are available for anyone to review, anytime.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ 5. OTHER WAYS TO HELP ══════ -->
  <section class="other-ways">
    <div class="other-ways-inner">
      <div class="other-ways-left" data-reveal>
        <div class="section-label">More Ways to Help</div>
        <h2>Can't donate right now? You can still make an <em class="highlight">impact</em>.</h2>
      </div>
      <div class="other-ways-right" data-reveal data-delay="1">
        <div class="way-item">
          <h3>Shop Our Stores</h3>
          <p>Every purchase at Sunny & Ranney directly funds room makeovers.</p>
          <a href="https://sunnyandranney.com" target="_blank" rel="noopener noreferrer">Shop Sunny & Ranney →</a>
        </div>
        <div class="way-item">
          <h3>Volunteer or Partner</h3>
          <p>Contractors, designers, and handy helpers — we need your skills to build these rooms.</p>
          <a href="/partners/">Get Involved →</a>
        </div>
        <div class="way-item">
          <h3>Stock, DAF & More</h3>
          <p>Donate stock, give through your donor-advised fund, or mail a check — all tax-deductible.</p>
          <a href="/ways-to-give">See All Options →</a>
        </div>
        <div class="way-item">
          <h3>Spread the Word</h3>
          <p>Share our mission with friends and family. A single share can connect us to the next partner or donor.</p>
          <a href="/about">Learn Our Story →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ 6. FAQ — Editorial Split ══════ -->
  <FAQSection
    heading='Everything you need to know before you <em class="highlight-dark">give</em>.'
    body="We believe in radical transparency. If your question isn't answered here, reach out — we'd love to hear from you."
    ctaLabel="Contact Us →"
    ctaHref="mailto:info@soardcharity.com"
    ctaClass="btn btn-ghost-light"
    items={donateFaqs}
    accordionName="donate-faq"
  />

  <!-- ══════ 7. FINALE ══════ -->
  <section class="donate-finale">
    <div class="donate-finale-inner">
      <h2 data-reveal>Every child deserves a room<br/>that feels like <em>home</em>.</h2>
      <p data-reveal data-delay="1">You can make that happen today.</p>
      <div class="donate-finale-ctas" data-reveal data-delay="2">
        <a href={ZEFFY_ONETIME} target="_blank" rel="noopener noreferrer" data-zeffy class="btn btn-dark btn-lg">Donate Now →</a>
        <a href="/kids" class="btn btn-outline-dark">Meet the Kids</a>
      </div>
      <p class="donate-finale-note" data-reveal data-delay="3">501(c)(3) · EIN 45-4773997 · All donations tax-deductible</p>
    </div>
  </section>

  <!-- ══════ STICKY MOBILE CTA BAR ══════ -->
  <div class="sticky-cta" id="sticky-cta" aria-hidden="true" inert>
    <div class="sticky-cta-inner">
      <span class="sticky-cta-text">Help build dreams</span>
      <a href={ZEFFY_ONETIME} target="_blank" rel="noopener noreferrer" data-zeffy class="btn btn-primary sticky-cta-btn">Donate Now</a>
    </div>
  </div>

  <!-- ══════ ZEFFY POPUP MODAL ══════ -->
  <div class="zeffy-modal" id="zeffy-modal" aria-hidden="true" inert role="dialog" aria-label="Donation form">
    <div class="zeffy-modal-backdrop" id="zeffy-modal-close"></div>
    <div class="zeffy-modal-container">
      <button class="zeffy-modal-x" id="zeffy-modal-x" type="button" aria-label="Close donation form">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      <iframe id="zeffy-iframe" title="Donation form powered by Zeffy" allowpaymentrequest></iframe>
    </div>
  </div>

</BaseLayout>

<script>
  const ZEFFY_ONETIME_EMBED = 'https://www.zeffy.com/embed/donation-form/help-build-a-brighter-home';
  const ZEFFY_MONTHLY_EMBED = 'https://www.zeffy.com/embed/donation-form/soard-monthly-builders';

  document.addEventListener('astro:page-load', () => {
    const stickyBar = document.getElementById('sticky-cta');
    const hero = document.querySelector('.donate-hero');
    const modal = document.getElementById('zeffy-modal');
    const iframe = document.getElementById('zeffy-iframe') as HTMLIFrameElement | null;
    const closeBtn = document.getElementById('zeffy-modal-close');
    const closeX = document.getElementById('zeffy-modal-x');

    // --- Sticky bar ---
    if (stickyBar && hero) {
      const obs = new IntersectionObserver(([e]) => {
        const hidden = e.isIntersecting;
        stickyBar.classList.toggle('is-visible', !hidden);
        stickyBar.setAttribute('aria-hidden', String(hidden));
        stickyBar.inert = hidden;
      }, { threshold: 0 });
      obs.observe(hero);
    }

    // --- Zeffy popup ---
    function openModal(href: string) {
      if (!modal || !iframe) return;
      const url = new URL(href);
      const amount = url.searchParams.get('amount') || undefined;
      const isMonthly = href.includes('monthly-builders');
      const base = isMonthly ? ZEFFY_MONTHLY_EMBED : ZEFFY_ONETIME_EMBED;
      iframe.src = amount ? `${base}?amount=${amount}` : base;
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      modal.inert = false;
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      if (!modal || !iframe) return;
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      modal.inert = true;
      document.body.style.overflow = '';
      setTimeout(() => { if (!modal.classList.contains('is-open')) iframe.src = ''; }, 350);
    }

    // --- Frequency toggle ---
    const freqBtns = document.querySelectorAll('.freq-btn');
    const tiersOnce = document.getElementById('tiers-once');
    const tiersMonthly = document.getElementById('tiers-monthly');
    const freqSlider = document.querySelector('.freq-slider');

    freqBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const freq = (btn as HTMLElement).dataset.freq;
        freqBtns.forEach(b => {
          b.classList.toggle('is-active', b === btn);
          b.setAttribute('aria-pressed', String(b === btn));
        });
        if (freqSlider) {
          freqSlider.setAttribute('data-pos', freq || 'once');
        }
        if (tiersOnce && tiersMonthly) {
          tiersOnce.style.display = freq === 'monthly' ? 'none' : '';
          tiersMonthly.style.display = freq === 'monthly' ? '' : 'none';
        }
      });
    });

    // Intercept all data-zeffy links
    document.querySelectorAll('[data-zeffy]').forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        openModal((link as HTMLAnchorElement).href);
      });
    });

    closeBtn?.addEventListener('click', closeModal);
    closeX?.addEventListener('click', closeModal);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal?.classList.contains('is-open')) closeModal();
    });
  });
</script>

