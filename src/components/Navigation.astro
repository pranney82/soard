---
// Navigation component — sticky header with brand colors
---

<nav class="nav" id="main-nav">
  <div class="nav-inner">
    <!-- Logo -->
    <a href="/" class="logo" aria-label="Sunshine on a Ranney Day — Home">
      <img
        src="https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/logo-light-bg/nav"
        alt="Sunshine on a Ranney Day — Dreams Built Here"
        width="120"
        height="60"
        class="logo-img"
      />
    </a>

    <!-- Desktop Nav -->
    <div class="nav-links">
      <a href="/about" class="nav-link">About</a>
      <a href="/kids" class="nav-link">Our Kids</a>
      <a href="/partners" class="nav-link">Partners</a>
      <a href="/get-involved" class="nav-link">Get Involved</a>
      <a href="/donate" zeffy-form-link="https://www.zeffy.com/embed/donation-form/help-build-a-brighter-home?modal=true" class="btn btn-primary btn-sm">Donate ♥</a>
    </div>

    <!-- Mobile hamburger -->
    <button class="mobile-toggle" id="mobile-toggle" aria-label="Menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<style>
  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    z-index: 101;
  }
  .logo-img {
    height: 52px;
    width: auto;
    object-fit: contain;
  }
  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  .mobile-toggle span {
    width: 24px;
    height: 2px;
    background: var(--c-dark);
    border-radius: 2px;
    transition: all 0.3s ease;
  }
  @media (max-width: 768px) {
    .nav-links { display: none; }
    .mobile-toggle { display: flex; }
  }
</style>

<script>
  // Scroll detection for nav background
  const nav = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      nav?.classList.add('scrolled');
    } else {
      nav?.classList.remove('scrolled');
    }
  }, { passive: true });
</script>
