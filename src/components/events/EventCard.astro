---
/**
 * EventCard.astro — Premium event card with category-driven visuals
 *
 * Supports two visual modes:
 *   1. Image header — event.image is set → CF Image with LQIP + gradient overlay
 *   2. Gradient header — no image → category gradient + icon pattern
 *
 * PERF: CF Images w/ srcset, LQIP blur-up, contain
 * A11Y: ARIA, keyboard focus, prefers-reduced-motion
 */
import { cfRaw, cfSrcset, cfLqip } from '../../utils/cf-image';

interface Props {
  event: {
    title: string;
    slug: string;
    date: string;
    time?: string;
    location: string;
    description: string;
    image?: string | null;
    ticketUrl?: string;
    ticketPrice?: string;
    category: string;
  };
  detailUrl?: string;
  calendarUrl?: string;
  index?: number;
}

const { event, detailUrl, calendarUrl, index = 0 } = Astro.props;

const catLabel: Record<string, string> = {
  fundraiser: 'Fundraiser', volunteer: 'Volunteer',
  reveal: 'Room Reveal', community: 'Community', other: 'Event',
};

const catGradient: Record<string, string> = {
  fundraiser: 'linear-gradient(135deg, #7a5a00 0%, #b8860b 40%, #d4a017 80%, #e6b422 100%)',
  volunteer:  'linear-gradient(135deg, #1a472a 0%, #2e7d32 40%, #388e3c 70%, #43a047 100%)',
  reveal:     'linear-gradient(135deg, #2d1b69 0%, #4a2d8a 40%, #6a3de8 70%, #7c4dff 100%)',
  community:  'linear-gradient(135deg, #0d3b66 0%, #1565c0 40%, #1976d2 70%, #2196f3 100%)',
  other:      'linear-gradient(135deg, #2c2c2c 0%, #4a4a4a 40%, #5A5B61 70%, #6D6E74 100%)',
};

const catIcon: Record<string, string> = {
  fundraiser: '<svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"/></svg>',
  volunteer:  '<svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 12-9.373 9.373a1 1 0 0 1-3.001-3L12 9"/><path d="m18 15 4-4"/><path d="m21.5 11.5-1.914-1.914A2 2 0 0 1 19 8.172v-.344a2 2 0 0 0-.586-1.414l-1.657-1.657A6 6 0 0 0 12.516 3H9l1.243 1.243A6 6 0 0 1 12 8.485V10l2 2h1.172a2 2 0 0 1 1.414.586L18.5 14.5"/></svg>',
  reveal:     '<svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"/></svg>',
  community:  '<svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.128a4 4 0 0 1 0 7.744"/></svg>',
  other:      '<svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>',
};

function fmtDate(d: string) {
  return new Date(d + 'T00:00:00').toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
function fmtWeekday(d: string) {
  return new Date(d + 'T00:00:00').toLocaleDateString('en-US', { weekday: 'long' });
}
function fmtMonth(d: string) {
  return new Date(d + 'T00:00:00').toLocaleDateString('en-US', { month: 'short' }).toUpperCase();
}
function fmtDay(d: string) {
  return new Date(d + 'T00:00:00').getDate().toString();
}
---

<article class="ev-card" data-reveal data-delay={String(Math.min(index, 3))}>
  {/* Full-card click target — sits below interactive children via z-index */}
  {detailUrl ? (
    <a class="ev-card__overlay" href={detailUrl} aria-label={`View details for ${event.title}`} tabindex="-1"></a>
  ) : event.ticketUrl ? (
    <a class="ev-card__overlay" href={event.ticketUrl} target="_blank" rel="noopener noreferrer" aria-label={`Get tickets for ${event.title}`} tabindex="-1"></a>
  ) : null}

  {/* Card header: event image with gradient overlay, or gradient-only fallback */}
  <div
    class={`ev-card__hero ${event.image ? 'ev-card__hero--img' : ''}`}
    style={event.image
      ? `background-image:url('${cfLqip(event.image)}')`
      : `background: ${catGradient[event.category]}`}
  >
    {event.image ? (
      <img
        src={cfRaw(event.image, 'w=600,h=558,fit=cover,q=80')}
        srcset={cfSrcset(event.image, [400, 600, 800], { fit: 'cover', aspectRatio: 768/826 })}
        sizes="(max-width: 639px) 100vw, (max-width: 959px) 50vw, 33vw"
        alt={event.title}
        class="ev-card__hero-img lqip-img"
        width="826" height="768"
        loading="lazy" decoding="async"
      />
    ) : (
      <Fragment>
        <div class="ev-card__hero-pattern" aria-hidden="true"></div>
        <div class="ev-card__hero-glow" aria-hidden="true"></div>
        <div class="ev-card__hero-icon" set:html={catIcon[event.category]} />
      </Fragment>
    )}
    <div class="ev-card__hero-date">
      <time datetime={event.date}>
        <span class="ev-card__hero-month">{fmtMonth(event.date)}</span>
        <span class="ev-card__hero-day">{fmtDay(event.date)}</span>
      </time>
    </div>
    <div class="ev-card__hero-cat">{catLabel[event.category]}</div>
    {event.ticketPrice && (
      <div class="ev-card__hero-price">{event.ticketPrice}</div>
    )}
  </div>

  <div class="ev-card__inner">
    <h3 class="ev-card__title">{event.title}</h3>
    <div class="ev-card__meta">
      <span class="ev-card__meta-item">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
        <time datetime={event.date}>{fmtWeekday(event.date)}, {fmtDate(event.date)}</time>
      </span>
      {event.time && (
        <span class="ev-card__meta-item">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          {event.time}
        </span>
      )}
      <span class="ev-card__meta-item">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
        {event.location}
      </span>
    </div>
    <p class="ev-card__desc">{event.description}</p>

    <div class="ev-card__foot">
      <div class="ev-card__actions">
        {detailUrl ? (
          <a href={detailUrl} class="ev-card__btn">
            View Details
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        ) : event.ticketUrl ? (
          <a href={event.ticketUrl} class="ev-card__btn" target="_blank" rel="noopener noreferrer">
            Get Tickets
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
          </a>
        ) : (
          <span class="ev-card__soon">Details coming soon</span>
        )}
        {calendarUrl && (
          <a href={calendarUrl} class="ev-card__cal" target="_blank" rel="noopener noreferrer" title="Add to Calendar">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>
          </a>
        )}
      </div>
    </div>
  </div>
</article>

<style>
  .ev-card {
    position: relative;
    isolation: isolate;
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    contain: layout style;
    display: flex;
    flex-direction: column;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  /* Card-wide cursor hint when there's a clickable target */
  .ev-card:has(.ev-card__btn) { cursor: pointer; }
  .ev-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 56px rgba(0, 0, 0, 0.12);
    border-color: rgba(255, 218, 36, 0.3);
  }

  /* ─ Card hero header ─ */
  .ev-card__hero {
    position: relative;
    height: 180px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  /* Image-backed heroes match the source aspect ratio so the full image shows */
  .ev-card__hero--img {
    height: auto;
    aspect-ratio: 826 / 768;
  }
  .ev-card__hero-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    background-image: radial-gradient(circle, #fff 1px, transparent 1px);
    background-size: 24px 24px;
  }
  .ev-card__hero-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 60% at 20% 80%, rgba(255, 255, 255, 0.12) 0%, transparent 55%),
      radial-gradient(ellipse 40% 40% at 85% 15%, rgba(255, 255, 255, 0.06) 0%, transparent 50%);
  }
  .ev-card__hero-icon {
    color: rgba(255, 255, 255, 0.18);
    z-index: 1;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                color 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .ev-card:hover .ev-card__hero-icon {
    transform: scale(1.2) rotate(3deg);
    color: rgba(255, 255, 255, 0.28);
  }

  /* Date badge */
  .ev-card__hero-date {
    position: absolute;
    top: var(--space-md);
    left: var(--space-md);
    background: rgba(0, 0, 0, 0.25);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 12px;
    padding: 0.35rem 0.55rem;
    text-align: center;
    min-width: 52px;
    z-index: 2;
    pointer-events: none;
  }
  .ev-card__hero-month {
    display: block;
    font-size: 0.55rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.7);
  }
  .ev-card__hero-day {
    display: block;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1;
    color: #fff;
  }

  /* Category pill */
  .ev-card__hero-cat {
    position: absolute;
    bottom: var(--space-md);
    left: var(--space-md);
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.9);
    background: rgba(0, 0, 0, 0.22);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 0.25rem 0.65rem;
    border-radius: 100px;
    z-index: 2;
    pointer-events: none;
  }

  /* Price badge */
  .ev-card__hero-price {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    font-size: 0.6rem;
    font-weight: 700;
    color: #fff;
    background: rgba(0, 0, 0, 0.25);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 0.25rem 0.65rem;
    border-radius: 100px;
    z-index: 2;
    pointer-events: none;
  }

  /* Image-backed card hero */
  .ev-card__hero--img {
    background-size: cover;
    background-position: center;
  }
  .ev-card__hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .ev-card:hover .ev-card__hero-img {
    transform: scale(1.04);
  }
  .ev-card__hero-img.lqip-pending { opacity: 0; }
  .ev-card__hero-img.loaded { opacity: 1; transition: opacity 0.4s ease; }
  .ev-card__hero--img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.1) 50%, transparent 100%);
    z-index: 1;
    pointer-events: none;
  }
  .ev-card__hero--img .ev-card__hero-date,
  .ev-card__hero--img .ev-card__hero-cat,
  .ev-card__hero--img .ev-card__hero-price { z-index: 2; }

  /* Card body */
  .ev-card__inner {
    padding: var(--space-lg) var(--space-lg) var(--space-md);
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .ev-card__title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    line-height: 1.25;
    color: var(--c-dark);
    margin-bottom: var(--space-md);
  }
  .ev-card__meta {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: var(--space-md);
  }
  .ev-card__meta-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8rem;
    color: var(--c-text-muted);
  }
  .ev-card__meta-item svg {
    flex-shrink: 0;
    color: var(--c-text-light);
  }
  .ev-card__desc {
    font-size: 0.85rem;
    line-height: 1.65;
    color: var(--c-text-muted);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  /* Card footer */
  .ev-card__foot {
    margin-top: var(--space-lg);
    padding-top: var(--space-md);
    border-top: 1px solid var(--c-border);
  }
  .ev-card__actions {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  /* Full-card click overlay — covers entire card, sits below interactive children */
  .ev-card__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    text-indent: -9999px;
    overflow: hidden;
  }
  .ev-card__overlay:focus-visible {
    outline: 3px solid var(--c-yellow);
    outline-offset: -3px;
    border-radius: var(--border-radius-lg);
  }

  /* Primary CTA button — sits above the overlay */
  .ev-card__btn {
    position: relative;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 0.5rem 1.15rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--c-dark);
    background: var(--c-yellow);
    border-radius: 100px;
    text-decoration: none;
    transition: transform 200ms, box-shadow 200ms, gap 200ms;
  }
  .ev-card__btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 16px var(--c-yellow-glow);
    gap: 8px;
  }
  .ev-card__btn:active { transform: scale(0.97); }

  /* Calendar icon button — sits above the overlay */
  .ev-card__cal {
    position: relative;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    color: var(--c-text-muted);
    background: var(--c-warm-gray);
    text-decoration: none;
    transition: background 200ms, color 200ms, transform 200ms;
    margin-left: auto;
    flex-shrink: 0;
  }
  .ev-card__cal:hover {
    background: var(--c-border);
    color: var(--c-dark);
    transform: scale(1.08);
  }

  .ev-card__soon {
    font-size: 0.82rem;
    color: var(--c-text-light);
    font-style: italic;
  }

  @media (max-width: 640px) {
    .ev-card__btn { min-height: 44px; }
    .ev-card__cal { width: 44px; height: 44px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ev-card { transition: none; }
    .ev-card__hero-icon { transition: none; }
    .ev-card__hero-img { transition: none; }
  }
</style>
