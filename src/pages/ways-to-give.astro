  .wtg-sh-text h2 { font-size: clamp(24px, 3vw, 36px); line-height: 1.25; margin-bottom: 6px; }
  .wtg-sh-text p { font-size: 16px; color: var(--c-text-muted); line-height: 1.6; }

  /* ══════════════════════════════════════════
     01 · GIVE TODAY
     ══════════════════════════════════════════ */
  .wtg-featured {
