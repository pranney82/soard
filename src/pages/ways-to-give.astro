    min-height: 48px;
  }
  .btn:hover { transform: translateY(-3px); }
  .btn:active { transform: translateY(0); }
  .btn-lg { font-size: 17px; padding: 18px 44px; }
  .btn-primary { background: var(--c-yellow); color: var(--c-dark); }
  .btn-primary:hover { box-shadow: 0 8px 24px var(--c-yellow-glow); }
  .btn-dark { background: var(--c-dark); color: #fff; }
  .btn-dark:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.2); }
  .btn-ghost-light {
    background: transparent;
    color: rgba(255,255,255,0.85);
    border: 1.5px solid rgba(255,255,255,0.2);
  }
  .btn-ghost-light:hover { background: rgba(255,255,255,0.08); color: #fff; }
  .btn-outline-dark {
    background: transparent;
    color: var(--c-dark);
