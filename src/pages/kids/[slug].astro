---
/**
 * [slug].astro — Individual kid profile page (Premium)
 *
 * PERF: CF Image transforms with srcset/avif/webp, lazy gallery, YouTube facade
 * SEO:  Article + Person schema, breadcrumbs, rich meta, OG image
 * A11Y: Heading hierarchy, ARIA labels, focus trap lightbox, keyboard nav
 * UX:   Full-bleed hero, masonry gallery, lightbox, prev/next nav, share
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import { getCollection } from 'astro:content';
import { getKidProfileSchema } from '../../utils/schema';

export async function getStaticPaths() {
  const kids = await getCollection('kids');
  const sorted = kids.sort((a, b) => (b.data.year || 0) - (a.data.year || 0));
  return sorted.map((kid, i) => {
    // Find related kids: same room type or same year, excluding self
    const others = sorted.filter((k, j) => j !== i);
    const sameType = others.filter(k =>
      k.data.roomTypes?.some(t => kid.data.roomTypes?.includes(t))
    );
    const sameYear = others.filter(k => k.data.year === kid.data.year);
    // Prioritize same room type, then same year, then nearest in list
    const related = [...new Set([...sameType, ...sameYear, ...others])]
      .filter(k => k.data.heroImage)
      .slice(0, 4)
      .map(k => ({ name: k.data.name, slug: k.data.slug, heroImage: k.data.heroImage, diagnosis: k.data.diagnosis }));

    return {
      params: { slug: kid.data.slug },
      props: {
        kid: kid.data,
        prevKid: i > 0 ? sorted[i - 1].data : null,
        nextKid: i < sorted.length - 1 ? sorted[i + 1].data : null,
        relatedKids: related,
      },
    };
  });
}

const { kid, prevKid, nextKid, relatedKids } = Astro.props;
const photos = kid.photos || [];

// ── CF Image helpers ──────────────────────
const CF_BASE = 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ';
function cfUrl(src: string, opts: string) {
  if (!src || !src.includes('imagedelivery.net')) return src;
  const id = src.replace(`${CF_BASE}/`, '').replace('/public', '');
  return `${CF_BASE}/${id}/${opts}`;
}
function cfSrcset(src: string, widths: number[]) {
  return widths.map(w => `${cfUrl(src, `w=${w},f=auto,q=85`)} ${w}w`).join(', ');
}

// ── YouTube ID extraction ─────────────────
function getYouTubeId(url: string): string | null {
  if (!url) return null;
  const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([a-zA-Z0-9_-]{11})/);
  return match ? match[1] : null;
}
const ytId = kid.videoUrl ? getYouTubeId(kid.videoUrl) : null;
const streamId = kid.streamVideoId || null;
const hasVideo = streamId || ytId;

// ── SEO ───────────────────────────────────
const SITE = 'https://sunshineonaranneyday.com';
const kidSchemas = getKidProfileSchema({
  ...kid,
  videoUrl: kid.videoUrl,
  photos: kid.photos,
  photographer: kid.photographer,
  status: kid.status,
});
const breadcrumbs = [
  { name: 'Home', url: SITE },
  { name: 'Meet the Kids', url: `${SITE}/kids/` },
  { name: kid.name, url: `${SITE}/kids/${kid.slug}/` },
];

const metaDesc = kid.metaDescription
  || kid.shortDescription
  || `Meet ${kid.name}${kid.diagnosis ? `, diagnosed with ${kid.diagnosis}` : ''}. Learn how Sunshine on a Ranney Day transformed their space${kid.roomTypes?.length ? ` with a ${kid.roomTypes.join(' & ')}` : ''}.`;

const dateModified = kid.year ? `${kid.year}-01-01` : undefined;
---

<BaseLayout
  title={`${kid.name}'s Story`}
  description={metaDesc}
  ogType="article"
  jsonLd={kidSchemas}
  breadcrumbs={breadcrumbs}
  datePublished={kid.year ? `${kid.year}-01-01` : undefined}
  dateModified={dateModified}
>
  <article class="kid-profile" itemscope itemtype="https://schema.org/Article">
    <!-- ═══ Hero ═══════════════════════════════ -->
    <section class="hero">
      {kid.heroImage && (
        <div class="hero__image">
          <img
            src={cfUrl(kid.heroImage, 'w=1600,f=auto,q=85')}
            srcset={cfSrcset(kid.heroImage, [640, 1024, 1600, 2400])}
            sizes="100vw"
            alt={`Photo of ${kid.name}${kid.diagnosis ? ` — ${kid.diagnosis}` : ''}`}
            class="hero__img"
            width="1600"
            height="900"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            itemprop="image"
          />
          <div class="hero__gradient" aria-hidden="true"></div>
        </div>
      )}

      <div class="hero__content container container--narrow">
        <a href="/kids/" class="hero__back" aria-label="Back to all kids">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          All Kids
        </a>

        <h1 class="hero__name" itemprop="headline">{kid.name}</h1>

        <div class="hero__meta">
          {kid.age && (
            <span class="meta-pill">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
              {kid.age} years old
            </span>
          )}
          {kid.diagnosis && (
            <span class="meta-pill">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              {kid.diagnosis}
            </span>
          )}
          {kid.roomTypes && kid.roomTypes.length > 0 && kid.roomTypes.map(type => (
            <span class="meta-pill meta-pill--project">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              {type}
            </span>
          ))}
          {kid.year && (
            <span class="meta-pill meta-pill--year">{kid.year}</span>
          )}
          {kid.status === 'in-progress' && (
            <span class="meta-pill meta-pill--status">In Progress</span>
          )}
        </div>

        <button class="hero__share" id="share-btn" type="button" aria-label="Share this story">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          Share
        </button>
      </div>
    </section>

    <!-- ═══ Bio ════════════════════════════════ -->
    {kid.bio && (
      <section class="bio-section">
        <div class="container container--narrow">
          <div class="bio prose" itemprop="articleBody">
            {kid.bio.split('\n\n').map(paragraph => (
              <p>{paragraph}</p>
            ))}
          </div>

          {kid.quote && (
            <blockquote class="quote">
              <p>{kid.quote}</p>
            </blockquote>
          )}
        </div>
      </section>
    )}

    <!-- ═══ Video ══════════════════════════════ -->
    {hasVideo && (
      <section class="video-section section">
        <div class="container container--narrow">
          <h2 class="section-heading">Watch {kid.name}'s Story</h2>
          {streamId ? (
            <div class="video-wrap">
              <iframe
                src={`https://iframe.videodelivery.net/${streamId}`}
                title={`${kid.name}'s story video`}
                allow="accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture"
                allowfullscreen
                loading="lazy"
                class="video-iframe"
              ></iframe>
              {ytId && (
                <p class="video-yt-link">
                  <a href={`https://www.youtube.com/watch?v=${ytId}`} target="_blank" rel="noopener noreferrer">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    Watch on YouTube
                  </a>
                </p>
              )}
            </div>
          ) : ytId ? (
            <div class="yt-facade" id="yt-facade" data-id={ytId} role="button" tabindex="0" aria-label={`Play ${kid.name}'s video`}>
              <picture>
                <source type="image/webp" srcset={`https://i.ytimg.com/vi_webp/${ytId}/maxresdefault.webp`} />
                <img
                  src={`https://i.ytimg.com/vi/${ytId}/maxresdefault.jpg`}
                  alt={`Video thumbnail for ${kid.name}'s story`}
                  class="yt-facade__thumb"
                  loading="lazy"
                  decoding="async"
                />
              </picture>
              <div class="yt-facade__play" aria-hidden="true">
                <svg width="68" height="48" viewBox="0 0 68 48">
                  <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="red"/>
                  <path d="M45 24L27 14v20" fill="white"/>
                </svg>
              </div>
            </div>
          ) : null}
        </div>
      </section>
    )}

    <!-- ═══ Photo Gallery ══════════════════════ -->
    {photos.length > 1 && (
      <section class="gallery-section section section--cream">
        <div class="container container--wide">
          <div class="gallery-header">
            <h2 class="section-heading">Room Transformation</h2>
            {kid.photographer && (
              <p class="photographer-credit">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                Photos by {kid.photographer}
              </p>
            )}
          </div>
          <div class="masonry-gallery" id="gallery">
            {photos.slice(0, 30).map((photo, i) => (
              <button
                class="gallery-item"
                data-index={i}
                data-src={cfUrl(photo.url, 'w=1600,f=auto,q=85')}
                data-alt={photo.alt || `${kid.name}'s room transformation photo ${i + 1}`}
                aria-label={`View photo ${i + 1} of ${Math.min(photos.length, 30)}`}
                type="button"
              >
                <img
                  src={cfUrl(photo.url, 'w=500,f=auto,q=85')}
                  srcset={cfSrcset(photo.url, [300, 500])}
                  sizes="(max-width: 600px) 45vw, (max-width: 1100px) 30vw, 280px"
                  alt={photo.alt || `${kid.name}'s room transformation photo ${i + 1}`}
                  class="gallery-item__img"
                  loading="lazy"
                  decoding="async"
                  width="500"
                  height="500"
                />
              </button>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ═══ Partner Logos ══════════════════════ -->
    {kid.partnerLogos && kid.partnerLogos.length > 0 && (
      <section class="partners-section section">
        <div class="container">
          <h2 class="section-heading" style="text-align: center;">Project Partners</h2>
          <p class="partners-subtitle">This project was made possible by the generous support of these partners.</p>
          <div class="partners-grid">
            {kid.partnerLogos.map(logo => (
              <div class="partner-logo">
                <img
                  src={cfUrl(logo.url, 'w=200,f=auto,q=85')}
                  alt={logo.name || 'Project partner'}
                  loading="lazy"
                  decoding="async"
                  width="160"
                  height="80"
                />
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ═══ Related Kids ═══════════════════════ -->
    {relatedKids && relatedKids.length > 0 && (
      <section class="related-section section section--cream">
        <div class="container">
          <h2 class="section-heading" style="text-align: center;">More Sunshine Stories</h2>
          <div class="related-grid">
            {relatedKids.map(rk => (
              <a href={`/kids/${rk.slug}/`} class="related-card">
                <div class="related-card__frame">
                  <img
                    src={cfUrl(rk.heroImage, 'w=600,f=auto,q=85')}
                    srcset={cfSrcset(rk.heroImage, [300, 600])}
                    sizes="(max-width: 600px) 45vw, 220px"
                    alt={`Photo of ${rk.name}`}
                    class="related-card__img"
                    loading="lazy"
                    decoding="async"
                    width="300"
                    height="400"
                  />
                </div>
                <span class="related-card__name">{rk.name}</span>
                {rk.diagnosis && (
                  <span class="related-card__diagnosis">{rk.diagnosis}</span>
                )}
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ═══ Prev / Next Navigation ════════════ -->
    <nav class="kid-nav" aria-label="Navigate between kid profiles">
      <div class="container">
        <div class="kid-nav__grid">
          {prevKid ? (
            <a href={`/kids/${prevKid.slug}/`} class="kid-nav__link kid-nav__link--prev">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
              <div class="kid-nav__text">
                <span class="kid-nav__label">Previous</span>
                <span class="kid-nav__name">{prevKid.name}</span>
              </div>
            </a>
          ) : <div />}
          <a href="/kids/" class="kid-nav__center" aria-label="View all kids">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            All Kids
          </a>
          {nextKid ? (
            <a href={`/kids/${nextKid.slug}/`} class="kid-nav__link kid-nav__link--next">
              <div class="kid-nav__text" style="text-align: right;">
                <span class="kid-nav__label">Next</span>
                <span class="kid-nav__name">{nextKid.name}</span>
              </div>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          ) : <div />}
        </div>
      </div>
    </nav>

    <!-- ═══ CTA ═══════════════════════════════ -->
    <section class="cta-section section section--dark">
      <div class="container container--narrow" style="text-align: center;">
        <h2 class="cta-section__title">Help kids like {kid.name}</h2>
        <p class="cta-section__text">Every donation helps transform a child's living space into a place of comfort, safety, and joy.</p>
        <div class="cta-section__buttons">
          <Button href="/donate/" variant="primary">Donate Now</Button>
          <Button href="/about/" variant="outline">Learn More</Button>
        </div>
      </div>
    </section>
  </article>

  <!-- ═══ Lightbox ════════════════════════════ -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer" hidden>
    <div class="lightbox__backdrop" data-close aria-hidden="true"></div>
    <button class="lightbox__close" data-close aria-label="Close photo viewer">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <button class="lightbox__nav lightbox__nav--prev" id="lb-prev" aria-label="Previous photo">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button class="lightbox__nav lightbox__nav--next" id="lb-next" aria-label="Next photo">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
    <div class="lightbox__content">
      <img class="lightbox__img" id="lb-img" src="" alt="" tabindex="0" />
      <p class="lightbox__counter" id="lb-counter" aria-live="polite"></p>
    </div>
  </div>
</BaseLayout>

<!-- ═══ Client-side JS ═══════════════════════ -->
<script>
  let _kidObserver: IntersectionObserver | null = null;

  function cleanupKidPage() {
    _kidObserver?.disconnect();
    _kidObserver = null;
  }

  function initKidPage() {
    cleanupKidPage();

  // ── YouTube facade ──────────────────────
  const facade = document.getElementById('yt-facade');
  if (facade) {
    const activate = () => {
      const id = facade.dataset.id;
      const wrapper = document.createElement('div');
      wrapper.style.cssText = 'position:relative;aspect-ratio:16/9;border-radius:var(--border-radius-lg);overflow:hidden';
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0';
      wrapper.appendChild(iframe);
      facade.replaceWith(wrapper);
    };
    facade.addEventListener('click', activate);
    facade.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(); }
    });
  }

  // ── Lightbox ────────────────────────────
  const lightbox = document.getElementById('lightbox') as HTMLElement;
  const lbImg = document.getElementById('lb-img') as HTMLImageElement;
  const lbCounter = document.getElementById('lb-counter') as HTMLElement;
  const lbPrev = document.getElementById('lb-prev') as HTMLButtonElement;
  const lbNext = document.getElementById('lb-next') as HTMLButtonElement;
  const galleryItems = document.querySelectorAll<HTMLButtonElement>('.gallery-item');

  if (lightbox && galleryItems.length > 0) {
    let currentIndex = 0;
    let previousFocus: HTMLElement | null = null;
    const prefetched = new Set<string>();

    function showPhoto(index: number) {
      const item = galleryItems[index];
      if (!item) return;
      currentIndex = index;
      lbImg.src = item.dataset.src || '';
      lbImg.alt = item.dataset.alt || '';
      lbCounter.textContent = `${index + 1} / ${galleryItems.length}`;
      lbPrev.style.display = index === 0 ? 'none' : '';
      lbNext.style.display = index === galleryItems.length - 1 ? 'none' : '';
      // Preload adjacent images (deduplicated)
      [index - 1, index + 1].forEach(adj => {
        const src = galleryItems[adj]?.dataset.src;
        if (src && !prefetched.has(src)) {
          prefetched.add(src);
          const link = document.createElement('link');
          link.rel = 'prefetch';
          link.href = src;
          link.as = 'image';
          document.head.appendChild(link);
        }
      });
    }

    function openLightbox(index: number) {
      previousFocus = document.activeElement as HTMLElement;
      showPhoto(index);
      lightbox.hidden = false;
      document.body.style.overflow = 'hidden';
      lbImg.focus();
    }

    function closeLightbox() {
      lightbox.hidden = true;
      document.body.style.overflow = '';
      previousFocus?.focus();
    }

    // Focus trap: keep Tab/Shift+Tab within lightbox (WCAG 2.1 AA)
    function trapFocus(e: KeyboardEvent) {
      if (e.key !== 'Tab') return;
      const focusable = lightbox.querySelectorAll<HTMLElement>(
        'button:not([style*="display: none"]):not([hidden]), [tabindex="0"]'
      );
      const list = Array.from(focusable).filter(el => el.offsetParent !== null);
      if (list.length === 0) return;
      const first = list[0];
      const last = list[list.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }

    galleryItems.forEach((item, i) => {
      item.addEventListener('click', () => openLightbox(i));
    });

    lbPrev.addEventListener('click', () => showPhoto(currentIndex - 1));
    lbNext.addEventListener('click', () => showPhoto(currentIndex + 1));

    lightbox.querySelectorAll('[data-close]').forEach(el => {
      el.addEventListener('click', closeLightbox);
    });

    lightbox.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft' && currentIndex > 0) showPhoto(currentIndex - 1);
      if (e.key === 'ArrowRight' && currentIndex < galleryItems.length - 1) showPhoto(currentIndex + 1);
      trapFocus(e);
    });

    // Touch swipe support for mobile
    let touchStartX = 0;
    let touchStartY = 0;
    lightbox.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.changedTouches[0].screenX;
      touchStartY = e.changedTouches[0].screenY;
    }, { passive: true });

    lightbox.addEventListener('touchend', (e: TouchEvent) => {
      const dx = e.changedTouches[0].screenX - touchStartX;
      const dy = e.changedTouches[0].screenY - touchStartY;
      // Only horizontal swipes (not vertical scrolls)
      if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy) * 1.5) {
        if (dx < 0 && currentIndex < galleryItems.length - 1) showPhoto(currentIndex + 1);
        if (dx > 0 && currentIndex > 0) showPhoto(currentIndex - 1);
      }
    }, { passive: true });
  }

  // ── Share button ───────────────────────
  const shareBtn = document.getElementById('share-btn');
  if (shareBtn) {
    shareBtn.addEventListener('click', async () => {
      const shareData = {
        title: document.title,
        url: window.location.href,
      };
      try {
        if (navigator.share) {
          await navigator.share(shareData);
        } else {
          await navigator.clipboard.writeText(shareData.url);
          shareBtn.classList.add('shared');
          shareBtn.querySelector('svg')!.style.display = 'none';
          shareBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Copied!';
          setTimeout(() => {
            shareBtn.classList.remove('shared');
            shareBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg> Share';
          }, 2000);
        }
      } catch { /* user cancelled share */ }
    });
  }

  // ── Image fade-in on load ──────────────
  document.querySelectorAll<HTMLImageElement>('.gallery-item__img, .related-card__img, .hero__img').forEach(img => {
    if (img.complete && img.naturalWidth > 0) {
      img.classList.add('is-loaded');
    } else {
      img.addEventListener('load', () => img.classList.add('is-loaded'), { once: true });
    }
  });

  // ── Scroll reveal for sections ──────────
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    _kidObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add('revealed');
            _kidObserver?.unobserve(entry.target);
          }
        });
      },
      { rootMargin: '40px', threshold: 0.1 }
    );
    document.querySelectorAll('.bio-section, .gallery-section, .video-section, .partners-section').forEach(el => {
      el.classList.add('reveal-target');
      _kidObserver!.observe(el);
    });
  }

  } // end initKidPage

  document.addEventListener('astro:page-load', initKidPage);
  document.addEventListener('astro:before-swap', cleanupKidPage);
</script>

