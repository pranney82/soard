---
/**
 * Home Page — Sunshine on a Ranney Day
 * Cinematic hero, editorial layout, scroll reveals
 * Performance: self-hosted fonts, minimal JS, scoped CSS
 * SEO: JSON-LD NonprofitOrganization, semantic HTML5
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import MediaLogos from '../components/ui/MediaLogos.astro';

const CF = 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ';
const stats = { totalKids: 132, totalRooms: 106, years: 13 };
const partners = ['Gas South', 'Randall Paulson', 'Kids R Kids', 'Cambria', 'Mohawk', 'Jackson Healthcare', 'Crosby Design', 'MSI', 'CR Construction', 'Stag Partners', 'WYP'];

/* ── Hero Configuration ──────────────────────────────
   Update these when you upload assets:
   - heroImage: CF Images ID (e.g. "hero/reveal-moment")
   - heroVideo: direct URL to an MP4 loop (set '' to use photo only)
   - revealVideoId: YouTube ID for the modal (set '' to disable play btn)
─────────────────────────────────────────────────────── */
const heroImage  = 'hero/reveal-moment';          // CF Images ID — replace with your upload
const heroVideo  = '';                              // e.g. 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/hero/loop.mp4' or ''
const revealVideoId = '';                           // e.g. 'dQw4w9WgXcQ' (YouTube ID) or ''

import { getWebSiteSchema } from '../utils/schema';

// Homepage gets WebSite schema (enables sitelinks search box)
// Organization schema is now automatically included on every page via BaseLayout
const jsonLd = getWebSiteSchema();
---

<BaseLayout
  title="Building Dreams, One Room at a Time"
  description="Sunshine on a Ranney Day is a 501(c)(3) nonprofit creating life-changing home makeovers for children with special needs — dream bedrooms, accessible bathrooms, and therapy spaces — all at no cost to families in greater Atlanta."
  jsonLd={jsonLd}
>

  <!-- ══════ HERO — CINEMATIC FULL-BLEED ══════ -->
  <!-- 
    HERO CONFIG — Update these values when you have your assets:
    - heroImage: Cloudflare Images ID for the background photo (a reveal moment or happy child)
    - heroVideo: URL to an MP4 loop (5-10s, muted, ~2-4MB) — set to '' to disable
    - revealVideoId: YouTube video ID for the "Watch a Reveal" modal
  -->
  <section class="hero" aria-label="Introduction">
    <div class="hero-media">
      <!-- Video background (if available) — falls back to poster image -->
      {heroVideo ? (
        <video
          class="hero-video"
          autoplay
          muted
          loop
          playsinline
          poster={`${CF}/${heroImage}/w=1920,q=80`}
          preload="auto"
        >
          <source src={heroVideo} type="video/mp4" />
        </video>
      ) : (
        <picture>
          <source
            type="image/avif"
            srcset={`${CF}/${heroImage}/w=640,f=avif 640w, ${CF}/${heroImage}/w=1024,f=avif 1024w, ${CF}/${heroImage}/w=1600,f=avif 1600w, ${CF}/${heroImage}/w=2400,f=avif 2400w`}
            sizes="100vw"
          />
          <source
            type="image/webp"
            srcset={`${CF}/${heroImage}/w=640,f=webp 640w, ${CF}/${heroImage}/w=1024,f=webp 1024w, ${CF}/${heroImage}/w=1600,f=webp 1600w, ${CF}/${heroImage}/w=2400,f=webp 2400w`}
            sizes="100vw"
          />
          <img
            class="hero-img"
            src={`${CF}/${heroImage}/w=1600,q=80`}
            alt="A child seeing their dream room for the first time"
            width="1600"
            height="900"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </picture>
      )}
      <div class="hero-overlay"></div>
    </div>

    <div class="hero-inner">
      <div class="hero-content">
        <div class="hero-eyebrow" data-reveal>
          <span class="hero-eyebrow-line"></span>
          501(c)(3) Nonprofit · Atlanta, GA · Since 2012
        </div>
        <h1 data-reveal data-delay="1">
          Building <em>dreams</em>,<br/>one room at a time
        </h1>
        <p class="hero-lead" data-reveal data-delay="2">
          We create life-changing spaces for children with special needs — dream bedrooms, accessible bathrooms, and therapy rooms — all at <strong>no cost to families</strong>.
        </p>
        <div class="hero-ctas" data-reveal data-delay="3">
          <a href="/donate" class="btn btn-primary btn-glow">
            Give Today
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 2.5C6.5 1 4 1 2.75 2.75S2.5 6.5 8 11.5C13.5 6.5 13.75 4.5 13.25 2.75S9.5 1 8 2.5Z" fill="currentColor"/></svg>
          </a>
          {revealVideoId ? (
            <button class="btn btn-ghost-light" id="heroPlayBtn" type="button" aria-label="Watch a room reveal video">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="11" stroke="currentColor" stroke-width="1.5"/><path d="M10 8.5L16 12L10 15.5V8.5Z" fill="currentColor"/></svg>
              Watch a Reveal
            </button>
          ) : (
            <a href="#stories" class="btn btn-ghost-light">See Our Work ↓</a>
          )}
        </div>
        <div class="hero-proof" data-reveal data-delay="4">
          <span class="hero-proof-avatars" aria-hidden="true">
            <span class="hero-proof-dot" style="background:#F9C846;"></span>
            <span class="hero-proof-dot" style="background:#A78BFA;"></span>
            <span class="hero-proof-dot" style="background:#5EEAD4;"></span>
          </span>
          <span class="hero-proof-text">{stats.totalKids}+ families served across Greater Atlanta since 2012</span>
        </div>
      </div>

      <div class="hero-impact" data-reveal data-delay="4">
        <div class="hero-impact-num">{stats.totalKids}<span>+</span></div>
        <div class="hero-impact-label">children's lives<br/>transformed</div>
      </div>
    </div>

    <div class="hero-scroll" aria-hidden="true">
      <div class="hero-scroll-line"></div>
    </div>
  </section>

  <!-- ══════ VIDEO MODAL (lightweight — no iframe until play) ══════ -->
  {revealVideoId && (
    <div class="vmodal" id="heroModal" role="dialog" aria-modal="true" aria-label="Room reveal video" hidden data-video-id={revealVideoId}>
      <div class="vmodal-backdrop" id="heroModalClose"></div>
      <div class="vmodal-frame">
        <button class="vmodal-x" id="heroModalX" aria-label="Close video">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </button>
        <div class="vmodal-embed" id="heroModalEmbed">
          <!-- iframe injected on play, removed on close — saves ~800KB -->
        </div>
      </div>
    </div>
  )}

  <!-- ══════ IMPACT RIBBON ══════ -->
  <section class="ribbon" aria-label="Impact numbers">
    <div class="ribbon-inner">
      <div class="ribbon-stat" data-reveal>
        <span class="ribbon-num">{stats.totalRooms}+</span>
        <span class="ribbon-label">Room Makeovers</span>
      </div>
      <div class="ribbon-divider" role="presentation"></div>
      <div class="ribbon-stat" data-reveal data-delay="1">
        <span class="ribbon-num">{stats.totalKids}+</span>
        <span class="ribbon-label">Children Served</span>
      </div>
      <div class="ribbon-divider" role="presentation"></div>
      <div class="ribbon-stat" data-reveal data-delay="2">
        <span class="ribbon-num">{stats.years}</span>
        <span class="ribbon-label">Years of Impact</span>
      </div>
      <div class="ribbon-divider" role="presentation"></div>
      <div class="ribbon-stat" data-reveal data-delay="3">
        <span class="ribbon-num">100<span class="ribbon-pct">%</span></span>
        <span class="ribbon-label">Goes to Kids</span>
      </div>
    </div>
  </section>

  <!-- ══════ AS SEEN ON — MEDIA LOGO BAR ══════ -->
  <MediaLogos theme="dark" linked={true} />

  <!-- ══════ MISSION — EDITORIAL SPREAD ══════ -->
  <section class="mission" aria-labelledby="mission-heading">
    <div class="mission-inner">
      <div class="mission-text" data-reveal>
        <div class="section-label">Our Mission</div>
        <h2 id="mission-heading">A bedroom isn't just a room. It's where a child feels <em class="highlight">safe</em>, <em class="highlight">seen</em>, and <em class="highlight">loved</em>.</h2>
        <p class="mission-body">For children with special needs, a thoughtfully designed room changes everything. Sensory-friendly lighting that calms instead of overwhelms. Adaptive furniture that grants independence. Colors and themes chosen by the child — because this space is <em>theirs</em>.</p>
        <p class="mission-body">Since 2012, we've partnered with designers, contractors, and families across Greater Atlanta to create over {stats.totalRooms} life-changing spaces. Every project is different because every child is different.</p>
      </div>
      <div class="mission-visual" role="presentation">
        <div class="mission-photo mission-photo--main" data-reveal>
          <div class="mission-placeholder"><span>Room reveal photo</span></div>
        </div>
        <div class="mission-photo mission-photo--accent" data-reveal data-delay="1">
          <div class="mission-placeholder mission-placeholder--warm"><span>Happy child</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ FEATURED STORY — CINEMATIC ══════ -->
  <section class="story" id="stories" aria-labelledby="story-heading">
    <div class="story-split">
      <figure class="story-photo">
        <div class="story-photo-placeholder"></div>
        <div class="story-photo-tag">Latest Reveal</div>
      </figure>
      <div class="story-content" data-reveal>
        <div class="section-label">Featured Story</div>
        <span class="story-type">Dream Bedroom</span>
        <h2 id="story-heading">Amari's room was a revelation — for him and everyone who built it.</h2>
        <p>At 7, Amari loves dinosaurs more than anything. His cerebral palsy means his old bedroom wasn't designed for his needs. Our team of designers and builders transformed it into a prehistoric paradise — with custom murals, an accessible loft, adaptive furniture, and a sensory lighting system that helps him sleep.</p>
        <div class="story-partners">
          <div><span class="story-partner-label">Design</span><span class="story-partner-name">Crosby Design Group</span></div>
          <div><span class="story-partner-label">Build</span><span class="story-partner-name">CR Construction</span></div>
        </div>
        <a href="/kids" class="btn btn-dark">Read Amari's Full Story →</a>
      </div>
    </div>
  </section>

  <!-- ══════ MORE KIDS — HORIZONTAL SCROLL ══════ -->
  <section class="kids-strip" aria-labelledby="kids-heading">
    <div class="kids-strip-header" data-reveal>
      <div>
        <div class="section-label">More Stories</div>
        <h2 id="kids-heading">Every room changes a <em class="highlight">life</em></h2>
      </div>
      <a href="/kids" class="kids-strip-all">See all {stats.totalKids}+ kids →</a>
    </div>
    <div class="kids-scroll" role="list">
      <a href="/kids" class="kid-thumb" role="listitem">
        <div class="kid-thumb-photo"><span>👦🏻</span></div>
        <h4>Liam</h4>
        <p>Sensory Room · Age 5</p>
      </a>
      <a href="/kids" class="kid-thumb" role="listitem">
        <div class="kid-thumb-photo"><span>👧🏾</span></div>
        <h4>Sofia</h4>
        <p>Accessible Bath · Age 11</p>
      </a>
      <a href="/kids" class="kid-thumb" role="listitem">
        <div class="kid-thumb-photo"><span>👦🏽</span></div>
        <h4>Marcus</h4>
        <p>Dream Bedroom · Age 9</p>
      </a>
      <a href="/kids" class="kid-thumb" role="listitem">
        <div class="kid-thumb-photo"><span>👧🏻</span></div>
        <h4>Emma</h4>
        <p>Therapy Room · Age 7</p>
      </a>
      <a href="/kids" class="kid-thumb" role="listitem">
        <div class="kid-thumb-photo"><span>👦🏿</span></div>
        <h4>Jayden</h4>
        <p>Dream Bedroom · Age 10</p>
      </a>
    </div>
  </section>

  <!-- ══════ HOW IT WORKS — TIMELINE ══════ -->
  <section class="process" aria-labelledby="process-heading">
    <div class="process-inner">
      <div class="process-header" data-reveal>
        <div class="section-label">The Process</div>
        <h2 id="process-heading">From first call to <em class="highlight">big reveal</em></h2>
      </div>
      <ol class="timeline" role="list">
        <li class="timeline-step" data-reveal>
          <div class="timeline-marker" aria-hidden="true"><span>1</span></div>
          <div class="timeline-body">
            <h3>Family Applies</h3>
            <p>A simple application — families tell us about their child, their needs, and their dreams for a new space.</p>
          </div>
        </li>
        <li class="timeline-step" data-reveal data-delay="1">
          <div class="timeline-marker" aria-hidden="true"><span>2</span></div>
          <div class="timeline-body">
            <h3>Design & Plan</h3>
            <p>Our designer partners meet the family, learn the child's personality, and create a custom room concept.</p>
          </div>
        </li>
        <li class="timeline-step" data-reveal data-delay="2">
          <div class="timeline-marker" aria-hidden="true"><span>3</span></div>
          <div class="timeline-body">
            <h3>Build & Transform</h3>
            <p>Construction partners bring it to life — usually in just a few intense, loving days of work.</p>
          </div>
        </li>
        <li class="timeline-step" data-reveal data-delay="3">
          <div class="timeline-marker" aria-hidden="true"><span>4</span></div>
          <div class="timeline-body">
            <h3>The Big Reveal ✨</h3>
            <p>The moment. The child walks in, sees their new room, and everything changes. This is why we do it.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- ══════ ROOM TYPES — MAGAZINE CARDS ══════ -->
  <section class="rooms" aria-labelledby="rooms-heading">
    <div class="rooms-inner">
      <div class="rooms-header" data-reveal>
        <div class="section-label">What We Build</div>
        <h2 id="rooms-heading">Three types of spaces, one purpose: <em class="highlight">empowering kids</em></h2>
      </div>

      <div class="rooms-grid">
        <a href="/kids" class="room-tile" data-accent="bedroom" data-reveal>
          <div class="room-tile-photo"><div class="room-tile-placeholder">🛏️</div></div>
          <div class="room-tile-content">
            <span class="room-tile-tag">Most Popular</span>
            <h3>Dream Bedrooms</h3>
            <p>Personalized sanctuaries where children can escape, imagine, and simply be kids — designed around their unique interests and needs.</p>
            <span class="room-tile-link">See bedrooms →</span>
          </div>
        </a>

        <a href="/kids" class="room-tile" data-accent="bath" data-reveal data-delay="1">
          <div class="room-tile-photo"><div class="room-tile-placeholder">🚿</div></div>
          <div class="room-tile-content">
            <span class="room-tile-tag">Life-Changing</span>
            <h3>Accessible Bathrooms</h3>
            <p>Roll-in showers, grab bars, and lowered vanities — giving children independence and giving families relief from daily struggles.</p>
            <span class="room-tile-link">See bathrooms →</span>
          </div>
        </a>

        <a href="/kids" class="room-tile" data-accent="therapy" data-reveal data-delay="2">
          <div class="room-tile-photo"><div class="room-tile-placeholder">🧩</div></div>
          <div class="room-tile-content">
            <span class="room-tile-tag">Therapeutic</span>
            <h3>Sensory & Therapy Rooms</h3>
            <p>Calming retreats with dimmable lights, swings, crash pads, and textured walls — spaces where children can decompress and develop.</p>
            <span class="room-tile-link">See therapy rooms →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ══════ TRUST — DARK EDITORIAL ══════ -->
  <section class="trust" aria-labelledby="trust-heading">
    <div class="trust-inner">
      <div class="trust-header" data-reveal>
        <div class="section-label" style="color:var(--c-yellow)">Trust & Transparency</div>
        <h2 id="trust-heading">We're an open book. <em>Always.</em></h2>
        <p class="trust-subtitle">We believe you should know exactly where every dollar goes. Our financials are public, our mission is clear, and our track record speaks for itself.</p>
      </div>

      <div class="trust-grid">
        <div class="trust-card" data-reveal>
          <div class="trust-card-top">
            <span class="trust-big">87%</span>
            <span class="trust-card-label">Program Services</span>
          </div>
          <p>The vast majority of every dollar funds room materials, labor, and design for children's spaces.</p>
        </div>
        <div class="trust-card" data-reveal data-delay="1">
          <div class="trust-card-top">
            <span class="trust-big">📋</span>
            <span class="trust-card-label">990 Public</span>
          </div>
          <p>Our IRS Form 990 tax returns are available for anyone to review, anytime.</p>
        </div>
        <div class="trust-card" data-reveal data-delay="2">
          <div class="trust-card-top">
            <span class="trust-big">✅</span>
            <span class="trust-card-label">501(c)(3)</span>
          </div>
          <p>Registered nonprofit. EIN 45-4773997. All donations are fully tax-deductible.</p>
        </div>
      </div>

      <div class="trust-cta" data-reveal>
        <a href="/about/financials" class="btn btn-ghost-light">View Our Financials →</a>
      </div>
    </div>
  </section>

  <!-- ══════ PARTNERS MARQUEE ══════ -->
  <section class="marquee" aria-label="Our partners">
    <div class="marquee-label">Trusted Partners Who Make It Possible</div>
    <div class="marquee-track" aria-hidden="true">
      {[...partners, ...partners, ...partners].map(name => (
        <div class="marquee-logo">{name}</div>
      ))}
    </div>
  </section>

  <!-- ══════ FINAL CTA — FULL BLEED YELLOW ══════ -->
  <section class="finale" aria-labelledby="cta-heading">
    <div class="finale-inner">
      <img src={`${CF}/sunny-pig/nav`} alt="" class="finale-pig" width="80" height="80" aria-hidden="true" loading="lazy" />
      <h2 id="cta-heading" data-reveal>A room can change a child's life.<br/><em>You</em> can make it happen.</h2>
      <p data-reveal data-delay="1">Every donation — every dollar — goes directly to building dream spaces for children with special needs in the Atlanta area. No middlemen. No overhead bloat. Just kids, rooms, and community.</p>
      <div class="finale-ctas" data-reveal data-delay="2">
        <a href="/donate" class="btn btn-dark btn-lg">Donate Today</a>
        <a href="/get-involved/apply" class="btn btn-outline-dark">Apply for a Room</a>
      </div>
      <p class="finale-note" data-reveal data-delay="3">All donations tax-deductible · 501(c)(3) · EIN 45-4773997</p>
    </div>
  </section>

</BaseLayout>

<style>
  /* ══════════════════════════════════════════
     HERO — Cinematic Full-Bleed (Best-in-Class)
     ══════════════════════════════════════════ */
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: flex-end;
    padding-bottom: 80px;
    overflow: hidden;
  }

  /* ── Background Media ── */
  .hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-img,
  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    animation: heroKenBurns 20s ease-in-out infinite alternate;
  }
  .hero-video {
    animation: none; /* videos have their own motion */
  }
  @keyframes heroKenBurns {
    0%   { transform: scale(1)    translate(0, 0); }
    100% { transform: scale(1.06) translate(-0.5%, -1%); }
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to top,
        rgba(26, 27, 31, 0.92) 0%,
        rgba(26, 27, 31, 0.55) 35%,
        rgba(26, 27, 31, 0.25) 60%,
        rgba(26, 27, 31, 0.15) 100%
      );
    /* subtle vignette for drama */
    box-shadow: inset 0 0 160px rgba(0, 0, 0, 0.25);
  }

  /* ── Content Layout ── */
  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--page-padding);
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }
  .hero-content { max-width: 680px; }

  /* ── Eyebrow ── */
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: 28px;
  }
  .hero-eyebrow-line {
    width: 32px;
    height: 1px;
    background: var(--c-yellow);
    flex-shrink: 0;
  }

  /* ── Heading ── */
  .hero h1 {
    font-size: clamp(40px, 6vw, 72px);
    color: #fff;
    line-height: 1.08;
    margin-bottom: 24px;
    letter-spacing: -0.03em;
    text-shadow: 0 2px 40px rgba(0,0,0,0.3);
  }
  .hero h1 em {
    font-style: italic;
    color: var(--c-yellow);
  }

  /* ── Lead Paragraph ── */
  .hero-lead {
    font-size: clamp(16px, 2vw, 19px);
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
    max-width: 540px;
    margin-bottom: 36px;
  }
  .hero-lead strong { color: #fff; }

  /* ── CTAs ── */
  .hero-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }
  .btn-glow {
    animation: pulseGlow 3s ease-in-out infinite;
  }
  @keyframes pulseGlow {
    0%, 100% { box-shadow: 0 8px 24px rgba(255, 218, 36, 0.3); }
    50% { box-shadow: 0 8px 40px rgba(255, 218, 36, 0.55); }
  }
  .btn-ghost-light {
    background: transparent;
    color: #fff;
    border: 1.5px solid rgba(255,255,255,0.25);
    backdrop-filter: blur(4px);
  }
  .btn-ghost-light:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.4);
    transform: translateY(-3px);
  }

  /* ── Social Proof Line ── */
  .hero-proof {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .hero-proof-avatars {
    display: flex;
    gap: 0;
  }
  .hero-proof-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1.5px solid rgba(26,27,31,0.8);
    margin-left: -3px;
  }
  .hero-proof-dot:first-child { margin-left: 0; }
  .hero-proof-text {
    font-size: 13px;
    color: rgba(255,255,255,0.35);
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  /* ── Floating Stat Badge ── */
  .hero-impact {
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(16px);
