<script>
  /* ── Sunny & Ranney: hero photo parallax ── */
  let _srScrollHandler: (() => void) | null = null;

  function srCleanup() {
    if (_srScrollHandler) window.removeEventListener('scroll', _srScrollHandler);
    _srScrollHandler = null;
  }

  function initSRPage() {
    const hero = document.querySelector('.sr-hero') as HTMLElement;
    if (!hero) return;

    srCleanup();

    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const photo = hero.querySelector('.sr-photo-main img') as HTMLElement;
      if (photo) {
        const heroH = hero.offsetHeight || window.innerHeight;
        let ticking = false;
        _srScrollHandler = function () {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            const scrollY = window.scrollY;
            if (scrollY < heroH) {
              photo.style.setProperty('--parallax-y', `${scrollY * 0.06}px`);
            }
            ticking = false;
          });
        };
        window.addEventListener('scroll', _srScrollHandler, { passive: true });
      }
    }
  }

  document.addEventListener('astro:page-load', initSRPage);
  document.addEventListener('astro:before-swap', srCleanup);
</script>
