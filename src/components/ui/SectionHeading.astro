---
/**
 * SectionHeading.astro
 * Section heading with optional yellow highlight on a keyword,
 * optional subtitle, and alignment control.
 */
interface Props {
  align?: 'left' | 'center';
  tag?: 'h1' | 'h2' | 'h3';
  subtitle?: string;
  class?: string;
}

const { align = 'center', tag: Tag = 'h2', subtitle, class: className = '' } = Astro.props;
---

<div class:list={['section-heading', `section-heading--${align}`, className]}>
  <Tag class="section-heading__title">
    <slot />
  </Tag>
  {subtitle && <p class="section-heading__subtitle">{subtitle}</p>}
</div>

<style>
  .section-heading {
    margin-bottom: var(--space-2xl);
  }

  .section-heading--center { text-align: center; }
  .section-heading--left { text-align: left; }

  .section-heading__title {
    font-size: clamp(1.625rem, 3vw + 0.5rem, 2.5rem);
  }

  .section-heading__subtitle {
    margin-top: var(--space-sm);
    font-size: 1.05rem;
    color: var(--c-text-muted);
    max-width: 640px;
  }

  .section-heading--center .section-heading__subtitle {
    margin-inline: auto;
  }
</style>
