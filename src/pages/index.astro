    opacity: 0;
    animation: pillarIn 0.7s cubic-bezier(0.16,1,0.3,1) both;
    animation-delay: calc(0.8s + var(--pi) * 0.12s);
  }
  .pillar:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 48px rgba(0,0,0,0.1), 0 8px 20px rgba(0,0,0,0.04);
