---
/**
 * CFImage.astro — Responsive Cloudflare Images component
 *
 * Single component for all CF Images on the site.
 * Accepts full URLs or bare image IDs. Generates proper srcset
 * with width descriptors and Cloudflare Image transforms.
 *
 * imagedelivery.net auto-negotiates AVIF → WebP → JPEG via Accept header.
 * format=auto is never appended (only needed on /cdn-cgi/image/ URLs).
 *
 * Non-CF URLs pass through as a plain <img>.
 */
import { cfUrl, cfSrcset, isCF, type TransformOpts, type SrcsetOpts } from '../../utils/cf-image';

interface Props {
  /** Full CF Images URL or bare image ID (e.g. "kids/amari/hero") */
  src: string;
  alt: string;
  width?: number;
  height?: number;
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
  style?: string;
  /** Responsive widths for srcset (px). Default: [400, 640, 800, 1024, 1600] */
  widths?: number[];
  /** Quality 1–100 (default 85) */
  quality?: number;
  /** Resize fit mode */
  fit?: TransformOpts['fit'];
  /** Gravity / focal point */
  gravity?: TransformOpts['gravity'];
  /** Aspect ratio (height/width) for proportional cropping at each breakpoint */
  aspectRatio?: number;
}

const {
  src,
  alt,
  width,
  height,
  sizes = '(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw',
  loading = 'lazy',
  fetchpriority,
  class: className = '',
  style = '',
  widths = [400, 640, 800, 1024, 1600],
  quality = 85,
  fit,
  gravity,
  aspectRatio,
} = Astro.props;

const cf = isCF(src);

const srcsetOpts: SrcsetOpts = { quality };
if (fit) srcsetOpts.fit = fit;
if (gravity) srcsetOpts.gravity = gravity;
if (aspectRatio) srcsetOpts.aspectRatio = aspectRatio;

const resolvedSrcset = cf ? cfSrcset(src, widths, srcsetOpts) : undefined;

// Fallback src uses second-to-last width (good balance of quality vs size)
const fallbackW = widths[widths.length - 2] || widths[widths.length - 1];
const fallbackOpts: TransformOpts = { w: fallbackW, q: quality };
if (fit) fallbackOpts.fit = fit;
if (gravity) fallbackOpts.gravity = gravity;
if (aspectRatio) fallbackOpts.h = Math.round(fallbackW * aspectRatio);
const resolvedSrc = cf ? cfUrl(src, fallbackOpts) : src;
---

<img
  src={resolvedSrc}
  srcset={resolvedSrcset}
  alt={alt}
  width={width}
  height={height}
  sizes={cf ? sizes : undefined}
  loading={loading}
  decoding="async"
  fetchpriority={fetchpriority}
  class:list={[className]}
  style={style}
/>
