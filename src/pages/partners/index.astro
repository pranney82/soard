---
/**
 * Partners Page — Sunshine on a Ranney Day
 * Top 1% editorial partner showcase with emotional narrative arc
 *
 * STRUCTURE:
 * 1. Hero — Editorial split (photo + bold typography with striking stat)
 * 2. Signature Partners — Magazine-style feature cards
 * 3. Impact Ribbon — Static stats strip (years, rooms, kids, partners)
 * 4. Champion Partners — Elevated grid on cream
 * 5. Editorial Interstitial — Large pull-quote
 * 6. Builder Partners — Dark refined grid
 * 7. All Partners — Filterable grid with smooth UX
 * 8. Ways to Partner — CTA cards
 * 9. CTA — Yellow emotional close
 *
 * PERF NOTES:
 * - Hero has NO data-reveal (LCP critical)
 * - Partner logos: lazy-loaded, density srcset at display size
 * - content-visibility: auto on friend grid (387+ cards)
 * - contain: content on all grids for layout perf
 * - All images via CF Images CDN
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { cfRaw, cfId, cfDensitySrcset, cfSrcset, cfLqip } from '../../utils/cf-image';
import { getWebPageSchema, getBreadcrumbSchema, buildSchemaGraph } from '../../utils/schema';
import { getSiteStats } from '../../utils/stats';

/* ── Site settings (editable from admin) ── */
import siteSettings from '../../content/site/settings.json';

/* ── Impact Moment (admin-editable via site settings) ── */
const impactQuote = siteSettings.partnerQuote || "Seeing the look on a child\u2019s face when they walk into their new room \u2014 that\u2019s why we show up every build day.";
const impactCiteName = siteSettings.partnerQuoteName || 'Lee Hainer';
const impactCiteOrg = siteSettings.partnerQuoteOrg || 'Lee Hainer Construction';
const heroPhoto = siteSettings.partnerPhoto || 'kids/oakley/photo-15';

/* ── Stats ── */
const stats = await getSiteStats();

/* ── All partners from content collection ── */
const allPartners = await getCollection('partners');

/* ── Sort by order, then alphabetically ── */
const sorted = [...allPartners].sort((a, b) =>
  (a.data.order || 0) - (b.data.order || 0) || a.data.name.localeCompare(b.data.name)
);

/* ── Level groups ── */
const signature = sorted.filter(p => p.data.level === 'signature');
const champions = sorted.filter(p => p.data.level === 'champion');
const builders  = sorted.filter(p => p.data.level === 'builder');
const friends   = sorted.filter(p => p.data.level === 'friend');

/* ── Category counts (for filter tab labels) ── */
const catCounts = {
  all: allPartners.length,
  build: allPartners.filter(p => p.data.category.includes('build')).length,
  design: allPartners.filter(p => p.data.category.includes('design')).length,
  funding: allPartners.filter(p => p.data.category.includes('funding')).length,
  community: allPartners.filter(p => p.data.category.includes('community')).length,
};

/* ── Schema ── */
const pageUrl = 'https://sunshineonaranneyday.com/partners/';
const pageDesc = `Meet the ${allPartners.length}+ partners who donate materials, labor, design, and funding to build life-changing rooms for children with special needs — all at no cost to families.`;
const breadcrumbs = [
  { name: 'Home', url: 'https://sunshineonaranneyday.com/' },
  { name: 'Partners', url: pageUrl },
];
const jsonLd = buildSchemaGraph(
  getWebPageSchema({ url: pageUrl, title: 'Our Partners', description: pageDesc }),
  getBreadcrumbSchema(breadcrumbs, pageUrl),
);
---

<BaseLayout
  title="Our Partners — Who Makes It Happen"
  description={pageDesc}
  jsonLd={jsonLd}
  breadcrumbs={breadcrumbs}
>

  <!-- Preload hero LCP image -->
  <link slot="head" rel="preload" as="image" imagesrcset={`${cfRaw(heroPhoto, 'w=400,h=500,fit=cover,gravity=auto,q=65')} 400w, ${cfRaw(heroPhoto, 'w=560,h=700,fit=cover,gravity=auto,q=65')} 560w, ${cfRaw(heroPhoto, 'w=800,h=1000,fit=cover,gravity=auto,q=65')} 800w`} imagesizes="(max-width:768px) 85vw, 420px" fetchpriority="high" />

  <!-- ══════ HERO — Editorial Split ══════ -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <p class="hero-eyebrow">Our Partners</p>
        <h1 class="hero-headline">The people who make <em>dreams</em> possible.</h1>
        <p class="hero-lead">Every room we build is a community effort. These incredible partners donate their time, talent, materials, and funding to transform the lives of children with special needs.</p>
        <div class="hero-ctas">
          <a href="#signature" class="btn btn-primary btn-lg">Meet Our Partners &darr;</a>
          <a href="mailto:info@soardcharity.com" class="btn btn-outline-dark btn-lg">Become a Partner &rarr;</a>
        </div>
      </div>
      <div class="hero-photo-wrap">
        <div class="hero-frame" style={`background-image:url('${cfLqip(heroPhoto)}')`}>
          <img
            src={cfRaw(heroPhoto, 'w=800,h=1000,fit=cover,gravity=auto,q=65')}
            srcset={`${cfRaw(heroPhoto, 'w=400,h=500,fit=cover,gravity=auto,q=65')} 400w, ${cfRaw(heroPhoto, 'w=560,h=700,fit=cover,gravity=auto,q=65')} 560w, ${cfRaw(heroPhoto, 'w=800,h=1000,fit=cover,gravity=auto,q=65')} 800w`}
            sizes="(max-width:768px) 85vw, 420px"
            alt="Partners and volunteers working together on a SOARD room build"
            width="800" height="1000"
            fetchpriority="high"
            loading="eager"
            decoding="sync"
            class="hero-img lqip-img"
          />
        </div>
        <div class="hero-accent" aria-hidden="true"></div>
        <div class="hero-stat">
          <span class="hero-stat-num">{allPartners.length}+</span>
          <span class="hero-stat-label">partners building<br/>dreams since 2012</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ SIGNATURE PARTNERS — MAGAZINE FEATURE ══════ -->
  {signature.length > 0 && (
    <section class="sig" id="signature" aria-labelledby="sig-heading">
      <div class="sig-inner">
        <div class="sig-header" data-reveal>
          <div class="section-label section-label--yellow">Signature Partners</div>
          <h2 id="sig-heading">The partners who <em>define</em> our mission</h2>
          <p class="sig-lead">These extraordinary organizations are the backbone of every build season — contributing at the highest level year after year.</p>
        </div>
        <div class="sig-grid" data-reveal data-delay="1">
          {signature.map(p => {
            const hasLink = !!p.data.website;
            const hasLogo = !!p.data.logo;
            const Tag = hasLink ? 'a' : 'div';
            return (
              <Tag
                class:list={['sig-card', { 'sig-card--linked': hasLink }]}
                {...(hasLink ? { href: p.data.website, target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                <div class="sig-card__logo">
                  {hasLogo ? (
                    <img
                      src={cfRaw(p.data.logo, 'w=400,h=120,fit=contain,q=85')}
                      srcset={cfDensitySrcset(cfId(p.data.logo), 200, 60, { quality: 85, fit: 'contain' })}
                      alt={p.data.name}
                      width="200" height="60"
                      loading="lazy" decoding="async"
                    />
                  ) : (
                    <span class="logo-placeholder">{p.data.name}</span>
                  )}
                </div>
                <div class="sig-card__info">
                  <h3 class="sig-card__name">{p.data.name}</h3>
                  {p.data.tagline && <p class="sig-card__tagline">{p.data.tagline}</p>}
                </div>
                {hasLink && (
                  <span class="sig-card__arrow" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
                  </span>
                )}
              </Tag>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ══════ IMPACT RIBBON — STATIC STATS ══════ -->
  <section class="ribbon" aria-label="Impact statistics">
    <div class="ribbon-inner" data-reveal>
      <div class="ribbon-stat">
        <span class="ribbon-stat__number">{stats.years}</span>
        <span class="ribbon-stat__label">Years of impact</span>
      </div>
      <div class="ribbon-divider" aria-hidden="true"></div>
      <div class="ribbon-stat">
        <span class="ribbon-stat__number">{stats.totalRooms}</span>
        <span class="ribbon-stat__label">Rooms built</span>
      </div>
      <div class="ribbon-divider" aria-hidden="true"></div>
      <div class="ribbon-stat">
        <span class="ribbon-stat__number">{stats.totalKids}</span>
        <span class="ribbon-stat__label">Children served</span>
      </div>
      <div class="ribbon-divider" aria-hidden="true"></div>
      <div class="ribbon-stat">
        <span class="ribbon-stat__number">{allPartners.length}+</span>
        <span class="ribbon-stat__label">Partners strong</span>
      </div>
    </div>
  </section>

  <!-- ══════ CHAMPION PARTNERS ══════ -->
  {champions.length > 0 && (
    <section class="champ" id="champions" aria-labelledby="champ-heading">
      <div class="champ-inner">
        <div class="champ-header" data-reveal>
          <div class="section-label">Champion Partners</div>
          <h2 id="champ-heading">Champions of <em class="highlight">Sunshine</em></h2>
          <p class="champ-lead">Major sponsors and top contributors who make an outsized impact through funding, materials, and expertise.</p>
        </div>
        <div class="champ-grid" data-reveal data-delay="1">
          {champions.map(p => {
            const hasLink = !!p.data.website;
            const hasLogo = !!p.data.logo;
            const Tag = hasLink ? 'a' : 'div';
            return (
              <Tag
                class:list={['champ-card', { 'champ-card--linked': hasLink }]}
                {...(hasLink ? { href: p.data.website, target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                <div class="champ-card__logo">
                  {hasLogo ? (
                    <img
                      src={cfRaw(p.data.logo, 'w=280,h=80,fit=contain,q=80')}
                      srcset={cfDensitySrcset(cfId(p.data.logo), 140, 40, { quality: 80, fit: 'contain' })}
                      alt={p.data.name}
                      width="140" height="40"
                      loading="lazy" decoding="async"
                    />
                  ) : (
                    <span class="logo-placeholder">{p.data.name}</span>
                  )}
                </div>
                <span class="champ-card__name">{p.data.name}</span>
                {hasLink && (
                  <svg class="champ-card__ext" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
                )}
              </Tag>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ══════ EDITORIAL INTERSTITIAL — PULL QUOTE ══════ -->
  <section class="interstitial" aria-label="Partner testimonial">
    <div class="interstitial-inner">
      <div class="interstitial-content" data-reveal>
        <blockquote class="interstitial-quote">
          <svg class="interstitial-mark" viewBox="0 0 48 48" fill="currentColor" aria-hidden="true"><path d="M21 7.2v1.6C14.4 12 10 17.6 10 24v17h17V24H17c0-6 3-10.8 8-13.6L21 7.2zm24 0v1.6C38.4 12 34 17.6 34 24v17h17V24H41c0-6 3-10.8 8-13.6L45 7.2z" opacity=".12"/></svg>
          <p>&ldquo;{impactQuote}&rdquo;</p>
          <footer>
            <cite>{impactCiteName}</cite>
            <span>{impactCiteOrg}</span>
          </footer>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ══════ BUILDER PARTNERS ══════ -->
  {builders.length > 0 && (
    <section class="build" id="builders" aria-labelledby="build-heading">
      <div class="build-inner">
        <div class="build-header" data-reveal>
          <div class="section-label section-label--yellow">Builder Partners</div>
          <h2 id="build-heading">The hands & hearts behind every <em>room</em></h2>
          <p class="build-lead">These partners donate materials, labor, and services on a regular basis. They are the hands and hearts behind every room we build.</p>
        </div>
        <div class="build-grid" data-reveal data-delay="1">
          {builders.map(p => {
            const hasLink = !!p.data.website;
            const hasLogo = !!p.data.logo;
            const Tag = hasLink ? 'a' : 'div';
            return (
              <Tag
                class:list={['build-card', { 'build-card--linked': hasLink }]}
                {...(hasLink ? { href: p.data.website, target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                <div class="build-card__logo">
                  {hasLogo ? (
                    <img
                      src={cfRaw(p.data.logo, 'w=200,h=64,fit=contain,q=80')}
                      srcset={cfDensitySrcset(cfId(p.data.logo), 100, 32, { quality: 80, fit: 'contain' })}
                      alt={p.data.name}
                      width="100" height="32"
                      loading="lazy" decoding="async"
                    />
                  ) : (
                    <span class="logo-placeholder">{p.data.name}</span>
                  )}
                </div>
                <span class="build-card__name">{p.data.name}</span>
              </Tag>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ══════ ALL PARTNERS — FILTERABLE ══════ -->
  <section class="all" id="all" aria-labelledby="all-heading">
    <div class="all-inner">
      <div class="all-header" data-reveal>
        <div class="section-label">Every Partner</div>
        <h2 id="all-heading">The full roster of <em class="highlight">dream-builders</em></h2>
        <p class="all-lead">{allPartners.length}+ organizations and individuals who have donated time, materials, or funding to SOARD since 2012.</p>
      </div>

      <!-- Filter tabs -->
      <div class="filter-tabs" role="tablist" aria-label="Filter partners by category" data-reveal data-delay="1">
        <button class="filter-tab is-active" role="tab" aria-selected="true" data-cat="all">
          All <span class="filter-tab__count">{catCounts.all}</span>
        </button>
        <button class="filter-tab" role="tab" aria-selected="false" data-cat="build">
          Build <span class="filter-tab__count">{catCounts.build}</span>
        </button>
        <button class="filter-tab" role="tab" aria-selected="false" data-cat="design">
          Design <span class="filter-tab__count">{catCounts.design}</span>
        </button>
        <button class="filter-tab" role="tab" aria-selected="false" data-cat="funding">
          Funding <span class="filter-tab__count">{catCounts.funding}</span>
        </button>
        <button class="filter-tab" role="tab" aria-selected="false" data-cat="community">
          Community <span class="filter-tab__count">{catCounts.community}</span>
        </button>
      </div>

      <p class="filter-count" aria-live="polite" style="display:none;"></p>

      <div class="all-grid" role="tabpanel" aria-label="Filtered partners" data-reveal data-delay="2">
        {sorted.map(p => {
          const hasLink = !!p.data.website;
          const Tag = hasLink ? 'a' : 'div';
          return (
            <Tag
              class:list={['ap-card', { 'ap-card--linked': hasLink }]}
              data-category={p.data.category.join(',')}
              {...(hasLink ? { href: p.data.website, target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              <div class="ap-card__logo">
                {!!p.data.logo ? (
                  <img
                    src={cfRaw(p.data.logo, 'w=180,h=64,fit=contain,q=75')}
                    srcset={cfDensitySrcset(cfId(p.data.logo), 90, 32, { quality: 75, fit: 'contain' })}
                    alt={p.data.name}
                    width="90" height="32"
                    loading="lazy" decoding="async"
                  />
                ) : (
                  <span class="logo-placeholder">{p.data.name}</span>
                )}
              </div>
              <span class="ap-card__name">{p.data.name}</span>
            </Tag>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ══════ WAYS TO PARTNER ══════ -->
  <section class="ways" id="ways" aria-labelledby="ways-heading">
    <div class="ways-inner">
      <div class="ways-header" data-reveal>
        <div class="section-label section-label--yellow">Get Involved</div>
        <h2 id="ways-heading">Ways to <em>partner</em> with us</h2>
        <p class="ways-lead">Whether you're a contractor, designer, brand, or individual — there's a place for you.</p>
      </div>
      <div class="ways-grid" data-reveal data-delay="1">
        <div class="way-card">
          <div class="way-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
          </div>
          <h3 class="way-card__title">Donate Materials</h3>
          <p class="way-card__desc">Flooring, paint, furniture, windows, countertops — every material makes a room possible.</p>
        </div>
        <div class="way-card">
          <div class="way-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.106-3.105c.32-.322.863-.22.983.218a6 6 0 0 1-8.259 7.057l-7.91 7.91a1 1 0 0 1-2.999-3l7.91-7.91a6 6 0 0 1 7.057-8.259c.438.12.54.662.219.984z"/></svg>
          </div>
          <h3 class="way-card__title">Volunteer Your Skills</h3>
          <p class="way-card__desc">Construction, design, photography, media — bring your expertise to a build day.</p>
        </div>
        <div class="way-card">
          <div class="way-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"/></svg>
          </div>
          <h3 class="way-card__title">Sponsor a Room</h3>
          <p class="way-card__desc">A gift of $10,000+ funds a complete room build for a child with special needs.</p>
        </div>
        <div class="way-card">
          <div class="way-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.128a4 4 0 0 1 0 7.744"/></svg>
          </div>
          <h3 class="way-card__title">Corporate Partnership</h3>
          <p class="way-card__desc">Year-round programs for companies who want to make a lasting, visible impact.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ CTA ══════ -->
  <section class="partners-cta" aria-labelledby="cta-heading">
    <div class="partners-cta-inner">
      <div class="partners-cta-content" data-reveal>
        <h2 id="cta-heading">Every dream room starts with a partner who says <em>yes</em>.</h2>
        <p>Join {allPartners.length}+ organizations building something bigger than any one of us.</p>
        <div class="partners-cta-btns">
          <a href="mailto:info@soardcharity.com" class="btn btn-primary btn-cta">Become a Partner &rarr;</a>
          <a href="/donate" class="btn btn-dark">Donate Today &rarr;</a>
        </div>
        <p class="partners-cta-note">501(c)(3) &middot; EIN 45-4773997 &middot; All donations tax-deductible</p>
      </div>
    </div>
  </section>

</BaseLayout>

<!-- ══════ CLIENT-SIDE FILTER ══════ -->
<script>
  function initPartnerFilters() {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
    const cards = document.querySelectorAll<HTMLElement>('.ap-card');
    const counter = document.querySelector<HTMLElement>('.filter-count');
    if (!tabs.length || !cards.length) return;

    function applyFilter(cat: string) {
      tabs.forEach(t => {
        t.classList.toggle('is-active', t.dataset.cat === cat);
        t.setAttribute('aria-selected', String(t.dataset.cat === cat));
      });

      let visible = 0;
      cards.forEach(card => {
        const show = cat === 'all' || (card.dataset.category || '').split(',').includes(cat);
        card.classList.toggle('is-hidden', !show);
        if (show) visible++;
      });

      if (counter) {
        const label = cat === 'all' ? 'all' : cat;
        counter.textContent = `Showing ${visible} ${label} partner${visible !== 1 ? 's' : ''}`;
        counter.style.display = cat === 'all' ? 'none' : '';
      }

      const hash = cat === 'all' ? '#all' : `#all:${cat}`;
      history.replaceState(null, '', hash);
    }

    // Click
    tabs.forEach(tab => {
      tab.addEventListener('click', () => applyFilter(tab.dataset.cat!));
    });

    // Keyboard arrow-key navigation (WAI-ARIA tabs pattern)
    tabs.forEach((tab, i) => {
      tab.addEventListener('keydown', (e: KeyboardEvent) => {
        let target: number | null = null;
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
          target = (i + 1) % tabs.length;
        } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
          target = (i - 1 + tabs.length) % tabs.length;
        } else if (e.key === 'Home') {
          target = 0;
        } else if (e.key === 'End') {
          target = tabs.length - 1;
        }
        if (target !== null) {
          e.preventDefault();
          tabs[target].focus();
          applyFilter(tabs[target].dataset.cat!);
        }
      });
    });

    // Restore from URL hash on load
    const hash = location.hash;
    if (hash.startsWith('#all:')) {
      const cat = hash.slice(5);
      if (['build', 'design', 'funding', 'community'].includes(cat)) {
        applyFilter(cat);
      }
    }
  }

  document.addEventListener('astro:page-load', initPartnerFilters);
</script>

<style>
  /* ══════════════════════════════════════════
     PAGE-LEVEL DATA-REVEAL
     ══════════════════════════════════════════ */
  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1),
                transform 0.7s cubic-bezier(0.16,1,0.3,1);
  }
  [data-reveal].is-visible { opacity: 1; transform: translateY(0); }
  [data-delay="1"] { transition-delay: 0.12s; }
  [data-delay="2"] { transition-delay: 0.24s; }
  [data-delay="3"] { transition-delay: 0.36s; }

  /* ══════════════════════════════════════════
     PAGE-SPECIFIC OVERRIDES
     ══════════════════════════════════════════ */
  .section-label--dark { color: var(--c-dark); }
  .section-label--dark::before { background: var(--c-dark); }

  h2 :global(em:not(.highlight)) {
    font-style: italic;
    color: var(--c-yellow);
  }

  /* ══════════════════════════════════════════
     HERO — EDITORIAL SPLIT (WTG pattern)
     ══════════════════════════════════════════ */
  .hero {
    position: relative;
    background: var(--c-cream);
    contain: layout style;
    padding: clamp(40px, 8vh, 100px) 0 40px;
    overflow: hidden;
  }

  .hero-inner {
    max-width: var(--max-width-wide, 1400px);
    margin: 0 auto;
    padding: 0 var(--space-lg);
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(32px, 5vw, 80px);
    align-items: center;
    min-height: clamp(480px, 70vh, 720px);
  }

  .hero-eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-text-light);
    margin-bottom: 28px;
    opacity: 0;
    animation: heroUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.05s both;
  }

  .hero-headline {
    font-size: clamp(42px, 6.5vw, 88px);
    line-height: 1.04;
    letter-spacing: -0.035em;
    color: var(--c-dark);
    margin-bottom: 28px;
    animation: heroSlide 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero-headline em {
    font-style: italic;
    background-image: linear-gradient(transparent 52%, var(--c-yellow-soft, rgba(255, 218, 36, 0.3)) 52%);
    background-repeat: no-repeat;
    background-size: 100% 100%;
    padding: 0 0.05em;
  }

  .hero-lead {
    font-size: clamp(16px, 1.3vw, 19px);
    line-height: 1.7;
    color: var(--c-text-muted);
    max-width: 480px;
    margin-bottom: 36px;
    opacity: 0;
    animation: heroUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
  }

  .hero-ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    opacity: 0;
    animation: heroUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.25s both;
  }

  .hero-photo-wrap {
    position: relative;
    animation: heroPhotoIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero-frame {
    display: block;
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.12), 0 8px 24px rgba(0, 0, 0, 0.06);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-frame:hover img { transform: scale(1.03); }

  .hero-accent {
    position: absolute;
    z-index: -1;
    bottom: -16px;
    right: -16px;
    width: 55%;
    height: 55%;
    border-radius: 20px;
    background: var(--c-yellow);
    opacity: 0.35;
  }

  .hero-stat {
    position: absolute;
    bottom: -24px;
    left: -24px;
    background: var(--c-dark);
    color: #fff;
    border-radius: 16px;
    padding: 20px 28px;
    text-align: center;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.15);
    opacity: 0;
    animation: heroUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both;
  }

  .hero-stat-num {
    font-family: var(--font-display);
    font-size: 40px;
    font-weight: 700;
    color: var(--c-yellow);
    line-height: 1;
    display: block;
  }

  .hero-stat-label {
    display: block;
    font-size: 12px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    margin-top: 4px;
    line-height: 1.4;
  }

  @keyframes heroUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes heroSlide {
    from { transform: translateY(20px); }
    to { transform: translateY(0); }
  }
  @keyframes heroPhotoIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow, .hero-lead, .hero-ctas,
    .hero-photo-wrap, .hero-stat { opacity: 1; transform: none; animation: none; }
  }

  @media (max-width: 768px) {
    .hero { padding: clamp(28px, 6vh, 60px) 0 24px; }
    .hero-inner {
      grid-template-columns: 1fr;
      min-height: auto;
      gap: var(--space-xl);
    }
    .hero-text { text-align: center; }
    .hero-lead { max-width: 100%; margin-inline: auto; }
    .hero-ctas { justify-content: center; }
    .hero-photo-wrap { max-width: 360px; margin: 0 auto; }
    .hero-stat { left: -12px; bottom: -16px; padding: 14px 20px; }
    .hero-stat-num { font-size: 28px; }
  }

  @media (max-width: 480px) {
    .hero-ctas { flex-direction: column; }
    .hero-ctas .btn { width: 100%; justify-content: center; }
  }

  /* ══════════════════════════════════════════
     LOGO PLACEHOLDER (shared across tiers)
     ══════════════════════════════════════════ */
  .logo-placeholder {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--c-text-muted);
    text-align: center;
    line-height: 1.2;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sig-card__logo .logo-placeholder { font-size: 1rem; }
  .champ-card__logo .logo-placeholder { font-size: 0.8125rem; }
  .build-card__logo .logo-placeholder { font-size: 0.75rem; }
  .ap-card__logo .logo-placeholder { font-size: 0.6875rem; }

  /* ══════════════════════════════════════════
     SIGNATURE PARTNERS — MAGAZINE FEATURE
     ══════════════════════════════════════════ */
  .sig {
    background: var(--c-dark);
    color: var(--c-white);
    padding-block: var(--space-4xl);
  }

  .sig-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding-inline: var(--space-lg);
  }

  .sig-header {
    max-width: 640px;
    margin-bottom: var(--space-2xl);
  }

  .sig-header h2 {
    color: var(--c-white);
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: var(--space-md);
  }

  .sig-lead {
    font-size: clamp(0.95rem, 1.5vw, 1.065rem);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.55);
  }

  .sig-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
    contain: content;
  }

  .sig-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 40px 32px;
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: var(--border-radius-lg);
    text-align: center;
    text-decoration: none;
    transition: border-color var(--transition-base),
                transform 0.35s cubic-bezier(0.16,1,0.3,1),
                box-shadow 0.35s cubic-bezier(0.16,1,0.3,1);
    will-change: transform;
  }

  .sig-card--linked:hover {
    border-color: var(--c-yellow);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(255, 218, 36, 0.15);
  }

  .sig-card__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 64px;
  }

  .sig-card__logo img {
    max-height: 64px;
    width: auto;
    object-fit: contain;
    transition: opacity var(--transition-base);
  }

  .sig-card__name {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--c-dark);
  }

  .sig-card__tagline {
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--c-text-muted);
    margin-top: -8px;
  }

  .sig-card__arrow {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--c-border);
    transition: color var(--transition-base);
  }
  .sig-card__arrow svg { width: 16px; height: 16px; }
  .sig-card--linked:hover .sig-card__arrow { color: var(--c-yellow); }

  @media (max-width: 640px) {
    .sig-grid { grid-template-columns: 1fr; }
    .sig-card { padding: 28px 20px; }
  }

  /* ══════════════════════════════════════════
     IMPACT RIBBON — STATS STRIP
     ══════════════════════════════════════════ */
  .ribbon {
    background: var(--c-yellow);
    padding-block: var(--space-2xl);
  }

  .ribbon-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding-inline: var(--space-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2xl);
  }

  .ribbon-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-align: center;
  }

  .ribbon-stat__number {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--c-dark);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .ribbon-stat__label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-dark);
    opacity: 0.55;
  }

  .ribbon-divider {
    width: 1px;
    height: 40px;
    background: var(--c-dark);
    opacity: 0.15;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .ribbon { padding-block: var(--space-xl); }
    .ribbon-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-lg);
    }
    .ribbon-divider { display: none; }
  }

  /* ══════════════════════════════════════════
     CHAMPION PARTNERS
     ══════════════════════════════════════════ */
  .champ {
    background: var(--c-cream);
    padding-block: var(--space-4xl);
  }

  .champ-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding-inline: var(--space-lg);
  }

  .champ-header {
    max-width: 640px;
    margin-bottom: var(--space-2xl);
  }

  .champ-header h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: var(--space-md);
  }

  .champ-lead {
    font-size: clamp(0.95rem, 1.5vw, 1.065rem);
    line-height: 1.65;
    color: var(--c-text-muted);
  }

  .champ-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 12px;
    contain: content;
  }

  .champ-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 28px 20px;
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: var(--border-radius);
    text-align: center;
    min-height: 130px;
    text-decoration: none;
    transition: border-color var(--transition-base),
                box-shadow 0.35s cubic-bezier(0.16,1,0.3,1),
                transform 0.35s cubic-bezier(0.16,1,0.3,1);
    will-change: transform;
  }

  .champ-card--linked:hover {
    border-color: var(--c-yellow);
    box-shadow: 0 6px 24px rgba(255, 218, 36, 0.12);
    transform: translateY(-3px);
  }

  .champ-card__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 48px;
  }

  .champ-card__logo img {
    max-height: 48px;
    width: auto;
    object-fit: contain;
  }

  .champ-card__name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--c-text-muted);
    line-height: 1.3;
  }

  .champ-card__ext {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 14px;
    height: 14px;
    color: var(--c-border);
    transition: color var(--transition-base);
  }

  .champ-card--linked:hover .champ-card__ext {
    color: var(--c-yellow);
  }

  @media (max-width: 480px) {
    .champ-grid { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); }
    .champ-card { min-height: 100px; padding: 20px 14px; }
  }

  /* ══════════════════════════════════════════
     EDITORIAL INTERSTITIAL — PULL QUOTE
     ══════════════════════════════════════════ */
  .interstitial {
    background: var(--c-warm-gray);
    padding-block: var(--space-4xl);
  }

  .interstitial-inner {
    max-width: 720px;
    margin: 0 auto;
    padding-inline: var(--space-lg);
  }

  .interstitial-content {
    text-align: center;
  }

  .interstitial-quote {
    position: relative;
    margin: 0;
  }

  .interstitial-mark {
    width: 48px;
    height: 48px;
    color: var(--c-yellow);
    margin-bottom: var(--space-md);
  }

  .interstitial-quote p {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.25rem, 2.8vw, 1.625rem);
    line-height: 1.5;
    color: var(--c-text);
    letter-spacing: -0.01em;
  }

  .interstitial-quote footer {
    margin-top: var(--space-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .interstitial-quote cite {
    font-family: var(--font-body);
    font-style: normal;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--c-dark);
    letter-spacing: 0.02em;
  }

  .interstitial-quote footer span {
    font-size: 0.8125rem;
    color: var(--c-text-muted);
  }

  @media (max-width: 640px) {
    .interstitial { padding-block: var(--space-2xl); }
    .interstitial-mark { width: 36px; height: 36px; }
  }

  /* ══════════════════════════════════════════
     BUILDER PARTNERS
     ══════════════════════════════════════════ */
  .build {
    background: var(--c-dark);
    color: var(--c-white);
    padding-block: var(--space-4xl);
  }

  .build-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding-inline: var(--space-lg);
  }

  .build-header {
    max-width: 640px;
    margin-bottom: var(--space-2xl);
  }

  .build-header h2 {
    color: var(--c-white);
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: var(--space-md);
  }

  .build-lead {
    font-size: clamp(0.95rem, 1.5vw, 1.065rem);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.55);
  }

  .build-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 10px;
    contain: content;
  }

  .build-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 22px 14px;
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: var(--border-radius);
    text-align: center;
    min-height: 100px;
    text-decoration: none;
    transition: border-color var(--transition-base),
                transform 0.35s cubic-bezier(0.16,1,0.3,1),
                box-shadow 0.35s cubic-bezier(0.16,1,0.3,1);
    will-change: transform;
  }

  .build-card--linked:hover {
    border-color: var(--c-yellow);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(255, 218, 36, 0.12);
  }

  .build-card__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 36px;
  }

  .build-card__logo img {
    max-height: 36px;
    width: auto;
    object-fit: contain;
    transition: opacity var(--transition-base);
  }

  .build-card__name {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--c-text-muted);
    line-height: 1.3;
  }

  @media (max-width: 480px) {
    .build-grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); }
    .build-card { min-height: 80px; padding: 16px 10px; }
  }

  /* ══════════════════════════════════════════
     ALL PARTNERS — FILTERABLE GRID
     ══════════════════════════════════════════ */
  .all {
    background: var(--c-cream);
    padding-block: var(--space-4xl);
  }

  .all-inner {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-inline: var(--space-lg);
  }

  .all-header {
    max-width: 640px;
    margin-bottom: var(--space-xl);
  }

  .all-header h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: var(--space-md);
  }

  .all-lead {
    font-size: clamp(0.95rem, 1.5vw, 1.065rem);
    line-height: 1.65;
    color: var(--c-text-muted);
  }

  /* ── Filter Tabs ── */
  .filter-tabs {
    position: relative;
    display: flex;
    gap: 6px;
    margin-bottom: var(--space-lg);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 4px;
  }
  .filter-tabs::-webkit-scrollbar { display: none; }

  /* Scroll affordance on mobile */
  @media (max-width: 600px) {
    .filter-tabs {
      -webkit-mask-image: linear-gradient(90deg, #000 85%, transparent);
      mask-image: linear-gradient(90deg, #000 85%, transparent);
    }
  }

  .filter-count {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--c-text-muted);
    margin-bottom: var(--space-md);
  }

  .filter-tab {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 18px;
    font-size: 0.8125rem;
    font-weight: 600;
    font-family: var(--font-body);
    color: var(--c-text-muted);
    background: transparent;
    border: 1px solid var(--c-border);
    border-radius: 100px;
    cursor: pointer;
    transition: all var(--transition-fast);
    white-space: nowrap;
  }

  .filter-tab:hover {
    border-color: var(--c-text-muted);
    color: var(--c-text);
  }

  .filter-tab:focus-visible {
    outline: 2px solid var(--c-yellow);
    outline-offset: 2px;
  }

  .filter-tab.is-active {
    background: var(--c-dark);
    color: var(--c-white);
    border-color: var(--c-dark);
  }

  .filter-tab__count {
    font-size: 0.6875rem;
    font-weight: 500;
    opacity: 0.6;
  }

  .filter-tab.is-active .filter-tab__count { opacity: 0.5; }

  /* ── Grid ── */
  .all-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
    gap: 8px;
    contain: content;
    content-visibility: auto;
    contain-intrinsic-size: auto 5000px;
  }

  .ap-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 18px 12px;
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: var(--border-radius);
    text-align: center;
    min-height: 90px;
    text-decoration: none;
    transition: border-color var(--transition-fast),
                box-shadow var(--transition-fast),
                opacity 0.25s ease;
  }

  .ap-card.is-hidden {
    display: none;
  }

  .ap-card--linked:hover {
    border-color: var(--c-yellow);
    box-shadow: 0 2px 12px rgba(255, 218, 36, 0.08);
  }

  .ap-card__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 32px;
  }

  .ap-card__logo img {
    max-height: 32px;
    width: auto;
    object-fit: contain;
    filter: grayscale(0.3);
    transition: filter var(--transition-base);
  }

  .ap-card--linked:hover .ap-card__logo img { filter: grayscale(0); }

  .ap-card__name {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--c-text-muted);
    line-height: 1.3;
  }

  @media (max-width: 600px) {
    .all-grid {
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 6px;
    }
    .ap-card { padding: 14px 8px; min-height: 76px; }
  }

  /* ══════════════════════════════════════════
     WAYS TO PARTNER
     ══════════════════════════════════════════ */
  .ways {
    background: var(--c-dark);
    color: var(--c-white);
    padding-block: var(--space-4xl);
  }

  .ways-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding-inline: var(--space-lg);
  }

  .ways-header {
    max-width: 640px;
    margin-bottom: var(--space-2xl);
  }

  .ways-header h2 {
    color: var(--c-white);
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: var(--space-md);
  }

  .ways-lead {
    font-size: clamp(0.95rem, 1.5vw, 1.065rem);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.55);
  }

  .ways-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 14px;
