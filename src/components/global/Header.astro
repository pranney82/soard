  document.addEventListener('click', function (e) {
    /* Close dropdown when clicking a link inside it (navigating away) */
    if (e.target.closest('.dd-link')) { closeAllDD(); return; }
    /* Close dropdown when clicking outside the nav */
    if (!e.target.closest('.nav-item') && !e.target.closest('.dd-morph')) closeAllDD();
  }, { signal: sig });

  window.addEventListener('resize', function () { if (activeGroup >= 0) closeAllDD(); }, { signal: sig });

  /* ═══════ SLIDING INDICATOR ═══════ */
  function posInd(el) {
    if (!indicator || !desktopNav) return;
    var nr = desktopNav.getBoundingClientRect();
    var er = el.getBoundingClientRect();
    indicator.style.width = er.width + 'px';
    indicator.style.transform = 'translateX(' + (er.left - nr.left) + 'px)';
    indicator.style.opacity = '1';
  }
  function resetInd() {
    if (!indicator) return;
    var ab = document.querySelector('.nav-link.parent-active');
    if (ab) posInd(ab); else indicator.style.opacity = '0';
  }
  navButtons.forEach(function (b) { b.addEventListener('mouseenter', function () { posInd(this); }); });
  // Also track direct nav links for the indicator
  document.querySelectorAll('.nav-item > a.nav-link').forEach(function (a) {
    a.addEventListener('mouseenter', function () { posInd(this); });
  });
  if (desktopNav) desktopNav.addEventListener('mouseleave', resetInd);
  requestAnimationFrame(function () {
    var ab = document.querySelector('.nav-link.parent-active');
    if (ab && indicator) { indicator.style.transition = 'none'; posInd(ab); requestAnimationFrame(function () { indicator.style.transition = ''; }); }
  });

  /* ═══════ KEYBOARD NAV ═══════ */
  var navList = document.querySelector('.nav-list');
  if (navList) {
    navList.addEventListener('keydown', function (e) {
      var t = e.target;
      var isBtn = t.matches('.nav-item > button');
      var parent = t.closest('.nav-item[data-nav-group]');
      if (!parent) return;
      var gi = parseInt(parent.dataset.navGroup);

      if (isBtn) {
        switch (e.key) {
