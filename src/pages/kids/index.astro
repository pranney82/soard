---
/**
 * Meet the Kids — Bespoke hero + premium grid with filtering
 *
 * PERF: gravity=face on CF Images, optimized srcsets, LCP preload,
 *       content-visibility, shimmer placeholders, smooth filter animations
 * SEO:  CollectionPage + ItemList + FAQPage schema, breadcrumbs, rich meta
 * A11Y: proper heading hierarchy, ARIA labels, focus management, 44px targets
 * UX:   Face collage hero, cinematic featured card, mobile bottom-sheet filters
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allKids = await getCollection('kids');
const kids = allKids
  .sort((a, b) => (b.data.year || 0) - (a.data.year || 0));

const years = [...new Set(kids.map(k => k.data.year).filter(Boolean))].sort((a, b) => b - a);
const roomTypes = [...new Set(kids.flatMap(k => k.data.roomTypes || []))].sort();
const hasInProgress = kids.some(k => k.data.status === 'in-progress');
const totalKids = kids.length;

// ── CF Image helpers ──────────────────────
const CF_BASE = 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ';
function cfUrl(src: string, opts: string) {
  if (!src || !src.includes('imagedelivery.net')) return src;
  const id = src.replace(`${CF_BASE}/`, '').replace('/public', '');
  return `${CF_BASE}/${id}/${opts}`;
}
/** Srcset with proportional height + face-crop at each breakpoint.
 *  hwRatio = height/width (e.g. 4/3 for portrait, 9/21 for cinematic) */
function cfCropSrcset(src: string, widths: number[], hwRatio: number) {
  return widths.map(w => {
    const h = Math.round(w * hwRatio);
    return `${cfUrl(src, `w=${w},h=${h},fit=cover,gravity=face,f=auto,q=80`)} ${w}w`;
  }).join(', ');
}

// ── Stats ────────────────────────────────
const completedCount = kids.filter(k => k.data.status === 'completed').length;
const inProgressCount = kids.filter(k => k.data.status === 'in-progress').length;
const startYear = years.length > 0 ? years[years.length - 1] : '';
const yearRange = startYear ? `Since ${startYear}` : '';

// ── SEO ──────────────────────────────────
const SITE = 'https://sunshineonaranneyday.com';
const pageDescription = `Meet ${totalKids} children whose lives were transformed by Sunshine on a Ranney Day — dream bedrooms, accessible bathrooms, therapy rooms, and more. ${completedCount} projects completed${inProgressCount > 0 ? `, ${inProgressCount} in progress` : ''}.`;

const itemListSchema = {
  "@type": "CollectionPage",
  "@id": `${SITE}/kids/#collectionpage`,
  "name": "Meet the Kids — Sunshine on a Ranney Day",
  "description": pageDescription,
  "url": `${SITE}/kids/`,
  "isPartOf": { "@id": `${SITE}/#website` },
  "about": { "@id": `${SITE}/#organization` },
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": totalKids,
    "itemListElement": kids.slice(0, 50).map((kid, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `${SITE}/kids/${kid.data.slug}/`,
      "name": kid.data.name,
      ...(kid.data.heroImage ? { "image": cfUrl(kid.data.heroImage, 'w=600,f=auto,q=80') } : {}),
    })),
  },
};

const faqSchema = {
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What does Sunshine on a Ranney Day do for children?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Sunshine on a Ranney Day transforms the living spaces of children with serious illnesses or disabilities. We've completed ${completedCount} projects${inProgressCount > 0 ? ` with ${inProgressCount} currently in progress` : ''}, creating dream bedrooms, accessible bathrooms, and therapy rooms tailored to each child's specific needs.`
      }
    },
    {
      "@type": "Question",
      "name": "How can I help a child through Sunshine on a Ranney Day?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You can support our mission by donating, volunteering for room builds, or nominating a child in need. Visit our donate page or contact us to learn more about how you can make a difference."
      }
    },
  ],
};

const breadcrumbs = [
  { name: 'Home', url: SITE },
  { name: 'Meet the Kids', url: `${SITE}/kids/` },
];

// ── Featured kid = most recent with hero image ──
const featuredKid = kids.find(k => k.data.heroImage);
const gridKids = [...kids];

// ── Hero face collage: 12 diverse kids across years ──
const heroFacePool = kids.filter(k => k.data.heroImage?.includes('imagedelivery.net'));
// Round-robin across years for visual diversity
const yearGroups: Record<number, typeof heroFacePool> = {};
heroFacePool.forEach(k => {
  const y = k.data.year || 0;
  (yearGroups[y] ||= []).push(k);
});
const sortedYears = Object.keys(yearGroups).map(Number).sort((a, b) => b - a);
const heroFaces: typeof heroFacePool = [];
let yi = 0;
while (heroFaces.length < 12 && yi < sortedYears.length * 3) {
  const bucket = yearGroups[sortedYears[yi % sortedYears.length]];
  const pick = bucket.shift();
  if (pick) heroFaces.push(pick);
  yi++;
}

// ── LCP: Preload featured card image ──
const featuredImgSrcset = featuredKid?.data.heroImage
  ? cfCropSrcset(featuredKid.data.heroImage, [640, 960, 1400], 9/21)
  : '';
const featuredImgSizes = '(max-width: 768px) 100vw, (max-width: 1100px) 80vw, 1200px';

// ── Pull quote from featured kid ──
const featuredQuote = featuredKid?.data.quote
  || (featuredKid?.data.bio
    ? featuredKid.data.bio.split(/[.!]/).filter((s: string) => s.trim().length > 20 && s.trim().length < 120)[0]?.trim()
    : null);
---

<BaseLayout
  title="Meet the Kids"
  description={pageDescription}
  jsonLd={[itemListSchema, faqSchema]}
  breadcrumbs={breadcrumbs}
>
  <!-- LCP preload: featured card image -->
  {featuredKid?.data.heroImage && (
    <link slot="head" rel="preload" as="image" imagesrcset={featuredImgSrcset} imagesizes={featuredImgSizes} fetchpriority="high" />
  )}

  <!-- ══════ HERO — Face Collage + Headline + Stats ══════ -->
  <section class="kids-hero" aria-label="Meet the Kids">
    <div class="kids-hero__inner">
      <div class="kids-hero__text">
        <p class="kids-hero__label">Our Kids</p>
        <h1 class="kids-hero__title">Meet our <em class="highlight">Sunshine</em> Kids</h1>
        <p class="kids-hero__subtitle">{totalKids} children. {completedCount} lives transformed. Discover the incredible stories behind every room we build.</p>
      </div>

      <!-- Face constellation -->
      <div class="faces" aria-label={`Photos of ${heroFaces.length} children helped by SOARD`}>
        {heroFaces.map((kid, i) => (
          <a
            href={`/kids/${kid.data.slug}/`}
            class="face"
            style={`--i:${i}`}
            aria-label={kid.data.name}
          >
            <img
              src={cfUrl(kid.data.heroImage, 'w=140,h=140,fit=cover,gravity=face,f=auto,q=80')}
              alt={kid.data.name}
              width="70"
              height="70"
              loading="eager"
              decoding="async"
            />
          </a>
        ))}
      </div>

      <!-- Impact stats inline -->
      <div class="hero-stats" aria-label="Impact statistics">
        <div class="hero-stat">
          <span class="hero-stat__num">{totalKids}</span>
          <span class="hero-stat__label">Kids Helped</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat__num">{completedCount}</span>
          <span class="hero-stat__label">Rooms Built</span>
        </div>
        {inProgressCount > 0 && (
          <div class="hero-stat">
            <span class="hero-stat__num">{inProgressCount}</span>
            <span class="hero-stat__label">In Progress</span>
          </div>
        )}
        <div class="hero-stat">
          <span class="hero-stat__num">{yearRange}</span>
          <span class="hero-stat__label">& Counting</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ FEATURED KID — Cinematic Full-Bleed ══════ -->
  {featuredKid && (
    <section class="featured-section">
      <div class="container container--wide">
        <a
          href={`/kids/${featuredKid.data.slug}/`}
          class="featured"
          aria-label={`Featured: ${featuredKid.data.name}'s story`}
          data-year={`year-${featuredKid.data.year}`}
          data-types={(featuredKid.data.roomTypes || []).map(t => `type-${t.toLowerCase().replace(/\s+/g, '-')}`).join(' ')}
          data-name={featuredKid.data.name.toLowerCase()}
          data-diagnosis={(featuredKid.data.diagnosis || '').toLowerCase()}
          data-status={featuredKid.data.status || 'completed'}
        >
          <div class="featured__media">
            <img
              src={cfUrl(featuredKid.data.heroImage, 'w=960,h=411,fit=cover,gravity=face,f=auto,q=82')}
              srcset={featuredImgSrcset}
              sizes={featuredImgSizes}
              alt={`Photo of ${featuredKid.data.name}${featuredKid.data.diagnosis ? ` — ${featuredKid.data.diagnosis}` : ''}`}
              class="featured__img"
              width="960"
              height="411"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
            <div class="featured__gradient"></div>
          </div>
          <div class="featured__overlay">
            <span class="featured__label">Latest Story</span>
            <h2 class="featured__name">{featuredKid.data.name}</h2>
            {featuredKid.data.diagnosis && (
              <p class="featured__diagnosis">{featuredKid.data.diagnosis}</p>
            )}
            {featuredQuote && (
              <p class="featured__quote">&ldquo;{featuredQuote}&rdquo;</p>
            )}
            <div class="featured__meta">
              {featuredKid.data.roomTypes && featuredKid.data.roomTypes.length > 0 && (
                <div class="featured__tags">
                  {featuredKid.data.roomTypes.map(type => (
                    <span class="featured__tag">{type}</span>
                  ))}
                </div>
              )}
              {featuredKid.data.status === 'in-progress' && (
                <span class="featured__badge">In Progress</span>
              )}
            </div>
            <span class="featured__cta">Read their story <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- ══════ GRID SECTION ══════ -->
  <section class="kids-section">
    <div class="container container--wide">

      <!-- Toolbar -->
      <div class="toolbar" id="toolbar">
        <div class="toolbar__row">
          <div class="search-box">
            <svg class="search-box__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input
              type="search"
              id="kid-search"
              class="search-box__input"
              placeholder="Search by name or diagnosis..."
              aria-label="Search kids by name or diagnosis"
              autocomplete="off"
            />
            <button class="search-box__clear" id="search-clear" type="button" aria-label="Clear search" hidden>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </div>

          <!-- Desktop filters -->
          <div class="toolbar__filters toolbar__filters--desktop">
            <select id="filter-year" class="filter-select" aria-label="Filter by year">
              <option value="all">All Years</option>
              {years.map(year => (
                <option value={`year-${year}`}>{year}</option>
              ))}
            </select>

            <select id="filter-type" class="filter-select" aria-label="Filter by project type">
              <option value="all">All Projects</option>
              {roomTypes.map(type => (
                <option value={`type-${type.toLowerCase().replace(/\s+/g, '-')}`}>{type}</option>
              ))}
            </select>

            {hasInProgress && (
              <button class="pill-toggle" id="filter-status" aria-pressed="false">
                <span class="pill-toggle__dot" aria-hidden="true"></span>
                In Progress
              </button>
            )}
          </div>

          <!-- Mobile filter button -->
          <button class="filter-btn-mobile" id="filter-btn-mobile" type="button" aria-label="Open filters">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="20" y2="12"/><line x1="12" y1="18" x2="20" y2="18"/></svg>
            Filters
            <span class="filter-btn-mobile__count" id="mobile-filter-count" hidden></span>
          </button>
        </div>

        <div class="toolbar__status" aria-live="polite" aria-atomic="true">
          <span class="result-count" id="result-count">
            Showing <strong id="visible-count">{gridKids.length}</strong> of {gridKids.length} kids
          </span>
          <button class="clear-btn" id="clear-filters" hidden aria-label="Clear all filters">
            Clear filters
          </button>
        </div>
      </div>

      <!-- Mobile Bottom Sheet -->
      <div class="bottom-sheet" id="bottom-sheet" aria-hidden="true">
        <div class="bottom-sheet__backdrop" id="sheet-backdrop"></div>
        <div class="bottom-sheet__panel" role="dialog" aria-label="Filter options">
          <div class="bottom-sheet__handle" aria-hidden="true"><span></span></div>
          <div class="bottom-sheet__header">
            <h3 class="bottom-sheet__title">Filters</h3>
            <button class="bottom-sheet__close" id="sheet-close" type="button" aria-label="Close filters">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </div>
          <div class="bottom-sheet__body">
            <div class="sheet-group">
              <label class="sheet-label" for="sheet-year">Year</label>
              <select id="sheet-year" class="sheet-select" aria-label="Filter by year">
                <option value="all">All Years</option>
                {years.map(year => (
                  <option value={`year-${year}`}>{year}</option>
                ))}
              </select>
            </div>
            <div class="sheet-group">
              <label class="sheet-label" for="sheet-type">Project Type</label>
              <select id="sheet-type" class="sheet-select" aria-label="Filter by project type">
                <option value="all">All Projects</option>
                {roomTypes.map(type => (
                  <option value={`type-${type.toLowerCase().replace(/\s+/g, '-')}`}>{type}</option>
                ))}
              </select>
            </div>
            {hasInProgress && (
              <div class="sheet-group">
                <button class="pill-toggle pill-toggle--sheet" id="sheet-status" aria-pressed="false">
                  <span class="pill-toggle__dot" aria-hidden="true"></span>
                  In Progress Only
                </button>
              </div>
            )}
          </div>
          <div class="bottom-sheet__footer">
            <button class="btn btn-dark btn--sm" id="sheet-clear" type="button">Clear All</button>
            <button class="btn btn-yellow btn--sm" id="sheet-apply" type="button">Show Results</button>
          </div>
        </div>
      </div>

      <!-- Kid Grid -->
      <h2 class="sr-only">All kid profiles</h2>
      <div class="kids-grid" id="kids-grid">
        {gridKids.map((kid, i) => (
          <a
            href={`/kids/${kid.data.slug}/`}
            class="kid-card"
            data-year={`year-${kid.data.year}`}
            data-types={(kid.data.roomTypes || []).map(t => `type-${t.toLowerCase().replace(/\s+/g, '-')}`).join(' ')}
            data-name={kid.data.name.toLowerCase()}
            data-diagnosis={(kid.data.diagnosis || '').toLowerCase()}
            data-status={kid.data.status || 'completed'}
          >
            <div class="kid-card__frame">
              {kid.data.heroImage ? (
                <img
                  src={cfUrl(kid.data.heroImage, 'w=340,h=453,fit=cover,gravity=face,f=auto,q=80')}
                  srcset={cfCropSrcset(kid.data.heroImage, [170, 340, 520, 680], 4/3)}
                  sizes="(max-width: 768px) calc(50vw - 30px), (max-width: 1100px) calc(33vw - 27px), 260px"
                  alt={`Photo of ${kid.data.name}${kid.data.diagnosis ? `, diagnosed with ${kid.data.diagnosis}` : ''} — Sunshine on a Ranney Day`}
                  class="kid-card__img"
                  width="340"
                  height="453"
                  loading={i < 8 ? 'eager' : 'lazy'}
                  decoding="async"
                  fetchpriority={i < 2 ? 'high' : undefined}
                />
              ) : (
                <div class="kid-card__placeholder" aria-hidden="true">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
              )}
              <div class="kid-card__hover-overlay" aria-hidden="true">
                {kid.data.diagnosis && (
                  <span class="kid-card__overlay-diagnosis">{kid.data.diagnosis}</span>
                )}
                <span class="kid-card__cta">Read their story &rarr;</span>
              </div>
            </div>
            <div class="kid-card__info">
              <span class="kid-card__name">{kid.data.name}</span>
              {kid.data.status === 'in-progress' && (
                <span class="kid-card__badge">In Progress</span>
              )}
            </div>
            {kid.data.diagnosis && (
              <span class="kid-card__diagnosis">{kid.data.diagnosis}</span>
            )}
          </a>
        ))}
      </div>

      <!-- No results -->
      <div class="no-results" id="no-results" hidden>
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="8" x2="14" y2="14"/><line x1="14" y1="8" x2="8" y2="14"/></svg>
        <p class="no-results__title">No kids found</p>
        <p class="no-results__hint">Try a different search term or adjust your filters.</p>
        <button class="btn btn-dark btn--sm" id="clear-filters-alt">Clear all filters</button>
      </div>

      {kids.length === 0 && (
        <p style="text-align: center; color: var(--c-text-muted); padding: var(--space-4xl) 0;">
          Kid profiles are being migrated. Check back soon!
        </p>
      )}
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bottom-cta section section--dark">
    <div class="container container--narrow" style="text-align: center;">
      <h2 class="bottom-cta__title">Every child deserves a space to thrive</h2>
      <p class="bottom-cta__text">Your generosity helps us transform bedrooms, bathrooms, and therapy rooms for children with serious illnesses and disabilities.</p>
      <div class="bottom-cta__buttons">
        <a href="/donate/" class="btn btn-yellow">Donate Now</a>
        <a href="/about/" class="btn btn-outline-light">Our Story</a>
      </div>
    </div>
  </section>

  <!-- Noscript: hide dead controls -->
  <noscript>
    <style>
      .toolbar, .bottom-sheet, .filter-btn-mobile { display: none !important; }
    </style>
  </noscript>
</BaseLayout>

<!-- ══════ FILTERING + INTERACTIONS ══════ -->
<script>
  let _kidsObserver: IntersectionObserver | null = null;
  let _kidsScrollHandler: (() => void) | null = null;

  function cleanupKidsIndex() {
    _kidsObserver?.disconnect();
    _kidsObserver = null;
    if (_kidsScrollHandler) window.removeEventListener('scroll', _kidsScrollHandler);
    _kidsScrollHandler = null;
  }

  function initKidsIndex() {
    const cards = document.querySelectorAll<HTMLElement>('.kid-card');
    if (!cards.length) return;

    cleanupKidsIndex();

    const searchInput = document.getElementById('kid-search') as HTMLInputElement;
    const yearSelect = document.getElementById('filter-year') as HTMLSelectElement;
    const typeSelect = document.getElementById('filter-type') as HTMLSelectElement;
    const statusBtn = document.getElementById('filter-status') as HTMLButtonElement | null;
    const noResults = document.getElementById('no-results') as HTMLElement;
    const visibleCountEl = document.getElementById('visible-count') as HTMLElement;
    const clearBtn = document.getElementById('clear-filters') as HTMLButtonElement;
    const clearBtnAlt = document.getElementById('clear-filters-alt') as HTMLButtonElement;
    const toolbar = document.getElementById('toolbar') as HTMLElement;
    const featuredCard = document.querySelector('.featured') as HTMLElement | null;
    const searchClear = document.getElementById('search-clear') as HTMLButtonElement;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ── Bottom sheet elements ──
    const sheet = document.getElementById('bottom-sheet') as HTMLElement;
    const sheetBackdrop = document.getElementById('sheet-backdrop') as HTMLElement;
    const sheetClose = document.getElementById('sheet-close') as HTMLButtonElement;
    const sheetYear = document.getElementById('sheet-year') as HTMLSelectElement;
    const sheetType = document.getElementById('sheet-type') as HTMLSelectElement;
    const sheetStatus = document.getElementById('sheet-status') as HTMLButtonElement | null;
    const sheetClear = document.getElementById('sheet-clear') as HTMLButtonElement;
    const sheetApply = document.getElementById('sheet-apply') as HTMLButtonElement;
    const filterBtnMobile = document.getElementById('filter-btn-mobile') as HTMLButtonElement;
    const mobileFilterCount = document.getElementById('mobile-filter-count') as HTMLElement;

    let statusActive = false;

    // ── URL state restore ────────────────────
    const params = new URLSearchParams(window.location.search);
    if (params.get('year')) yearSelect.value = params.get('year')!;
    if (params.get('type')) typeSelect.value = params.get('type')!;
    if (params.get('q')) {
      searchInput.value = params.get('q')!;
      searchClear.hidden = false;
    }
    if (params.get('status') === 'in-progress' && statusBtn) {
      statusActive = true;
      statusBtn.classList.add('active');
      statusBtn.setAttribute('aria-pressed', 'true');
    }

    // ── Filtering ─────────────────────────────
    function applyFilters() {
      const query = searchInput.value.toLowerCase().trim();
      const yearFilter = yearSelect.value;
      const typeFilter = typeSelect.value;
      let visibleCount = 0;

      const hasFilters = yearFilter !== 'all' || typeFilter !== 'all' || statusActive || query.length > 0;

      if (featuredCard) {
        const fd = featuredCard.dataset;
        const fMatchYear = yearFilter === 'all' || fd.year === yearFilter;
        const fMatchType = typeFilter === 'all' || (fd.types ? fd.types.split(' ').includes(typeFilter) : false);
        const fMatchStatus = !statusActive || fd.status === 'in-progress';
        const fMatchSearch = !query || (fd.name || '').includes(query) || (fd.diagnosis || '').includes(query);
        featuredCard.closest('.featured-section')?.classList.toggle('is-filtered', hasFilters && !(fMatchYear && fMatchType && fMatchStatus && fMatchSearch));
      }

      cards.forEach(card => {
        const { year, types, name, diagnosis, status } = card.dataset;
        const matchesYear = yearFilter === 'all' || year === yearFilter;
        const matchesType = typeFilter === 'all' || (types ? types.split(' ').includes(typeFilter) : false);
        const matchesStatus = !statusActive || status === 'in-progress';
        const matchesSearch = !query || (name || '').includes(query) || (diagnosis || '').includes(query);
        const visible = matchesYear && matchesType && matchesStatus && matchesSearch;

        if (visible) {
          card.classList.remove('is-hidden');
          visibleCount++;
        } else {
          card.classList.add('is-hidden');
        }
      });

      visibleCountEl.textContent = String(visibleCount);
      noResults.hidden = visibleCount > 0;
      clearBtn.hidden = !hasFilters;

      // Mobile filter count badge
      let filterCount = 0;
      if (yearFilter !== 'all') filterCount++;
      if (typeFilter !== 'all') filterCount++;
      if (statusActive) filterCount++;
      if (filterCount > 0) {
        mobileFilterCount.textContent = String(filterCount);
        mobileFilterCount.hidden = false;
      } else {
        mobileFilterCount.hidden = true;
      }

      const url = new URL(window.location.href);
      yearFilter !== 'all' ? url.searchParams.set('year', yearFilter) : url.searchParams.delete('year');
      typeFilter !== 'all' ? url.searchParams.set('type', typeFilter) : url.searchParams.delete('type');
      query ? url.searchParams.set('q', query) : url.searchParams.delete('q');
      statusActive ? url.searchParams.set('status', 'in-progress') : url.searchParams.delete('status');
      history.replaceState(null, '', url.toString());
    }

    function clearAll() {
      searchInput.value = '';
      yearSelect.value = 'all';
      typeSelect.value = 'all';
      if (statusBtn) {
        statusActive = false;
        statusBtn.classList.remove('active');
        statusBtn.setAttribute('aria-pressed', 'false');
      }
      applyFilters();
      searchInput.focus();
    }

    // ── Events ───────────────────────────────
    let searchTimer: ReturnType<typeof setTimeout>;
    yearSelect.addEventListener('change', applyFilters);
    typeSelect.addEventListener('change', applyFilters);
    searchInput.addEventListener('input', () => {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(applyFilters, 150);
      searchClear.hidden = !searchInput.value;
    });
    searchClear.addEventListener('click', () => {
      searchInput.value = '';
      searchClear.hidden = true;
      applyFilters();
      searchInput.focus();
    });
    clearBtn.addEventListener('click', clearAll);
    clearBtnAlt.addEventListener('click', clearAll);

    if (statusBtn) {
      statusBtn.addEventListener('click', () => {
        statusActive = !statusActive;
        statusBtn.classList.toggle('active', statusActive);
        statusBtn.setAttribute('aria-pressed', String(statusActive));
        applyFilters();
      });
    }

    // ── Bottom sheet ─────────────────────────
    let savedScrollY = 0;

    function openSheet() {
      // Sync sheet values with main filters
      sheetYear.value = yearSelect.value;
      sheetType.value = typeSelect.value;
      if (sheetStatus) {
        sheetStatus.classList.toggle('active', statusActive);
        sheetStatus.setAttribute('aria-pressed', String(statusActive));
      }
      sheet.classList.add('is-open');
      sheet.setAttribute('aria-hidden', 'false');
      // iOS-safe scroll lock: position:fixed preserves scroll pos
      savedScrollY = window.scrollY;
      document.body.style.position = 'fixed';
      document.body.style.top = `-${savedScrollY}px`;
      document.body.style.left = '0';
      document.body.style.right = '0';
      document.body.style.overflow = 'hidden';
    }

    function closeSheet() {
      sheet.classList.remove('is-open');
      sheet.setAttribute('aria-hidden', 'true');
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.left = '';
      document.body.style.right = '';
      document.body.style.overflow = '';
      window.scrollTo(0, savedScrollY);
    }

    filterBtnMobile?.addEventListener('click', openSheet);
    sheetBackdrop?.addEventListener('click', closeSheet);
    sheetClose?.addEventListener('click', closeSheet);

    if (sheetStatus) {
      sheetStatus.addEventListener('click', () => {
        const isActive = sheetStatus.classList.toggle('active');
        sheetStatus.setAttribute('aria-pressed', String(isActive));
      });
    }

    sheetClear?.addEventListener('click', () => {
      sheetYear.value = 'all';
      sheetType.value = 'all';
      if (sheetStatus) {
        sheetStatus.classList.remove('active');
        sheetStatus.setAttribute('aria-pressed', 'false');
      }
    });

    sheetApply?.addEventListener('click', () => {
      // Apply sheet values to main filters
      yearSelect.value = sheetYear.value;
      typeSelect.value = sheetType.value;
      if (statusBtn && sheetStatus) {
        statusActive = sheetStatus.classList.contains('active');
        statusBtn.classList.toggle('active', statusActive);
        statusBtn.setAttribute('aria-pressed', String(statusActive));
      }
      applyFilters();
      closeSheet();
    });

    // Close on escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && sheet.classList.contains('is-open')) closeSheet();
    });

    // ── Staggered reveal on scroll ──
    if (!reducedMotion) {
      document.documentElement.classList.add('js-anim');
      cards.forEach((card, i) => {
        if (i < 8) card.classList.add('revealed');
      });

      _kidsObserver = new IntersectionObserver(
        (entries) => {
          const visible = entries.filter(e => e.isIntersecting);
          visible.forEach((entry, i) => {
            const el = entry.target as HTMLElement;
            el.style.setProperty('--stagger', String(i));
            el.classList.add('revealed');
            _kidsObserver?.unobserve(el);
          });
        },
        { rootMargin: '100px', threshold: 0.01 }
      );
      cards.forEach((card, i) => {
        if (i >= 8) _kidsObserver!.observe(card);
      });
    }

    // ── Toolbar scroll shadow ────────────────
    let ticking = false;
    _kidsScrollHandler = function () {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(() => {
          toolbar.classList.toggle('is-scrolled', window.scrollY > 300);
          ticking = false;
        });
      }
    };
    window.addEventListener('scroll', _kidsScrollHandler, { passive: true });

    // ── Image shimmer: remove on load ─────────
    document.querySelectorAll<HTMLImageElement>('.kid-card__img').forEach(img => {
      if (img.complete) {
        img.closest('.kid-card__frame')?.classList.add('is-loaded');
      } else {
        img.addEventListener('load', () => {
          img.closest('.kid-card__frame')?.classList.add('is-loaded');
        }, { once: true });
      }
    });

    // ── Apply URL filters + scroll to grid ───
    const hasURLFilters = params.get('year') || params.get('type') || params.get('q') || params.get('status');
    if (hasURLFilters) {
      applyFilters();
      toolbar.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

  } // end initKidsIndex

  document.addEventListener('astro:page-load', initKidsIndex);
  document.addEventListener('astro:before-swap', cleanupKidsIndex);
</script>

<!-- View Transitions: card morph -->
<script>
  function initKidTransitions() {
    document.querySelectorAll<HTMLAnchorElement>('.kid-card').forEach(card => {
      card.addEventListener('click', () => {
        document.querySelectorAll('[style*="view-transition-name"]').forEach(el => {
          (el as HTMLElement).style.viewTransitionName = '';
        });
        const img = card.querySelector('.kid-card__img') as HTMLElement | null;
        const name = card.querySelector('.kid-card__name') as HTMLElement | null;
        if (img) img.style.viewTransitionName = 'kid-hero';
        if (name) name.style.viewTransitionName = 'kid-name';
      });
    });
  }
  document.addEventListener('astro:page-load', initKidTransitions);
</script>

