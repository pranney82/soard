---
const CF = 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ';
---

<!-- ══════ PRE-FOOTER CTA ══════ -->
<div class="prefooter">
  <div class="prefooter-inner">
    <h2>Every child deserves a space to <em class="highlight">dream</em></h2>
    <p>Your support creates life-changing rooms for children with special needs in Atlanta.</p>
    <div class="prefooter-btns">
      <a href="/donate" class="btn btn-primary">Make a Donation ♥</a>
      <a href="/get-involved" class="btn btn-ghost-light">Other Ways to Help →</a>
    </div>
  </div>
</div>

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-about">
        <div class="footer-logo">
          <img src={`${CF}/logo-dark-bg/footer`} alt="Sunshine on a Ranney Day — Dreams Built Here" width="200" height="120" class="footer-logo-img" loading="lazy" />
        </div>
        <p>A 501(c)(3) nonprofit creating life-changing home makeovers for children with special needs in the greater Atlanta area.</p>
        <address>250 Hembree Park Drive, Suite 106, Roswell GA 30076</address>
        <div class="footer-contact">
          <a href="tel:7709902434">770.990.2434</a>
          <a href="mailto:info@soardcharity.com">info@soardcharity.com</a>
        </div>
      </div>

      <div class="footer-col">
        <h4>About</h4>
        <a href="/about">Our Story</a>
        <a href="/about#leadership">Leadership</a>
        <a href="/about#financials">Financials</a>
      </div>

      <div class="footer-col">
        <h4>Programs</h4>
        <a href="/kids">Meet the Kids</a>
        <a href="/partners">Our Partners</a>
      </div>

      <div class="footer-col">
        <h4>Get Involved</h4>
        <a href="/donate">Donate</a>
        <a href="/get-involved">Volunteer</a>
        <a href="/get-involved#apply">Apply for a Room</a>
        <a href="https://sunnyandranney.com" target="_blank" rel="noopener">Shop Sunny & Ranney</a>
        <a href="https://partlysunnystore.com" target="_blank" rel="noopener">Shop Partly Sunny</a>
      </div>
    </div>

    <div class="footer-bottom">
      <span>&copy; {new Date().getFullYear()} Sunshine on a Ranney Day. All rights reserved.</span>
      <div class="footer-social">
        <a href="https://www.facebook.com/sunshineonaranneyday" target="_blank" rel="noopener" aria-label="Facebook">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="https://www.instagram.com/sunshineonaranneyday" target="_blank" rel="noopener" aria-label="Instagram">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
      </div>
      <span class="footer-ein">EIN: 45-4773997</span>
    </div>
  </div>
</footer>

<style>
  .prefooter {
    background: var(--c-dark);
    padding: 80px var(--page-padding);
    text-align: center;
  }
  .prefooter-inner {
    max-width: 600px;
    margin: 0 auto;
  }
  .prefooter h2 {
    color: #fff;
    font-size: clamp(26px, 3.5vw, 38px);
    margin-bottom: 16px;
  }
  .prefooter h2 em { font-style: italic; }
  .prefooter p {
    color: rgba(255,255,255,0.5);
    font-size: 17px;
    line-height: 1.7;
    margin-bottom: 32px;
  }
  .prefooter-btns {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-ghost-light {
    background: transparent;
    color: #fff;
    border: 1.5px solid rgba(255,255,255,0.2);
  }
  .btn-ghost-light:hover {
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.35);
  }

  .site-footer {
    background: var(--c-dark-deep);
    padding: 64px var(--page-padding) 32px;
    color: rgba(255, 255, 255, 0.5);
  }
  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2.5fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 48px;
  }
  .footer-logo {
    margin-bottom: 20px;
  }
  .footer-logo-img {
    height: 72px;
    width: auto;
    object-fit: contain;
  }
  .footer-about p {
    font-size: 14px;
    line-height: 1.75;
    max-width: 340px;
    color: rgba(255, 255, 255, 0.5);
  }
  .footer-about address {
    font-style: normal;
    margin-top: 20px;
    font-size: 13px;
  }
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 8px;
  }
  .footer-contact a {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    transition: color 0.2s;
  }
  .footer-contact a:hover { color: var(--c-yellow); }
  .footer-col h4 {
    font-family: var(--f-body);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-yellow);
    margin-bottom: 18px;
  }
  .footer-col a {
    display: block;
    font-size: 14px;
    margin-bottom: 12px;
    color: rgba(255, 255, 255, 0.5);
    transition: color 0.2s;
  }
  .footer-col a:hover { color: #fff; }
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    flex-wrap: wrap;
    gap: 16px;
  }
  .footer-social {
    display: flex;
    gap: 16px;
  }
  .footer-social a {
    color: rgba(255,255,255,0.4);
    transition: color 0.2s;
  }
  .footer-social a:hover { color: var(--c-yellow); }
  .footer-ein { color: var(--c-yellow); }

  @media (max-width: 768px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
    .footer-about { grid-column: 1 / -1; }
    .footer-bottom { flex-direction: column; text-align: center; }
  }
  @media (max-width: 480px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
