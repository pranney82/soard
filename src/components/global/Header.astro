  .dd-label { font-size: 0.875rem; font-weight: 500; color: var(--c-dark); display: flex; align-items: center; gap: 4px; }
  .dd-desc { font-size: 0.75rem; color: rgba(0, 0, 0, 0.55); }
  .dd-ext { opacity: 0.55; }

  /* ── Donate CTA ── */
