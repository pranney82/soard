---
/**
 * Our Story — Sunshine on a Ranney Day
 * Editorial long-form page: founding story, milestones, mascot, mission
 * 
 * PERF NOTES:
 * - Hero image: fetchpriority="high", eager loading, explicit dimensions
 * - All below-fold images: loading="lazy"
 * - data-reveal only on below-fold elements
 * - Team photos from CF Images
 */
import PageLayout from '../../layouts/PageLayout.astro';
import { getWebPageSchema, getBreadcrumbSchema, buildSchemaGraph } from '../../utils/schema';
import { getSiteStats } from '../../utils/stats';
import page from '../../content/site/our-story.json';

const CF = 'https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ';

/* ── Auto-computed stats ── */
const computed = await getSiteStats();
const stats = {
  totalKids: computed.totalKids,
  totalRooms: computed.totalRooms,
  years: computed.years,
  communityKids: 17000, // kept from page data — community reach is a separate metric
};
const founderPhotoId = page.images.founder;
const revealPhotoId = page.images.reveal;
const communityPhotoId = page.images.community;
const storePhotoId = page.images.store;
const graciePhotoId = page.images.gracie;
const trippPhotoId = page.images.tripp;
const milestones = page.milestones;
const ribbon = (page.ribbon || []).map((r: { value: string; label: string }) => ({
  ...r,
  value: r.value
    .replace('{totalRooms}', String(stats.totalRooms))
    .replace('{totalKids}', String(stats.totalKids))
    .replace('{communityKids}', stats.communityKids >= 1000 ? Math.floor(stats.communityKids / 1000) + 'K' : String(stats.communityKids))
    .replace('{years}', String(stats.years)),
}));

/* ── Schema ── */
const pageUrl = 'https://sunshineonaranneyday.com/about/';
const aboutDesc = `How Peter and Holly Ranney founded Sunshine on a Ranney Day in 2012 — and built a movement that has transformed ${stats.totalRooms}+ rooms for children with special needs across greater Atlanta.`;
const breadcrumbs = [
  { name: 'Home', url: 'https://sunshineonaranneyday.com/' },
  { name: 'Our Story', url: pageUrl },
];
const jsonLd = buildSchemaGraph(
  getWebPageSchema({ url: pageUrl, title: 'Our Story', description: aboutDesc }),
  getBreadcrumbSchema(breadcrumbs, pageUrl),
);
---

<PageLayout
  title="Our Story — How It All Started"
  description={aboutDesc}
  jsonLd={jsonLd}
  breadcrumbs={breadcrumbs}
  heroLabel="About"
  heroTitle={'Our <em class="highlight">Story</em>'}
  heroSubtitle="How it all started — and where we're headed"
>

  <!-- ══════ FOUNDERS — The Beginning ══════ -->
  <section class="founders" id="our-story" aria-labelledby="founders-heading">
    <div class="founders-inner">
      <div class="founders-photo" data-reveal>
        <img src={`${CF}/${founderPhotoId}/w=800,f=auto,q=85`} srcset={`${CF}/${founderPhotoId}/w=500,f=auto,q=85 500w, ${CF}/${founderPhotoId}/w=800,f=auto,q=85 800w`} sizes="(max-width:768px) 90vw, 40vw" alt="Peter and Holly Ranney, founders of Sunshine on a Ranney Day" width="800" height="600" loading="lazy" decoding="async" />
      </div>
      <div class="founders-text" data-reveal>
        <div class="section-label">{page.founders.label}</div>
        <h2 id="founders-heading" set:html={page.founders.heading} />
        {page.founders.paragraphs.map((p: string) => <p set:html={p} />)}
      </div>
    </div>
  </section>

  <!-- ══════ TRIPP — The Turning Point ══════ -->
  <section class="turning-point" aria-labelledby="tripp-heading">
    <div class="turning-point-inner">
      <div class="turning-point-text" data-reveal>
        <div class="section-label">{page.turningPoint.label}</div>
        <h2 id="tripp-heading" set:html={page.turningPoint.heading} />
        {page.turningPoint.paragraphs.map((p: string) => <p set:html={p} />)}
      </div>
      <div class="turning-point-photo" data-reveal data-delay="1">
        <img src={`${CF}/${trippPhotoId}/w=800,f=auto,q=85`} srcset={`${CF}/${trippPhotoId}/w=500,f=auto,q=85 500w, ${CF}/${trippPhotoId}/w=800,f=auto,q=85 800w`} sizes="(max-width:768px) 90vw, 45vw" alt="The Halstead family — Tripp's story inspired millions and helped expand SOARD's mission" width="800" height="600" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  <!-- ══════ TIMELINE ══════ -->
  <section class="timeline-section" aria-labelledby="timeline-heading">
    <div class="timeline-header" data-reveal>
      <div class="section-label section-label--yellow">Milestones</div>
      <h2 id="timeline-heading">{stats.years} years of building <em>dreams</em>.</h2>
    </div>
    <div class="timeline">
      {milestones.map((m, i) => (
        <div class="tl-item" data-reveal data-delay={String(Math.min(i, 3))}>
          <div class="tl-year">{m.year}</div>
          <div class="tl-dot" aria-hidden="true"></div>
          <div class={`tl-card${m.image ? ' has-image' : ''}`}>
            {m.image && (
              <div class="tl-image">
                <img src={`${CF}/${m.image}/w=480,f=auto,q=85`} srcset={`${CF}/${m.image}/w=320,f=auto,q=85 320w, ${CF}/${m.image}/w=480,f=auto,q=85 480w`} sizes="(max-width:768px) 100%, 200px" alt={m.title} width="480" height="320" loading="lazy" decoding="async" />
              </div>
            )}
            <div class="tl-text">
              <h3 class="tl-title">{m.title}</h3>
              <p class="tl-desc">{m.desc}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ══════ IMPACT RIBBON ══════ -->
  <section class="ribbon" aria-label="Impact numbers">
    <div class="ribbon-inner">
      {ribbon.map((r: { value: string; label: string }, i: number) => (
        <>
          {i > 0 && <div class="ribbon-divider" role="presentation"></div>}
          <div class="ribbon-stat" data-reveal data-delay={String(i)}>
            <span class="ribbon-num" set:html={r.value} />
            <span class="ribbon-label">{r.label}</span>
          </div>
        </>
      ))}
    </div>
  </section>

  <!-- ══════ GRACIE — The Mascot ══════ -->
  <section class="mascot" aria-labelledby="mascot-heading">
    <div class="mascot-inner">
      <div class="mascot-text" data-reveal>
        <div class="section-label">{page.mascot.label}</div>
        <h2 id="mascot-heading" set:html={page.mascot.heading} />
        {page.mascot.paragraphs.map((p: string) => <p set:html={p} />)}
        <p class="mascot-tagline" set:html={page.mascot.tagline} />
      </div>
      <div class="mascot-visual" data-reveal data-delay="1">
        <div class="mascot-photo">
          <img src={`${CF}/${graciePhotoId}/w=800,f=auto,q=85`} srcset={`${CF}/${graciePhotoId}/w=500,f=auto,q=85 500w, ${CF}/${graciePhotoId}/w=800,f=auto,q=85 800w`} sizes="(max-width:768px) 90vw, 40vw" alt="Gracie the Pig — the real pot-bellied pig that inspired SOARD's mascot" width="800" height="533" loading="lazy" decoding="async" />
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ SUNNY & RANNEY — The Store ══════ -->
  <section class="store-section" aria-labelledby="store-heading">
    <div class="store-inner">
      <div class="store-photo" data-reveal>
        <img src={`${CF}/${storePhotoId}/w=800,f=auto,q=85`} srcset={`${CF}/${storePhotoId}/w=500,f=auto,q=85 500w, ${CF}/${storePhotoId}/w=800,f=auto,q=85 800w`} sizes="(max-width:768px) 90vw, 45vw" alt="Sunny & Ranney, a nonprofit home furnishings store in Roswell, Georgia" width="800" height="600" loading="lazy" decoding="async" />
      </div>
      <div class="store-text" data-reveal data-delay="1">
        <div class="section-label">{page.store.label}</div>
        <h2 id="store-heading" set:html={page.store.heading} />
        {page.store.paragraphs.map((p: string) => <p set:html={p} />)}
        <a href="https://sunnyandranney.com" target="_blank" rel="noopener noreferrer" class="btn btn-dark">Shop Sunny & Ranney →</a>
      </div>
    </div>
  </section>

  <!-- ══════ WHERE WE ARE TODAY ══════ -->
  <section class="today-section" aria-labelledby="today-heading">
    <div class="today-inner" data-reveal>
      <div class="section-label">{page.today.label}</div>
      <h2 id="today-heading" set:html={page.today.heading} />
      <p class="today-body" set:html={page.today.body} />
      <div class="today-links">
        <a href="/about/leadership" class="btn btn-dark">Meet Our Team →</a>
        <a href="/about/financials" class="btn btn-outline">View Financials →</a>
      </div>
    </div>
  </section>

  <!-- ══════ FINAL CTA ══════ -->
  <section class="story-finale">
    <div class="story-finale-inner">
      <h2 data-reveal set:html={page.finale.heading} />
      <p data-reveal data-delay="1" set:html={page.finale.body} />
      <div class="story-finale-ctas" data-reveal data-delay="2">
        <a href="/donate" class="btn btn-dark btn-lg">Donate Today</a>
        <a href="/kids" class="btn btn-outline-dark">Meet the Kids</a>
      </div>
      <p class="story-finale-note" data-reveal data-delay="3">501(c)(3) · EIN 45-4773997 · All donations tax-deductible</p>
    </div>
  </section>

</PageLayout>

<style>
  /* ══════════════════════════════════════════
     SHARED
     ══════════════════════════════════════════ */
  .section-label {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-accent);
    margin-bottom: 20px;
  }
  .section-label::before {
    content: '';
    width: 28px;
    height: 2px;
    background: currentColor;
    flex-shrink: 0;
  }
  .section-label--yellow { color: var(--c-yellow); }
  .highlight {
    font-style: italic;
    background-image: linear-gradient(transparent 55%, var(--c-yellow-soft) 55%);
    padding: 0 0.1em;
  }
  h2 em:not(.highlight) { font-style: italic; color: var(--c-yellow); }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    border-radius: 60px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    white-space: nowrap;
  }
  .btn:hover { transform: translateY(-3px); }
  .btn-dark {
    background: var(--c-dark);
    color: var(--c-white);
  }
  .btn-dark:hover {
    background: #3a3b40;
    box-shadow: 0 8px 24px rgba(45, 46, 51, 0.3);
  }
  .btn-outline {
    background: transparent;
    color: var(--c-dark);
    border: 2px solid var(--c-border);
  }
  .btn-outline:hover {
    border-color: var(--c-dark);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  }
  .btn-outline-dark {
    background: transparent;
    color: var(--c-dark);
    border: 2px solid var(--c-dark);
  }
  .btn-outline-dark:hover {
    background: var(--c-dark);
    color: var(--c-white);
  }
  .btn-lg { padding: 16px 40px; font-size: 16px; }

  /* ══════════════════════════════════════════
     FOUNDERS — Split layout
     ══════════════════════════════════════════ */
  .founders {
    background: var(--c-warm-gray);
    padding-block: var(--space-5xl) var(--space-4xl);
  }

  .founders-inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-lg);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
  }

  .founders-photo {
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
  }

  .founders-photo img {
    width: 100%;
    height: auto;
    display: block;
  }

  .founders-text h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    margin-bottom: var(--space-xl);
  }

  .founders-text p {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--c-text);
    margin-bottom: var(--space-md);
  }

  .founders-text p:last-of-type {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--c-text-muted);
  }

  @media (max-width: 768px) {
    .founders { padding-block: var(--space-3xl); }
    .founders-inner {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
  }

  /* ══════════════════════════════════════════
     TURNING POINT — Reversed split
     ══════════════════════════════════════════ */
  .turning-point {
    background: var(--c-warm-gray);
    padding-block: var(--space-4xl);
  }

  .turning-point-inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-lg);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
  }

  .turning-point-text h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    margin-bottom: var(--space-xl);
  }

  .turning-point-text p {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--c-text);
    margin-bottom: var(--space-md);
  }

  .turning-point-photo {
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
  }

  .turning-point-photo img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 768px) {
    .turning-point { padding-block: var(--space-3xl); }
    .turning-point-inner {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
    .turning-point-text { order: 1; }
    .turning-point-photo { order: 2; }
  }

  /* ══════════════════════════════════════════
     TIMELINE
     ══════════════════════════════════════════ */
  .timeline-section {
    background: var(--c-dark);
    color: var(--c-white);
    padding-block: var(--space-5xl);
  }

  .timeline-header {
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
    margin-bottom: var(--space-4xl);
    padding-inline: var(--space-lg);
  }

  .timeline-header .section-label {
    justify-content: center;
  }

  .timeline-header h2 {
    color: var(--c-white);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
  }

  .timeline {
    position: relative;
    max-width: 800px;
    margin-inline: auto;
    padding-inline: var(--space-lg);
  }

  /* Vertical line */
  .timeline::before {
    content: '';
    position: absolute;
    left: calc(var(--space-lg) + 60px + 14px);
    top: 0;
    bottom: 0;
    width: 2px;
    background: rgba(255, 218, 36, 0.25);
  }

  .tl-item {
    display: grid;
    grid-template-columns: 60px 30px 1fr;
    gap: 0;
    align-items: start;
    margin-bottom: var(--space-2xl);
  }

  .tl-item:last-child { margin-bottom: 0; }

  .tl-year {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--c-yellow);
    text-align: right;
    padding-top: 4px;
    line-height: 1;
  }

  .tl-dot {
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }

  .tl-dot::before {
    content: '';
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--c-yellow);
    box-shadow: 0 0 0 4px rgba(255, 218, 36, 0.2);
    flex-shrink: 0;
  }

  .tl-card {
    background: rgba(255, 255, 255, 0.06);
    border-radius: var(--border-radius);
    border: 1px solid rgba(255, 255, 255, 0.08);
    overflow: hidden;
  }

  .tl-card .tl-text {
    padding: var(--space-lg) var(--space-xl);
  }

  .tl-card.has-image {
    display: grid;
    grid-template-columns: 180px 1fr;
  }

  .tl-image {
    overflow: hidden;
  }

  .tl-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .tl-title {
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--c-white);
    margin-bottom: var(--space-xs);
  }

  .tl-desc {
    font-size: 0.95rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.7);
  }

  @media (max-width: 768px) {
    .timeline-section { padding-block: var(--space-3xl); }
    .timeline::before { left: calc(var(--space-lg) + 14px); }
    .tl-item {
      grid-template-columns: 30px 1fr;
      gap: 0;
    }
    .tl-year {
      grid-column: 1 / -1;
      text-align: left;
      margin-bottom: var(--space-sm);
      padding-left: 36px;
    }
    .tl-card .tl-text { padding: var(--space-md) var(--space-lg); }
    .tl-card.has-image {
      grid-template-columns: 1fr;
    }
    .tl-image {
      max-height: 160px;
    }
  }

  /* ══════════════════════════════════════════
     IMPACT RIBBON
     ══════════════════════════════════════════ */
  .ribbon {
    background: var(--c-yellow);
    padding-block: var(--space-2xl);
  }

  .ribbon-inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2xl);
    flex-wrap: wrap;
  }

  .ribbon-stat { text-align: center; }

  .ribbon-num {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--c-dark);
    line-height: 1;
  }

  .ribbon-pct { font-size: 0.6em; }

  .ribbon-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(45, 46, 51, 0.7);
    margin-top: 6px;
  }

  .ribbon-divider {
    width: 1px;
    height: 48px;
    background: rgba(45, 46, 51, 0.2);
  }

  @media (max-width: 640px) {
    .ribbon-inner { gap: var(--space-lg); }
    .ribbon-divider { display: none; }
    .ribbon-stat { flex: 1 1 40%; }
  }

  /* ══════════════════════════════════════════
     MASCOT — Gracie
     ══════════════════════════════════════════ */
  .mascot {
    padding-block: var(--space-5xl);
  }

  .mascot-inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-lg);
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-4xl);
    align-items: center;
  }

  .mascot-text h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    margin-bottom: var(--space-xl);
  }

  .mascot-text p {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--c-text);
    margin-bottom: var(--space-md);
  }

  .mascot-tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem !important;
    color: var(--c-text-muted) !important;
    margin-top: var(--space-lg) !important;
  }

  .mascot-visual {
    display: flex;
    justify-content: center;
  }

  .mascot-photo {
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
    transition: transform var(--transition-slow);
  }

  .mascot-photo:hover {
    transform: scale(1.02);
  }

  .mascot-photo img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 768px) {
    .mascot { padding-block: var(--space-3xl); }
    .mascot-inner {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
    .mascot-visual { order: -1; }
  }

  /* ══════════════════════════════════════════
     STORE — Sunny & Ranney
     ══════════════════════════════════════════ */
  .store-section {
    background: var(--c-warm-gray);
    padding-block: var(--space-4xl);
  }

  .store-inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-lg);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
  }

  .store-photo {
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
  }

  .store-photo img {
    width: 100%;
    height: auto;
    display: block;
  }

  .store-text h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    margin-bottom: var(--space-xl);
  }

  .store-text p {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--c-text);
    margin-bottom: var(--space-md);
  }

  .store-text a:not(.btn) {
    color: var(--c-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .store-text .btn { margin-top: var(--space-lg); }

  @media (max-width: 768px) {
    .store-section { padding-block: var(--space-3xl); }
    .store-inner {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
  }

  /* ══════════════════════════════════════════
     TODAY — Where We Are
     ══════════════════════════════════════════ */
  .today-section {
    padding-block: var(--space-5xl);
    text-align: center;
  }

  .today-inner {
