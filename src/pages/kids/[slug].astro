---
/**
 * [slug].astro — Individual kid profile page
 *
 * Guided Journey — immersive editorial storytelling with interactive chapters:
 *   1. Meet [Name]: Editorial split hero with hook, pills, stats
 *   2. The Story: Editorial photo/text pairs with alternating layouts
 *   3. The Design: Side-by-side as-built vs proposed plans
 *   4. Before & After: Interactive comparison sliders
 *   5. The Reveal: Video climax (Cloudflare Stream / YouTube)
 *   6. The Gallery: Masonry grid with hero treatment + cascade reveal
 *   + Sticky chapter nav (desktop right rail, mobile bottom bar)
 *
 * PERF: CF Images w/ srcset + gravity:face, LQIP blur-up, lazy loading,
 *       video facade, content-visibility, inline CSS (build config)
 * SEO:  Article + Person schema, breadcrumbs, rich meta, OG image
 * A11Y: Heading hierarchy, ARIA, focus trap lightbox, keyboard nav,
 *       prefers-reduced-motion respected
 * UX:   View Transitions, staggered scroll-reveals, no full-bleed images
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/ui/Button.astro';
import { getCollection } from 'astro:content';
import { getPublishedKids } from '../../utils/collections';
import { getKidProfileSchema } from '../../utils/schema';

export async function getStaticPaths() {
  const kids = await getPublishedKids();
  const sorted = kids.sort((a, b) => (b.data.year || 0) - (a.data.year || 0));
  const seedHash = (str: string) => {
    let h = 0;
    for (let i = 0; i < str.length; i++) {
      h = ((h << 5) - h + str.charCodeAt(i)) | 0;
    }
    return h;
  };
  const seededShuffle = (arr: typeof kids, seed: string) => {
    const a = [...arr];
    let s = seedHash(seed);
    for (let j = a.length - 1; j > 0; j--) {
      s = (s * 1664525 + 1013904223) | 0;
      const r = ((s >>> 0) % (j + 1));
      [a[j], a[r]] = [a[r], a[j]];
    }
    return a;
  };
  return sorted.map((kid, i) => {
    const others = sorted.filter((k, j) => j !== i);
    const sameType = others.filter(k =>
      k.data.roomTypes?.some(t => kid.data.roomTypes?.includes(t))
    );
    const sameYear = others.filter(k => k.data.year === kid.data.year);
    const seen = new Set();
    const slug = kid.data.slug;
    const deduped = [...seededShuffle(sameType, slug), ...seededShuffle(sameYear, slug + ':year'), ...seededShuffle(others, slug + ':all')]
      .filter(k => {
        if (seen.has(k.data.slug)) return false;
        seen.add(k.data.slug);
        return true;
      });
    const related = deduped
      .filter(k => k.data.heroImage)
      .slice(0, 4)
      .map(k => ({ name: k.data.name, slug: k.data.slug, heroImage: k.data.heroImage, diagnosis: k.data.diagnosis, roomTypes: k.data.roomTypes }));

    return {
      params: { slug: kid.data.slug },
      props: {
        kid: kid.data,
        prevKid: i > 0 ? { name: sorted[i - 1].data.name, slug: sorted[i - 1].data.slug, heroImage: sorted[i - 1].data.heroImage } : null,
        nextKid: i < sorted.length - 1 ? { name: sorted[i + 1].data.name, slug: sorted[i + 1].data.slug, heroImage: sorted[i + 1].data.heroImage } : null,
        relatedKids: related,
      },
    };
  });
}

const { kid, prevKid, nextKid, relatedKids } = Astro.props;
const photos = kid.photos || [];
// ── CF Image helpers ──────────────────────
import { cfUrl as _cfUrl, cfSrcset as _cfSrcset, cfRaw, CF_BASE, cfId } from '../../utils/cf-image';
import lqipManifest from '../../data/lqip-kids.json';
import dimsManifest from '../../data/dimensions-kids.json';
const _lqipMap: Record<string, string> = lqipManifest;
const _dimsMap: Record<string, [number, number]> = dimsManifest;

function cfUrl(src: string, opts: string) { return cfRaw(src, opts); }
function cfSrcset(src: string, widths: number[]) {
  return _cfSrcset(src, widths);
}
function lqip(src: string): string {
  const id = cfId(src);
  return _lqipMap[id] || cfRaw(src, 'w=30,q=30,blur=20');
}
function dims(src: string): [number, number] {
  const id = cfId(src);
  return _dimsMap[id] || [4, 3];
}

// ── YouTube ID extraction ─────────────────
function getYouTubeId(url: string): string | null {
  if (!url) return null;
  const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([a-zA-Z0-9_-]{11})/);
  return match ? match[1] : null;
}
const ytId = kid.videoUrl ? getYouTubeId(kid.videoUrl) : null;
const streamId = kid.streamVideoId || null;
const hasVideo = streamId || ytId;

// ── SEO ───────────────────────────────────
const SITE = 'https://sunshineonaranneyday.com';
const kidSchemas = getKidProfileSchema({
  ...kid,
  videoUrl: kid.videoUrl,
  streamVideoId: kid.streamVideoId,
  photos: kid.photos,
  photographer: kid.photographer,
  status: kid.status,
});
const breadcrumbs = [
  { name: 'Home', url: SITE },
  { name: 'Meet the Kids', url: `${SITE}/kids/` },
  { name: kid.name, url: `${SITE}/kids/${kid.slug}/` },
];

const metaDesc = kid.metaDescription
  || kid.shortDescription
  || `Meet ${kid.name}${kid.diagnosis ? `, diagnosed with ${kid.diagnosis}` : ''}. Learn how Sunshine on a Ranney Day transformed their space${kid.roomTypes?.length ? ` with a ${kid.roomTypes.join(' & ')}` : ''}.`;

const dateModified = kid.year ? `${kid.year}-01-01` : undefined;

// ── LCP preload for hero image ────────────
const heroSrcset = kid.heroImage ? _cfSrcset(kid.heroImage, [600, 900, 1200, 1600, 2400], { fit: 'cover', gravity: 'face' }) : '';
const heroSizes = '(max-width: 768px) 92vw, (max-width: 1100px) 55vw, 640px';

// ── Bio paragraphs + pull quote ───────────
function splitBio(bio: string): string[] {
  if (!bio) return [];
  if (bio.includes('<p>')) {
    return [...bio.matchAll(/<p>([\s\S]*?)<\/p>/gi)]
      .map(m => m[1].replace(/<br\s*\/?>/gi, '').trim())
      .filter(Boolean);
  }
  return bio.split('\n\n').filter(p => p.trim());
}
const bioParas = splitBio(kid.bio || '');
const introPara = bioParas.length > 0 ? bioParas[0] : '';
const remainingParas = bioParas.slice(1);

let pullQuote: string | null = null;
if (kid.quote && kid.quote !== kid.bio && kid.quote !== introPara) {
  pullQuote = kid.quote;
}

const galleryPhotos = photos.slice(0, 30);

// ── Hero: art-directed mobile ─────────────
const heroMobileSrcset = kid.heroImage ? _cfSrcset(kid.heroImage, [600, 900, 1200], { fit: 'cover', gravity: 'face' }) : '';
const heroMobileSizes = '(max-width: 480px) 92vw, 92vw';

// ── Story Photo Essay ─────────────────────
const storyPhotos = kid.storyPhotos || [];
const hasStoryPhotos = storyPhotos.length > 0;
const usePhotoEssay = hasStoryPhotos
  ? remainingParas.length >= 1
  : remainingParas.length >= 2 && galleryPhotos.length >= 3;

type StoryPair = { text: string; photo: typeof photos[0] | null; layout: 'left' | 'right' };
let storyPairs: StoryPair[] = [];
let overflowParas: string[] = remainingParas;

if (usePhotoEssay) {
  const srcPhotos = hasStoryPhotos ? storyPhotos : (() => {
    const pairCount = Math.min(remainingParas.length, 4, Math.floor(galleryPhotos.length / 2));
    const step = galleryPhotos.length / pairCount;
    return Array.from({ length: pairCount }, (_, i) =>
      galleryPhotos[Math.min(Math.floor(i * step), galleryPhotos.length - 1)]
    );
  })();
  const paras = [...remainingParas];
  const pairCount = Math.min(paras.length, srcPhotos.length);
  for (let i = 0; i < pairCount; i++) {
    storyPairs.push({
      text: paras[i],
      photo: srcPhotos[i],
      layout: i % 2 === 0 ? 'left' : 'right',
    });
  }
  overflowParas = paras.slice(pairCount);
}

// ── Minimal data detection ────────────────
const hasDetails = kid.age || (kid.roomTypes && kid.roomTypes.length > 0) || kid.year;
const hasRichContent = kid.bio || galleryPhotos.length > 1 || hasVideo;

// ── Plans — proposed vs as-built ──────────
const plans = kid.plans || [];
const hasPlans = plans.length > 0;
const proposedPlans = plans.filter((p: any) => p.type === 'proposed');
const asBuiltPlans = plans.filter((p: any) => p.type === 'as-built');

// ── Before/After photos ───────────────────
const beforeAfterPhotos = kid.beforeAfterPhotos || [];
const hasBeforeAfter = beforeAfterPhotos.length > 0;

// ── Gallery — masonry with hero treatment ──
const galleryFeatured = kid.galleryFeatured || [];
const heroGalleryPhotos = galleryPhotos.slice(0, 2);
const supportingPhotos = galleryPhotos.slice(2, 8);
const overflowGalleryPhotos = galleryPhotos.slice(8);
const showExpandButton = galleryPhotos.length > 8;

// ── Partner count for hero stats ──────────
const partnerCount = kid.partnerLogos?.length || 0;

// ── Hero hook ─────────────────────────────
const _rawHook = kid.heroSummary
  || (introPara ? introPara.replace(/<[^>]+>/g, '') : '');
const heroHook = (() => {
  if (!_rawHook) return '';
  const firstSentence = _rawHook.match(/^[^.!?]+[.!?]/)?.[0] || _rawHook;
  if (firstSentence.length <= 130) return firstSentence;
  return firstSentence.slice(0, 120).replace(/\s+\S*$/, '') + '...';
})();
const storyLede = kid.heroSummary || introPara;

// ── Stats for hero at-a-glance ────────────
const statsItems = [
  kid.age && `Age ${Array.isArray(kid.age) ? kid.age.join(' & ') : kid.age}`,
  kid.roomCount && `${kid.roomCount} Room${kid.roomCount > 1 ? 's' : ''}`,
  partnerCount > 0 && `${partnerCount} Partner${partnerCount > 1 ? 's' : ''}`,
  kid.year,
].filter(Boolean);

// ── Chapter Nav — conditional rendering ───
const chapters = [
  { id: 'chapter-meet', label: 'Meet', icon: 'user', show: true },
  { id: 'chapter-story', label: 'Story', icon: 'book', show: !!(storyLede || bioParas.length) },
  { id: 'chapter-design', label: 'Design', icon: 'blueprint', show: hasPlans },
  { id: 'chapter-transform', label: 'Transform', icon: 'compare', show: hasBeforeAfter },
  { id: 'chapter-reveal', label: 'Reveal', icon: 'play', show: !!hasVideo },
  { id: 'chapter-gallery', label: 'Gallery', icon: 'camera', show: galleryPhotos.length > 1 },
].filter(c => c.show);

// ── Plans display ─────────────────────────
const displayAsBuilt = asBuiltPlans.slice(0, 1);
const displayProposed = proposedPlans.slice(0, 1);
const extraPlansCount = plans.length - displayAsBuilt.length - displayProposed.length;
---

<BaseLayout
  title={`${kid.name}'s Story`}
  description={metaDesc}
  ogType="article"
  jsonLd={kidSchemas}
  breadcrumbs={breadcrumbs}
  datePublished={kid.year ? `${kid.year}-01-01` : undefined}
  dateModified={dateModified}
>
  {kid.heroImage && <link slot="head" rel="preload" as="image" imagesrcset={heroMobileSrcset} imagesizes={heroMobileSizes} fetchpriority="high" media="(max-width: 768px)" />}
  {kid.heroImage && <link slot="head" rel="preload" as="image" imagesrcset={heroSrcset} imagesizes={heroSizes} fetchpriority="high" media="(min-width: 769px)" />}

  <!-- Scroll progress indicator -->
  <div class="scroll-progress" aria-hidden="true"></div>

  <article class="kid-profile" itemscope itemtype="https://schema.org/Article">

    <!-- ═══ Sticky Chapter Nav — Top Pill Bar ═══ -->
    {chapters.length > 1 && (
      <nav class="chapter-nav" id="chapter-nav" aria-label="Page chapters">
        <div class="chapter-nav__track">
          {chapters.map((ch, i) => (
            <a
              href={`#${ch.id}`}
              class={`chapter-nav__pill${i === 0 ? ' chapter-nav__pill--active' : ''}`}
              data-target={ch.id}
            >
              {ch.label}
            </a>
          ))}
        </div>
      </nav>
    )}

    <!-- ═══ 1. Meet — Hero ═══ -->
    <section class="hero" id="chapter-meet" data-chapter="Meet">
      <div class="hero__split">
        {kid.heroImage ? (
          <div class="hero__portrait" style={`--lqip: url('${lqip(kid.heroImage)}')`} transition:name="kid-hero">
            <picture>
              <source
                media="(max-width: 768px)"
                srcset={heroMobileSrcset}
                sizes={heroMobileSizes}
                width="300"
                height="400"
              />
              <img
                src={cfUrl(kid.heroImage, 'w=1200,fit=cover,gravity=face,q=85')}
                srcset={heroSrcset}
                sizes={heroSizes}
                alt={`Photo of ${kid.name}${kid.diagnosis ? ` — ${kid.diagnosis}` : ''}`}
                class="hero__img lqip-img"
                width="900"
                height="1200"
                loading="eager"
                decoding="async"
                fetchpriority="high"
                itemprop="image"
              />
            </picture>
            {kid.status === 'in-progress' && (
              <span class="hero__badge">In Progress</span>
            )}
          </div>
        ) : (
          <div class="hero__portrait hero__portrait--empty">
            <svg class="hero__placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
            <span class="hero__placeholder-text">{kid.name}</span>
          </div>
        )}

        <div class="hero__info">
          <a href="/kids/" class="hero__back stagger" aria-label="Back to Meet the Kids">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            Meet the Kids
          </a>
          <h1 class="hero__name" itemprop="headline" transition:name="kid-name">{kid.name}</h1>

          {kid.diagnosis && (
            <p class="hero__diagnosis stagger">{kid.diagnosis}</p>
          )}

          {kid.roomTypes && kid.roomTypes.length > 0 && (
            <div class="hero__pills stagger">
              {kid.roomTypes.map(type => (
                <span class="hero__pill">{type}</span>
              ))}
            </div>
          )}

          {statsItems.length > 0 && (
            <p class="hero__meta stagger">{statsItems.join(' · ')}</p>
          )}

          {heroHook && (
            <p class="hero__hook stagger">{heroHook}</p>
          )}

          <div class="hero__actions stagger">
            {kid.fundraisingUrl && (
              <a href={kid.fundraisingUrl} target="_blank" rel="noopener noreferrer" class="hero__donate-btn">
                Donate
              </a>
            )}
            <button class="hero__share-btn" id="share-btn" type="button" aria-label="Share this story">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
              Share
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ 2. The Story — Narrative ═══ -->
    {(storyLede || storyPairs.length > 0 || overflowParas.length > 0) && (
      <section class="story" id="chapter-story" data-chapter="Story" itemprop="articleBody">
        <div class="story__divider container container--narrow">
          <span class="section-rule"></span>
          <span class="section-rule__label">The Story</span>
        </div>

        {storyLede && (
          <div class="story__lede container container--narrow">
            <p class="story__lede-text prose--dropcap" itemprop="description">
              <span set:html={storyLede} />
            </p>
          </div>
        )}

        {storyPairs.length > 0 && (
          <div class="story__pairs">
            {storyPairs.map((pair, i) => (
              <div class={`story__pair story__pair--${pair.layout}`} data-reveal="fade-up" style={`--reveal-delay: ${i * 100}ms`}>
                {pair.photo && (
                  <figure class="story__pair-photo">
                    <div class="story__pair-img-wrap" style={`--lqip: url('${lqip(pair.photo.url)}')`}>
                      <img
                        src={_cfUrl(pair.photo.url, { w: 900, q: 85 })}
                        srcset={_cfSrcset(pair.photo.url, [400, 600, 900, 1200])}
                        sizes="(max-width: 768px) 92vw, (max-width: 1200px) 45vw, 500px"
                        alt={pair.photo.alt || `${kid.name}'s room`}
                        class="story__pair-img lqip-img"
                        loading="lazy"
                        decoding="async"
                        width={dims(pair.photo.url)[0]}
                        height={dims(pair.photo.url)[1]}
                      />
                    </div>
                  </figure>
                )}
                <div class="story__pair-text">
                  <p set:html={pair.text} />
                </div>
              </div>
            ))}
          </div>
        )}

        {overflowParas.length > 0 && (
          <div class="story__overflow container container--narrow">
            <div class="story__body prose">
              {overflowParas.map(paragraph => (
                <p set:html={paragraph} />
              ))}
            </div>
          </div>
        )}

        {pullQuote && (
          <div class="story__quote-wrap">
            <blockquote class="story__pullquote">
              <div class="story__pullquote-inner">
                <svg class="story__pullquote-mark" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                  <path d="M14 28c-2.2 0-4-1.8-4-4 0-6.6 5.4-12 12-12v4c-4.4 0-8 3.6-8 8h4c2.2 0 4 1.8 4 4s-1.8 4-4 4h-4zm20 0c-2.2 0-4-1.8-4-4 0-6.6 5.4-12 12-12v4c-4.4 0-8 3.6-8 8h4c2.2 0 4 1.8 4 4s-1.8 4-4 4h-4z" fill="currentColor"/>
                </svg>
                <p>{pullQuote}</p>
              </div>
            </blockquote>
          </div>
        )}
      </section>
    )}

    <!-- ═══ 3. The Design — Overlapping Cards ═══ -->
    {hasPlans && (
      <section class="design" id="chapter-design" data-chapter="Design">
        <div class="container">
          <div class="design__divider">
            <span class="section-rule"></span>
            <span class="section-rule__label">The Design</span>
          </div>
          <h2 class="section-label" style="text-align: center;">From Blueprint to Reality</h2>
          <p class="design__sub">Explore the architectural plans behind {kid.name}'s transformation.</p>

          <div class="design__desk">
            {displayAsBuilt.length > 0 && (
              displayAsBuilt.map((plan, i) => {
                const lbIndex = galleryPhotos.length + plans.indexOf(plan);
                return (
                  <div class="design__stack design__stack--back" data-reveal="fade-up" style="--reveal-delay: 0ms">
                    <span class="design__tag">As Built</span>
                    <button
                      class="design__card masonry__item"
                      data-index={lbIndex}
                      data-src={cfUrl(plan.url, 'w=1600,q=85')}
                      data-srcset={_cfSrcset(plan.url, [800, 1200, 1600, 2400])}
                      data-alt={plan.label || `As-built plan`}
                      type="button"
                      aria-label={`View plan: ${plan.label || 'As-built plan'}`}
                      style={`--lqip: url('${lqip(plan.url)}')`}
                    >
                      <img
                        src={cfUrl(plan.url, 'w=800,q=85')}
                        srcset={cfSrcset(plan.url, [400, 600, 800, 1200])}
                        sizes="(max-width: 768px) 80vw, (max-width: 1100px) 45vw, 440px"
                        alt={plan.label || `As-built plan`}
                        class="design__img lqip-img"
                        loading="lazy"
                        decoding="async"
                        width={dims(plan.url)[0]}
                        height={dims(plan.url)[1]}
                      />
                    </button>
                  </div>
                );
              })
            )}

            {displayProposed.length > 0 && (
              displayProposed.map((plan, i) => {
                const lbIndex = galleryPhotos.length + plans.indexOf(plan);
                return (
                  <div class="design__stack design__stack--front" data-reveal="fade-up" style="--reveal-delay: 200ms">
                    <span class="design__tag design__tag--accent">Proposed Design</span>
                    <button
                      class="design__card masonry__item"
                      data-index={lbIndex}
                      data-src={cfUrl(plan.url, 'w=1600,q=85')}
                      data-srcset={_cfSrcset(plan.url, [800, 1200, 1600, 2400])}
                      data-alt={plan.label || `Proposed plan`}
                      type="button"
                      aria-label={`View plan: ${plan.label || 'Proposed plan'}`}
                      style={`--lqip: url('${lqip(plan.url)}')`}
                    >
                      <img
                        src={cfUrl(plan.url, 'w=800,q=85')}
                        srcset={cfSrcset(plan.url, [400, 600, 800, 1200])}
                        sizes="(max-width: 768px) 80vw, (max-width: 1100px) 45vw, 440px"
                        alt={plan.label || `Proposed plan`}
                        class="design__img lqip-img"
                        loading="lazy"
                        decoding="async"
                        width={dims(plan.url)[0]}
                        height={dims(plan.url)[1]}
                      />
                    </button>
                  </div>
                );
              })
            )}

            <!-- Directional arrow between cards -->
            <div class="design__arrow" aria-hidden="true">
              <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                <circle cx="24" cy="24" r="23" stroke="var(--c-yellow)" stroke-width="2" opacity="0.4"/>
                <path d="M18 24h12m0 0-5-5m5 5-5 5" stroke="var(--c-yellow)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>

          {extraPlansCount > 0 && (
            <p class="design__more">
              <button class="design__more-btn masonry__item" data-index={galleryPhotos.length + (displayAsBuilt.length > 0 ? 1 : 0) + (displayProposed.length > 0 ? 1 : 0)}
                data-src={cfUrl(plans[2]?.url || plans[0].url, 'w=1600,q=85')}
                data-srcset={_cfSrcset(plans[2]?.url || plans[0].url, [800, 1200, 1600, 2400])}
                data-alt="Plan"
                type="button">
                View all {plans.length} plans
              </button>
            </p>
          )}
        </div>
      </section>
    )}

    <!-- ═══ 4. Before & After — Comparison Sliders ═══ -->
    {hasBeforeAfter && (
      <section class="ba-section" id="chapter-transform" data-chapter="Transform">
        <div class="container">
          <div class="ba-section__divider">
            <span class="section-rule"></span>
            <span class="section-rule__label">The Transformation</span>
          </div>
          <h2 class="section-label" style="text-align: center;">Before & After</h2>
          <p class="ba-section__sub">Drag the slider to compare {kid.name}'s space before and after renovation.</p>

          <div class="ba-section__sliders">
            {beforeAfterPhotos.map((pair: any, i: number) => (
              <div class="ba-slider" data-ba-slider data-reveal="fade-up" style={`--reveal-delay: ${i * 150}ms`}>
                {pair.room && <p class="ba-slider__room">{pair.room}</p>}
                <div class="ba-slider__container" style="--ba-pos: 50%">
                  <img
                    class="ba-slider__after lqip-img"
                    src={_cfUrl(pair.after, { w: 1200, q: 85 })}
                    srcset={_cfSrcset(pair.after, [600, 900, 1200, 1600])}
                    sizes="(max-width: 768px) 92vw, (max-width: 1100px) 70vw, 800px"
                    alt={pair.afterAlt || `${kid.name}'s room after renovation`}
                    loading="lazy"
                    decoding="async"
                    width="1200"
                    height="900"
                    style={`--lqip: url('${lqip(pair.after)}')`}
                  />
                  <div class="ba-slider__before-clip">
                    <img
                      class="ba-slider__before lqip-img"
                      src={_cfUrl(pair.before, { w: 1200, q: 85 })}
