                    max="100"
                    value="50"
                    class="ba-slider__range"
                    aria-label={`Compare before and after${pair.room ? ` for ${pair.room}` : ''}`}
                  />
                  <div class="ba-slider__handle" aria-hidden="true">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="m9 18-6-6 6-6"/><path d="m15 6 6 6-6 6"/>
                    </svg>
                  </div>
                  <span class="ba-slider__label ba-slider__label--before">Before</span>
                  <span class="ba-slider__label ba-slider__label--after">After</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ═══ 5. The Reveal — Video ═══ -->
    {hasVideo && (
      <section class="reveal" id="chapter-reveal" data-chapter="Reveal">
