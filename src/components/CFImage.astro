---
/**
 * Cloudflare Images responsive image component.
 * Usage: <CFImage id="abc123" alt="Description" widths={[400, 800, 1200]} />
 * 
 * TODO: Replace ACCOUNT_HASH with your Cloudflare Images account hash
 */

interface Props {
  id: string;
  alt: string;
  widths?: number[];
  sizes?: string;
  class?: string;
  loading?: 'lazy' | 'eager';
}

const ACCOUNT_HASH = 'YOUR_CF_ACCOUNT_HASH'; // Replace after Cloudflare Images setup

const {
  id,
  alt,
  widths = [400, 800, 1200],
  sizes = '(max-width: 600px) 400px, (max-width: 1000px) 800px, 1200px',
  class: className,
  loading = 'lazy',
} = Astro.props;

const srcset = widths
  .map(w => `https://imagedelivery.net/${ACCOUNT_HASH}/${id}/w=${w} ${w}w`)
  .join(', ');

const src = `https://imagedelivery.net/${ACCOUNT_HASH}/${id}/w=${widths[widths.length - 1]}`;
---

<img
  src={src}
  srcset={srcset}
  sizes={sizes}
  alt={alt}
  loading={loading}
  decoding="async"
  class={className}
/>
