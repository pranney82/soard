  }
  /* Bleed strip: covers the 1px gap between the header snapshot and
     the incoming page during view-transitions on mobile.  The pseudo
     sits just below the header and paints cream so the dark body bg
     can never peek through. */
  .site-header::after {
    content: '';
    position: absolute;
    left: 0; right: 0;
    bottom: -2px;
    height: 2px;
