  }

  /* ═══════ SCROLL ═══════ */
  var ticking = false, mobileOpen = false;
  function onScroll() {
    ticking = false;
    header.classList.toggle('header--scrolled', window.scrollY > 20);
  }
  window.addEventListener('scroll', function () {
    if (!ticking) { requestAnimationFrame(onScroll); ticking = true; }
  }, { passive: true, signal: sig });

  /* ═══════ MOBILE NAV ═══════ */
  var mBtn = document.getElementById('mobile-toggle');
  var mPanel = document.getElementById('mobile-panel');
  var mainEl = document.querySelector('main');
  var footerEl = document.querySelector('footer');
  var savedY = 0;

  function mGetFocusable() {
    return [mBtn].concat(Array.from(mPanel.querySelectorAll('a, button'))).filter(Boolean);
  }

  function mOpen() {
    mobileOpen = true; savedY = window.scrollY;
    mPanel.style.transition = '';            /* restore in case mHideInstant killed it */
    document.documentElement.classList.add('menu-open');
    document.body.style.top = '-' + savedY + 'px';
