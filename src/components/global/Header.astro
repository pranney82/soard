---
/**
 * Header.astro — v3 — Stripe-style morphing navigation
 *
 * Design:
 *   - MORPHING DROPDOWN: Single shared dropdown background that smoothly
 *     scales + translates (GPU-composited via transforms) as user moves
 *     between nav items. Content cross-fades via opacity. Arrow tracks.
 *   - Glass header with backdrop-filter, scrolled state
 *   - Sliding yellow indicator bar under hovered items
 *   - Rich dropdown content with icons + descriptions
 *   - 3D perspective swing on dropdown open
 *   - Editorial mobile takeover with large serif headings
 *
 * Accessibility:
 *   - Skip-to-content link
 *   - Full WAI-ARIA menubar pattern (arrow keys, Home/End, Escape)
 *   - Focus trap in mobile menu
 *   - inert on main/footer when menu open
 *   - aria-expanded, aria-controls, aria-label, aria-hidden
 *   - prefers-reduced-motion: all animations disabled
 *   - 44px+ touch targets everywhere
 *
 * Performance:
 *   - ~160 lines vanilla JS, zero framework
 *   - Dropdown animation: transform + opacity only (GPU composited)
 *   - will-change on animated elements
 *   - Passive scroll/touch listeners
 *   - No layout thrashing — dimensions cached on first hover
 */
const currentPath = Astro.url.pathname;

interface NavChild {
  label: string;
  href: string;
  external?: boolean;
  desc?: string;
  icon?: string;
}

interface NavGroup {
  label: string;
  children: NavChild[];
}

const nav: NavGroup[] = [
  {
    label: 'About',
    children: [
      { label: 'Our Story', href: '/about/', desc: 'How it all began', icon: '📖' },
      { label: 'Leadership', href: '/about/leadership/', desc: 'Meet the team', icon: '👥' },
      { label: 'Financials', href: '/about/financials/', desc: 'Full transparency', icon: '📊' },
    ],
  },
  {
    label: 'Kids & Projects',
    children: [
      { label: 'Featured Rooms', href: '/rooms/', desc: 'Dream rooms revealed', icon: '✨' },
      { label: 'Meet the Kids', href: '/kids/', desc: 'Stories of joy', icon: '💛' },
      { label: 'Community Projects', href: '/rooms/community/', desc: 'Beyond bedrooms', icon: '🏘️' },
    ],
  },
  {
    label: 'Our Partners',
    children: [
      { label: 'All Partners', href: '/partners/', desc: 'Who makes it happen', icon: '🤝' },
      { label: 'Construction', href: '/partners/construction/', desc: 'Builders & contractors', icon: '🔨' },
      { label: 'Design', href: '/partners/design/', desc: 'Designers & brands', icon: '🎨' },
    ],
  },
  {
    label: 'Get Involved',
    children: [
      { label: 'Events', href: 'https://www.sunnyandranney.com/events', external: true, desc: 'Upcoming gatherings', icon: '📅' },
      { label: 'Donate', href: '/donate/', desc: 'Change a life today', icon: '❤️' },
      { label: '2026 Application', href: '/apply/', desc: 'Apply for a room', icon: '📝' },
    ],
  },
  {
    label: 'Shop Our Stores',
    children: [
      { label: 'Sunny & Ranney', href: 'https://www.sunnyandranney.com', external: true, desc: 'Home & décor store', icon: '🏠' },
      { label: 'Partly Sunny', href: 'https://partlysunnystore.com', external: true, desc: 'Clothing & gifts', icon: '👕' },
    ],
  },
];

function isActive(href: string) {
  if (href.startsWith('http')) return false;
  return currentPath === href;
}

function isGroupActive(group: NavGroup) {
  return group.children.some((child) => isActive(child.href));
}
---

<!-- Skip Navigation -->
<a href="#main-content" class="skip-nav">Skip to main content</a>

<header class="site-header" id="site-header">
  <div class="header-inner">
    <!-- Logo -->
    <a href="/" class="logo" aria-label="Sunshine on a Ranney Day — Home">
      <picture>
        <source srcset="/images/logos/sunny-pig-transparent.webp" type="image/webp" />
        <img
          src="/images/logos/sunny-pig-transparent.png"
          alt=""
          class="logo-icon"
          width="96"
          height="34"
          loading="eager"
          fetchpriority="high"
        />
      </picture>
      <span class="logo-text">
        <span class="logo-line1">Sunshine on a</span>
        <span class="logo-line2">Ranney Day</span>
      </span>
    </a>

    <!-- Desktop Navigation with morphing dropdown -->
    <nav class="desktop-nav" id="desktop-nav" aria-label="Main navigation">
      <ul class="nav-list" role="menubar">
        {nav.map((item, groupIndex) => (
          <li
            class:list={['nav-item', { 'group-active': isGroupActive(item) }]}
            role="none"
            data-nav-group={groupIndex}
          >
            <button
              class:list={['nav-link', { 'parent-active': isGroupActive(item) }]}
              role="menuitem"
              aria-haspopup="true"
              aria-expanded="false"
              tabindex={groupIndex === 0 ? '0' : '-1'}
              data-nav-trigger={groupIndex}
            >
              <span class="nav-link-text">{item.label}</span>
              <svg class="chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </li>
        ))}
      </ul>

      <!-- Sliding indicator -->
      <div class="nav-indicator" id="nav-indicator" aria-hidden="true"></div>

      <!-- Morphing dropdown — single shared container -->
      <div class="dropdown-root" id="dropdown-root" aria-hidden="true">
        <div class="dropdown-arrow" id="dropdown-arrow"></div>
        <div class="dropdown-bg" id="dropdown-bg"></div>
        <div class="dropdown-content" id="dropdown-content">
          {nav.map((item, groupIndex) => (
            <div
              class="dropdown-section"
              data-dropdown-section={groupIndex}
              role="menu"
              id={`dropdown-section-${groupIndex}`}
            >
              {item.children.map((child, childIndex) => (
                <a
                  href={child.href}
                  role="menuitem"
                  class:list={['dropdown-link', { active: isActive(child.href) }]}
                  tabindex="-1"
                  data-child-index={childIndex}
                  {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  <span class="dd-icon" aria-hidden="true">{child.icon}</span>
                  <span class="dd-text">
                    <span class="dd-label">
                      {child.label}
                      {child.external && (
                        <svg class="ext-icon" width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                          <path d="M4.5 1.5H1.5V10.5H10.5V7.5M7 1.5H10.5M10.5 1.5V5M10.5 1.5L5.5 6.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      )}
                    </span>
                    {child.desc && <span class="dd-desc">{child.desc}</span>}
                  </span>
                </a>
              ))}
            </div>
          ))}
        </div>
      </div>
    </nav>

    <!-- Donate CTA -->
    <a href="/donate/" class="header-cta">
      <span class="header-cta-heart" aria-hidden="true">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
      </span>
      Donate
    </a>

    <!-- Mobile hamburger -->
    <button
      type="button"
      class="mobile-toggle"
      id="mobile-toggle-btn"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-nav-panel"
    >
      <span class="hamburger" aria-hidden="true">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </span>
    </button>
  </div>
</header>

<!-- Mobile full-screen nav -->
<div class="mobile-nav" id="mobile-nav-panel" role="dialog" aria-label="Mobile navigation" aria-modal="true" aria-hidden="true">
  <div class="mobile-nav-header">
    <a href="/" class="mobile-nav-logo" aria-label="Home">
      <picture>
        <source srcset="/images/logos/logo-dark-bg.webp" type="image/webp" />
        <img src="/images/logos/logo-dark-bg.png" alt="Sunshine on a Ranney Day" width="80" height="80" loading="eager" />
      </picture>
    </a>
    <button type="button" class="mobile-close-btn" id="mobile-close-btn" aria-label="Close menu">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <path d="M17 5L5 17M5 5L17 17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <div class="mobile-nav-body">
    {nav.map((item, i) => (
      <div class="mob-group" style={`--i: ${i}`}>
        <h3 class="mob-heading">{item.label}</h3>
        <div class="mob-links">
          {item.children.map((child) => (
            <a
              href={child.href}
              class:list={['mob-link', { active: isActive(child.href) }]}
              {...(child.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              <span class="mob-link-icon">{child.icon}</span>
              <span class="mob-link-inner">
                <span class="mob-link-label">{child.label}</span>
                {child.desc && <span class="mob-link-desc">{child.desc}</span>}
              </span>
              {child.external && (
                <svg class="mob-ext" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-label="Opens in new tab">
                  <path d="M5.25 2H2V12H12V8.75M8.5 2H12M12 2V5.5M12 2L6.5 7.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>

  <div class="mobile-nav-footer">
    <a href="/donate/" class="mobile-donate-btn">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
      Donate Now
    </a>
  </div>
</div>

<script>
(function () {
  /* ═══════════════════════════════════════════
     MORPHING DROPDOWN — Stripe-style
     ═══════════════════════════════════════════ */
  var desktopNav = document.getElementById('desktop-nav');
  var dropdownRoot = document.getElementById('dropdown-root');
  var dropdownBg = document.getElementById('dropdown-bg');
  var dropdownArrow = document.getElementById('dropdown-arrow');
  var dropdownContent = document.getElementById('dropdown-content');
  var indicator = document.getElementById('nav-indicator');
  var header = document.getElementById('site-header');
  var navItems = document.querySelectorAll('.nav-item[data-nav-group]');
  var navButtons = document.querySelectorAll('[data-nav-trigger]');
  var sections = document.querySelectorAll('.dropdown-section');

  if (!desktopNav || !dropdownRoot || !dropdownBg || !dropdownContent) return;

  // Cache dimensions for each section (measured lazily)
  var dimCache = {};
  var activeSection = -1;
  var isDropdownOpen = false;
  var closeTimer = null;
  var GRACE = 220;

  // Measure a section's natural dimensions
  function measureSection(idx) {
    if (dimCache[idx]) return dimCache[idx];
    var sec = sections[idx];
    if (!sec) return null;

    // Temporarily make visible to measure
    sec.style.display = 'block';
    sec.style.opacity = '0';
    sec.style.position = 'relative';
    var rect = sec.getBoundingClientRect();
    sec.style.display = '';
    sec.style.opacity = '';
    sec.style.position = '';

    dimCache[idx] = { width: rect.width, height: rect.height };
    return dimCache[idx];
  }

  // Show the morphing dropdown for a given nav index
  function showDropdown(idx) {
    if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }

    var dim = measureSection(idx);
    if (!dim) return;

    // Get trigger button position relative to nav
    var trigger = navButtons[idx];
    if (!trigger) return;
    var navRect = desktopNav.getBoundingClientRect();
    var triggerRect = trigger.getBoundingClientRect();

    // Center dropdown under the trigger
    var dropdownX = triggerRect.left - navRect.left + triggerRect.width / 2 - dim.width / 2;

    // Clamp to not overflow nav edges
    var minX = 0;
    var maxX = navRect.width - dim.width;
    dropdownX = Math.max(minX, Math.min(maxX, dropdownX));

    // Arrow position — center under trigger
    var arrowX = triggerRect.left - navRect.left + triggerRect.width / 2;

    var firstOpen = !isDropdownOpen;
    isDropdownOpen = true;

    // Update ARIA
    navButtons.forEach(function (b) { b.setAttribute('aria-expanded', 'false'); });
    trigger.setAttribute('aria-expanded', 'true');

    // Position and morph the background
    if (firstOpen) {
      dropdownRoot.classList.remove('morph-transition');
      // Don't show as opening by setting no-transition
    } else {
      dropdownRoot.classList.add('morph-transition');
    }

    dropdownRoot.classList.add('is-open');
    dropdownBg.style.transform = 'translateX(' + dropdownX + 'px) scaleX(' + (dim.width / 420) + ') scaleY(' + (dim.height / 280) + ')';
    dropdownArrow.style.transform = 'translateX(' + arrowX + 'px) rotate(45deg)';
    dropdownContent.style.transform = 'translateX(' + dropdownX + 'px)';
    dropdownContent.style.width = dim.width + 'px';
    dropdownContent.style.height = dim.height + 'px';

    // Cross-fade sections
    sections.forEach(function (sec, i) {
      if (i === idx) {
        sec.classList.add('active');
      } else {
        sec.classList.remove('active');
      }
    });

    activeSection = idx;

    // After the first frame, enable transitions for morphing
    if (firstOpen) {
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          dropdownRoot.classList.add('morph-transition');
        });
      });
    }
  }

  function hideDropdown() {
    isDropdownOpen = false;
    activeSection = -1;
    dropdownRoot.classList.remove('is-open');
    navButtons.forEach(function (b) { b.setAttribute('aria-expanded', 'false'); });
    sections.forEach(function (sec) { sec.classList.remove('active'); });
  }

  function scheduleClose() {
    if (closeTimer) clearTimeout(closeTimer);
    closeTimer = setTimeout(function () {
      hideDropdown();
      closeTimer = null;
    }, GRACE);
  }

  // Hover intent on nav items
  navItems.forEach(function (item) {
    item.addEventListener('mouseenter', function () {
      var idx = parseInt(item.dataset.navGroup);
      showDropdown(idx);
    });
  });

  // Keep dropdown open when hovering the dropdown itself
  dropdownRoot.addEventListener('mouseenter', function () {
    if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
  });

  dropdownRoot.addEventListener('mouseleave', function () {
    scheduleClose();
  });

  // Close when leaving nav area
  navItems.forEach(function (item) {
    item.addEventListener('mouseleave', function () {
      scheduleClose();
    });
  });

  // Close on click outside
  document.addEventListener('click', function (e) {
    if (!e.target.closest('.desktop-nav')) hideDropdown();
  });

  /* ═══════════════════════════════════════════
     SLIDING NAV INDICATOR
     ═══════════════════════════════════════════ */
  function positionIndicator(el) {
    if (!indicator || !desktopNav) return;
    var navRect = desktopNav.getBoundingClientRect();
    var elRect = el.getBoundingClientRect();
    indicator.style.width = elRect.width + 'px';
    indicator.style.transform = 'translateX(' + (elRect.left - navRect.left) + 'px)';
    indicator.style.opacity = '1';
  }

  function resetIndicator() {
    if (!indicator) return;
    var activeBtn = document.querySelector('.nav-link.parent-active');
    if (activeBtn) positionIndicator(activeBtn);
    else indicator.style.opacity = '0';
  }

  navButtons.forEach(function (btn) {
    btn.addEventListener('mouseenter', function () { positionIndicator(this); });
  });

  desktopNav.addEventListener('mouseleave', resetIndicator);

  // Init indicator on active item
  requestAnimationFrame(function () {
    var activeBtn = document.querySelector('.nav-link.parent-active');
    if (activeBtn && indicator) {
      indicator.style.transition = 'none';
      positionIndicator(activeBtn);
      requestAnimationFrame(function () { indicator.style.transition = ''; });
    }
  });

  /* ═══════════════════════════════════════════
     KEYBOARD NAV — WAI-ARIA Menubar
     ═══════════════════════════════════════════ */
  function getDropdownLinks(idx) {
    return Array.from(sections[idx] ? sections[idx].querySelectorAll('.dropdown-link') : []);
  }

  var navList = document.querySelector('.nav-list');
  if (navList) {
    navList.addEventListener('keydown', function (e) {
      var target = e.target;
      var isButton = target.hasAttribute('data-nav-trigger');
      var parentItem = target.closest('.nav-item[data-nav-group]');
      if (!parentItem) return;
      var groupIdx = parseInt(parentItem.dataset.navGroup);

      if (isButton) {
        switch (e.key) {
          case 'ArrowRight': {
            e.preventDefault(); hideDropdown();
            var nxt = navButtons[(groupIdx + 1) % navButtons.length];
            navButtons.forEach(function (b) { b.setAttribute('tabindex', '-1'); });
            nxt.setAttribute('tabindex', '0'); nxt.focus();
            break;
          }
          case 'ArrowLeft': {
            e.preventDefault(); hideDropdown();
            var prv = navButtons[(groupIdx - 1 + navButtons.length) % navButtons.length];
            navButtons.forEach(function (b) { b.setAttribute('tabindex', '-1'); });
            prv.setAttribute('tabindex', '0'); prv.focus();
            break;
          }
          case 'ArrowDown': case 'Enter': case ' ': {
            e.preventDefault(); showDropdown(groupIdx);
            var links = getDropdownLinks(groupIdx);
            if (links.length) links[0].focus();
            break;
          }
          case 'Escape': { e.preventDefault(); hideDropdown(); target.focus(); break; }
        }
      }
    });

    // Keyboard nav inside dropdown
    dropdownRoot.addEventListener('keydown', function (e) {
      var target = e.target;
      if (!target.classList.contains('dropdown-link')) return;
      var section = target.closest('.dropdown-section');
      if (!section) return;
      var idx = parseInt(section.dataset.dropdownSection);
      var links = getDropdownLinks(idx);
      var pos = links.indexOf(target);

      switch (e.key) {
        case 'ArrowDown': { e.preventDefault(); links[(pos + 1) % links.length].focus(); break; }
        case 'ArrowUp': {
          e.preventDefault();
          if (pos === 0) { hideDropdown(); navButtons[idx].focus(); }
          else links[pos - 1].focus();
          break;
        }
        case 'ArrowRight': {
          e.preventDefault(); var ni = (idx + 1) % navButtons.length;
          showDropdown(ni);
          navButtons.forEach(function (b) { b.setAttribute('tabindex', '-1'); });
          navButtons[ni].setAttribute('tabindex', '0');
          var nl = getDropdownLinks(ni); if (nl.length) nl[0].focus();
          break;
        }
        case 'ArrowLeft': {
          e.preventDefault(); var pi = (idx - 1 + navButtons.length) % navButtons.length;
          showDropdown(pi);
          navButtons.forEach(function (b) { b.setAttribute('tabindex', '-1'); });
          navButtons[pi].setAttribute('tabindex', '0');
          var pl = getDropdownLinks(pi); if (pl.length) pl[0].focus();
          break;
        }
        case 'Escape': { e.preventDefault(); hideDropdown(); navButtons[idx].focus(); break; }
        case 'Home': { e.preventDefault(); if (links.length) links[0].focus(); break; }
        case 'End': { e.preventDefault(); if (links.length) links[links.length - 1].focus(); break; }
        case 'Tab': { hideDropdown(); break; }
      }
    });
  }

  /* ═══════════════════════════════════════════
     SCROLL BEHAVIOR — hide/show + scrolled state
     ═══════════════════════════════════════════ */
  var lastScrollY = 0, scrollTicking = false, THRESHOLD = 8;
  function onScroll() {
    scrollTicking = false;
    var y = window.scrollY;
    header.classList.toggle('header--scrolled', y > 20);
    if (y <= 10) { header.classList.remove('header--hidden'); lastScrollY = y; return; }
    if (mobileIsOpen) { lastScrollY = y; return; }
    if (y - lastScrollY > THRESHOLD) header.classList.add('header--hidden');
    else if (lastScrollY - y > THRESHOLD) header.classList.remove('header--hidden');
    lastScrollY = y;
  }
  window.addEventListener('scroll', function () {
    if (!scrollTicking) { requestAnimationFrame(onScroll); scrollTicking = true; }
  }, { passive: true });

  /* ═══════════════════════════════════════════
     MOBILE NAV
     ═══════════════════════════════════════════ */
  var mobileBtn = document.getElementById('mobile-toggle-btn');
  var mobilePanel = document.getElementById('mobile-nav-panel');
  var mobileClose = document.getElementById('mobile-close-btn');
  var mainEl = document.querySelector('main');
  var footerEl = document.querySelector('footer');
  var mobileIsOpen = false;
  var savedScrollY = 0;

  function mobileGetFocusable() {
    return [mobileClose].concat(Array.from(mobilePanel.querySelectorAll('a, button:not(#mobile-close-btn)'))).filter(Boolean);
  }

  function mobileOpen() {
    mobileIsOpen = true;
    savedScrollY = window.scrollY;
    document.body.style.cssText = 'position:fixed;top:-' + savedScrollY + 'px;left:0;right:0;overflow:hidden;';
    mobileBtn.setAttribute('aria-expanded', 'true');
    mobileBtn.setAttribute('aria-label', 'Close menu');
    mobilePanel.classList.add('is-open');
    mobilePanel.setAttribute('aria-hidden', 'false');
    if (mainEl) mainEl.setAttribute('inert', '');
    if (footerEl) footerEl.setAttribute('inert', '');
    if (mobileClose) mobileClose.focus();
  }

  function mobileCloseMenu() {
    mobileIsOpen = false;
    document.body.style.cssText = '';
    window.scrollTo(0, savedScrollY);
    mobileBtn.setAttribute('aria-expanded', 'false');
    mobileBtn.setAttribute('aria-label', 'Open menu');
    mobilePanel.classList.remove('is-open');
    mobilePanel.setAttribute('aria-hidden', 'true');
    if (mainEl) mainEl.removeAttribute('inert');
    if (footerEl) footerEl.removeAttribute('inert');
    mobileBtn.focus();
  }

  if (mobileBtn) {
    mobileBtn.addEventListener('click', function () { mobileIsOpen ? mobileCloseMenu() : mobileOpen(); });
  }
  if (mobileClose) mobileClose.addEventListener('click', mobileCloseMenu);

  document.addEventListener('keydown', function (e) {
    if (!mobileIsOpen) return;
    if (e.key === 'Escape') { mobileCloseMenu(); return; }
    if (e.key === 'Tab') {
      var focusable = mobileGetFocusable();
      var first = focusable[0], last = focusable[focusable.length - 1];
      if (e.shiftKey) { if (document.activeElement === first) { e.preventDefault(); last.focus(); } }
      else { if (document.activeElement === last) { e.preventDefault(); first.focus(); } }
    }
  });

  window.matchMedia('(min-width: 1024px)').addEventListener('change', function (e) {
    if (e.matches && mobileIsOpen) mobileCloseMenu();
  });

  if (mobilePanel) {
    mobilePanel.querySelectorAll('a').forEach(function (a) { a.addEventListener('click', mobileCloseMenu); });

    // Swipe down to close
    var ty = 0, sw = false;
    mobilePanel.addEventListener('touchstart', function (e) { ty = e.touches[0].clientY; sw = true; }, { passive: true });
    mobilePanel.addEventListener('touchmove', function (e) { if (sw && e.touches[0].clientY - ty > 80) { sw = false; mobileCloseMenu(); } }, { passive: true });
    mobilePanel.addEventListener('touchend', function () { sw = false; }, { passive: true });
  }
})();
</script>

<style>
  /* ── Skip Nav ─────────────────────────── */
  .skip-nav {
    position: fixed; top: -100%; left: var(--space-md); z-index: 10000;
    padding: var(--space-sm) var(--space-lg);
    background: var(--c-yellow); color: var(--c-dark);
