---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
---

<BaseLayout title="Page Not Found">
  <section class="not-found">
    <div class="container" style="text-align: center;">
      <span class="not-found__emoji" aria-hidden="true">🐷</span>
      <h1>Oops! Page Not Found</h1>
      <p style="margin-top: var(--space-md); color: var(--c-text-muted); font-size: 1.1rem; max-width: 500px; margin-inline: auto;">
        Gracie couldn't find the page you're looking for.
        It may have been moved during our site rebuild.
      </p>
      <div style="margin-top: var(--space-xl); display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap;">
        <Button href="/">Go Home</Button>
        <Button href="/kids/" variant="outline">Meet the Kids</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    padding-block: var(--space-5xl);
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .not-found__emoji {
    font-size: 4rem;
    display: block;
    margin-bottom: var(--space-lg);
  }
</style>
