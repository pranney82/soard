---
/**
 * PartnerShowcase.astro
 * Premium partner logo showcase — clean card grid, no names.
 *
 * Subtle bordered cards with generous whitespace give logos
 * a gallery-like presentation. Zero JS. Scoped styles. CF density srcset.
 */
import { CF_BASE as CF, cfDensitySrcset } from '../../utils/cf-image';

interface Logo {
  id: string;
  name: string;
}

interface Props {
  logos: Logo[];
  totalPartners: number;
}

const { logos, totalPartners } = Astro.props;
const featured = logos;
---

<section class="ps" aria-labelledby="ps-heading">
  <div class="ps__inner">
    <div class="ps__header" data-reveal>
      <div class="ps__label">Signature Partners</div>
      <h2 id="ps-heading" class="ps__title">We don't build alone.</h2>
      <p class="ps__body">
        Every dream room starts with a team. {totalPartners}+ partners across
        Greater Atlanta bring the time, talent, and materials that make it all possible.
      </p>
    </div>

    <div class="ps__grid" data-reveal data-delay="1" role="list" aria-label="Featured partners">
      {featured.map(p => (
        <div role="listitem"><a class="ps__cell" href="/partners" aria-label={p.name}>
          <div class="ps__logo-frame">
            <img
              src={`${CF}/${p.id}/w=180,h=100,fit=contain,trim=20,q=80`}
              srcset={`${CF}/${p.id}/w=180,h=100,fit=contain,trim=20,q=80 1x, ${CF}/${p.id}/w=360,h=200,fit=contain,trim=20,q=80 2x`}
              alt={p.name}
              width="180"
              height="100"
              loading="lazy"
              decoding="async"
            />
          </div>
        </a></div>
      ))}
    </div>

    <div class="ps__footer" data-reveal data-delay="2">
      <a href="/partners" class="ps__link">
        Meet all {totalPartners}+ partners
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3.5 8h9M8.5 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .ps {
    padding: clamp(80px, 10vw, 128px) 0;
    background: var(--c-cream, #FEFCF5);
    border-top: 1px solid var(--c-border, #E5E4E0);
    contain: layout style;
  }

  .ps__inner {
    max-width: var(--max-width, 1200px);
    margin: 0 auto;
    padding: 0 var(--page-padding, clamp(1rem, 4vw, 2rem));
    text-align: center;
  }

  .ps__label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--c-text-light, #6D6E74);
    margin-bottom: 20px;
  }

  .ps__title {
    font-family: var(--font-display, 'Libre Baskerville', Georgia, serif);
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 700;
    line-height: 1.2;
    color: var(--c-dark, #373A36);
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }

  .ps__body {
    font-size: clamp(16px, 1.3vw, 18px);
    line-height: 1.7;
    color: var(--c-text-muted, #5A5B61);
    max-width: 540px;
    margin: 0 auto;
  }

  /* Centered flex grid — adapts to any number of signature logos */
  .ps__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: clamp(12px, 1.8vw, 20px);
    margin: clamp(52px, 6vw, 80px) auto 0;
    max-width: 1040px;
  }

  .ps__cell {
    display: flex;
    align-items: center;
    justify-content: center;
    width: clamp(120px, 16vw, 176px);
    padding: clamp(24px, 3vw, 36px) clamp(16px, 2vw, 24px);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                background 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .ps__cell:hover {
    border-color: rgba(0, 0, 0, 0.1);
    background: #fff;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.04);
  }

  /* Fixed-size frame — every logo gets the same box */
  .ps__logo-frame {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 64px;
  }

  .ps__logo-frame img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0.55;
    filter: grayscale(1);
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                filter 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .ps__cell:hover .ps__logo-frame img {
    opacity: 1;
    filter: grayscale(0);
  }

  /* ── Footer link ── */
  .ps__footer {
    margin-top: clamp(40px, 5vw, 60px);
  }

  .ps__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 600;
    color: var(--c-text-light, #6D6E74);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.3s ease, gap 0.3s ease;
  }

  .ps__link:hover {
    color: var(--c-dark, #373A36);
    gap: 10px;
  }

  .ps__link svg {
    transition: transform 0.3s ease;
  }

  .ps__link:hover svg {
    transform: translateX(2px);
  }

  /* ── Tablet ── */
  @media (max-width: 840px) {
    .ps__grid { max-width: 560px; }
    .ps__cell { width: clamp(110px, 28vw, 160px); }
  }

  /* ── Mobile ── */
  @media (max-width: 480px) {
    .ps { padding: 56px 0; }
    .ps__grid { gap: 10px; }
    .ps__cell { width: calc(50% - 10px); padding: 20px 12px; }
    .ps__logo-frame { height: 48px; }
  }
</style>
