---
/**
 * Golf Tournament — Sunshine on a Ranney Fairway 2026
 * Ported from sunnyandranney.com/events/ and adapted for SOARD design system
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { cfRaw, cfSrcset, cfLqip } from '../../utils/cf-image';

/* ── Sponsorship tiers (data-driven) ── */
interface Tier {
  name: string;
  price: string;
  detail?: string;
  perk?: string;
  badge?: string;
  badgeStyle?: 'gold' | 'green';
  highlight?: 'featured' | 'popular';
}

const mainTiers: Tier[] = [
  { name: 'Presenting Sponsor', price: '$20,000', detail: '2 Foursomes (8 Golfers)', perk: 'Oakley sunglasses + Footjoy shoes per player, video interview, logo on all signage & social media', badge: 'Top Sponsor', badgeStyle: 'gold', highlight: 'featured' },
  { name: 'Titanium Sponsor',   price: '$15,000', detail: '2 Foursomes (8 Golfers)', perk: 'Oakley sunglasses or Footjoy shoes, video interview, logo placement' },
  { name: 'Diamond Sponsor',    price: '$10,000', detail: '1 Foursome (4 Golfers)',  perk: 'Video interview, logo on social media & signage' },
  { name: 'Platinum Sponsor',   price: '$7,500',  detail: '1 Foursome (4 Golfers)',  perk: 'Signage, multiple social media posts' },
  { name: 'Gold Sponsor',       price: '$5,000',  detail: '1 Foursome (4 Golfers)',  perk: 'Signage, social media posts' },
  { name: 'Foursome',           price: '$1,500',  detail: '4 Golfers',               perk: 'Lunch & beverages included', badge: 'Most Popular', badgeStyle: 'green', highlight: 'popular' },
];

const addOnTiers: Tier[] = [
  { name: 'Lunch Sponsor',    price: '$2,500' },
  { name: 'Putting Contest',   price: '$2,500' },
  { name: 'Beverage Cart',     price: '$2,000' },
  { name: 'Bloody Mary Bar',   price: '$2,000' },
  { name: 'Banquet Bar',       price: '$2,000' },
  { name: 'Raffle Sponsor',    price: '$2,000' },
  { name: 'Banquet Sponsor',   price: '$1,500' },
  { name: 'Closest to the Pin', price: '$1,500' },
  { name: 'Hole Sponsor',      price: '$1,000' },
];

const eventJsonLd = {
  "@type": "Event",
  "@id": "https://sunshineonaranneyday.com/events/golf/#event",
  "name": "Sunshine on a Ranney Fairway 2026",
  "description": "Charity golf tournament funding dream room makeovers for children with special needs.",
  "startDate": "2026-05-18T07:00:00-04:00",
  "endDate": "2026-05-18T18:00:00-04:00",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  "eventStatus": "https://schema.org/EventScheduled",
  "location": {
    "@type": "Place",
    "name": "Indian Hills Country Club",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "4001 Clubland Dr.",
      "addressLocality": "Marietta",
      "addressRegion": "GA",
      "postalCode": "30068",
      "addressCountry": "US",
    },
  },
  "organizer": { "@id": "https://sunshineonaranneyday.com/#organization" },
  "image": "https://imagedelivery.net/ROYFuPmfN2vPS6mt5sCkZQ/golf-logo-dark/public",
  "offers": [
    {
      "@type": "Offer",
      "name": "Foursome",
      "price": "1500",
      "priceCurrency": "USD",
      "url": "https://www.zeffy.com/en-US/ticketing/sunshine-on-a-ranney-fairway--2026",
      "availability": "https://schema.org/InStock",
      "validFrom": "2026-01-01",
    },
    {
      "@type": "Offer",
      "name": "Gold Sponsor",
      "price": "5000",
      "priceCurrency": "USD",
      "url": "https://www.zeffy.com/en-US/ticketing/sunshine-on-a-ranney-fairway--2026",
      "availability": "https://schema.org/InStock",
      "validFrom": "2026-01-01",
    },
    {
      "@type": "Offer",
      "name": "Presenting Sponsor",
      "price": "20000",
      "priceCurrency": "USD",
      "url": "https://www.zeffy.com/en-US/ticketing/sunshine-on-a-ranney-fairway--2026",
      "availability": "https://schema.org/InStock",
      "validFrom": "2026-01-01",
    },
  ],
};

/* ── LCP preload — hero logo (must be byte-identical to <img>) ── */
const heroLogoSrcset = cfSrcset('golf-logo-dark', [280, 400]);
const heroLogoSizes = '(max-width: 767px) 200px, 320px';
---

<BaseLayout
  title="Sunshine on a Ranney Fairway 2026 — Charity Golf Tournament"
  description="Join us for Sunshine on a Ranney Fairway 2026 — a charity golf tournament where every swing supports life-changing room makeovers for children with special needs."
  ogImage={cfRaw('golf-logo-light', 'w=1200,h=630,fit=contain,q=85')}
  jsonLd={eventJsonLd}
  breadcrumbs={[
    { name: 'Events', url: '/events/' },
    { name: 'Golf Tournament', url: '/events/golf/' },
  ]}
>
  <!-- Preload hero LCP image — imagesrcset/imagesizes must match the <img> -->
  <link slot="head" rel="preload" as="image" imagesrcset={heroLogoSrcset} imagesizes={heroLogoSizes} fetchpriority="high" />

  <!-- ═══ HERO ═══ -->
  <section class="ev-hero">
    <div class="ev-hero__bg" aria-hidden="true">
      <div class="ev-hero__gradient"></div>
    </div>
    <div class="container ev-hero__inner">
      <div class="ev-hero__content">
        <span class="ev-hero__eyebrow" data-reveal>Charity Golf Tournament</span>
        <h1 class="ev-hero__title" data-reveal transition:name="event-title">
          Sunshine on a<br/>Ranney <span class="ev-hero__accent">Fairway</span>
        </h1>
        <p class="ev-hero__subtitle" data-reveal>
          Tee up for a cause. Every swing supports life-changing room makeovers for children with special needs through <a href="https://sunshineonaranneyday.com" target="_blank" rel="noopener" class="ev-hero__link">Sunshine on a Ranney Day</a>.
        </p>
        <div class="ev-hero__actions" data-reveal>
          <a href="#tickets" class="ev-btn ev-btn--gold ev-btn--hero">Register</a>
          <a href="#details" class="ev-hero__scroll-link">
            Learn More
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
          </a>
        </div>
      </div>
      <div class="ev-hero__visual" data-reveal>
        <img
          src={cfRaw('golf-logo-dark', 'w=400,q=85')}
          srcset={heroLogoSrcset}
          sizes={heroLogoSizes}
          alt="Sunshine on a Ranney Fairway Golf Tournament logo"
          class="ev-hero__logo"
          width="400"
          height="400"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          transition:name="event-hero"
        />
      </div>
    </div>
    <div class="ev-hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" fill="var(--c-cream)"><path d="M0,40 C360,80 720,0 1080,40 C1260,60 1380,50 1440,40 L1440,80 L0,80 Z"/></svg>
    </div>
  </section>

  <!-- ═══ EVENT DETAILS ═══ -->
  <section class="ev-details" id="details">
    <div class="container ev-details__inner">
      <div class="ev-details__grid">
        <div class="ev-details__card" data-reveal>
          <div class="ev-details__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3 class="ev-details__card-title">When</h3>
          <p class="ev-details__card-date"><time datetime="2026-05-18">Monday, May 18th, 2026</time></p>
          <p class="ev-details__card-text">
            <strong><time datetime="2026-05-18T07:00:00-04:00">7:00 AM</time></strong> &mdash; Registration<br/>
            <strong><time datetime="2026-05-18T10:00:00-04:00">10:00 AM</time></strong> &mdash; Tee Off<br/>
            <strong>TBA</strong> &mdash; Banquet
          </p>
        </div>
        <div class="ev-details__card" data-reveal>
          <div class="ev-details__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3 class="ev-details__card-title">Where</h3>
          <p class="ev-details__card-text">
            <strong>Indian Hills Country Club</strong><br/>
            <a href="https://maps.google.com/?q=4001+Clubland+Dr+Marietta+GA+30068" target="_blank" rel="noopener" class="ev-details__map-link">
              4001 Clubland Dr.<br/>Marietta, GA 30068
            </a>
          </p>
        </div>
        <div class="ev-details__card" data-reveal>
          <div class="ev-details__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
          </div>
          <h3 class="ev-details__card-title">The Cause</h3>
          <p class="ev-details__card-text">Proceeds fund dream room makeovers for children with special needs.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ DEDICATED TO ═══ -->
  <section class="ev-chair">
    <div class="container ev-chair__inner" data-reveal>
      <div class="ev-chair__photo-wrap" style={`background-image:url('${cfLqip('golf-brent-aronson')}')`}>
        <img
          src={cfRaw('golf-brent-aronson', 'w=500,q=80')}
          srcset={cfSrcset('golf-brent-aronson', [340, 500], { fit: 'cover', gravity: 'face' })}
          sizes="(max-width: 639px) 220px, 260px"
          alt="Brent Aronson"
          class="ev-chair__photo lqip-img"
          width="500"
          height="500"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="ev-chair__text">
        <span class="ev-chair__label">Dedicated To</span>
        <h2 class="ev-chair__name">Brent Aronson</h2>
        <p>This year's tournament is dedicated to Brent Aronson, whose vision and commitment helped build SOARD. Join us as we celebrate his legacy and see the impact firsthand. Many of the kids you support will be out on the course!</p>
      </div>
    </div>
  </section>

  <!-- ═══ HOW IT HELPS ═══ -->
  <section class="ev-impact">
    <div class="container ev-impact__inner">
      <span class="ev-impact__label" data-reveal>Your Impact</span>
      <h2 class="ev-impact__heading" data-reveal>Every Ticket Changes a Life</h2>
      <div class="ev-impact__steps">
        <div class="ev-impact__step" data-reveal>
          <div class="ev-impact__num" aria-hidden="true">1</div>
          <h4>You Play</h4>
          <p>Grab your clubs and enjoy a day on the course with friends, food, and fun.</p>
        </div>
        <div class="ev-impact__connector" aria-hidden="true">
          <svg width="40" height="24" viewBox="0 0 40 24" fill="none"><path d="M4 12h32M28 5l8 7-8 7" stroke="var(--c-yellow)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="ev-impact__step" data-reveal>
          <div class="ev-impact__num" aria-hidden="true">2</div>
          <h4>We Give</h4>
          <p>Every dollar goes directly to Sunshine on a Ranney Day to fund room makeovers.</p>
        </div>
        <div class="ev-impact__connector" aria-hidden="true">
          <svg width="40" height="24" viewBox="0 0 40 24" fill="none"><path d="M4 12h32M28 5l8 7-8 7" stroke="var(--c-yellow)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="ev-impact__step" data-reveal>
          <div class="ev-impact__num" aria-hidden="true">3</div>
          <h4>Kids Dream</h4>
          <p>A child with special needs gets the room they've always dreamed of.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TICKETS ═══ -->
  <section class="ev-tickets" id="tickets">
    <div class="container ev-tickets__inner">
      <span class="ev-tickets__label" data-reveal>Reserve Your Spot</span>
      <h2 class="ev-tickets__heading" data-reveal>Sponsorships &amp; Tickets</h2>
      <p class="ev-tickets__sub" data-reveal>Browse sponsorship packages and foursomes, then register on Zeffy to complete your purchase.</p>

      <!-- Sponsor tiers (data-driven) -->
      <div class="ev-tiers" data-reveal>
        {mainTiers.map(tier => (
          <div class={`ev-tier ${tier.highlight === 'featured' ? 'ev-tier--featured' : tier.highlight === 'popular' ? 'ev-tier--popular' : ''}`}>
            {tier.badge && (
              <span class={`ev-tier__badge ${tier.badgeStyle === 'gold' ? 'ev-tier__badge--gold' : ''}`}>{tier.badge}</span>
            )}
            <h3 class="ev-tier__name">{tier.name}</h3>
            <span class="ev-tier__price">{tier.price}</span>
            {tier.detail && <span class="ev-tier__detail">{tier.detail}</span>}
            {tier.perk && <span class="ev-tier__perk">{tier.perk}</span>}
          </div>
        ))}
      </div>

      <!-- Additional sponsorships (data-driven) -->
      <details class="ev-more" data-reveal>
        <summary class="ev-more__toggle">
          <span>Additional Sponsorships</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <div class="ev-more__grid">
          {addOnTiers.map(tier => (
            <div class="ev-tier ev-tier--sm">
              <h3 class="ev-tier__name">{tier.name}</h3>
              <span class="ev-tier__price">{tier.price}</span>
            </div>
          ))}
        </div>
      </details>

      <!-- CTA -->
      <div class="ev-tickets__cta" data-reveal>
        <a href="https://www.zeffy.com/en-US/ticketing/sunshine-on-a-ranney-fairway--2026" target="_blank" rel="noopener" class="ev-btn ev-btn--gold ev-btn--hero">
          Register &amp; Select Your Package
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
        <p class="ev-tickets__secure-note">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          Secure checkout powered by Zeffy &middot; Zero platform fees
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="ev-cta">
    <div class="container ev-cta__inner">
      <div class="ev-cta__card" data-reveal>
        <h2>Can't Make It?<br/>You Can Still Help.</h2>
        <p>Shop Sunny &amp; Ranney &mdash; profits help fund room makeovers for children with special needs.</p>
        <div class="ev-cta__actions">
          <a href="https://www.sunnyandranney.com/shop/" class="ev-btn ev-btn--gold" target="_blank" rel="noopener noreferrer">Shop &amp; Give Back</a>
          <a href="/donate/" class="ev-btn ev-btn--outline-white">Donate Directly</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ═══════════════════════════════════════════════════════════════
     GOLF TOURNAMENT PAGE
     Adapted from sunnyandranney.com/events/ for SOARD design system
     ═══════════════════════════════════════════════════════════════ */

  /* ─── Scroll offset for anchor targets ───── */
  [id] {
    scroll-margin-top: calc(var(--header-height, 84px) + 1.5rem);
  }

  /* ─── Reveal animation (uses global ScrollReveal via data-reveal) ───── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── Buttons ───── */
  .ev-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0.75rem 1.6rem;
    border-radius: 100px;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    border: 1.5px solid transparent;
    cursor: pointer;
    transition: background 200ms, color 200ms, transform 200ms, box-shadow 200ms;
  }
  .ev-btn:active { transform: scale(0.97); }
  .ev-btn--hero {
    padding: 0.85rem 2rem;
    font-size: 0.92rem;
  }
  .ev-btn--gold {
    background: var(--c-yellow);
    color: var(--c-dark);
    border-color: var(--c-yellow);
  }
  .ev-btn--gold:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px var(--c-yellow-glow);
  }
  .ev-btn--outline-white {
    background: transparent;
    color: #fff;
    border-color: rgba(255, 255, 255, 0.4);
  }
  .ev-btn--outline-white:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.7);
  }

  /* ─── Hero ──────────────────────────────────────────────────── */
  .ev-hero {
    position: relative;
    overflow: hidden;
    padding: var(--space-5xl) 0 calc(var(--space-4xl) + 40px);
    min-height: 520px;
    display: flex;
    align-items: center;
  }

  .ev-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(135deg, #1a472a 0%, #2e7d32 40%, #388e3c 70%, #43a047 100%);
  }

  .ev-hero__gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 20% 80%, rgba(255, 218, 36, 0.12) 0%, transparent 70%),
      radial-gradient(ellipse 50% 50% at 80% 20%, rgba(255, 255, 255, 0.06) 0%, transparent 60%);
  }

  .ev-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  @media (min-width: 768px) {
    .ev-hero {
      min-height: 600px;
      padding: var(--space-5xl) 0 calc(var(--space-4xl) + 60px);
    }
    .ev-hero__inner {
      grid-template-columns: 1fr auto;
    }
  }

  .ev-hero__eyebrow {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--c-yellow);
    margin-bottom: var(--space-sm);
  }

  .ev-hero__title {
    font-family: var(--font-display);
    color: #fff;
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    line-height: 1.08;
    margin-bottom: var(--space-md);
  }

  .ev-hero__accent {
    color: var(--c-yellow);
    font-style: italic;
  }

  .ev-hero__subtitle {
    color: rgba(255, 255, 255, 0.85);
    font-size: clamp(0.95rem, 1.2vw, 1.15rem);
    max-width: 52ch;
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .ev-hero__link {
    color: var(--c-yellow);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }
  .ev-hero__link:hover { opacity: 0.85; }

  .ev-hero__actions {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .ev-hero__scroll-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.88rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s;
  }
  .ev-hero__scroll-link:hover { color: #fff; }

  .ev-hero__visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ev-hero__logo {
    width: 200px;
    height: auto;
    filter: drop-shadow(0 4px 24px rgba(0, 0, 0, 0.2));
  }

  @media (min-width: 768px) {
    .ev-hero__logo { width: 320px; }
  }

  .ev-hero__wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    line-height: 0;
    z-index: 2;
  }
  .ev-hero__wave svg {
    width: 100%;
    height: 60px;
  }
  @media (min-width: 768px) {
    .ev-hero__wave svg { height: 80px; }
  }

  /* ─── Event Details ─────────────────────────────────────────── */
  .ev-details {
    padding: var(--space-2xl) 0 var(--space-3xl);
    background: var(--c-cream);
  }

  .ev-details__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 640px) {
    .ev-details__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .ev-details__card {
    text-align: center;
    padding: var(--space-xl) var(--space-lg);
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: var(--border-radius-lg);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ev-details__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .ev-details__icon {
    width: 56px;
    height: 56px;
    margin: 0 auto var(--space-md);
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e8f5e9;
    color: #2e7d32;
    border-radius: 50%;
  }

  .ev-details__card-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--c-dark);
    margin-bottom: 0.4rem;
  }

