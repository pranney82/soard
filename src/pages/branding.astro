---
import BaseLayout from '../layouts/BaseLayout.astro';
import media from '../content/site/media.json';

const founderParagraphs = media.founderStory.split('\n\n');

/* tiny svg string reused in download buttons */
const dlIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>`;
const copyIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>`;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Brand & Media Kit', url: '/branding/' },
];

const jsonLd = {
  '@type': 'WebPage',
  name: 'Brand & Media Kit — Sunshine on a Ranney Day',
  description: media.metaDescription,
  mainEntity: {
    '@type': 'Organization',
    name: 'Sunshine on a Ranney Day',
    url: 'https://sunshineonaranneyday.com',
  },
};
---
<BaseLayout title="Brand & Media Kit" description={media.metaDescription} breadcrumbs={breadcrumbs} jsonLd={jsonLd}>

  <section class="page-hero">
    <div class="container">
      <p class="hero-label">Brand & Media Resources</p>
      <h1>Brand & Media Kit</h1>
      <p class="page-hero-sub">Official brand assets, logos, and press-ready information for representing Sunshine on a Ranney Day.</p>
    </div>
  </section>

  <!-- Mobile sticky horizontal nav -->
  <nav class="brand-mobile-nav" aria-label="Brand kit sections">
    <div class="mobile-nav-scroll">
      <a href="#logos" class="mobile-nav-link active">Logos</a>
      <a href="#logo-usage" class="mobile-nav-link">Usage</a>
      <a href="#colors" class="mobile-nav-link">Colors</a>
      <a href="#typography" class="mobile-nav-link">Typography</a>
      <a href="#voice" class="mobile-nav-link">Voice</a>
      <a href="#media-bio" class="mobile-nav-link">Bio</a>
      <a href="#media-mission" class="mobile-nav-link">Mission</a>
      <a href="#media-founders" class="mobile-nav-link">Founders</a>
      <a href="#media-contact" class="mobile-nav-link">Contact</a>
    </div>
  </nav>

  <div class="brand-layout">
    <nav class="brand-sidebar" aria-label="Brand kit navigation">
      <div class="sidebar-inner">
        <p class="sidebar-label">Contents</p>
        <p class="sidebar-group-label">Brand Guidelines</p>
        <a href="#logos" class="sidebar-link active">Logos</a>
        <a href="#logo-usage" class="sidebar-link">Logo Usage</a>
        <a href="#colors" class="sidebar-link">Colors</a>
        <a href="#typography" class="sidebar-link">Typography</a>
        <a href="#voice" class="sidebar-link">Voice & Tone</a>
        <p class="sidebar-group-label">Media Kit</p>
        <a href="#media-bio" class="sidebar-link">Bio & Overview</a>
        <a href="#media-mission" class="sidebar-link">Mission</a>
        <a href="#media-founders" class="sidebar-link">Founder's Story</a>
        <a href="#media-contact" class="sidebar-link">Contact & Social</a>
      </div>
    </nav>

    <div class="brand-content">

      <section id="logos" class="brand-section">
        <div class="section-header-row">
          <div><h2>Logos</h2><p>Download our official logos in various formats and variations.</p></div>
          <a href="/SOARD-Brand-Guidelines.pdf" download class="download-all-btn" aria-label="Download brand guidelines PDF"><Fragment set:html={dlIcon} />Download All Assets</a>
        </div>

        <h3 class="logo-subhead">Primary Logos</h3>
        <p class="section-desc">Main logos with the "Dreams Built Here" tagline.</p>
        <div class="logo-grid logo-grid-3">
          <div class="card"><div class="card-preview bg-light"><picture><source type="image/webp" srcset="/images/logos/logo-light-bg-tagline-display.webp" /><img src="/images/logos/logo-light-bg-tagline-display.png" alt="Sunshine on a Ranney Day logo with Dreams Built Here tagline on white background" class="logo-img" width="600" height="600" loading="lazy" decoding="async"/></picture></div><div class="card-body"><h3>White Background</h3><p>Logo with tagline for light backgrounds</p><div class="btn-row"><a href="/images/logos/logo-light-bg-tagline.svg" download class="dl-btn" aria-label="Download white background logo with tagline as SVG"><Fragment set:html={dlIcon} />SVG</a><a href="/images/logos/logo-light-bg-tagline.png" download class="dl-btn" aria-label="Download white background logo with tagline as PNG"><Fragment set:html={dlIcon} />PNG</a></div></div></div>
          <div class="card"><div class="card-preview bg-dark"><picture><source type="image/webp" srcset="/images/logos/logo-dark-bg-tagline-display.webp" /><img src="/images/logos/logo-dark-bg-tagline-display.png" alt="Sunshine on a Ranney Day logo with Dreams Built Here tagline on dark background" class="logo-img" width="600" height="600" loading="lazy" decoding="async"/></picture></div><div class="card-body"><h3>Dark Background</h3><p>Logo with tagline for dark backgrounds</p><div class="btn-row"><a href="/images/logos/logo-dark-bg-tagline.svg" download class="dl-btn" aria-label="Download dark background logo with tagline as SVG"><Fragment set:html={dlIcon} />SVG</a><a href="/images/logos/logo-dark-bg-tagline.png" download class="dl-btn" aria-label="Download dark background logo with tagline as PNG"><Fragment set:html={dlIcon} />PNG</a></div></div></div>
          <div class="card"><div class="card-preview bg-light"><picture><source type="image/webp" srcset="/images/logos/logo-circle-tagline-display.webp" /><img src="/images/logos/logo-circle-tagline-display.png" alt="Sunshine on a Ranney Day circle logo with Dreams Built Here tagline" class="logo-img logo-img-circle" width="600" height="600" loading="lazy" decoding="async"/></picture></div><div class="card-body"><h3>Circle</h3><p>Circle logo with tagline</p><div class="btn-row"><a href="/images/logos/logo-circle-tagline.svg" download class="dl-btn" aria-label="Download circle logo with tagline as SVG"><Fragment set:html={dlIcon} />SVG</a><a href="/images/logos/logo-circle-tagline.png" download class="dl-btn" aria-label="Download circle logo with tagline as PNG"><Fragment set:html={dlIcon} />PNG</a></div></div></div>
        </div>

        <h3 class="logo-subhead">Alternate Logos</h3>
        <p class="section-desc">Logos without the tagline for smaller uses.</p>
        <div class="logo-grid logo-grid-3">
          <div class="card"><div class="card-preview bg-light"><picture><source type="image/webp" srcset="/images/logos/logo-light-bg-display.webp" /><img src="/images/logos/logo-light-bg-display.png" alt="Sunshine on a Ranney Day logo without tagline on white background" class="logo-img" width="600" height="600" loading="lazy" decoding="async"/></picture></div><div class="card-body"><h3>White Background</h3><p>Logo without tagline for light backgrounds</p><div class="btn-row"><a href="/images/logos/logo-light-bg.svg" download class="dl-btn" aria-label="Download white background logo without tagline as SVG"><Fragment set:html={dlIcon} />SVG</a><a href="/images/logos/logo-light-bg.png" download class="dl-btn" aria-label="Download white background logo without tagline as PNG"><Fragment set:html={dlIcon} />PNG</a></div></div></div>
          <div class="card"><div class="card-preview bg-dark"><picture><source type="image/webp" srcset="/images/logos/logo-dark-bg-display.webp" /><img src="/images/logos/logo-dark-bg-display.png" alt="Sunshine on a Ranney Day logo without tagline on dark background" class="logo-img" width="600" height="600" loading="lazy" decoding="async"/></picture></div><div class="card-body"><h3>Dark Background</h3><p>Logo without tagline for dark backgrounds</p><div class="btn-row"><a href="/images/logos/logo-dark-bg.svg" download class="dl-btn" aria-label="Download dark background logo without tagline as SVG"><Fragment set:html={dlIcon} />SVG</a><a href="/images/logos/logo-dark-bg.png" download class="dl-btn" aria-label="Download dark background logo without tagline as PNG"><Fragment set:html={dlIcon} />PNG</a></div></div></div>
          <div class="card"><div class="card-preview bg-light"><picture><source type="image/webp" srcset="/images/logos/logo-circle-display.webp" /><img src="/images/logos/logo-circle-display.png" alt="Sunshine on a Ranney Day circle logo without tagline" class="logo-img logo-img-circle" width="600" height="600" loading="lazy" decoding="async"/></picture></div><div class="card-body"><h3>Circle</h3><p>Circle logo without tagline</p><div class="btn-row"><a href="/images/logos/logo-circle.svg" download class="dl-btn" aria-label="Download circle logo without tagline as SVG"><Fragment set:html={dlIcon} />SVG</a><a href="/images/logos/logo-circle.png" download class="dl-btn" aria-label="Download circle logo without tagline as PNG"><Fragment set:html={dlIcon} />PNG</a></div></div></div>
        </div>
      </section>

      <section id="logo-usage" class="brand-section">
        <h2>Logo Usage</h2>
        <p class="section-desc">Guidelines for proper logo implementation and presentation.</p>
        <div class="usage-grid">
          <div class="usage-card"><div class="usage-label">Light Background</div><div class="usage-preview bg-light"><picture><source type="image/webp" srcset="/images/logos/logo-light-bg-tagline-display.webp" /><img src="/images/logos/logo-light-bg-tagline-display.png" alt="Logo correctly placed on light background" class="logo-img" width="600" height="600" loading="lazy" decoding="async"/></picture></div><p class="usage-text">Use the primary logo on light backgrounds. Ensure adequate contrast and clear space.</p></div>
          <div class="usage-card"><div class="usage-label">Dark Background</div><div class="usage-preview bg-dark"><picture><source type="image/webp" srcset="/images/logos/logo-dark-bg-tagline-display.webp" /><img src="/images/logos/logo-dark-bg-tagline-display.png" alt="Logo correctly placed on dark background" class="logo-img" width="600" height="600" loading="lazy" decoding="async"/></picture></div><p class="usage-text">Use the dark background version on dark backgrounds. Maintain strong contrast.</p></div>
        </div>
        <h3>Logo Guidelines</h3>
        <div class="dodont-grid">
          <div class="dodont-card do"><h4>✓ Do</h4><ul><li><span class="chk">✓</span>Maintain clear space around logo</li><li><span class="chk">✓</span>Scale proportionally</li><li><span class="chk">✓</span>Ensure sufficient contrast</li><li><span class="chk">✓</span>Min. 1.25" print, 75px digital</li></ul></div>
          <div class="dodont-card dont"><h4>✗ Don't</h4><ul><li><span class="x">✗</span>Distort or rotate the logo</li><li><span class="x">✗</span>Change logo colors</li><li><span class="x">✗</span>Add effects or shadows</li><li><span class="x">✗</span>Modify or recreate</li></ul></div>
        </div>
        <h3>Visual Examples</h3>
        <div class="vis-grid">
          <div class="vis-card ok"><div class="vis-badge ok">Correct</div><div class="vis-preview bg-light"><picture><source type="image/webp" srcset="/images/logos/logo-light-bg-tagline-display.webp" /><img src="/images/logos/logo-light-bg-tagline-display.png" alt="Logo displayed correctly with proper proportions" class="vis-logo" width="600" height="600" loading="lazy" decoding="async"/></picture></div><p>Proper proportions and clear space</p></div>
          <div class="vis-card bad"><div class="vis-badge bad">Incorrect</div><div class="vis-preview bg-light"><picture><source type="image/webp" srcset="/images/logos/logo-light-bg-tagline-display.webp" /><img src="/images/logos/logo-light-bg-tagline-display.png" alt="Logo incorrectly stretched horizontally" class="vis-logo" width="600" height="600" loading="lazy" decoding="async" style="transform:scaleX(1.4);"/></picture></div><p>Don't stretch or distort</p></div>
          <div class="vis-card ok"><div class="vis-badge ok">Correct</div><div class="vis-preview bg-dark"><picture><source type="image/webp" srcset="/images/logos/logo-dark-bg-tagline-display.webp" /><img src="/images/logos/logo-dark-bg-tagline-display.png" alt="Logo displayed correctly on dark background" class="vis-logo" width="600" height="600" loading="lazy" decoding="async"/></picture></div><p>Good contrast with background</p></div>
          <div class="vis-card bad"><div class="vis-badge bad">Incorrect</div><div class="vis-preview" style="background:#e8e0c0;"><picture><source type="image/webp" srcset="/images/logos/logo-light-bg-tagline-display.webp" /><img src="/images/logos/logo-light-bg-tagline-display.png" alt="Logo incorrectly placed on low-contrast background" class="vis-logo" width="600" height="600" loading="lazy" decoding="async" style="opacity:0.3;"/></picture></div><p>Don't use on low-contrast backgrounds</p></div>
        </div>
      </section>

      <section id="colors" class="brand-section">
        <h2>Color Palette</h2>
        <p class="section-desc">Our color system ensures visual consistency and brand recognition.</p>
        <div class="color-grid">
          <div class="color-card" data-hex="#FFDA24"><div class="color-swatch" style="background:#FFDA24;"></div><div class="color-body"><h3>Sunshine Yellow</h3><p class="color-usage">CTAs, brand accents</p><div class="color-vals"><span class="pms">PMS 116 C</span><span class="hex">#FFDA24</span><span>RGB 254, 217, 37</span><span>CMYK 0, 6, 87, 0</span></div></div></div>
          <div class="color-card" data-hex="#373A36"><div class="color-swatch" style="background:#373A36;"></div><div class="color-body"><h3>SOARD Dark</h3><p class="color-usage">Primary text, headings</p><div class="color-vals"><span class="pms">PMS 447 C</span><span class="hex">#373A36</span><span>RGB 55, 58, 54</span><span>CMYK 50, 30, 40, 90</span></div></div></div>
          <div class="color-card" data-hex="#FFFFFF"><div class="color-swatch" style="background:#FFFFFF;border-bottom:1px solid #E5E7EB;"></div><div class="color-body"><h3>White</h3><p class="color-usage">Backgrounds</p><div class="color-vals"><span class="hex">#FFFFFF</span><span>RGB 255, 255, 255</span><span>CMYK 0, 0, 0, 0</span></div></div></div>

          <div class="color-card" data-hex="#1A1B1F"><div class="color-swatch" style="background:#1A1B1F;"></div><div class="color-body"><h3>Dark Deep</h3><p class="color-usage">Footer, dark sections</p><div class="color-vals"><span class="hex">#1A1B1F</span><span>RGB 26, 27, 31</span></div></div></div>
          <div class="color-card" data-hex="#FEFCF5"><div class="color-swatch" style="background:#FEFCF5;border-bottom:1px solid #E5E7EB;"></div><div class="color-body"><h3>Cream</h3><p class="color-usage">Page backgrounds</p><div class="color-vals"><span class="hex">#FEFCF5</span><span>RGB 254, 252, 245</span></div></div></div>
        </div>
        <div class="info-box"><p>💡 <strong>Color Usage</strong></p><p>Use Sunshine Yellow (#FFDA24) sparingly for CTAs and highlights. SOARD Dark and neutrals form the foundation. <strong>Important:</strong> The three core brand colors — Sunshine Yellow (PMS 116 C), SOARD Dark (PMS 447 C), and White — are required for all print materials. Ensure WCAG AA contrast minimum for accessibility. Click any color to copy HEX.</p></div>
      </section>

      <section id="typography" class="brand-section">
        <h2>Typography</h2>
        <p class="section-desc">We use Libre Baskerville for display and Outfit for body text, providing an editorial feel with modern readability.</p>
        <div class="type-block"><div class="type-block-header"><h3>Libre Baskerville</h3><span>Display / Headlines</span></div><div class="type-rows"><div class="type-row"><span class="wt-name">Regular (400)</span><span class="wt-sample" style="font-family:var(--font-display);font-weight:400;">Dreams built here since 2012</span></div><div class="type-row"><span class="wt-name">Italic (400)</span><span class="wt-sample" style="font-family:var(--font-display);font-style:italic;">Dreams built here since 2012</span></div><div class="type-row"><span class="wt-name">Bold (700)</span><span class="wt-sample" style="font-family:var(--font-display);font-weight:700;">Dreams built here since 2012</span></div></div></div>
        <div class="type-block"><div class="type-block-header"><h3>Outfit</h3><span>Body / UI</span></div><div class="type-rows"><div class="type-row"><span class="wt-name">Light (300)</span><span class="wt-sample" style="font-family:var(--font-body);font-weight:300;">The quick brown fox jumps over the lazy dog</span></div><div class="type-row"><span class="wt-name">Regular (400)</span><span class="wt-sample" style="font-family:var(--font-body);font-weight:400;">The quick brown fox jumps over the lazy dog</span></div><div class="type-row"><span class="wt-name">Medium (500)</span><span class="wt-sample" style="font-family:var(--font-body);font-weight:500;">The quick brown fox jumps over the lazy dog</span></div><div class="type-row"><span class="wt-name">Semibold (600)</span><span class="wt-sample" style="font-family:var(--font-body);font-weight:600;">The quick brown fox jumps over the lazy dog</span></div><div class="type-row"><span class="wt-name">Bold (700)</span><span class="wt-sample" style="font-family:var(--font-body);font-weight:700;">The quick brown fox jumps over the lazy dog</span></div></div></div>
        <div class="two-col"><div class="info-card"><h4>Font Weight Usage</h4><ul><li><span class="bullet">●</span>Light (300) for hero text, large displays</li><li><span class="bullet">●</span>Regular (400) for body copy</li><li><span class="bullet">●</span>Semibold (600) for emphasis, buttons</li><li><span class="bullet">●</span>Bold (700) for headings, CTAs</li></ul></div><div class="info-card"><h4>Spacing &amp; Hierarchy</h4><ul><li><span class="bullet">●</span>Very tight leading (1.05–1.2) for headings</li><li><span class="bullet">●</span>Relaxed leading (1.625) for body text</li><li><span class="bullet">●</span>Tight tracking for headlines</li><li><span class="bullet">●</span>Wide tracking (0.05em) for uppercase labels</li></ul></div></div>
      </section>

      <section id="voice" class="brand-section" style="border-bottom:none;">
        <h2>Voice &amp; Tone</h2>
        <p class="section-desc">Our brand voice reflects who we are and how we communicate.</p>
        <div class="two-col">
          <div class="info-card"><h3>We are</h3><div class="voice-items"><div class="voice-item"><h5>Warm &amp; Genuine</h5><p>Approachable and heartfelt in every interaction</p></div><div class="voice-item"><h5>Hopeful &amp; Empowering</h5><p>Focused on possibility, never pity</p></div><div class="voice-item"><h5>Professional</h5><p>Yet approachable and human</p></div><div class="voice-item"><h5>Joyful</h5><p>Building dream rooms is what we do — let the energy show</p></div></div></div>
          <div class="info-card"><h3>We are not</h3><div class="voice-items"><div class="voice-item"><h5>Pitying</h5><p>Never reduce children to their diagnosis</p></div><div class="voice-item"><h5>Clinical</h5><p>Not stiff or corporate — always personal</p></div><div class="voice-item"><h5>Guilt-Driven</h5><p>Inspire through joy, never through pressure</p></div><div class="voice-item"><h5>Sloppy</h5><p>Playful doesn't mean careless</p></div></div></div>
        </div>
      </section>

      <!-- ═══ MEDIA KIT ═══ -->

      <div class="media-divider">
        <span class="media-divider-label">Media Kit</span>
      </div>

      <section id="media-bio" class="brand-section">
        <h2>Bio & Overview</h2>
        <p class="section-desc">Press-ready organization information. Click any block to copy text to clipboard.</p>

        <div class="media-card" data-copy>
          <div class="media-card-header">
            <h3>Organization Bio</h3>
            <button class="copy-btn" aria-label="Copy to clipboard"><Fragment set:html={copyIcon} />Copy</button>
          </div>
          <p class="media-copy-text">{media.bio.boilerplate}</p>
        </div>

        <div class="media-details-grid">
          <div class="media-detail">
            <span class="media-detail-label">Organization</span>
            <span class="media-detail-value">{media.bio.orgName}</span>
          </div>
          <div class="media-detail">
            <span class="media-detail-label">Founded</span>
            <span class="media-detail-value">{media.bio.founded}</span>
          </div>
          <div class="media-detail">
            <span class="media-detail-label">Founders</span>
            <span class="media-detail-value">{media.bio.founders}</span>
          </div>
          <div class="media-detail">
            <span class="media-detail-label">Location</span>
            <span class="media-detail-value">{media.bio.location}</span>
          </div>
          <div class="media-detail">
            <span class="media-detail-label">EIN</span>
            <span class="media-detail-value">{media.bio.ein}</span>
          </div>
          <div class="media-detail">
            <span class="media-detail-label">Website</span>
            <span class="media-detail-value">{media.bio.website}</span>
          </div>
        </div>
      </section>

      <section id="media-mission" class="brand-section">
        <h2>Mission Statement</h2>
        <p class="section-desc">Our official mission statement for press materials and publications.</p>

        <div class="media-card" data-copy>
          <div class="media-card-header">
            <h3>Mission</h3>
            <button class="copy-btn" aria-label="Copy to clipboard"><Fragment set:html={copyIcon} />Copy</button>
          </div>
          <p class="media-copy-text">{media.mission}</p>
        </div>

        <div class="media-card" data-copy>
          <div class="media-card-header">
            <h3>Who We Are</h3>
            <button class="copy-btn" aria-label="Copy to clipboard"><Fragment set:html={copyIcon} />Copy</button>
          </div>
          <p class="media-copy-text">{media.who}</p>
        </div>
      </section>

      <section id="media-founders" class="brand-section">
        <h2>Founder's Story</h2>
        <p class="section-desc">Background on how Sunshine on a Ranney Day began.</p>

        <div class="media-card" data-copy>
          <div class="media-card-header">
            <h3>Founder's Story</h3>
            <button class="copy-btn" aria-label="Copy to clipboard"><Fragment set:html={copyIcon} />Copy</button>
          </div>
          <div class="media-copy-text">
            {founderParagraphs.map((p: string) => <p>{p}</p>)}
          </div>
        </div>
      </section>

      <section id="media-contact" class="brand-section" style="border-bottom:none;">
        <h2>Contact & Social</h2>
        <p class="section-desc">Official contact information and social media links for press inquiries.</p>

        <div class="media-details-grid">
          <div class="media-detail">
            <span class="media-detail-label">Press Contact</span>
            <span class="media-detail-value"><a href={`mailto:${media.contactEmail}`}>{media.contactEmail}</a></span>
          </div>
          {media.socialLinks.facebook && (
            <div class="media-detail">
              <span class="media-detail-label">Facebook</span>
              <span class="media-detail-value"><a href={media.socialLinks.facebook} target="_blank" rel="noopener">{media.socialLinks.facebook.replace('https://www.facebook.com/', 'facebook.com/')}</a></span>
            </div>
          )}
          {media.socialLinks.instagram && (
            <div class="media-detail">
              <span class="media-detail-label">Instagram</span>
              <span class="media-detail-value"><a href={media.socialLinks.instagram} target="_blank" rel="noopener">{media.socialLinks.instagram.replace('https://www.instagram.com/', 'instagram.com/')}</a></span>
            </div>
          )}
          {media.socialLinks.youtube && (
            <div class="media-detail">
              <span class="media-detail-label">YouTube</span>
              <span class="media-detail-value"><a href={media.socialLinks.youtube} target="_blank" rel="noopener">YouTube Channel</a></span>
            </div>
          )}
        </div>
      </section>

    </div>
  </div>

</BaseLayout>

<style>
  .page-hero{background:var(--c-warm-gray);padding:80px 0 60px;text-align:center}
  .hero-label{font-size:13px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--c-yellow);margin-bottom:16px}
  .page-hero h1{font-size:clamp(2.5rem,5vw,3.75rem);font-weight:300;color:var(--c-dark);margin-bottom:16px;letter-spacing:-.02em}
