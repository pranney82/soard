---
/**
 * Footer.astro
 * 4-column footer with newsletter signup, social links, GuideStar seal,
 * address/EIN, and legal links.
 */
---

<footer class="site-footer">
  <!-- Newsletter Section -->
  <div class="footer-newsletter section--sm">
    <div class="container container--narrow" style="text-align: center;">
      <h2><span class="highlight">Brighten your inbox</span> with a little Sunshine.</h2>
      <p style="margin-top: var(--space-sm); color: var(--c-text-muted);">
        Stay inspired with makeover stories, news, and upcoming events.
      </p>
      <form class="newsletter-form" action="#" method="POST">
        <div class="newsletter-fields">
          <input
            type="email"
            name="email"
            placeholder="Your email address"
            required
            aria-label="Email address"
            class="newsletter-input"
          />
          <button type="submit" class="newsletter-btn">Subscribe</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Main Footer -->
  <div class="footer-main">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h4 class="footer-heading">About</h4>
          <ul>
            <li><a href="/about/">Our Story</a></li>
            <li><a href="/about/financials/">Financials</a></li>
            <li><a href="/branding/">Branding</a></li>
            <li><a href="/publicity/">Publicity</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4 class="footer-heading">Kids & Projects</h4>
          <ul>
            <li><a href="/rooms/">Featured Rooms</a></li>
            <li><a href="/kids/">Meet the Kids</a></li>
            <li><a href="/rooms/community/">Community Projects</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4 class="footer-heading">Get Involved</h4>
          <ul>
            <li><a href="https://sunnyandranney.com/events" target="_blank" rel="noopener noreferrer">Events</a></li>
            <li><a href="/apply/">Application</a></li>
            <li><a href="/partners/">Become a Partner</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4 class="footer-heading">Shop Our Stores</h4>
          <ul>
            <li><a href="https://sunnyandranney.com" target="_blank" rel="noopener noreferrer">Sunny & Ranney</a></li>
            <li><a href="https://partlysunnystore.com" target="_blank" rel="noopener noreferrer">Partly Sunny</a></li>
            <li><a href="/faq/">FAQs</a></li>
            <li><a href="/resources/">Resources</a></li>
          </ul>
        </div>
      </div>

      <!-- Social + GuideStar -->
      <div class="footer-social">
        <a href="https://www.guidestar.org/profile/shared/2954b510-8c76-42e4-b589-7e826ca2cc47"
           target="_blank" rel="noopener noreferrer" aria-label="GuideStar Transparency Seal">
          <img
            src="https://widgets.guidestar.org/TransparencySeal/9198660"
            alt="GuideStar Transparency Seal"
            width="80"
            height="80"
            loading="lazy"
          />
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="footer-bottom">
    <div class="container">
      <div class="footer-bottom-inner">
        <p class="footer-contact">
          250 Hembree Park Drive, Suite 106, Roswell GA 30076 &middot; 770.990.2434 &middot;
          <a href="mailto:info@soardcharity.com">info@soardcharity.com</a>
        </p>
        <p class="footer-legal">
          &copy; {new Date().getFullYear()} Sunshine on a Ranney Day is a 501(c)(3) &middot; EIN: 45-4773997
        </p>
        <p class="footer-legal-links">
          <a href="/privacy-policy/">Privacy Policy</a>
          <span>&middot;</span>
          <a href="/terms/">Terms</a>
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
  }

  /* ─── Newsletter ───────────────────────── */
  .footer-newsletter {
    background: var(--c-warm-gray);
    padding-block: var(--space-3xl);
  }

  .footer-newsletter h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
  }

  .newsletter-form {
    margin-top: var(--space-lg);
  }

  .newsletter-fields {
    display: flex;
    gap: var(--space-sm);
    max-width: 460px;
    margin-inline: auto;
  }

  .newsletter-input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 2px solid var(--c-border);
    border-radius: 100px;
    background: var(--c-white);
    font-size: 0.95rem;
    transition: border-color var(--transition-fast);
  }

  .newsletter-input:focus {
    outline: none;
    border-color: var(--c-yellow);
  }

  .newsletter-btn {
    padding: 0.75rem 1.5rem;
    background: var(--c-yellow);
    color: var(--c-dark);
    font-weight: 600;
    font-size: 0.95rem;
    border: none;
    border-radius: 100px;
    cursor: pointer;
    white-space: nowrap;
    transition: background var(--transition-fast), transform var(--transition-fast);
  }

  .newsletter-btn:hover {
    background: var(--c-yellow-hover);
    transform: translateY(-1px);
  }

  @media (max-width: 480px) {
    .newsletter-fields {
      flex-direction: column;
    }
  }

  /* ─── Main Footer ──────────────────────── */
  .footer-main {
    background: var(--c-dark);
    color: rgba(255, 255, 255, 0.75);
    padding-block: var(--space-3xl) var(--space-xl);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-xl);
  }

  .footer-heading {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--c-white);
    margin-bottom: var(--space-md);
  }

  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer-col a {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.65);
    transition: color var(--transition-fast);
  }

  .footer-col a:hover {
    color: var(--c-yellow);
  }

  /* ─── Social / GuideStar ───────────────── */
  .footer-social {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    justify-content: center;
  }

  .footer-social img {
    opacity: 0.8;
    transition: opacity var(--transition-fast);
  }

  .footer-social img:hover {
    opacity: 1;
  }

  /* ─── Bottom Bar ───────────────────────── */
  .footer-bottom {
    background: var(--c-dark-deep);
    padding-block: var(--space-lg);
  }

  .footer-bottom-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .footer-contact {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .footer-contact a {
    color: var(--c-yellow);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer-legal {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
  }

  .footer-legal-links {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
  }

  .footer-legal-links a {
    color: rgba(255, 255, 255, 0.45);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer-legal-links a:hover {
    color: var(--c-white);
  }
</style>
