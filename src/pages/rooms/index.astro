---
/**
 * rooms/index.astro — Featured Projects index
 *
 * Shows kids where `featured: true` with case study content.
 * Falls back to a message if no featured kids exist yet.
 */
import PageLayout from '../../layouts/PageLayout.astro';
import Button from '../../components/ui/Button.astro';
import { getCollection } from 'astro:content';
import { cfRaw, cfSrcset } from '../../utils/cf-image';

const allKids = await getCollection('kids');
const featured = allKids
  .filter(k => k.data.featured && k.data.caseStudy && k.data.heroImage)
  .sort((a, b) => (b.data.year || 0) - (a.data.year || 0));
---

<PageLayout
  title="Featured Projects"
  heroLabel="Our Rooms"
  heroTitle={'<em class="highlight">Dreams</em> Really Are Built Here'}
  heroSubtitle="Go behind the scenes of our room makeovers — from design concept to reveal day"
>
  {featured.length > 0 ? (
    <section class="section featured-section">
      <div class="container">
        <div class="featured-grid">
          {featured.map((entry, i) => {
            const kid = entry.data;
            const cs = kid.caseStudy;
            return (
              <a href={`/kids/${kid.slug}/`} class={`featured-card ${i === 0 ? 'featured-card--large' : ''}`}>
                <div class="featured-card__frame">
                  <img
                    src={cfRaw(kid.heroImage!, 'w=800,q=85')}
                    srcset={cfSrcset(kid.heroImage!, [400, 800, 1200])}
                    sizes={i === 0 ? '(max-width: 768px) 90vw, 60vw' : '(max-width: 768px) 90vw, 30vw'}
                    alt={`${kid.name}'s room makeover`}
                    class="featured-card__img"
                    loading={i === 0 ? 'eager' : 'lazy'}
                    decoding="async"
                    width="800"
                    height="500"
                  />
                  <div class="featured-card__gradient" aria-hidden="true" />
                </div>
                <div class="featured-card__content">
                  {cs?.designTheme && (
                    <span class="featured-card__theme">{cs.designTheme}</span>
                  )}
                  <h2 class="featured-card__name">{kid.name}</h2>
                  <div class="featured-card__meta">
                    {kid.roomTypes && kid.roomTypes.length > 0 && (
                      <span class="featured-card__type">{kid.roomTypes.join(' & ')}</span>
                    )}
                    {kid.year && <span class="featured-card__year">{kid.year}</span>}
                  </div>
                  {kid.shortDescription && (
                    <p class="featured-card__desc">{kid.shortDescription}</p>
                  )}
                  <span class="featured-card__cta">
                    View Case Study
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  ) : (
    <section class="section">
      <div class="container container--narrow" style="text-align: center; padding-block: var(--space-4xl);">
        <p style="color: var(--c-text-muted); font-size: 1.1rem; margin-bottom: var(--space-xl);">
          Featured project case studies are coming soon. In the meantime, explore all the kids we've served.
        </p>
        <Button href="/kids/">Meet the Kids</Button>
      </div>
    </section>
  )}

  <!-- Browse all kids CTA -->
  <section class="section section--dark browse-cta">
    <div class="container container--narrow" style="text-align: center;">
      <h2 class="browse-cta__title">Every child has a story</h2>
      <p class="browse-cta__text">We've served over 132 children since 2012. Browse all their profiles and see how each room was uniquely designed for them.</p>
      <div style="display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; margin-top: var(--space-xl);">
        <Button href="/kids/" variant="primary">Meet All the Kids</Button>
        <Button href="/donate/" variant="outline">Support a Build</Button>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  /* ═══ Featured Grid ═══════════════════════ */
  .featured-section {
    padding-block: var(--space-4xl);
  }

  .featured-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
  }

  .featured-card--large {
    grid-column: 1 / -1;
  }

  .featured-card {
    position: relative;
    display: block;
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: #fff;
    min-height: 340px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .featured-card--large {
    min-height: 480px;
  }

  .featured-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.15);
  }

  .featured-card__frame {
    position: absolute;
    inset: 0;
  }

  .featured-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .featured-card:hover .featured-card__img {
    transform: scale(1.03);
  }

  .featured-card__gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.75) 0%,
      rgba(0, 0, 0, 0.35) 40%,
      rgba(0, 0, 0, 0.05) 100%
    );
  }

  .featured-card__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    height: 100%;
    padding: var(--space-xl) var(--space-xl) var(--space-lg);
  }

  .featured-card__theme {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-yellow);
    margin-bottom: var(--space-xs);
  }

  .featured-card__name {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: var(--space-xs);
  }

  .featured-card__meta {
    display: flex;
    gap: var(--space-sm);
    align-items: center;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: var(--space-sm);
  }

  .featured-card__type {
    background: rgba(255, 255, 255, 0.15);
    padding: 3px 10px;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .featured-card__year {
    font-weight: 600;
  }

  .featured-card__desc {
    font-size: 0.9rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.85);
    max-width: 500px;
    margin-bottom: var(--space-md);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-card--large .featured-card__desc {
    -webkit-line-clamp: 3;
  }

  .featured-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--c-yellow);
    transition: gap 0.2s ease;
  }

  .featured-card:hover .featured-card__cta {
    gap: 10px;
  }

  /* ═══ Browse CTA ═══════════════════════════ */
  .browse-cta {
    padding-block: var(--space-4xl);
  }

  .browse-cta__title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 700;
    color: #fff;
    margin-bottom: var(--space-md);
  }

  .browse-cta__text {
    color: rgba(255, 255, 255, 0.75);
    font-size: 1.05rem;
    line-height: 1.6;
    max-width: 550px;
    margin-inline: auto;
  }

  /* ═══ Responsive ═══════════════════════════ */
  @media (max-width: 768px) {
    .featured-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .featured-card,
    .featured-card--large {
      min-height: 300px;
    }

    .featured-card__content {
      padding: var(--space-lg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .featured-card,
    .featured-card__img {
      transition: none;
    }
  }
</style>
