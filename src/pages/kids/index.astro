---
/**
 * Meet the Kids — Bespoke hero + premium grid with filtering
 *
 * PERF: gravity=face on CF Images, optimized srcsets, LCP preload,
 *       static JSON manifest for load-more
 * SEO:  CollectionPage + ItemList + FAQPage schema, breadcrumbs, rich meta
 * A11Y: proper heading hierarchy, ARIA labels, focus management, 44px targets
 * UX:   Face collage hero, cinematic featured card, mobile bottom-sheet filters
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getPublishedKids } from '../../utils/collections';
import { getSiteStats } from '../../utils/stats';
import siteSettings from '../../content/site/settings.json';

const allKids = await getPublishedKids();
const kids = allKids
  .sort((a, b) => {
    const sA = a.data.status === 'in-progress' ? 0 : 1;
    const sB = b.data.status === 'in-progress' ? 0 : 1;
    if (sA !== sB) return sA - sB;
    return (b.data.year || 0) - (a.data.year || 0);
  });

const years = [...new Set(kids.map(k => k.data.year).filter(Boolean))].sort((a, b) => b - a);
const roomTypes = [...new Set(kids.flatMap(k => k.data.roomTypes || []))].sort();
const totalKids = kids.reduce((sum, k) => sum + (k.data.childCount || 1), 0);

// ── CF Image helpers ──────────────────────
import { cfUrl, cfRaw, cfSrcset as _cfSrcset, cfDensitySrcset, cfId, CF_BASE } from '../../utils/cf-image';
import lqipManifest from '../../data/lqip-kids.json';
const lqip: Record<string, string> = lqipManifest;
/** Srcset with proportional height + face-crop at each breakpoint. */
function cfCropSrcset(src: string, widths: number[], hwRatio: number) {
  return _cfSrcset(src, widths, { fit: 'cover', gravity: 'face', quality: 70, aspectRatio: hwRatio, sharpen: 1 });
}

// ── Stats ────────────────────────────────
const siteStats = await getSiteStats();
const inProgressCount = kids.filter(k => k.data.status === 'in-progress').length;
const startYear = years.length > 0 ? years[years.length - 1] : '';
const yearRange = startYear ? `Since ${startYear}` : '';

// ── SEO ──────────────────────────────────
const SITE = 'https://sunshineonaranneyday.com';
const pageDescription = `Meet ${totalKids} children whose lives were transformed by Sunshine on a Ranney Day — dream bedrooms, accessible bathrooms, therapy rooms, and more. ${siteStats.totalRooms} rooms built${inProgressCount > 0 ? `, ${inProgressCount} in progress` : ''}.`;

const itemListSchema = {
  "@type": "CollectionPage",
  "@id": `${SITE}/kids/#collectionpage`,
  "name": "Meet the Kids — Sunshine on a Ranney Day",
  "description": pageDescription,
  "url": `${SITE}/kids/`,
  "isPartOf": { "@id": `${SITE}/#website` },
  "about": { "@id": `${SITE}/#organization` },
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": totalKids,
    "itemListElement": kids.slice(0, 50).map((kid, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `${SITE}/kids/${kid.data.slug}/`,
      "name": kid.data.name,
      ...(kid.data.heroImage ? { "image": cfUrl(kid.data.heroImage, { w: 600, q: 80 }) } : {}),
    })),
  },
};

const faqSchema = {
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What does Sunshine on a Ranney Day do for children?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Sunshine on a Ranney Day transforms the living spaces of children with serious illnesses or disabilities. We've built ${siteStats.totalRooms} rooms${inProgressCount > 0 ? ` with ${inProgressCount} currently in progress` : ''}, creating dream bedrooms, accessible bathrooms, and therapy rooms tailored to each child's specific needs.`
      }
    },
    {
      "@type": "Question",
      "name": "How can I help a child through Sunshine on a Ranney Day?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You can support our mission by donating, volunteering for room builds, or nominating a child in need. Visit our donate page or contact us to learn more about how you can make a difference."
      }
    },
  ],
};

const breadcrumbs = [
  { name: 'Home', url: SITE },
  { name: 'Meet the Kids', url: `${SITE}/kids/` },
];

// ── First batch rendered server-side; overflow created client-side from JSON ──
const INITIAL_BATCH = 10;
const totalKidsCount = kids.length;

// JSON manifest for overflow cards (created client-side on demand)
const overflowKids = kids.slice(INITIAL_BATCH).map(kid => ({
  s: kid.data.slug,
  n: kid.data.name,
  i: kid.data.heroImage ? cfId(kid.data.heroImage) : '',
  b: kid.data.heroImage ? (lqip[cfId(kid.data.heroImage)] || '') : '',
  y: kid.data.year || 0,
  t: kid.data.roomTypes || [],
  d: kid.data.diagnosis || '',
  st: kid.data.status || 'completed',
}));

// ── LCP preload: first card's hero image (must match <picture> srcset exactly) ──
const lcpKid = kids[0];
const lcpSrcsetMobile = lcpKid?.data.heroImage
  ? cfCropSrcset(lcpKid.data.heroImage, [160, 240, 360, 480], 5/4)
  : null;
const lcpSrcsetDesktop = lcpKid?.data.heroImage
  ? cfCropSrcset(lcpKid.data.heroImage, [180, 260, 380, 520], 4/3)
  : null;

// ── Hero face collage: 12 diverse kids across years ──
const heroFacePool = kids.filter(k => !!k.data.heroImage);
// Round-robin across years for visual diversity
const yearGroups: Record<number, typeof heroFacePool> = {};
heroFacePool.forEach(k => {
  const y = k.data.year || 0;
  (yearGroups[y] ||= []).push(k);
});
const sortedYears = Object.keys(yearGroups).map(Number).sort((a, b) => b - a);
const heroFaces: typeof heroFacePool = [];
let yi = 0;
while (heroFaces.length < 12 && yi < sortedYears.length * 3) {
  const bucket = yearGroups[sortedYears[yi % sortedYears.length]];
  const pick = bucket.shift();
  if (pick) heroFaces.push(pick);
  yi++;
}

---

<BaseLayout
  title="Meet the Kids"
  description={pageDescription}
  jsonLd={[itemListSchema, faqSchema]}
  breadcrumbs={breadcrumbs}
>
  {/* LCP preload — must match the <picture> srcset so the browser reuses the preloaded resource */}
  {lcpSrcsetMobile && (
    <link slot="head" rel="preload" as="image" fetchpriority="high"
      media="(max-width: 768px)"
      imagesrcset={lcpSrcsetMobile}
      imagesizes="calc(50vw - 31px)" />
  )}
  {lcpSrcsetDesktop && (
    <link slot="head" rel="preload" as="image" fetchpriority="high"
      media="(min-width: 769px)"
      imagesrcset={lcpSrcsetDesktop}
      imagesizes="(min-width: 1400px) 240px, (min-width: 1100px) calc(25vw - 30px), calc(33vw - 27px)" />
  )}

  <!-- ══════ HERO — Face Collage + Headline + Stats ══════ -->
  <section class="kids-hero" aria-label="Meet the Kids">
    <div class="kids-hero__inner">
      <div class="kids-hero__text">
        <p class="kids-hero__label">Our Kids</p>
        <h1 class="kids-hero__title">Meet our <em class="highlight">Sunshine</em> Kids</h1>
        <p class="kids-hero__subtitle">{siteSettings.kidsPageSummary || 'Discover the incredible stories behind every room we build.'}</p>
      </div>

      <!-- Face constellation -->
      <div class="faces" aria-label={`Photos of ${heroFaces.length} children helped by SOARD`}>
        {heroFaces.map((kid, i) => (
          <a
            href={`/kids/${kid.data.slug}/`}
            class="face"
            style={`--i:${i}`}
            aria-label={kid.data.name}
          >
            <img
              src={cfUrl(kid.data.heroImage!, { w: 68, h: 68, fit: 'cover', gravity: 'face', q: 70 })}
              srcset={cfDensitySrcset(kid.data.heroImage!, 68, 68, { fit: 'cover', gravity: 'face', quality: 70 })}
              alt={kid.data.name}
              width="68"
              height="68"
              loading="lazy"
              decoding="async"
            />
          </a>
        ))}
      </div>

      <!-- Impact stats inline -->
      <div class="hero-stats" aria-label="Impact statistics">
        <div class="hero-stat">
          <span class="hero-stat__num">{totalKids}</span>
          <span class="hero-stat__label">Kids Helped</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat__num">{siteStats.totalRooms}</span>
          <span class="hero-stat__label">Rooms Built</span>
        </div>
        {inProgressCount > 0 && (
          <div class="hero-stat">
            <span class="hero-stat__num">{inProgressCount}</span>
            <span class="hero-stat__label">In Progress</span>
          </div>
        )}
        <div class="hero-stat">
          <span class="hero-stat__num">{new Date().getFullYear() - (years[years.length - 1] || 2012)}</span>
          <span class="hero-stat__label">Years Strong</span>
        </div>
      </div>

      <!-- Accent rule — matches site-wide PageLayout pattern -->
      <div class="kids-hero__rule" aria-hidden="true">
        <span class="kids-hero__rule-accent"></span>
      </div>
    </div>
  </section>

  <!-- ══════ GRID SECTION ══════ -->
  <section class="kids-section">
    <div class="container container--wide">

      <!-- Toolbar -->
      <div class="toolbar" id="toolbar">
        <div class="toolbar__row">
          <div class="search-box">
            <svg class="search-box__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.34-4.34"/></svg>
            <input
              type="search"
              id="kid-search"
              class="search-box__input"
              placeholder="Search by name, diagnosis, or project..."
              aria-label="Search kids by name, diagnosis, year, or project type"
              autocomplete="off"
            />
            <span class="search-box__count" id="search-count" hidden aria-live="polite"></span>
            <kbd class="search-box__kbd" id="search-kbd" aria-hidden="true">/</kbd>
            <button class="search-box__clear" id="search-clear" type="button" aria-label="Clear search" hidden>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </button>
          </div>

          <!-- Desktop filters -->
          <div class="toolbar__filters toolbar__filters--desktop">
            <select id="sort-order" class="filter-select" aria-label="Sort order">
              <option value="newest">Newest First</option>
              <option value="oldest">Oldest First</option>
              <option value="name-az">Name A → Z</option>
              <option value="name-za">Name Z → A</option>
            </select>

            <select id="filter-year" class="filter-select" aria-label="Filter by year">
              <option value="all">All Years</option>
              {years.map(year => (
                <option value={`year-${year}`}>{year}</option>
              ))}
            </select>

            <select id="filter-type" class="filter-select" aria-label="Filter by project type">
              <option value="all">All Projects</option>
              <option value="type-accessible-bathroom">Accessible Bathroom</option>
              <option value="type-dream-bedroom">Dream Bedroom</option>
              <option value="type-therapy-room">Therapy Room</option>
            </select>

          </div>

          <!-- Mobile filter button -->
          <button class="filter-btn-mobile" id="filter-btn-mobile" type="button" aria-label="Open filters">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="20" y2="12"/><line x1="12" y1="18" x2="20" y2="18"/></svg>
            <span class="filter-btn-mobile__badge" id="mobile-filter-count" hidden aria-live="polite"></span>
          </button>
        </div>

        <div class="toolbar__status" aria-live="polite" aria-atomic="true">
          <span class="result-count" id="result-count" hidden>
            Showing <strong id="visible-count">{INITIAL_BATCH}</strong> of <span id="total-count">{totalKidsCount}</span> kids
          </span>
          <span class="result-loading" id="result-loading" hidden>
            <svg class="result-loading__spinner" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M12 2v4"/><path d="m16.2 7.8 2.9-2.9"/><path d="M18 12h4"/><path d="m16.2 16.2 2.9 2.9"/><path d="M12 18v4"/><path d="m4.9 19.1 2.9-2.9"/><path d="M2 12h4"/><path d="m4.9 4.9 2.9 2.9"/></svg>
            Loading all kids...
          </span>
          <button class="clear-btn" id="clear-filters" hidden aria-label="Clear all filters">
            Clear filters
          </button>
        </div>
      </div>

      <!-- Filter Chips -->
      <div class="filter-chips" id="filter-chips" hidden aria-label="Active filters">
      </div>

      <!-- Mobile Bottom Sheet -->
      <div class="bottom-sheet" id="bottom-sheet" aria-hidden="true">
        <div class="bottom-sheet__backdrop" id="sheet-backdrop"></div>
        <div class="bottom-sheet__panel" role="dialog" aria-modal="true" aria-label="Filter options">
          <div class="bottom-sheet__handle" aria-hidden="true"><span></span></div>
          <div class="bottom-sheet__header">
            <h3 class="bottom-sheet__title">Filters</h3>
            <button class="bottom-sheet__close" id="sheet-close" type="button" aria-label="Close filters">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </button>
          </div>
          <div class="bottom-sheet__body">
            <div class="sheet-group">
              <label class="sheet-label" for="sheet-sort">Sort By</label>
              <select id="sheet-sort" class="sheet-select" aria-label="Sort order">
                <option value="newest">Newest First</option>
                <option value="oldest">Oldest First</option>
                <option value="name-az">Name A → Z</option>
                <option value="name-za">Name Z → A</option>
              </select>
            </div>
            <div class="sheet-group">
              <label class="sheet-label" for="sheet-year">Year</label>
              <select id="sheet-year" class="sheet-select" aria-label="Filter by year">
                <option value="all">All Years</option>
                {years.map(year => (
                  <option value={`year-${year}`}>{year}</option>
                ))}
              </select>
            </div>
            <div class="sheet-group">
              <label class="sheet-label" for="sheet-type">Project Type</label>
              <select id="sheet-type" class="sheet-select" aria-label="Filter by project type">
                <option value="all">All Projects</option>
                <option value="type-accessible-bathroom">Accessible Bathroom</option>
                <option value="type-dream-bedroom">Dream Bedroom</option>
                <option value="type-therapy-room">Therapy Room</option>
              </select>
            </div>
          </div>
          <div class="bottom-sheet__footer">
            <button class="btn btn-dark btn--sm" id="sheet-clear" type="button">Clear All</button>
            <button class="btn btn-yellow btn--sm" id="sheet-apply" type="button">Show Results <span class="sheet-result-count" id="sheet-result-count"></span></button>
          </div>
        </div>
      </div>

      <!-- SVG sprite for repeated icons (avoids 187 inline copies) -->
      <svg xmlns="http://www.w3.org/2000/svg" style="display:none">
        <symbol id="icon-cta-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </symbol>
        <symbol id="icon-placeholder" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </symbol>
      </svg>

      <!-- Kid Grid -->
      <h2 class="sr-only">All kid profiles</h2>
      <div class="kids-grid" id="kids-grid">
        {kids.slice(0, INITIAL_BATCH).map((kid, i) => (
          <a
            href={`/kids/${kid.data.slug}/`}
            class="kid-card"
            data-year={`year-${kid.data.year}`}
            data-types={(kid.data.roomTypes || []).map(t => `type-${t.toLowerCase().replace(/\s+/g, '-')}`).join(' ')}
            data-name={kid.data.name.toLowerCase()}
            data-diagnosis={(kid.data.diagnosis || '').toLowerCase()}
            data-status={kid.data.status || 'completed'}
          >
            <div class="kid-card__frame" style={kid.data.heroImage && lqip[cfId(kid.data.heroImage)] ? `background-image:url(${lqip[cfId(kid.data.heroImage)]})` : undefined}>
              {kid.data.heroImage ? (
                <picture>
                  <source
                    media="(max-width: 768px)"
                    srcset={cfCropSrcset(kid.data.heroImage, [160, 240, 360, 480], 5/4)}
                    sizes="calc(50vw - 31px)"
                  />
                  <img
                    src={cfUrl(kid.data.heroImage, { w: 220, h: 293, fit: 'cover', gravity: 'face', q: 70 })}
                    srcset={cfCropSrcset(kid.data.heroImage, [180, 260, 380, 520], 4/3)}
                    sizes="(min-width: 1400px) 240px, (min-width: 1100px) calc(25vw - 30px), calc(33vw - 27px)"
                    alt={`Photo of ${kid.data.name}${(kid.data.roomTypes || []).length > 0 ? ` — ${(kid.data.roomTypes || []).join(', ')}` : ''} — Sunshine on a Ranney Day`}
                    class="kid-card__img"
                    width="340"
                    height="453"
                    loading={i < 4 ? 'eager' : 'lazy'}
                    fetchpriority={i < 2 ? 'high' : undefined}
                    decoding={i < 4 ? 'sync' : 'async'}
                  />
                </picture>
              ) : (
                <div class="kid-card__placeholder" aria-hidden="true">
                  <svg width="48" height="48"><use href="#icon-placeholder"/></svg>
                </div>
              )}
              <div class="kid-card__hover-overlay" aria-hidden="true">
                <span class="kid-card__cta">
                  <span class="kid-card__cta-text">Read their story</span>
                  <svg class="kid-card__cta-arrow" width="14" height="14"><use href="#icon-cta-arrow"/></svg>
                </span>
              </div>
              {kid.data.status === 'in-progress' && (
                <span class="kid-card__badge">In Progress</span>
              )}
            </div>
            <div class="kid-card__info">
              <span class="kid-card__name">{kid.data.name}</span>
            </div>
            {(kid.data.roomTypes || []).length > 0 && (
              <span class="kid-card__diagnosis">{(kid.data.roomTypes || []).join(', ')}</span>
            )}
          </a>
        ))}
      </div>

      <!-- Load More -->
      {totalKidsCount > INITIAL_BATCH && (
        <div class="load-more" id="load-more">
          <button class="btn btn-dark btn--sm load-more__btn" id="load-more-btn" type="button"
            data-total={totalKidsCount}
            data-loaded={INITIAL_BATCH}>
            Show More Kids
            <span class="load-more__count" id="load-more-count">({totalKidsCount - INITIAL_BATCH} remaining)</span>
          </button>
        </div>
      )}

      <!-- No results -->
      <div class="no-results" id="no-results" hidden>
        <div class="no-results__icon" aria-hidden="true">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.34-4.34"/></svg>
        </div>
        <p class="no-results__title">No matches found</p>
        <p class="no-results__hint" id="no-results-hint">Try a different search term or adjust your filters.</p>
        <div class="no-results__suggestions" id="no-results-suggestions"></div>
        <button class="btn btn-dark btn--sm" id="clear-filters-alt">Start fresh</button>
      </div>

      {kids.length === 0 && (
        <p style="text-align: center; color: var(--c-text-muted); padding: var(--space-4xl) 0;">
          Kid profiles are being migrated. Check back soon!
        </p>
      )}
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bottom-cta section section--dark">
    <div class="container container--narrow" style="text-align: center;">
      <h2 class="bottom-cta__title">Every child deserves a space to thrive</h2>
      <p class="bottom-cta__text">Your generosity helps us transform bedrooms, bathrooms, and therapy rooms for children with serious illnesses and disabilities.</p>
      <div class="bottom-cta__buttons">
        <a href="/donate/" class="btn btn-yellow">Donate Now</a>
        <a href="/about/" class="btn btn-outline-light">Our Story</a>
      </div>
    </div>
  </section>

  <!-- Noscript: hide dead controls -->
  <noscript>
    <style>
      .toolbar, .bottom-sheet, .filter-btn-mobile, .load-more { display: none !important; }
    </style>
    <p style="text-align: center; color: var(--c-text-muted); padding: var(--space-lg);">
      Showing {INITIAL_BATCH} of {totalKidsCount} kids. Enable JavaScript to see all profiles, search, and filter.
    </p>
  </noscript>

  <!-- Overflow kids data — rendered client-side on demand to reduce initial DOM size -->
  <script type="application/json" id="kids-overflow" set:html={JSON.stringify(overflowKids)} />
</BaseLayout>

<!-- ══════ FILTERING + INTERACTIONS ══════ -->
<script>
  let _kidsObserver: IntersectionObserver | null = null;
  let _kidsAbortController: AbortController | null = null;

  function cleanupKidsIndex() {
    _kidsObserver?.disconnect();
    _kidsObserver = null;
    _kidsAbortController?.abort();
    _kidsAbortController = null;
  }

  function initKidsIndex() {
    const grid = document.getElementById('kids-grid') as HTMLElement;
    if (!grid) return;

    cleanupKidsIndex();
    _kidsAbortController = new AbortController();
    const signal = _kidsAbortController.signal;

    // ══════════════════════════════════════════
    //  FUZZY SEARCH — bigram similarity
    // ══════════════════════════════════════════
    function bigrams(str: string): Set<string> {
      const s = str.toLowerCase();
      const bg = new Set<string>();
      for (let i = 0; i < s.length - 1; i++) bg.add(s.slice(i, i + 2));
      return bg;
    }

    function similarity(a: string, b: string): number {
      if (a === b) return 1;
      if (a.length < 2 || b.length < 2) return 0;
      const bgA = bigrams(a);
      const bgB = bigrams(b);
      let intersection = 0;
      bgA.forEach(bg => { if (bgB.has(bg)) intersection++; });
      return (2 * intersection) / (bgA.size + bgB.size);
    }

    function fuzzyMatch(query: string, ...candidates: (string | null | undefined)[]): number {
      const q = query.toLowerCase().trim();
      if (!q) return 1;
      // Exact full-string containment in name (first candidate) gets highest score
      const nameCandidate = candidates[0];
      if (nameCandidate && nameCandidate.toLowerCase().includes(q)) return 1.0;
      // Exact containment in other fields
      for (let i = 1; i < candidates.length; i++) {
        if (candidates[i] && candidates[i]!.toLowerCase().includes(q)) return 0.98;
      }
      const words = q.split(/\s+/).filter(w => w.length > 1);
      if (words.length === 0) return 0;
      let totalScore = 0;
      for (const word of words) {
        let bestWord = 0;
        for (let ci = 0; ci < candidates.length; ci++) {
          const c = candidates[ci];
          if (!c) continue;
          const cl = c.toLowerCase();
          // Exact containment of word — boost name field
          if (cl.includes(word)) { bestWord = Math.max(bestWord, ci === 0 ? 1.0 : 0.98); continue; }
          const cWords = cl.split(/[\s,\-\/]+/).filter(w => w.length > 1);
          for (const cw of cWords) {
            if (cw.startsWith(word)) { bestWord = Math.max(bestWord, 0.95); continue; }
            const sim = similarity(word, cw);
            bestWord = Math.max(bestWord, sim);
          }
        }
        totalScore += bestWord;
      }
      const avgScore = totalScore / words.length;
      return avgScore >= 0.55 ? avgScore : 0;
    }

    // ══════════════════════════════════════════
    //  MULTI-TERM SEARCH HIGHLIGHTING
    // ══════════════════════════════════════════
    /** Build a highlight regex once per query (called before the card loop). */
    function buildHighlightRe(query: string): RegExp | null {
      if (!query) return null;
      const terms = query.toLowerCase().split(/\s+/).filter(t => t.length > 0);
      if (terms.length === 0) return null;
      const sorted = [...terms].sort((a, b) => b.length - a.length);
      const escaped = sorted.map(t => t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'));
      return new RegExp(`(${escaped.join('|')})`, 'gi');
    }

    /** Apply pre-compiled regex to a single element. DOM-based — no innerHTML. */
    function highlightText(el: HTMLElement, re: RegExp | null, originalText: string) {
      if (!re || !originalText) { el.textContent = originalText; return; }
      const parts = originalText.split(re);
      if (parts.length === 1) { el.textContent = originalText; return; }
      const frag = document.createDocumentFragment();
      for (let i = 0; i < parts.length; i++) {
        const p = parts[i];
        if (!p) continue;
        re.lastIndex = 0;
        if (re.test(p)) {
          const mark = document.createElement('mark');
          mark.textContent = p;
          frag.appendChild(mark);
        } else {
          frag.appendChild(document.createTextNode(p));
        }
      }
      re.lastIndex = 0;
      el.textContent = '';
      el.appendChild(frag);
    }

    function escapeHtml(s: string): string {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    // ── State ──
    let allCardsLoaded = false;
    let statusActive = false;
    let currentSort = 'newest';
    const originalTexts = new WeakMap<HTMLElement, { name: string; diagnosis: string }>();

    // ── DOM refs ──
    const searchInput = document.getElementById('kid-search') as HTMLInputElement;
    const yearSelect = document.getElementById('filter-year') as HTMLSelectElement;
    const typeSelect = document.getElementById('filter-type') as HTMLSelectElement;
    const sortSelect = document.getElementById('sort-order') as HTMLSelectElement;
    const statusBtn = document.getElementById('filter-status') as HTMLButtonElement | null;
    const noResults = document.getElementById('no-results') as HTMLElement;
    const noResultsHint = document.getElementById('no-results-hint') as HTMLElement;
    const noResultsSuggestions = document.getElementById('no-results-suggestions') as HTMLElement;
    const visibleCountEl = document.getElementById('visible-count') as HTMLElement;
    const clearBtn = document.getElementById('clear-filters') as HTMLButtonElement;
    const clearBtnAlt = document.getElementById('clear-filters-alt') as HTMLButtonElement;
    const toolbar = document.getElementById('toolbar') as HTMLElement;
    const searchClear = document.getElementById('search-clear') as HTMLButtonElement;
    const searchCountEl = document.getElementById('search-count') as HTMLElement;
    const kbdHint = document.getElementById('search-kbd') as HTMLElement;
    const chipsEl = document.getElementById('filter-chips') as HTMLElement;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const sheet = document.getElementById('bottom-sheet') as HTMLElement;
    const sheetBackdrop = document.getElementById('sheet-backdrop') as HTMLElement;
    const sheetClose = document.getElementById('sheet-close') as HTMLButtonElement;
    const sheetYear = document.getElementById('sheet-year') as HTMLSelectElement;
    const sheetType = document.getElementById('sheet-type') as HTMLSelectElement;
    const sheetSort = document.getElementById('sheet-sort') as HTMLSelectElement;
    const sheetStatus = document.getElementById('sheet-status') as HTMLButtonElement | null;
    const sheetClear = document.getElementById('sheet-clear') as HTMLButtonElement;
    const sheetApply = document.getElementById('sheet-apply') as HTMLButtonElement;
    const filterBtnMobile = document.getElementById('filter-btn-mobile') as HTMLButtonElement;
    const mobileFilterCount = document.getElementById('mobile-filter-count') as HTMLElement | null;

    const loadMoreWrap = document.getElementById('load-more') as HTMLElement | null;
    const loadMoreBtn = document.getElementById('load-more-btn') as HTMLButtonElement | null;
    const resultLoading = document.getElementById('result-loading') as HTMLElement | null;
    const resultCount = document.getElementById('result-count') as HTMLElement | null;

    // ── Cache original text ──
    function cacheOriginalText(card: HTMLElement) {
      if (originalTexts.has(card)) return;
      const nameEl = card.querySelector('.kid-card__name') as HTMLElement | null;
      const diagEl = card.querySelector('.kid-card__diagnosis') as HTMLElement | null;
      originalTexts.set(card, {
        name: nameEl?.textContent || '',
        diagnosis: diagEl?.textContent || '',
      });
    }
    // ── Cached card array — one querySelectorAll, reused everywhere ──
    let cachedCards = Array.from(grid.querySelectorAll<HTMLElement>('.kid-card'));
    cachedCards.forEach(cacheOriginalText);

    // ── Create overflow cards from JSON data island ──
    const CF = 'https://sunshineonaranneyday.com/cdn-cgi/imagedelivery/ROYFuPmfN2vPS6mt5sCkZQ';
    function cfCard(id: string, w: number, h: number) {
      return `${CF}/${id}/w=${w},h=${h},fit=cover,gravity=face,q=70,sharpen=1,metadata=none`;
    }
    function cfSS(id: string, widths: number[], ratio: number) {
      return widths.map(w => `${cfCard(id, w, Math.round(w * ratio))} ${w}w`).join(', ');
    }
    function createCard(kid: { s: string; n: string; i: string; b: string; y: number; t: string[]; d: string; st: string }) {
      const a = document.createElement('a');
      a.href = `/kids/${kid.s}/`;
      a.className = 'kid-card';
      a.dataset.year = `year-${kid.y}`;
      a.dataset.types = kid.t.map(t => `type-${t.toLowerCase().replace(/\s+/g, '-')}`).join(' ');
      a.dataset.name = kid.n.toLowerCase();
      a.dataset.diagnosis = kid.d.toLowerCase();
      a.dataset.status = kid.st;
      const roomTypes = kid.t.join(', ');
      const alt = escapeHtml(`Photo of ${kid.n}${roomTypes ? ` — ${roomTypes}` : ''} — Sunshine on a Ranney Day`);
      let imgHtml: string;
      if (kid.i) {
        imgHtml = `<picture><source media="(max-width:768px)" srcset="${cfSS(kid.i,[160,240,360,480],5/4)}" sizes="calc(50vw - 31px)"/><img src="${cfCard(kid.i,220,293)}" srcset="${cfSS(kid.i,[180,260,380,520],4/3)}" sizes="(min-width:1400px) 240px,(min-width:1100px) calc(25vw - 30px),calc(33vw - 27px)" alt="${alt}" class="kid-card__img" width="340" height="453" loading="lazy" decoding="async"/></picture>`;
      } else {
        imgHtml = `<div class="kid-card__placeholder" aria-hidden="true"><svg width="48" height="48"><use href="#icon-placeholder"/></svg></div>`;
      }
      const blurStyle = kid.b ? ` style="background-image:url(${kid.b})"` : '';
      a.innerHTML = `<div class="kid-card__frame"${blurStyle}>${imgHtml}<div class="kid-card__hover-overlay" aria-hidden="true"><span class="kid-card__cta"><span class="kid-card__cta-text">Read their story</span><svg class="kid-card__cta-arrow" width="14" height="14"><use href="#icon-cta-arrow"/></svg></span></div>${kid.st === 'in-progress' ? '<span class="kid-card__badge">In Progress</span>' : ''}</div><div class="kid-card__info"><span class="kid-card__name">${escapeHtml(kid.n)}</span></div>${roomTypes ? `<span class="kid-card__diagnosis">${escapeHtml(roomTypes)}</span>` : ''}`;
      return a;
    }

    function revealAllCards() {
      if (allCardsLoaded) return;
      const dataEl = document.getElementById('kids-overflow');
      if (!dataEl?.textContent) { allCardsLoaded = true; return; }
      const overflow: { s: string; n: string; i: string; b: string; y: number; t: string[]; d: string; st: string }[] = JSON.parse(dataEl.textContent);
      const frag = document.createDocumentFragment();
      for (const kid of overflow) {
        const card = createCard(kid);
        if (!reducedMotion && _kidsObserver) _kidsObserver.observe(card);
        else card.classList.add('revealed');
        cacheOriginalText(card);
        frag.appendChild(card);
      }
      grid.appendChild(frag);
      if (!reducedMotion) {
        grid.querySelectorAll<HTMLImageElement>('.kid-card__img:not(.is-loaded)').forEach(initImageFade);
      }
      cachedCards = Array.from(grid.querySelectorAll<HTMLElement>('.kid-card'));
      allCardsLoaded = true;
    }

    // ── Load more ──
    function handleLoadMore() {
      if (!loadMoreBtn || !loadMoreWrap) return;
      revealAllCards();
      updateYearBadges();
      loadMoreWrap.classList.add('is-hidden');
      visibleCountEl.textContent = String(cachedCards.length);
    }
    if (loadMoreBtn) loadMoreBtn.addEventListener('click', handleLoadMore, { signal });

    // ── Auto-load remaining cards when user scrolls near the load-more button ──
    if (loadMoreWrap) {
      const autoLoadObserver = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting && !allCardsLoaded) {
          handleLoadMore();
          autoLoadObserver.disconnect();
        }
      }, { rootMargin: '200px' });
      autoLoadObserver.observe(loadMoreWrap);
    }

    // ── URL state restore ──
    const params = new URLSearchParams(window.location.search);
    if (params.get('year')) yearSelect.value = params.get('year')!;
    if (params.get('type')) typeSelect.value = params.get('type')!;
    if (params.get('sort') && sortSelect) sortSelect.value = params.get('sort')!;
    if (params.get('q')) {
      searchInput.value = params.get('q')!;
      searchClear.hidden = false;
      if (kbdHint) kbdHint.classList.add('is-hidden');
    }
    if (params.get('status') === 'in-progress' && statusBtn) {
      statusActive = true;
      statusBtn.classList.add('active');
      statusBtn.setAttribute('aria-pressed', 'true');
    }
    currentSort = sortSelect?.value || 'newest';

    // ══════════════════════════════════════════
    //  FLIP ANIMATION SYSTEM
    // ══════════════════════════════════════════
    type Rect = { x: number; y: number; w: number; h: number };

    function capturePositions(): Map<HTMLElement, Rect> {
      const map = new Map<HTMLElement, Rect>();
      for (const card of cachedCards) {
        if (card.classList.contains('is-hidden')) continue;
        const r = card.getBoundingClientRect();
        map.set(card, { x: r.left, y: r.top, w: r.width, h: r.height });
      }
      return map;
    }

    function animateFLIP(oldPositions: Map<HTMLElement, Rect>) {
      if (reducedMotion) return;
      for (const card of cachedCards) {
        if (card.classList.contains('is-hidden')) continue;
        const oldPos = oldPositions.get(card);
        if (!oldPos) continue;
        const newRect = card.getBoundingClientRect();
        const dx = oldPos.x - newRect.left;
        const dy = oldPos.y - newRect.top;
        if (Math.abs(dx) < 1 && Math.abs(dy) < 1) continue;
        card.style.transform = `translate(${dx}px, ${dy}px)`;
        card.classList.add('is-flipping');
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            card.style.transform = '';
          });
        });
      }
    }

    // Clean up FLIP class
    grid.addEventListener('transitionend', (e) => {
      const card = (e.target as HTMLElement).closest('.kid-card');
      if (card?.classList.contains('is-flipping')) {
        card.classList.remove('is-flipping');
      }
    }, { signal });

    // ══════════════════════════════════════════
    //  SORT with FLIP
    // ══════════════════════════════════════════
    function sortCards(animate = true) {
      const oldPos = animate ? capturePositions() : null;
      cachedCards.sort((a, b) => {
        // Always show in-progress kids first
        const sA = a.dataset.status === 'in-progress' ? 0 : 1;
        const sB = b.dataset.status === 'in-progress' ? 0 : 1;
        if (sA !== sB) return sA - sB;

        const yearA = parseInt((a.dataset.year || '').replace('year-', '')) || 0;
        const yearB = parseInt((b.dataset.year || '').replace('year-', '')) || 0;
        const nameA = a.dataset.name || '';
        const nameB = b.dataset.name || '';
        switch (currentSort) {
          case 'oldest': return yearA - yearB;
          case 'name-az': return nameA.localeCompare(nameB);
          case 'name-za': return nameB.localeCompare(nameA);
          default: return yearB - yearA;
        }
      });
      const frag = document.createDocumentFragment();
      cachedCards.forEach(c => frag.appendChild(c));
      grid.appendChild(frag);
      if (oldPos) animateFLIP(oldPos);
    }

    // ══════════════════════════════════════════
    //  YEAR BADGES on cards
    // ══════════════════════════════════════════
    function updateYearBadges() {
      const showYear = currentSort === 'newest' || currentSort === 'oldest';
      cachedCards.forEach(card => {
        let badge = card.querySelector('.kid-card__year-badge') as HTMLElement | null;
        if (showYear) {
          const year = (card.dataset.year || '').replace('year-', '');
          if (!year || year === '0') {
            if (badge) badge.classList.remove('is-visible');
            return;
          }
          if (!badge) {
            badge = document.createElement('span');
            badge.className = 'kid-card__year-badge';
            badge.setAttribute('aria-hidden', 'true');
            const frame = card.querySelector('.kid-card__frame');
            if (frame) frame.appendChild(badge);
          }
          badge.textContent = year;
          requestAnimationFrame(() => badge!.classList.add('is-visible'));
        } else {
          if (badge) badge.classList.remove('is-visible');
        }
      });
    }

    // ══════════════════════════════════════════
    //  LIVE FILTER COUNTS on dropdowns
    // ══════════════════════════════════════════
    // Build lightweight data array from ALL kids (server-rendered + overflow JSON)
    // so counts are accurate even before overflow cards are created in the DOM.
    type CountEntry = { year: string; types: string; name: string; diagnosis: string; status: string };
    const allKidData: CountEntry[] = [];
    cachedCards.forEach(card => {
      const { year, types, name, diagnosis, status } = card.dataset;
      allKidData.push({ year: year || '', types: types || '', name: name || '', diagnosis: diagnosis || '', status: status || '' });
    });
    // Also include overflow kids from JSON island
    {
      const overflowEl = document.getElementById('kids-overflow');
      if (overflowEl?.textContent) {
        try {
          const overflow: { s: string; n: string; i: string; b: string; y: number; t: string[]; d: string; st: string }[] = JSON.parse(overflowEl.textContent);
          for (const kid of overflow) {
            allKidData.push({
              year: `year-${kid.y}`,
              types: kid.t.map(t => `type-${t.toLowerCase().replace(/\s+/g, '-')}`).join(' '),
              name: kid.n.toLowerCase(),
              diagnosis: kid.d.toLowerCase(),
              status: kid.st,
            });
          }
        } catch { /* ignore parse errors */ }
      }
    }

    // Store original option labels (without counts)
    const origYearLabels = new Map<string, string>();
    const origTypeLabels = new Map<string, string>();
    for (const opt of Array.from(yearSelect.options)) origYearLabels.set(opt.value, opt.textContent || '');
    for (const opt of Array.from(typeSelect.options)) origTypeLabels.set(opt.value, opt.textContent || '');

    function updateFilterCounts() {
      const query = searchInput.value.toLowerCase().trim();
      const currentYear = yearSelect.value;
      const currentType = typeSelect.value;

      // Year counts: how many match if we pick each year (with current type + status + search)
      for (const opt of Array.from(yearSelect.options)) {
        if (opt.value === 'all') continue;
        let count = 0;
        for (const kid of allKidData) {
          if (kid.year !== opt.value) continue;
          if (currentType !== 'all' && !kid.types.split(' ').includes(currentType)) continue;
          if (statusActive && kid.status !== 'in-progress') continue;
          const yearStr = kid.year.replace('year-', '');
          const typesStr = kid.types.replace(/type-/g, '').replace(/-/g, ' ');
          if (query && fuzzyMatch(query, kid.name, kid.diagnosis, yearStr, typesStr) <= 0) continue;
          count++;
        }
        const base = origYearLabels.get(opt.value) || opt.value;
        opt.textContent = `${base} (${count})`;
      }

      // Type counts: how many match if we pick each type (with current year + status + search)
      for (const opt of Array.from(typeSelect.options)) {
        if (opt.value === 'all') continue;
        let count = 0;
        for (const kid of allKidData) {
          if (!kid.types.split(' ').includes(opt.value)) continue;
          if (currentYear !== 'all' && kid.year !== currentYear) continue;
          if (statusActive && kid.status !== 'in-progress') continue;
          const yearStr = kid.year.replace('year-', '');
          const typesStr = kid.types.replace(/type-/g, '').replace(/-/g, ' ');
          if (query && fuzzyMatch(query, kid.name, kid.diagnosis, yearStr, typesStr) <= 0) continue;
          count++;
        }
        const base = origTypeLabels.get(opt.value) || opt.value;
        opt.textContent = `${base} (${count})`;
      }

      // Visual state: mark active filters with data attribute for CSS styling
      yearSelect.classList.toggle('is-active', currentYear !== 'all');
      typeSelect.classList.toggle('is-active', currentType !== 'all');
      if (sortSelect) sortSelect.classList.toggle('is-active', currentSort !== 'newest');
    }

    // ══════════════════════════════════════════
    //  FILTER CHIPS
    // ══════════════════════════════════════════
    function renderChips() {
      const yearFilter = yearSelect.value;
      const typeFilter = typeSelect.value;
      const query = searchInput.value.trim();
      const hasAny = yearFilter !== 'all' || typeFilter !== 'all' || statusActive;

      if (!hasAny) {
        chipsEl.hidden = true;
        chipsEl.innerHTML = '';
        return;
      }

      let html = '';
      let chipCount = 0;
      // Search query chip omitted — already visible in the input
      if (yearFilter !== 'all') {
        const label = yearSelect.options[yearSelect.selectedIndex]?.text || yearFilter;
        html += `<span class="filter-chip" role="group" aria-label="Year: ${escapeHtml(label)}"><svg class="filter-chip__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>${escapeHtml(label)}<button class="filter-chip__remove" data-chip="year" aria-label="Remove year filter"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg></button></span>`;
        chipCount++;
      }
      if (typeFilter !== 'all') {
        const label = typeSelect.options[typeSelect.selectedIndex]?.text || typeFilter;
        const typeIconMap: Record<string, string> = {
          'dream bedroom': '<svg class="filter-chip__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/></svg>',
          'accessible bathroom': '<svg class="filter-chip__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="16" cy="4" r="1"/><path d="m18 19 1-7-6 1"/><path d="m5 8 3-3 5.5 3-2.36 3.5"/><path d="M4.24 14.5a5 5 0 0 0 6.88 6"/><path d="M13.76 17.5a5 5 0 0 0-6.88-6"/></svg>',
          'therapy room': '<svg class="filter-chip__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12.409 13.017A5 5 0 0 1 22 15c0 3.866-4 7-9 7-4.077 0-8.153-.82-10.371-2.462-.426-.316-.631-.832-.62-1.362C2.118 12.723 2.627 2 10 2a3 3 0 0 1 3 3 2 2 0 0 1-2 2c-1.105 0-1.64-.444-2-1"/><path d="M15 14a5 5 0 0 0-7.584 2"/><path d="M9.964 6.825C8.019 7.977 9.5 13 8 15"/></svg>',
        };
        const typeIcon = typeIconMap[label.toLowerCase()] || '<svg class="filter-chip__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>';
        html += `<span class="filter-chip" role="group" aria-label="Project: ${escapeHtml(label)}">${typeIcon}${escapeHtml(label)}<button class="filter-chip__remove" data-chip="type" aria-label="Remove project filter"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg></button></span>`;
        chipCount++;
      }
      if (statusActive) {
        html += `<span class="filter-chip" role="group" aria-label="Status: In Progress"><span class="pill-toggle__dot" style="width:6px;height:6px;border-radius:50%;background:var(--c-yellow);display:inline-block" aria-hidden="true"></span>In Progress<button class="filter-chip__remove" data-chip="status" aria-label="Remove status filter"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg></button></span>`;
        chipCount++;
      }
      html += `<button class="filter-chips__clear" data-chip="all" style="animation-delay:${chipCount * 0.04}s">Clear all</button>`;

      chipsEl.innerHTML = html;
      chipsEl.hidden = false;
    }

    // Chip click delegation
    chipsEl.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('[data-chip]') as HTMLElement | null;
      if (!btn) return;
      const chip = btn.dataset.chip;
      if (chip === 'search') { searchInput.value = ''; searchClear.hidden = true; if (kbdHint) kbdHint.classList.remove('is-hidden'); }
      else if (chip === 'year') { yearSelect.value = 'all'; }
      else if (chip === 'type') { typeSelect.value = 'all'; }
      else if (chip === 'status' && statusBtn) { statusActive = false; statusBtn.classList.remove('active'); statusBtn.setAttribute('aria-pressed', 'false'); }
      else if (chip === 'all') { clearAll(); return; }
      applyFilters();
    }, { signal });

    // ══════════════════════════════════════════
    //  ANIMATED FILTER TRANSITIONS
    // ══════════════════════════════════════════
    let hideTimers = new Map<HTMLElement, number>();

    function showCard(card: HTMLElement) {
      const timer = hideTimers.get(card);
      if (timer) { clearTimeout(timer); hideTimers.delete(card); }
      card.classList.remove('is-hiding');
      if (card.classList.contains('is-hidden')) {
        card.classList.remove('is-hidden');
        if (!reducedMotion) card.classList.add('is-showing');
      }
    }

    function hideCard(card: HTMLElement) {
      if (card.classList.contains('is-hidden')) return;
      if (reducedMotion) { card.classList.add('is-hidden'); return; }
      card.classList.remove('is-showing');
      card.classList.add('is-hiding');
      const timer = window.setTimeout(() => {
        card.classList.remove('is-hiding');
        card.classList.add('is-hidden');
        hideTimers.delete(card);
      }, 200);
      hideTimers.set(card, timer);
    }

    grid.addEventListener('animationend', (e) => {
      const card = (e.target as HTMLElement).closest('.kid-card') as HTMLElement | null;
      if (card?.classList.contains('is-showing')) card.classList.remove('is-showing');
    }, { signal });

    // ══════════════════════════════════════════
    //  SMART EMPTY STATE
    // ══════════════════════════════════════════
    function buildSmartEmptyState(query: string, yearFilter: string, typeFilter: string) {
      const suggestions: { label: string; count: number; action: () => void }[] = [];

      // Test removing each filter to see what would match
      if (yearFilter !== 'all') {
        let countWithoutYear = 0;
        cachedCards.forEach(card => {
          const { types, name, diagnosis, status } = card.dataset;
          const matchType = typeFilter === 'all' || (types?.split(' ').includes(typeFilter));
          const matchStatus = !statusActive || status === 'in-progress';
          const matchSearch = !query || fuzzyMatch(query, name, diagnosis) > 0;
          if (matchType && matchStatus && matchSearch) countWithoutYear++;
        });
        if (countWithoutYear > 0) {
          const yearLabel = yearSelect.options[yearSelect.selectedIndex]?.text || yearFilter;
          suggestions.push({
            label: `All years`,
            count: countWithoutYear,
            action: () => { yearSelect.value = 'all'; applyFilters(); }
          });
        }
      }

      if (typeFilter !== 'all') {
        let countWithoutType = 0;
        cachedCards.forEach(card => {
          const { year, name, diagnosis, status } = card.dataset;
          const matchYear = yearFilter === 'all' || year === yearFilter;
          const matchStatus = !statusActive || status === 'in-progress';
          const matchSearch = !query || fuzzyMatch(query, name, diagnosis) > 0;
          if (matchYear && matchStatus && matchSearch) countWithoutType++;
        });
        if (countWithoutType > 0) {
          suggestions.push({
            label: `All projects`,
            count: countWithoutType,
            action: () => { typeSelect.value = 'all'; applyFilters(); }
          });
        }
      }

      if (query) {
        // Find the closest fuzzy match from card names
        let bestMatch = '';
        let bestScore = 0;
        cachedCards.forEach(card => {
          const name = originalTexts.get(card)?.name || '';
          if (!name) return;
          const s = similarity(query.toLowerCase(), name.toLowerCase());
          if (s > bestScore && s >= 0.4) { bestScore = s; bestMatch = name; }
        });
        if (bestMatch && bestMatch.toLowerCase() !== query.toLowerCase()) {
          suggestions.push({
            label: `"${bestMatch}"`,
            count: 1,
            action: () => { searchInput.value = bestMatch; searchClear.hidden = false; applyFilters(); }
          });
        }

        // Test with only search
        let countSearchOnly = 0;
        cachedCards.forEach(card => {
          const { name, diagnosis } = card.dataset;
          if (fuzzyMatch(query, name, diagnosis) > 0) countSearchOnly++;
        });
        if (countSearchOnly > 0 && (yearFilter !== 'all' || typeFilter !== 'all' || statusActive)) {
          suggestions.push({
            label: `Search only`,
            count: countSearchOnly,
            action: () => { yearSelect.value = 'all'; typeSelect.value = 'all'; if (statusBtn) { statusActive = false; statusBtn.classList.remove('active'); statusBtn.setAttribute('aria-pressed', 'false'); } applyFilters(); }
          });
        }
      }

      // Build hint text
      const parts: string[] = [];
      if (query) parts.push(`"${query}"`);
      if (yearFilter !== 'all') parts.push(yearSelect.options[yearSelect.selectedIndex]?.text || yearFilter);
      if (typeFilter !== 'all') parts.push(typeSelect.options[typeSelect.selectedIndex]?.text || typeFilter);
      if (statusActive) parts.push('In Progress');

      noResultsHint.textContent = parts.length > 1
        ? `No results matching ${parts.join(' + ')}. Try removing a filter:`
        : `No results for ${parts[0] || 'this combination'}. Try:`;

      // Render suggestion buttons
      noResultsSuggestions.innerHTML = suggestions.map(s =>
        `<button class="no-results__suggestion" data-suggestion-idx="${suggestions.indexOf(s)}">${escapeHtml(s.label)} <span class="no-results__suggestion-count">(${s.count})</span></button>`
      ).join('');

      // Wire clicks
      const sugBtns = noResultsSuggestions.querySelectorAll<HTMLElement>('.no-results__suggestion');
      sugBtns.forEach((btn, i) => {
        btn.addEventListener('click', () => suggestions[i]?.action(), { signal });
      });
    }

    // ══════════════════════════════════════════
    //  MAIN FILTER LOGIC
    // ══════════════════════════════════════════
    function applyFilters() {
      const query = searchInput.value.toLowerCase().trim();
      const yearFilter = yearSelect.value;
      const typeFilter = typeSelect.value;
      const hasFilters = yearFilter !== 'all' || typeFilter !== 'all' || statusActive || query.length > 0;

      // When filtering, reveal all server-rendered cards so filters can match them
      if (hasFilters && !allCardsLoaded) {
        revealAllCards();
        if (loadMoreWrap) loadMoreWrap.classList.add('is-hidden');
      }

      if (!hasFilters && !allCardsLoaded && loadMoreWrap) {
        loadMoreWrap.classList.remove('is-hidden');
      }

      // Capture positions for FLIP
      const oldPos = capturePositions();

      // Build highlight regex once for the entire pass (not per-card)
      const hlRe = buildHighlightRe(query);

      let visibleCount = 0;

      for (const card of cachedCards) {
        const { year, types, name, diagnosis, status } = card.dataset;
        const matchesYear = yearFilter === 'all' || year === yearFilter;
        const matchesType = typeFilter === 'all' || (types ? types.split(' ').includes(typeFilter) : false);
        const matchesStatus = !statusActive || status === 'in-progress';
        const yearStr = (year || '').replace('year-', '');
        const typesStr = (types || '').replace(/type-/g, '').replace(/-/g, ' ');
        const matchScore = fuzzyMatch(query, name, diagnosis, yearStr, typesStr);

        if (matchesYear && matchesType && matchesStatus && matchScore > 0) {
          showCard(card);
          visibleCount++;
        } else {
          hideCard(card);
        }

        // Multi-term search highlighting (regex compiled once above)
        const orig = originalTexts.get(card);
        if (orig) {
          const nameEl = card.querySelector('.kid-card__name') as HTMLElement | null;
          const diagEl = card.querySelector('.kid-card__diagnosis') as HTMLElement | null;
          if (nameEl) highlightText(nameEl, hlRe, orig.name);
          if (diagEl) highlightText(diagEl, hlRe, orig.diagnosis);
        }
      }

      // No DOM reorder during search — cards stay in sort order, search only
      // shows/hides. This preserves spatial memory, avoids image flash from
      // DOM detachment, and matches best-in-class grid filter UX (Airbnb, Zillow).
      // Relevance score is still used above for the match threshold (fuzzyMatch > 0).

      // FLIP animate position changes from cards appearing/disappearing
      requestAnimationFrame(() => animateFLIP(oldPos));

      // Update status text — use stable DOM references, never recreate #visible-count
      const totalText = String(cachedCards.length);
      const prevCount = visibleCountEl.textContent;
      const newCount = String(visibleCount);
      if (prevCount !== newCount) {
        visibleCountEl.classList.add('is-updating');
        requestAnimationFrame(() => {
          visibleCountEl.textContent = newCount;
          requestAnimationFrame(() => visibleCountEl.classList.remove('is-updating'));
        });
      }
      if (resultCount) {
        if (query && visibleCount > 0) {
          resultCount.innerHTML = `<strong>${visibleCount}</strong> ${visibleCount === 1 ? 'result' : 'results'} for \u201c${escapeHtml(query)}\u201d`;
          resultCount.hidden = false;
        } else if (hasFilters && visibleCount > 0) {
          resultCount.innerHTML = `Showing <strong>${visibleCount}</strong> of ${totalText} kids`;
          resultCount.hidden = false;
        } else if (!hasFilters) {
          resultCount.hidden = true;
        }
      }
      // Sync badge with actual filtered count
      if (query) updateSearchCount(visibleCount);
      else searchCountEl.hidden = true;
      // Few results — center the grid
      grid.classList.toggle('is-few-results', hasFilters && visibleCount > 0 && visibleCount <= 3);
      const showingNoResults = visibleCount === 0 && hasFilters;
      noResults.hidden = !showingNoResults;
      if (showingNoResults) buildSmartEmptyState(query, yearFilter, typeFilter);
      clearBtn.hidden = !hasFilters;

      // Update chips
      renderChips();

      // Live filter counts on dropdowns
      updateFilterCounts();

      // Year badges
      updateYearBadges();

      // Mobile filter count
      let filterCount = 0;
      if (yearFilter !== 'all') filterCount++;
      if (typeFilter !== 'all') filterCount++;
      if (statusActive) filterCount++;
      if (mobileFilterCount) {
        if (filterCount > 0) {
          mobileFilterCount.textContent = String(filterCount);
          mobileFilterCount.hidden = false;
        } else {
          mobileFilterCount.hidden = true;
        }
      }

      // URL state
      const url = new URL(window.location.href);
      yearFilter !== 'all' ? url.searchParams.set('year', yearFilter) : url.searchParams.delete('year');
      typeFilter !== 'all' ? url.searchParams.set('type', typeFilter) : url.searchParams.delete('type');
      query ? url.searchParams.set('q', query) : url.searchParams.delete('q');
      statusActive ? url.searchParams.set('status', 'in-progress') : url.searchParams.delete('status');
      currentSort !== 'newest' ? url.searchParams.set('sort', currentSort) : url.searchParams.delete('sort');
      history.replaceState(null, '', url.toString());
    }

    function clearAll() {
      searchInput.value = '';
      searchInput.style.paddingRight = '';
      searchCountEl.hidden = true;
      searchClear.hidden = true;
      grid.classList.remove('is-few-results');
      if (kbdHint) kbdHint.classList.remove('is-hidden');
      yearSelect.value = 'all';
      typeSelect.value = 'all';
      if (sortSelect) { sortSelect.value = 'newest'; currentSort = 'newest'; }
      if (statusBtn) {
        statusActive = false;
        statusBtn.classList.remove('active');
        statusBtn.setAttribute('aria-pressed', 'false');
      }
      cachedCards.forEach(card => {
        const orig = originalTexts.get(card);
        if (orig) {
          const nameEl = card.querySelector('.kid-card__name') as HTMLElement | null;
          const diagEl = card.querySelector('.kid-card__diagnosis') as HTMLElement | null;
          if (nameEl) nameEl.textContent = orig.name;
          if (diagEl) diagEl.textContent = orig.diagnosis;
        }
      });
      sortCards(false);
      applyFilters();
      searchInput.focus();
    }

    function updateSearchCount(count: number) {
      if (count < 0) {
        searchCountEl.hidden = true;
        searchInput.style.paddingRight = '';
        return;
      }
      searchCountEl.textContent = `${count}`;
      searchCountEl.hidden = false;
      // Measure badge width and set input padding to avoid text overlap
      requestAnimationFrame(() => {
        const badgeW = searchCountEl.offsetWidth;
        searchInput.style.paddingRight = `${44 + badgeW + 8}px`;
      });
    }

    // ══════════════════════════════════════════
    //  EVENT WIRING
    // ══════════════════════════════════════════
    let searchTimer: ReturnType<typeof setTimeout>;
    yearSelect.addEventListener('change', () => applyFilters(), { signal });
    typeSelect.addEventListener('change', () => applyFilters(), { signal });
    if (sortSelect) {
      sortSelect.addEventListener('change', () => {
        currentSort = sortSelect.value;
        sortCards();
        applyFilters();
      }, { signal });
    }

    // Search input: debounced single-pass filter-as-you-type
    searchInput.addEventListener('input', () => {
      clearTimeout(searchTimer);
      const val = searchInput.value;
      searchClear.hidden = !val;
      if (kbdHint) kbdHint.classList.toggle('is-hidden', !!val);

      // Debounce the single-pass DOM filter
      visibleCountEl.style.opacity = '0.4';
      searchTimer = setTimeout(() => {
        visibleCountEl.style.opacity = '';
        applyFilters();
      }, 80);
    }, { signal });

    searchInput.addEventListener('focus', () => {
      if (kbdHint) kbdHint.classList.add('is-hidden');
    }, { signal });
    searchInput.addEventListener('blur', () => {
      if (kbdHint && !searchInput.value) kbdHint.classList.remove('is-hidden');
    }, { signal });

    searchClear.addEventListener('click', () => {
      searchInput.value = '';
      searchClear.hidden = true;
      searchCountEl.hidden = true;
      if (kbdHint) kbdHint.classList.remove('is-hidden');
      applyFilters();
      searchInput.focus();
    }, { signal });
    clearBtn.addEventListener('click', clearAll, { signal });
    clearBtnAlt.addEventListener('click', clearAll, { signal });

    if (statusBtn) {
      statusBtn.addEventListener('click', () => {
        statusActive = !statusActive;
        statusBtn.classList.toggle('active', statusActive);
        statusBtn.setAttribute('aria-pressed', String(statusActive));
        applyFilters();
      }, { signal });
    }

    // ══════════════════════════════════════════
    //  KEYBOARD SHORTCUT — / or Cmd+K
    // ══════════════════════════════════════════
    document.addEventListener('keydown', (e) => {
      const tag = (e.target as HTMLElement).tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;
      if ((e.target as HTMLElement).isContentEditable) return;
      if (e.key === '/' || (e.key === 'k' && (e.metaKey || e.ctrlKey))) {
        e.preventDefault();
        searchInput.focus();
        searchInput.select();
        toolbar.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    }, { signal });

    // ══════════════════════════════════════════
    //  BOTTOM SHEET
    // ══════════════════════════════════════════
    let savedScrollY = 0;
    function syncSheetCounts() {
      // Copy count labels from desktop selects to sheet selects
      for (const opt of Array.from(yearSelect.options)) {
        const sheetOpt = sheetYear.querySelector(`option[value="${opt.value}"]`) as HTMLOptionElement | null;
        if (sheetOpt) sheetOpt.textContent = opt.textContent;
      }
      for (const opt of Array.from(typeSelect.options)) {
        const sheetOpt = sheetType.querySelector(`option[value="${opt.value}"]`) as HTMLOptionElement | null;
        if (sheetOpt) sheetOpt.textContent = opt.textContent;
      }
    }

    function openSheet() {
      syncSheetCounts();
      sheetYear.value = yearSelect.value;
      sheetType.value = typeSelect.value;
      if (sheetSort) sheetSort.value = sortSelect?.value || 'newest';
      if (sheetStatus) {
        sheetStatus.classList.toggle('active', statusActive);
        sheetStatus.setAttribute('aria-pressed', String(statusActive));
      }
      sheet.classList.add('is-open');
      sheet.setAttribute('aria-hidden', 'false');
      updateSheetPreview();
      savedScrollY = window.scrollY;
      document.body.style.position = 'fixed';
      document.body.style.top = `-${savedScrollY}px`;
      document.body.style.left = '0';
      document.body.style.right = '0';
      document.body.style.overflow = 'hidden';
    }
    function closeSheet() {
      sheet.classList.remove('is-open');
      sheet.setAttribute('aria-hidden', 'true');
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.left = '';
      document.body.style.right = '';
      document.body.style.overflow = '';
      window.scrollTo(0, savedScrollY);
      const panel = sheet.querySelector('.bottom-sheet__panel') as HTMLElement;
      if (panel) { panel.style.transform = ''; panel.style.transition = ''; }
    }

    filterBtnMobile?.addEventListener('click', openSheet, { signal });
    sheetBackdrop?.addEventListener('click', closeSheet, { signal });
    sheetClose?.addEventListener('click', closeSheet, { signal });
    if (sheetStatus) {
      sheetStatus.addEventListener('click', () => {
        const isActive = sheetStatus.classList.toggle('active');
        sheetStatus.setAttribute('aria-pressed', String(isActive));
      }, { signal });
    }
    // Live result count preview in bottom sheet
    const sheetResultCount = document.getElementById('sheet-result-count') as HTMLElement | null;
    function updateSheetPreview() {
      if (!sheetResultCount) return;
      const query = searchInput.value.toLowerCase().trim();
      const yr = sheetYear.value;
      const tp = sheetType.value;
      const st = sheetStatus ? sheetStatus.classList.contains('active') : false;
      let count = 0;
      for (const kid of allKidData) {
        if (yr !== 'all' && kid.year !== yr) continue;
        if (tp !== 'all' && !kid.types.split(' ').includes(tp)) continue;
        if (st && kid.status !== 'in-progress') continue;
        const yearStr = kid.year.replace('year-', '');
        const typesStr = kid.types.replace(/type-/g, '').replace(/-/g, ' ');
        if (query && fuzzyMatch(query, kid.name, kid.diagnosis, yearStr, typesStr) <= 0) continue;
        count++;
      }
      sheetResultCount.textContent = `(${count})`;
    }
    sheetYear.addEventListener('change', updateSheetPreview, { signal });
    sheetType.addEventListener('change', updateSheetPreview, { signal });
    if (sheetStatus) sheetStatus.addEventListener('click', () => setTimeout(updateSheetPreview, 10), { signal });

    sheetClear?.addEventListener('click', () => {
      sheetYear.value = 'all';
      sheetType.value = 'all';
      if (sheetSort) sheetSort.value = 'newest';
      if (sheetStatus) {
        sheetStatus.classList.remove('active');
        sheetStatus.setAttribute('aria-pressed', 'false');
      }
      updateSheetPreview();
    }, { signal });
    sheetApply?.addEventListener('click', () => {
      yearSelect.value = sheetYear.value;
      typeSelect.value = sheetType.value;
      if (sortSelect && sheetSort) {
        sortSelect.value = sheetSort.value;
        currentSort = sheetSort.value;
        sortCards();
      }
      if (statusBtn && sheetStatus) {
        statusActive = sheetStatus.classList.contains('active');
        statusBtn.classList.toggle('active', statusActive);
        statusBtn.setAttribute('aria-pressed', String(statusActive));
      }
      applyFilters();
      closeSheet();
      // Move focus to first visible result for screen readers
      requestAnimationFrame(() => {
        const firstVisible = grid.querySelector('.kid-card:not(.is-hidden)') as HTMLElement | null;
        if (firstVisible) firstVisible.focus({ preventScroll: true });
        else searchInput.focus();
      });
    }, { signal });

    document.addEventListener('keydown', (e) => {
      if (!sheet.classList.contains('is-open')) return;
      if (e.key === 'Escape') { closeSheet(); return; }
      if (e.key === 'Tab') {
        const panel = sheet.querySelector('.bottom-sheet__panel') as HTMLElement;
        const focusable = panel.querySelectorAll<HTMLElement>('button, select, input, [tabindex]:not([tabindex="-1"])');
        if (!focusable.length) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
        else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    }, { signal });

    // ══════════════════════════════════════════
    //  VELOCITY-BASED SWIPE-TO-DISMISS
    // ══════════════════════════════════════════
    {
      const panel = sheet?.querySelector('.bottom-sheet__panel') as HTMLElement;
      if (panel) {
        let startY = 0;
        let currentY = 0;
        let isDragging = false;
        let startTime = 0;
        let velocitySamples: { y: number; t: number }[] = [];

        const handle = panel.querySelector('.bottom-sheet__handle') as HTMLElement;
        const header = panel.querySelector('.bottom-sheet__header') as HTMLElement;
        const swipeTargets = [handle, header].filter(Boolean);

        swipeTargets.forEach(target => {
          target!.addEventListener('touchstart', (e: TouchEvent) => {
            if (!sheet.classList.contains('is-open')) return;
            isDragging = true;
            startY = e.touches[0].clientY;
            startTime = Date.now();
            currentY = 0;
            velocitySamples = [{ y: 0, t: startTime }];
            panel.style.transition = 'none';
          }, { passive: true, signal });
        });

        panel.addEventListener('touchmove', (e: TouchEvent) => {
          if (!isDragging) return;
          const dy = e.touches[0].clientY - startY;
          currentY = Math.max(0, dy);
          panel.style.transform = `translateY(${currentY}px)`;
          const progress = Math.min(currentY / 300, 1);
          sheetBackdrop.style.opacity = String(1 - progress * 0.6);
          // Track velocity samples (keep last 5)
          velocitySamples.push({ y: currentY, t: Date.now() });
          if (velocitySamples.length > 5) velocitySamples.shift();
        }, { passive: true, signal });

        const endSwipe = () => {
          if (!isDragging) return;
          isDragging = false;
          panel.style.transition = '';
          sheetBackdrop.style.opacity = '';

          // Calculate velocity (px/ms)
          let velocity = 0;
          if (velocitySamples.length >= 2) {
            const first = velocitySamples[0];
            const last = velocitySamples[velocitySamples.length - 1];
            const dt = last.t - first.t;
            if (dt > 0) velocity = (last.y - first.y) / dt;
          }

          // Dismiss if: fast flick (>0.5 px/ms) OR dragged >100px
          if (velocity > 0.5 || currentY > 100) {
            closeSheet();
          } else {
            panel.style.transform = '';
          }
        };

        panel.addEventListener('touchend', endSwipe, { signal });
        panel.addEventListener('touchcancel', endSwipe, { signal });
      }
    }

    // ── Staggered reveal ──
    if (!reducedMotion) {
      document.documentElement.classList.add('js-anim');
      cachedCards.forEach((card, i) => {
        if (i < 8) card.classList.add('revealed');
      });
      _kidsObserver = new IntersectionObserver(
        (entries) => {
          entries.filter(e => e.isIntersecting).forEach((entry, i) => {
            const el = entry.target as HTMLElement;
            el.style.setProperty('--stagger', String(i));
            el.classList.add('revealed');
            _kidsObserver?.unobserve(el);
          });
        },
        { rootMargin: '100px', threshold: 0.01 }
      );
      cachedCards.forEach((card, i) => {
        if (i >= 8) _kidsObserver!.observe(card);
      });
    }

    // ── Smooth image fade-in on load (with LQIP blur-up) ──
    function initImageFade(img: HTMLImageElement) {
      const onLoaded = () => {
        img.classList.add('is-loaded');
        // Remove blur placeholder once real image is visible
        const frame = img.closest('.kid-card__frame');
        if (frame) frame.classList.add('lqip-done');
      };
      if (img.complete && img.naturalWidth > 0) {
        onLoaded();
      } else {
        img.addEventListener('load', onLoaded, { once: true });
      }
    }
    if (!reducedMotion) {
      document.documentElement.classList.add('js-img-fade');
      grid.querySelectorAll<HTMLImageElement>('.kid-card__img').forEach(initImageFade);
    }

    // ── Toolbar scroll shadow ──
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(() => {
          toolbar.classList.toggle('is-scrolled', window.scrollY > 300);
          ticking = false;
        });
      }
    }, { passive: true, signal });


    // ── URL filter restore ──
    const hasURLFilters = params.get('year') || params.get('type') || params.get('q') || params.get('status') || params.get('sort');
    if (hasURLFilters) {
      if (currentSort !== 'newest') sortCards(false);
      applyFilters();
      toolbar.scrollIntoView({ behavior: 'smooth', block: 'start' });
    } else {
      // Still show year badges on initial load if sort is year-based
      updateYearBadges();
      updateFilterCounts();
    }

  } // end initKidsIndex

  document.addEventListener('astro:page-load', initKidsIndex);
  document.addEventListener('astro:before-swap', cleanupKidsIndex);
</script>

<!-- View Transitions: card ↔ hero morph (forward + back) -->
<script>
  function initKidTransitions() {
    const grid = document.getElementById('kids-grid');
    if (!grid) return;

    // Forward: index → profile — morph clicked card's frame + name
    grid.addEventListener('click', (e) => {
      const card = (e.target as HTMLElement).closest('.kid-card') as HTMLElement | null;
      if (!card) return;
      // Clear any previous transition names
      document.querySelectorAll('[style*="view-transition-name"]').forEach(el => {
        (el as HTMLElement).style.viewTransitionName = '';
      });
      const frame = card.querySelector('.kid-card__frame') as HTMLElement | null;
      const name = card.querySelector('.kid-card__name') as HTMLElement | null;
      if (frame) {
        frame.style.viewTransitionName = 'kid-hero';
        // Reset ALL hover artifacts before the snapshot is captured —
        // otherwise the yellow glow, overlay, and image scale persist in the morph
        frame.style.boxShadow = 'none';
        const overlay = frame.querySelector('.kid-card__hover-overlay') as HTMLElement | null;
        if (overlay) overlay.style.opacity = '0';
        const cta = frame.querySelector('.kid-card__cta') as HTMLElement | null;
        if (cta) cta.style.opacity = '0';
        const img = frame.querySelector('.kid-card__img') as HTMLElement | null;
        if (img) { img.style.transform = 'none'; img.style.filter = 'none'; }
      }
      if (name) name.style.viewTransitionName = 'kid-name';
    });
  }

  // Back: profile → index — find the matching card in the incoming DOM
  function setupBackTransition(e: any) {
    const fromPath = window.location.pathname;
    const slugMatch = fromPath.match(/^\/kids\/([^/]+)\/?$/);
    if (!slugMatch) return;
    const newDoc = e.newDocument as Document;
    // Verify the incoming page is the kids index
    if (!newDoc.getElementById('kids-grid')) return;
    const slug = slugMatch[1];
    const card = newDoc.querySelector(`a.kid-card[href="/kids/${slug}/"]`) as HTMLElement | null;
    if (!card) return;
    const frame = card.querySelector('.kid-card__frame') as HTMLElement | null;
    const name = card.querySelector('.kid-card__name') as HTMLElement | null;
    if (frame) frame.style.viewTransitionName = 'kid-hero';
    if (name) name.style.viewTransitionName = 'kid-name';
  }

  document.addEventListener('astro:page-load', initKidTransitions);
  document.addEventListener('astro:before-swap', setupBackTransition);
</script>

