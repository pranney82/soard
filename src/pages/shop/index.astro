<script>
/**
 * Shop — Premium Client Interactions
 *
 * Modules: sidebar nav, search dropdown, sort, grid toggle, PDP modal, mobile drawer
 * Architecture: document-level event delegation + astro:page-load lifecycle
 */
var STORE_URL = 'https://sunnyandranney.com';
var SHOP_SVG = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>';

function fmtPrice(a, c) { return new Intl.NumberFormat('en-US', { style: 'currency', currency: c || 'USD' }).format(parseFloat(a)); }
function esc(s) { var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }
function titleCase(s) { return (s || '').toLowerCase().replace(/(?:^|\s)\S/g, function(a) { return a.toUpperCase(); }); }

var shopState = { productMap: null, ac: null, previousFocus: null, currentCat: 'all', searchIndex: null, gridCols: 3 };

function getProductMap() {
  if (!shopState.productMap) {
    try { shopState.productMap = JSON.parse(document.getElementById('shop-product-data').textContent); }
    catch(e) { shopState.productMap = {}; }
  }
  return shopState.productMap;
}
function getSearchIndex() {
  if (!shopState.searchIndex) {
    try { shopState.searchIndex = JSON.parse(document.getElementById('shop-search-index').textContent); }
    catch(e) { shopState.searchIndex = []; }
  }
  return shopState.searchIndex;
}

/* ─── SIDEBAR / CATEGORY NAVIGATION ─── */
function setActiveCategory(handle) {
  shopState.currentCat = handle;
  var collectionsGrid = document.getElementById('shop-collections');
  var breadcrumb = document.getElementById('shop-breadcrumb');
  var countEl = document.getElementById('shop-count');
  if (!collectionsGrid) return;

  document.querySelectorAll('.shop-cat-btn').forEach(function(b) { b.classList.toggle('is-active', b.dataset.cat === handle); });
  document.querySelectorAll('.shop-chip').forEach(function(b) { b.classList.toggle('is-active', b.dataset.cat === handle); });

  document.querySelectorAll('.shop-products-grid[data-collection-panel]').forEach(function(p) { p.style.display = 'none'; });

  if (handle === 'all') {
    collectionsGrid.style.display = '';
    breadcrumb.innerHTML = '<span class="shop-breadcrumb-base">Shop</span>';
    countEl.textContent = collectionsGrid.children.length + ' collections';
    history.pushState(null, '', window.location.pathname);
  } else {
    collectionsGrid.style.display = 'none';
    var panel = document.getElementById('products-' + handle);
    if (panel) {
      panel.style.display = '';
      panel.setAttribute('data-cols', shopState.gridCols);
      var name = titleCase(handle.replace(/-/g, ' '));
      var catBtn = document.querySelector('.shop-cat-btn[data-cat="' + handle + '"] span:first-child');
      if (catBtn) name = catBtn.textContent;
      breadcrumb.innerHTML = '<span class="shop-breadcrumb-base" style="cursor:pointer" data-cat="all">Shop</span><span class="shop-breadcrumb-sep">/</span><span class="shop-breadcrumb-current">' + esc(name) + '</span>';
      countEl.textContent = panel.children.length + ' items';
      history.pushState({ cat: handle }, '', '#' + handle);
    }
  }

  closeSidebar();
  var toolbar = document.getElementById('shop-toolbar');
  if (toolbar) toolbar.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function openSidebar() {
  var sb = document.getElementById('shop-sidebar');
  var ov = document.getElementById('sidebar-overlay');
  if (sb) sb.classList.add('is-open');
  if (ov) ov.classList.add('is-open');
  document.body.style.overflow = 'hidden';
}
function closeSidebar() {
  var sb = document.getElementById('shop-sidebar');
  var ov = document.getElementById('sidebar-overlay');
  if (sb) sb.classList.remove('is-open');
  if (ov) ov.classList.remove('is-open');
  document.body.style.overflow = '';
}

/* ─── SORT ─── */
function sortProducts(mode) {
  document.querySelectorAll('.shop-products-grid[data-collection-panel]').forEach(function(panel) {
    var cards = Array.from(panel.children);
    if (mode === 'default') return;
    cards.sort(function(a, b) {
      if (mode === 'price-asc') return parseFloat(a.dataset.price) - parseFloat(b.dataset.price);
      if (mode === 'price-desc') return parseFloat(b.dataset.price) - parseFloat(a.dataset.price);
      if (mode === 'title-asc') return (a.dataset.title || '').localeCompare(b.dataset.title || '');
      if (mode === 'title-desc') return (b.dataset.title || '').localeCompare(a.dataset.title || '');
      return 0;
    });
    cards.forEach(function(c) { panel.appendChild(c); });
  });
}

/* ─── GRID TOGGLE ─── */
function setGridCols(n) {
  shopState.gridCols = n;
  document.querySelectorAll('.shop-grid-toggle button').forEach(function(b) { b.classList.toggle('is-active', b.dataset.cols == n); });
  var active = document.querySelector('.shop-products-grid[data-collection-panel]:not([style*="display: none"])');
  if (active) active.setAttribute('data-cols', n);
}

/* ─── SEARCH ─── */
var searchTimer = null;
function handleSearch(query) {
  var dd = document.getElementById('shop-search-dropdown');
  if (!dd) return;
  query = (query || '').trim().toLowerCase();
  if (query.length < 2) { dd.classList.remove('is-open'); dd.innerHTML = ''; return; }

  var idx = getSearchIndex();
  var matches = idx.filter(function(item) {
    return item.t.toLowerCase().indexOf(query) > -1 || item.h.toLowerCase().indexOf(query) > -1;
  }).slice(0, 8);

  if (matches.length === 0) {
    dd.innerHTML = '<div class="search-empty">No products found for "' + esc(query) + '"</div>';
  } else {
    var html = '';
    matches.forEach(function(m) {
      html += '<div class="search-item" data-handle="' + esc(m.h) + '" role="button" tabindex="0">';
      html += m.i ? '<img class="search-item-img" src="' + esc(m.i) + '" alt="" loading="lazy" />' : '<div class="search-item-img"></div>';
      html += '<div class="search-item-info"><div class="search-item-title">' + esc(m.t) + '</div>';
      html += '<div class="search-item-price">' + fmtPrice(m.p, m.c) + (m.a ? '' : ' · Sold Out') + '</div></div></div>';
    });
    var totalMatches = idx.filter(function(item) { return item.t.toLowerCase().indexOf(query) > -1 || item.h.toLowerCase().indexOf(query) > -1; }).length;
    if (matches.length < totalMatches) {
      html += '<div class="search-hint">Showing top ' + matches.length + ' of ' + totalMatches + ' results</div>';
    }
    dd.innerHTML = html;
  }
  dd.classList.add('is-open');
}

/* ─── PDP MODAL ─── */
function fetchLiveAvailability(handle, cb) {
  fetch('/api/shopify', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ query: 'query($h:String!){product(handle:$h){handle availableForSale variants(first:100){edges{node{id availableForSale}}}}}', variables: { h: handle } })
  }).then(function(r) { return r.json(); }).then(function(j) {
    if (j.data && j.data.product) cb(j.data.product);
  }).catch(function() {});
}

function applyLiveAvailability(live, variants, btn, getSelected) {
  if (!live || !live.variants) return;
  live.variants.edges.forEach(function(e) {
    var match = variants.find(function(v) { return v.id === e.node.id; });
    if (match) match.availableForSale = e.node.availableForSale;
  });
  if (!btn) return;
  var sel = getSelected();
  var match = variants.find(function(v) { return v.selectedOptions.every(function(o) { return sel[o.name] === o.value; }); });
  if (match && !match.availableForSale) {
    if (btn.tagName === 'A') btn.removeAttribute('href');
    btn.innerHTML = 'Sold Out'; btn.classList.add('is-disabled'); btn.setAttribute('aria-disabled', 'true');
  } else if (match && match.availableForSale && btn.classList.contains('is-disabled')) {
    btn.classList.remove('is-disabled'); btn.removeAttribute('aria-disabled');
    btn.innerHTML = SHOP_SVG + ' Buy Now';
  }
  if (live.hasOwnProperty('availableForSale')) {
    var pm = getProductMap();
    if (pm[live.handle || '']) pm[live.handle].availableForSale = live.availableForSale;
  }
}

function openProduct(handle) {
  shopState.previousFocus = document.activeElement;
  var pm = getProductMap();
  var p = pm[handle];
  if (!p) return;

  var modal = document.getElementById('pdp-modal');
  var backdrop = document.getElementById('pdp-backdrop');
  var body = document.getElementById('pdp-body');

  var images = p.images.edges.map(function(e) { return e.node; });
  var variants = p.variants.edges.map(function(e) { return e.node; });
  var fv = variants[0];
  var hasV = variants.length > 1;
  var price = fv.price;
  var cmpAt = fv.compareAtPrice;
  var disc = cmpAt && parseFloat(cmpAt.amount) > parseFloat(price.amount);

  var html = '<div class="pdp-gallery"><div class="pdp-main-img" id="pdp-main-img">' +
    (images[0] ? '<img id="pdp-hero" src="' + images[0].url + '&width=900" alt="' + esc(images[0].altText || p.title) + '" />' : '') + '</div>';
  if (images.length > 1) {
    html += '<div class="pdp-thumbs">';
    images.forEach(function(img, i) {
      html += '<button type="button" class="pdp-thumb' + (i === 0 ? ' is-active' : '') + '" data-idx="' + i + '" data-src="' + img.url + '&width=900" data-alt="' + esc(img.altText || p.title) + '" aria-label="View image ' + (i+1) + '"><img src="' + img.url + '&width=120" alt="" width="60" height="60" loading="lazy" decoding="async" /></button>';
    });
    html += '</div>';
  }
  html += '</div><div class="pdp-info"><h2 class="pdp-title">' + esc(p.title) + '</h2>' +
    '<div class="pdp-price"><span class="pdp-price-amount' + (disc ? ' has-sale' : '') + '" id="pdp-live-price">' + fmtPrice(price.amount, price.currencyCode) + '</span>' +
    (disc ? '<span class="pdp-price-compare" id="pdp-live-compare">' + fmtPrice(cmpAt.amount, cmpAt.currencyCode) + '</span>' : '<span class="pdp-price-compare" id="pdp-live-compare" style="display:none"></span>') + '</div>';

  if (hasV) {
    p.options.forEach(function(opt) {
      html += '<div class="pdp-option" data-option-name="' + esc(opt.name) + '"><label class="pdp-option-label">' + esc(opt.name) + '</label><div class="pdp-option-values">';
      opt.values.forEach(function(v, i) {
        html += '<button type="button" class="pdp-option-btn' + (i === 0 ? ' is-active' : '') + '" data-opt-name="' + esc(opt.name) + '" data-opt-value="' + esc(v) + '">' + esc(v) + '</button>';
      });
      html += '</div></div>';
    });
  }

  html += (p.availableForSale
    ? '<a href="' + STORE_URL + '/products/' + p.handle + '" target="_blank" rel="noopener" class="pdp-atc btn btn-primary" id="pdp-atc-btn">' + SHOP_SVG + ' Buy Now</a>'
    : '<button type="button" class="pdp-atc btn btn-primary" id="pdp-atc-btn" disabled>Sold Out</button>');
  if (p.descriptionHtml) html += '<div class="pdp-desc">' + p.descriptionHtml + '</div>';
  html += '<p class="pdp-mission-note"><strong>100% of proceeds</strong> fund dream room makeovers for kids with special needs.</p></div>';

  body.innerHTML = html;
  modal.classList.add('is-open');
  modal.setAttribute('aria-hidden', 'false');
  backdrop.classList.add('is-open');
  document.body.style.overflow = 'hidden';
  document.getElementById('pdp-close').focus();

  /* Zoom on hover (desktop only) */
  var mainImg = document.getElementById('pdp-main-img');
  if (mainImg && window.innerWidth > 768) {
    mainImg.addEventListener('mousemove', function(e) {
      var rect = mainImg.getBoundingClientRect();
      var x = ((e.clientX - rect.left) / rect.width * 100).toFixed(1);
      var y = ((e.clientY - rect.top) / rect.height * 100).toFixed(1);
      mainImg.style.setProperty('--zoom-x', x + '%');
      mainImg.style.setProperty('--zoom-y', y + '%');
    });
    mainImg.addEventListener('mouseleave', function() {
      mainImg.style.setProperty('--zoom-x', '50%');
      mainImg.style.setProperty('--zoom-y', '50%');
    });
  }

  /* Thumbnail + variant interactions */
  var heroImg = document.getElementById('pdp-hero');
  var atcBtn = document.getElementById('pdp-atc-btn');
  var priceEl = document.getElementById('pdp-live-price');
  var compareEl = document.getElementById('pdp-live-compare');
  var selected = {};

  body.querySelectorAll('.pdp-option').forEach(function(g) {
    var n = g.dataset.optionName;
    var f = g.querySelector('.pdp-option-btn.is-active');
    if (f) selected[n] = f.dataset.optValue;
  });
  function getSelected() { return selected; }

  fetchLiveAvailability(p.handle, function(liveData) {
    var liveBtn = document.getElementById('pdp-atc-btn');
    applyLiveAvailability(liveData, variants, liveBtn, getSelected);
  });

  body.querySelectorAll('.pdp-thumb').forEach(function(thumb) {
    thumb.addEventListener('click', function() {
      body.querySelectorAll('.pdp-thumb').forEach(function(t) { t.classList.remove('is-active'); });
      thumb.classList.add('is-active');
      if (heroImg) { heroImg.src = thumb.dataset.src; heroImg.alt = thumb.dataset.alt || ''; }
    });
  });

  body.querySelectorAll('.pdp-option-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      selected[btn.dataset.optName] = btn.dataset.optValue;
      btn.closest('.pdp-option-values').querySelectorAll('.pdp-option-btn').forEach(function(b) { b.classList.toggle('is-active', b === btn); });
      var match = variants.find(function(v) { return v.selectedOptions.every(function(o) { return selected[o.name] === o.value; }); });
      var liveAtcBtn = document.getElementById('pdp-atc-btn');
      if (match && liveAtcBtn) {
        if (match.availableForSale) {
          if (liveAtcBtn.tagName === 'A') liveAtcBtn.href = STORE_URL + '/products/' + p.handle + '?variant=' + match.id.replace(/\D/g, '');
          liveAtcBtn.innerHTML = SHOP_SVG + ' Buy Now';
          liveAtcBtn.classList.remove('is-disabled'); liveAtcBtn.removeAttribute('aria-disabled');
        } else {
          if (liveAtcBtn.tagName === 'A') liveAtcBtn.removeAttribute('href');
          liveAtcBtn.innerHTML = 'Sold Out';
          liveAtcBtn.classList.add('is-disabled'); liveAtcBtn.setAttribute('aria-disabled', 'true');
        }
        if (priceEl) { priceEl.textContent = fmtPrice(match.price.amount, match.price.currencyCode); priceEl.classList.toggle('has-sale', !!(match.compareAtPrice && parseFloat(match.compareAtPrice.amount) > parseFloat(match.price.amount))); }
        if (compareEl) {
          if (match.compareAtPrice && parseFloat(match.compareAtPrice.amount) > parseFloat(match.price.amount)) { compareEl.textContent = fmtPrice(match.compareAtPrice.amount, match.compareAtPrice.currencyCode); compareEl.style.display = ''; }
          else { compareEl.style.display = 'none'; }
        }
        if (match.image && heroImg) { heroImg.src = match.image.url + '&width=900'; heroImg.alt = match.image.altText || ''; }
      }
    });
  });
}

function closeModal() {
  var modal = document.getElementById('pdp-modal');
  var backdrop = document.getElementById('pdp-backdrop');
  if (modal) { modal.classList.remove('is-open'); modal.setAttribute('aria-hidden', 'true'); }
  if (backdrop) backdrop.classList.remove('is-open');
  document.body.style.overflow = '';
  if (shopState.previousFocus) { try { shopState.previousFocus.focus(); } catch(e) {} }
}

/* ─── DOCUMENT-LEVEL EVENT DELEGATION ─── */
document.addEventListener('click', function(e) {
  var catBtn = e.target.closest('[data-cat]');
  if (catBtn) { setActiveCategory(catBtn.dataset.cat); return; }

  var cc = e.target.closest('[data-collection]');
  if (cc && cc.closest('#shop-collections')) { setActiveCategory(cc.dataset.collection); return; }

  var qv = e.target.closest('.product-card-quickview');
  if (qv) { var card = qv.closest('[data-handle]'); if (card) openProduct(card.dataset.handle); return; }
  var pc = e.target.closest('[data-handle]');
  if (pc && pc.closest('.shop-products-grid')) { openProduct(pc.dataset.handle); return; }

  var si = e.target.closest('.search-item');
  if (si && si.dataset.handle) {
    openProduct(si.dataset.handle);
    var searchInput = document.getElementById('shop-search');
    var dd = document.getElementById('shop-search-dropdown');
    if (searchInput) searchInput.value = '';
    if (dd) { dd.classList.remove('is-open'); dd.innerHTML = ''; }
    return;
  }

  if (!e.target.closest('#shop-search-wrap')) {
    var dd = document.getElementById('shop-search-dropdown');
    if (dd) dd.classList.remove('is-open');
  }

  if (e.target.closest('#pdp-close') || e.target.id === 'pdp-backdrop') closeModal();
  if (e.target.closest('#shop-filter-btn')) openSidebar();
  if (e.target.closest('#sidebar-close') || e.target.id === 'sidebar-overlay') closeSidebar();

  var gt = e.target.closest('.shop-grid-toggle button');
  if (gt) setGridCols(parseInt(gt.dataset.cols));
});

document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    var m = document.getElementById('pdp-modal');
    if (m && m.classList.contains('is-open')) { closeModal(); return; }
    var sb = document.getElementById('shop-sidebar');
    if (sb && sb.classList.contains('is-open')) { closeSidebar(); return; }
    var dd = document.getElementById('shop-search-dropdown');
    if (dd && dd.classList.contains('is-open')) { dd.classList.remove('is-open'); return; }
  }
  if (e.key === 'Enter' || e.key === ' ') {
    var cc = e.target.closest('[data-collection]');
    if (cc && cc.closest('#shop-collections')) { e.preventDefault(); setActiveCategory(cc.dataset.collection); return; }
    var pc = e.target.closest('[data-handle]');
    if (pc && pc.closest('.shop-products-grid')) { e.preventDefault(); openProduct(pc.dataset.handle); return; }
    var si = e.target.closest('.search-item');
    if (si && si.dataset.handle) { e.preventDefault(); openProduct(si.dataset.handle); return; }
  }
});

/* ─── ASTRO PAGE-LOAD ENTRY POINT ─── */
document.addEventListener('astro:page-load', function() {
  if (!window.location.pathname.startsWith('/shop')) return;
  if (shopState.ac) shopState.ac.abort();
  shopState.ac = new AbortController();
  var sig = shopState.ac.signal;
  shopState.productMap = null;
  shopState.searchIndex = null;

  var searchInput = document.getElementById('shop-search');
  if (searchInput) {
    searchInput.addEventListener('input', function(e) {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(function() { handleSearch(e.target.value); }, 150);
    }, { signal: sig });
  }

  var sortEl = document.getElementById('shop-sort');
  if (sortEl) {
    sortEl.addEventListener('change', function(e) { sortProducts(e.target.value); }, { signal: sig });
  }

  window.addEventListener('popstate', function() {
    var hash = window.location.hash.replace('#', '');
    setActiveCategory(hash || 'all');
  }, { signal: sig });

  var hash = window.location.hash.replace('#', '');
  if (hash && document.getElementById('products-' + hash)) {
    setActiveCategory(hash);
  }
});
</script>
