---
/**
 * Lightweight YouTube/Vimeo embed.
 * Shows thumbnail + play button, loads iframe only on click.
 * Saves ~800KB per embed = huge Lighthouse win.
 */

interface Props {
  url: string;
  title: string;
}

const { url, title } = Astro.props;

let videoId = '';
let platform = '';

if (url.includes('youtube.com') || url.includes('youtu.be')) {
  platform = 'youtube';
  const match = url.match(/(?:v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
  videoId = match ? match[1] : '';
} else if (url.includes('vimeo.com')) {
  platform = 'vimeo';
  const match = url.match(/vimeo\.com\/(\d+)/);
  videoId = match ? match[1] : '';
}

const thumbnail = platform === 'youtube'
  ? `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`
  : '';
---

<div
  class="video-facade"
  data-platform={platform}
  data-video-id={videoId}
  role="button"
  aria-label={`Play video: ${title}`}
  tabindex="0"
>
  {platform === 'youtube' && thumbnail && (
    <img src={thumbnail} alt={title} loading="lazy" />
  )}
  <div class="play-btn">
    <svg viewBox="0 0 68 48" width="68" height="48">
      <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="red"/>
      <path d="M45 24L27 14v20" fill="white"/>
    </svg>
  </div>
</div>

<style>
  .video-facade {
    position: relative;
    aspect-ratio: 16 / 9;
    background: #000;
    border-radius: 16px;
    overflow: hidden;
    cursor: pointer;
  }
  .video-facade img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .play-btn {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s;
  }
  .video-facade:hover .play-btn {
    transform: scale(1.1);
  }
</style>

<script>
  document.querySelectorAll('.video-facade').forEach(el => {
    const activate = () => {
      const platform = (el as HTMLElement).dataset.platform;
      const id = (el as HTMLElement).dataset.videoId;
      const iframe = document.createElement('iframe');
      iframe.style.cssText = 'width:100%;height:100%;position:absolute;inset:0;border:none;';
      iframe.allow = 'accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      if (platform === 'youtube') {
        iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1`;
      } else if (platform === 'vimeo') {
        iframe.src = `https://player.vimeo.com/video/${id}?autoplay=1`;
      }
      el.innerHTML = '';
      el.appendChild(iframe);
    };
    el.addEventListener('click', activate);
    el.addEventListener('keydown', (e) => { if ((e as KeyboardEvent).key === 'Enter') activate(); });
  });
</script>
