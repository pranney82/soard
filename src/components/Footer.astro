---
// Footer component
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-about">
        <div class="footer-logo">
          <img src="/logo-footer.png" alt="Sunshine on a Ranney Day" width="170" height="160" class="footer-logo-img" />
        </div>
        <p>
          A 501(c)(3) nonprofit creating life-changing home makeovers
          for children with special needs and life-altering illnesses
          in the greater Atlanta area.
        </p>
        <address>42-C Oak Street, Roswell GA 30075</address>
      </div>

      <div class="footer-col">
        <h4>About</h4>
        <a href="/about">Our Story</a>
        <a href="/about#leadership">Leadership</a>
        <a href="/about#financials">Financials</a>
      </div>

      <div class="footer-col">
        <h4>Programs</h4>
        <a href="/kids">Meet the Kids</a>
        <a href="/partners">Our Partners</a>
      </div>

      <div class="footer-col">
        <h4>Get Involved</h4>
        <a href="/donate">Donate</a>
        <a href="/get-involved">Volunteer</a>
        <a href="/get-involved#apply">Apply for a Room</a>
        <a href="https://www.sunnyandranney.com" target="_blank" rel="noopener">Shop Sunny & Ranney</a>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {new Date().getFullYear()} Sunshine on a Ranney Day. All rights reserved.</span>
      <span class="footer-ein">EIN: XX-XXXXXXX</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--c-dark-deep);
    padding: 64px var(--page-padding) 32px;
    color: rgba(255, 255, 255, 0.5);
  }
  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2.5fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 48px;
  }
  .footer-logo {
    margin-bottom: 20px;
  }
  .footer-logo-img {
    width: auto;
    height: 80px;
    object-fit: contain;
  }
  .footer-about p {
    font-size: 14px;
    line-height: 1.75;
    max-width: 340px;
    color: rgba(255, 255, 255, 0.5);
  }
  .footer-about address {
    font-style: normal;
    margin-top: 20px;
    font-size: 13px;
  }
  .footer-col h4 {
    font-family: var(--f-body);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-yellow);
    margin-bottom: 18px;
  }
  .footer-col a {
    display: block;
    font-size: 14px;
    margin-bottom: 12px;
    color: rgba(255, 255, 255, 0.5);
    transition: color 0.2s;
  }
  .footer-col a:hover {
    color: #fff;
  }
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
  }
  .footer-ein {
    color: var(--c-yellow);
  }
  @media (max-width: 768px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
  }
  @media (max-width: 480px) {
    .footer-grid { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; gap: 8px; text-align: center; }
  }
</style>
