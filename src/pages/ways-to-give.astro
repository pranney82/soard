    height: 16px;
    flex-shrink: 0;
    color: var(--c-text-muted);
  }

  /* ── Photo column — portrait (4:5), accent, stat badge ── */
  .hero-photo-wrap {
    position: relative;
    animation: heroPhotoIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero-frame {
    display: block;
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.12), 0 8px 24px rgba(0, 0, 0, 0.06);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-frame:hover img {
    transform: scale(1.03);
  }

  .hero-accent {
    position: absolute;
    z-index: -1;
    bottom: -16px;
    right: -16px;
    width: 55%;
    height: 55%;
    border-radius: 20px;
    background: var(--c-yellow);
    opacity: 0.35;
  }

  .hero-stat {
    position: absolute;
    bottom: -24px;
    left: -24px;
    background: var(--c-dark);
    color: #fff;
    border-radius: 16px;
    padding: 20px 28px;
    text-align: center;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.15);
