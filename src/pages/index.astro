  .trust-card:hover { background: rgba(255,255,255,0.07); transform: translateY(-4px); }
  .trust-card-top { margin-bottom: 16px; }
  .trust-big { display: block; font-family: var(--font-display); font-size: 40px; font-weight: 700; color: var(--c-yellow); line-height: 1; margin-bottom: 8px; }
  .trust-big--icon { font-family: inherit; font-size: 0; line-height: 0; }
  .trust-card-label { font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.08em; }
  .trust-card p { font-size: 15px; color: rgba(255,255,255,0.6); line-height: 1.65; }
