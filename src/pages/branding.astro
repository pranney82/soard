---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Brand Guidelines" description="Official brand resources, logos, and usage guidelines for representing Sunshine on a Ranney Day.">

  <section class="page-hero">
    <div class="container">
      <p class="hero-label">Brand Resources</p>
      <h1>Brand Guidelines</h1>
      <p class="page-hero-sub">Official brand resources, logos, and usage guidelines for representing Sunshine on a Ranney Day.</p>
    </div>
  </section>

  <!-- ══════ TOC ══════ -->
  <nav class="brand-toc">
    <div class="container">
      <p class="toc-label">Contents</p>
      <div class="toc-links">
        <a href="#logos">Logos</a>
        <a href="#icons">Icons</a>
        <a href="#logo-usage">Logo Usage</a>
        <a href="#colors">Colors</a>
        <a href="#typography">Typography</a>
        <a href="#voice">Voice &amp; Tone</a>
      </div>
    </div>
  </nav>

  <!-- ══════ LOGOS ══════ -->
  <section id="logos" class="brand-section">
    <div class="container">
      <div class="bsec-header">
        <h2>Logos</h2>
        <p>Download our official logos in various formats and variations.</p>
      </div>

      <a href="/SOARD-Brand-Guidelines.pdf" download class="download-all-btn">Download All Assets</a>

      <div class="logo-grid">
        <div class="logo-card">
          <div class="logo-card-preview bg-light">
            <img src="/images/logos/logo-light-bg.png" alt="Sunshine on a Ranney Day logo for light backgrounds" class="logo-img" loading="lazy" />
          </div>
          <div class="logo-card-body">
            <h3>Primary Logo</h3>
            <p>Main logo for light backgrounds</p>
            <div class="logo-formats">
              <a href="/images/logos/logo-light-bg.png" download class="fmt-btn">PNG</a>
              <a href="/images/logos/logo-light-bg.webp" download class="fmt-btn">WebP</a>
            </div>
          </div>
        </div>

        <div class="logo-card">
          <div class="logo-card-preview bg-dark">
            <img src="/images/logos/logo-dark-bg.png" alt="Sunshine on a Ranney Day logo for dark backgrounds" class="logo-img" loading="lazy" />
          </div>
          <div class="logo-card-body">
            <h3>White Logo</h3>
            <p>Logo for dark backgrounds</p>
            <div class="logo-formats">
              <a href="/images/logos/logo-dark-bg.png" download class="fmt-btn">PNG</a>
              <a href="/images/logos/logo-dark-bg.webp" download class="fmt-btn">WebP</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ ICONS ══════ -->
  <section id="icons" class="brand-section">
    <div class="container">
      <div class="bsec-header">
        <h2>Icons</h2>
        <p>Square icons, badges, and mascot marks for web, mobile, social, and print use.</p>
      </div>

      <div class="icon-grid">
        <div class="icon-card">
          <div class="icon-preview bg-dark">
            <img src="/images/logos/logo-circle.png" alt="Sunshine on a Ranney Day circle badge" class="icon-img" loading="lazy" />
          </div>
          <div class="icon-body">
            <h3>Circle Badge</h3>
            <p>Social profiles, stickers</p>
            <div class="logo-formats">
              <a href="/images/logos/logo-circle.png" download class="fmt-btn">PNG</a>
            </div>
          </div>
        </div>

        <div class="icon-card">
          <div class="icon-preview bg-dark">
            <img src="/images/logos/sunny.png" alt="Sunny the Dream Pig mascot" class="icon-img" loading="lazy" />
          </div>
          <div class="icon-body">
            <h3>Sunny the Dream Pig</h3>
            <p>Mascot mark</p>
            <div class="logo-formats">
              <a href="/images/logos/sunny.png" download class="fmt-btn">PNG</a>
            </div>
          </div>
        </div>

        <div class="icon-card">
          <div class="icon-preview bg-dark">
            <img src="/images/logos/sunny-circle.png" alt="Sunny the Dream Pig circle badge" class="icon-img" loading="lazy" />
          </div>
          <div class="icon-body">
            <h3>Sunny Circle Badge</h3>
            <p>Compact mascot badge</p>
            <div class="logo-formats">
              <a href="/images/logos/sunny-circle.png" download class="fmt-btn">PNG</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ LOGO USAGE ══════ -->
  <section id="logo-usage" class="brand-section">
    <div class="container">
      <div class="bsec-header">
        <h2>Logo Usage</h2>
        <p>Guidelines for proper logo implementation and presentation.</p>
      </div>

      <div class="usage-grid">
        <div class="usage-card">
          <div class="usage-label">Light Background</div>
          <div class="usage-preview bg-light">
            <img src="/images/logos/logo-light-bg.png" alt="Logo on light background" class="logo-img" loading="lazy" />
          </div>
          <div class="usage-body">
            <p>Use the primary logo on light backgrounds. Ensure adequate contrast and clear space.</p>
          </div>
        </div>
        <div class="usage-card">
          <div class="usage-label">Dark Background</div>
          <div class="usage-preview bg-dark">
            <img src="/images/logos/logo-dark-bg.png" alt="Logo on dark background" class="logo-img" loading="lazy" />
          </div>
          <div class="usage-body">
            <p>Use white or inverted version on dark backgrounds. Maintain strong contrast.</p>
          </div>
        </div>
      </div>

      <h3 class="sub-heading">Logo Guidelines</h3>
      <div class="dodont-grid">
        <div class="dodont-card">
          <h4><span style="color:#16a34a">●</span> Do</h4>
          <ul>
            <li><span class="chk">✓</span> Maintain clear space around logo</li>
            <li><span class="chk">✓</span> Scale proportionally</li>
            <li><span class="chk">✓</span> Ensure sufficient contrast</li>
            <li><span class="chk">✓</span> Min. 1.25" print, 75px digital</li>
          </ul>
        </div>
        <div class="dodont-card">
          <h4><span style="color:#dc2626">●</span> Don't</h4>
          <ul>
            <li><span class="x">✗</span> Distort or rotate the logo</li>
            <li><span class="x">✗</span> Change logo colors</li>
            <li><span class="x">✗</span> Add effects or shadows</li>
            <li><span class="x">✗</span> Modify or recreate</li>
          </ul>
        </div>
      </div>

      <h3 class="sub-heading">Visual Examples</h3>
      <div class="vis-examples">
        <div class="vis-ex">
          <div class="vis-label ve-ok">Correct</div>
          <div class="vis-preview bg-light"><img src="/images/logos/logo-light-bg.png" alt="Correct logo usage" class="vis-logo" loading="lazy" /></div>
          <div class="vis-body"><p>Proper proportions and clear space</p></div>
        </div>
        <div class="vis-ex">
          <div class="vis-label ve-bad">Incorrect</div>
          <div class="vis-preview bg-light"><img src="/images/logos/logo-light-bg.png" alt="Incorrect — stretched logo" class="vis-logo" style="transform:scaleX(1.4);" loading="lazy" /></div>
          <div class="vis-body"><p>Don't stretch or distort</p></div>
        </div>
        <div class="vis-ex">
          <div class="vis-label ve-ok">Correct</div>
          <div class="vis-preview bg-dark"><img src="/images/logos/logo-dark-bg.png" alt="Correct contrast" class="vis-logo" loading="lazy" /></div>
          <div class="vis-body"><p>Good contrast with background</p></div>
        </div>
        <div class="vis-ex">
          <div class="vis-label ve-bad">Incorrect</div>
          <div class="vis-preview" style="background:#e8e0c0;"><img src="/images/logos/logo-light-bg.png" alt="Incorrect — low contrast" class="vis-logo" style="opacity:0.3;" loading="lazy" /></div>
          <div class="vis-body"><p>Don't use on low-contrast backgrounds</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ COLORS ══════ -->
  <section id="colors" class="brand-section">
    <div class="container">
      <div class="bsec-header">
        <h2>Color Palette</h2>
        <p>Our color system ensures visual consistency and brand recognition.</p>
      </div>

      <div class="color-grid">
        <div class="color-card" data-hex="#FFDA24">
          <div class="color-swatch" style="background:#FFDA24;"></div>
          <div class="color-body">
            <h4>Sunshine Yellow</h4>
            <p class="color-usage">CTAs, brand accents, logo, highlights</p>
            <div class="color-vals">
              <span class="pms">PMS 116 C</span>
              <span class="hex">#FFDA24</span>
              <span>RGB 254, 217, 37</span>
              <span>CMYK 0, 6, 87, 0</span>
              <span class="css-var">--c-yellow</span>
            </div>
          </div>
        </div>

        <div class="color-card" data-hex="#373A36">
          <div class="color-swatch" style="background:#373A36;"></div>
          <div class="color-body">
            <h4>SOARD Dark</h4>
            <p class="color-usage">Primary text, headings, dark sections</p>
            <div class="color-vals">
              <span class="pms">PMS 447 C</span>
              <span class="hex">#373A36</span>
              <span>RGB 55, 58, 54</span>
              <span>CMYK 50, 30, 40, 90</span>
              <span class="css-var">--c-dark</span>
            </div>
          </div>
        </div>

        <div class="color-card" data-hex="#FFFFFF">
          <div class="color-swatch" style="background:#FFFFFF;border-bottom:1px solid #E5E7EB;"></div>
          <div class="color-body">
            <h4>White</h4>
            <p class="color-usage">Cards, overlays, text on dark</p>
            <div class="color-vals">
              <span class="hex">#FFFFFF</span>
              <span>RGB 255, 255, 255</span>
              <span>CMYK 0, 0, 0, 0</span>
              <span class="css-var">--c-white</span>
            </div>
          </div>
        </div>


        <div class="color-card" data-hex="#1A1B1F">
          <div class="color-swatch" style="background:#1A1B1F;"></div>
          <div class="color-body">
            <h4>Dark Deep</h4>
            <p class="color-usage">Footer background, dark sections</p>
            <div class="color-vals">
              <span class="hex">#1A1B1F</span>
              <span>RGB 26, 27, 31</span>
              <span class="css-var">--c-dark-deep</span>
            </div>
          </div>
        </div>

        <div class="color-card" data-hex="#FEFCF5">
          <div class="color-swatch" style="background:#FEFCF5;border-bottom:1px solid #E5E7EB;"></div>
          <div class="color-body">
            <h4>Cream</h4>
            <p class="color-usage">Page backgrounds</p>
            <div class="color-vals">
              <span class="hex">#FEFCF5</span>
              <span>RGB 254, 252, 245</span>
              <span class="css-var">--c-cream</span>
            </div>
          </div>
        </div>

        <div class="color-card" data-hex="#F5F4F0">
          <div class="color-swatch" style="background:#F5F4F0;border-bottom:1px solid #E5E7EB;"></div>
          <div class="color-body">
            <h4>Warm Gray</h4>
            <p class="color-usage">Section backgrounds, alternating rows</p>
            <div class="color-vals">
              <span class="hex">#F5F4F0</span>
              <span>RGB 245, 244, 240</span>
              <span class="css-var">--c-warm-gray</span>
            </div>
          </div>
        </div>
      </div>

      <div class="color-note">
        <p>💡 Use Sunshine Yellow (#FFDA24) sparingly for CTAs and highlights. SOARD Dark and neutrals form the foundation. <strong>Important:</strong> The three core brand colors — Sunshine Yellow (PMS 116 C), SOARD Dark (PMS 447 C), and White — are required for all print materials. Dark Deep, Cream, and Warm Gray are the extended digital palette. Ensure WCAG AA contrast minimum for accessibility. Click any color to copy its HEX code.</p>
      </div>
    </div>
  </section>

  <!-- ══════ TYPOGRAPHY ══════ -->
  <section id="typography" class="brand-section">
    <div class="container">
      <div class="bsec-header">
        <h2>Typography</h2>
        <p>We use Libre Baskerville for display and Outfit for body text, providing an editorial feel with modern readability.</p>
      </div>

      <div class="type-block">
        <div class="type-block-header">
          <h3>Libre Baskerville</h3>
          <span>Display / Headlines</span>
        </div>
        <div class="type-rows">
          <div class="type-row">
            <span class="wt-name">Regular (400)</span>
            <span class="wt-sample" style="font-family:var(--font-display);font-weight:400;">Dreams built here since 2012</span>
          </div>
          <div class="type-row">
            <span class="wt-name">Italic (400)</span>
            <span class="wt-sample" style="font-family:var(--font-display);font-style:italic;">Dreams built here since 2012</span>
          </div>
          <div class="type-row">
            <span class="wt-name">Bold (700)</span>
            <span class="wt-sample" style="font-family:var(--font-display);font-weight:700;">Dreams built here since 2012</span>
          </div>
        </div>
      </div>

      <div class="type-block">
        <div class="type-block-header">
          <h3>Outfit</h3>
          <span>Body / UI</span>
        </div>
        <div class="type-rows">
          <div class="type-row">
            <span class="wt-name">Light (300)</span>
            <span class="wt-sample" style="font-family:var(--font-body);font-weight:300;">The quick brown fox jumps over the lazy dog</span>
          </div>
          <div class="type-row">
            <span class="wt-name">Regular (400)</span>
            <span class="wt-sample" style="font-family:var(--font-body);font-weight:400;">The quick brown fox jumps over the lazy dog</span>
          </div>
          <div class="type-row">
            <span class="wt-name">Medium (500)</span>
            <span class="wt-sample" style="font-family:var(--font-body);font-weight:500;">The quick brown fox jumps over the lazy dog</span>
          </div>
          <div class="type-row">
            <span class="wt-name">Semibold (600)</span>
            <span class="wt-sample" style="font-family:var(--font-body);font-weight:600;">The quick brown fox jumps over the lazy dog</span>
          </div>
          <div class="type-row">
            <span class="wt-name">Bold (700)</span>
            <span class="wt-sample" style="font-family:var(--font-body);font-weight:700;">The quick brown fox jumps over the lazy dog</span>
          </div>
        </div>
      </div>

      <div class="type-usage-grid">
        <div class="type-usage-card">
          <h4>Font Weight Usage</h4>
          <ul>
            <li><span class="bullet">●</span> Light (300) for hero text, large displays</li>
            <li><span class="bullet">●</span> Regular (400) for body copy</li>
            <li><span class="bullet">●</span> Semibold (600) for emphasis, buttons</li>
            <li><span class="bullet">●</span> Bold (700) for headings, CTAs</li>
          </ul>
        </div>
        <div class="type-usage-card">
          <h4>Spacing &amp; Hierarchy</h4>
          <ul>
            <li><span class="bullet">●</span> Very tight leading (1.05–1.2) for headings</li>
            <li><span class="bullet">●</span> Relaxed leading (1.625) for body text</li>
            <li><span class="bullet">●</span> Tight tracking for headlines</li>
            <li><span class="bullet">●</span> Wide tracking (0.05em) for uppercase labels</li>
          </ul>
        </div>
      </div>

      <h3 class="sub-heading" style="margin-top:48px;">Legacy Print Typefaces (Retired)</h3>
      <p class="sub-desc">From the original 2019 brand guidelines. These are no longer in active use but may appear in older print materials.</p>
      <div class="legacy-grid">
        <div class="legacy-chip"><p class="lg-name">Rainer North 100</p><p class="lg-role">Previously: logo / display</p></div>
        <div class="legacy-chip"><p class="lg-name">Brandon Grotesque</p><p class="lg-role">Previously: headlines</p></div>
        <div class="legacy-chip"><p class="lg-name">DIN Neuzeit Grotesk</p><p class="lg-role">Previously: body copy</p></div>
        <div class="legacy-chip"><p class="lg-name">Montserrat</p><p class="lg-role">Previously: general use</p></div>
      </div>
    </div>
  </section>

  <!-- ══════ VOICE & TONE ══════ -->
  <section id="voice" class="brand-section" style="border-bottom:none;">
    <div class="container">
      <div class="bsec-header">
        <h2>Voice &amp; Tone</h2>
        <p>Our brand voice reflects who we are and how we communicate.</p>
      </div>

      <div class="voice-grid">
        <div class="voice-card">
          <h3>We are</h3>
          <div class="voice-items">
            <div class="voice-item"><h5>Warm &amp; Genuine</h5><p>Approachable and heartfelt in every interaction</p></div>
            <div class="voice-item"><h5>Hopeful &amp; Empowering</h5><p>Focused on possibility, never pity</p></div>
            <div class="voice-item"><h5>Professional</h5><p>Yet approachable and human</p></div>
            <div class="voice-item"><h5>Joyful</h5><p>Building dream rooms is what we do — let the energy show</p></div>
          </div>
        </div>
        <div class="voice-card">
          <h3>We are not</h3>
          <div class="voice-items">
            <div class="voice-item"><h5>Pitying</h5><p>Never reduce children to their diagnosis</p></div>
            <div class="voice-item"><h5>Clinical</h5><p>Not stiff or corporate — always personal</p></div>
            <div class="voice-item"><h5>Guilt-Driven</h5><p>Inspire through joy, never through pressure</p></div>
            <div class="voice-item"><h5>Sloppy</h5><p>Playful doesn't mean careless</p></div>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ── */
  .page-hero {
    background: var(--c-dark);
    color: var(--c-white);
    padding-block: var(--space-3xl) var(--space-2xl);
    text-align: center;
  }
  .hero-label {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--c-yellow);
    margin-bottom: var(--space-sm);
  }
  .page-hero h1 {
    color: var(--c-white);
    font-size: clamp(2rem, 5vw, 3.25rem);
  }
  .page-hero-sub {
    margin-top: var(--space-md);
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(255, 255, 255, 0.65);
    max-width: 640px;
    margin-inline: auto;
  }

  /* ── TOC ── */
  .brand-toc {
    padding: 28px 0;
    border-bottom: 1px solid rgba(45,46,51,0.08);
    background: var(--c-white);
  }
  .toc-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--c-text-muted);
    margin-bottom: 14px;
  }
  .toc-links { display: flex; flex-wrap: wrap; gap: 10px; }
  .toc-links a {
    font-size: 14px;
    font-weight: 500;
    color: var(--c-dark);
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid rgba(45,46,51,0.1);
    transition: all 0.15s ease;
  }
  .toc-links a:hover {
    background: var(--c-yellow);
    border-color: var(--c-yellow);
  }

  /* ── Sections ── */
  .brand-section {
    padding-block: var(--space-4xl);
    border-bottom: 1px solid rgba(45,46,51,0.08);
  }
  .bsec-header { margin-bottom: 40px; }
  .bsec-header h2 {
    font-size: clamp(28px, 3vw, 36px);
    margin-bottom: 10px;
  }
  .bsec-header p {
    font-size: 16px;
    max-width: 600px;
  }
  .sub-heading {
    font-size: clamp(18px, 2vw, 22px);
    margin-bottom: 24px;
  }
  .sub-desc {
    font-size: 14px;
    margin-bottom: 20px;
    max-width: 560px;
  }

  /* ── Logo Cards ── */
  .logo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .logo-card {
    border: 1px solid rgba(45,46,51,0.08);
    border-radius: 16px;
    overflow: hidden;
    background: var(--c-white);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .logo-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
  }
  .logo-card-preview {
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px;
  }
  .bg-dark { background: var(--c-dark-deep); }
  .bg-light { background: var(--c-warm-gray); }
  .bg-yellow { background: var(--c-yellow); }
  .logo-card-body {
    padding: 20px 24px;
    border-top: 1px solid rgba(45,46,51,0.08);
  }
  .logo-card-body h3 {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 4px;
  }
  .logo-card-body p { font-size: 14px; margin-bottom: 16px; }
  .logo-formats { display: flex; gap: 8px; }
  .fmt-btn {
    font-size: 13px;
    font-weight: 600;
    color: var(--c-dark);
    background: var(--c-warm-gray);
    border: 1px solid rgba(45,46,51,0.1);
    padding: 6px 14px;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.15s;
    text-decoration: none;
  }
  .fmt-btn:hover {
    background: var(--c-yellow);
    border-color: var(--c-yellow);
  }

  /* ── Logo Images ── */
  .logo-img {
    max-width: 100%;
    max-height: 160px;
    object-fit: contain;
  }
  .vis-logo {
    max-width: 80%;
    max-height: 50px;
    object-fit: contain;
  }

  /* ── Download All ── */
  .download-all-btn {
    display: inline-block;
    font-size: 14px;
    font-weight: 600;
    color: var(--c-dark);
    background: var(--c-warm-gray);
    border: 1px solid rgba(45,46,51,0.1);
    padding: 10px 20px;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.15s;
    margin-bottom: 28px;
  }
  .download-all-btn:hover {
    background: var(--c-yellow);
    border-color: var(--c-yellow);
  }

  /* ── Icon Grid ── */
  .icon-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .icon-card {
    border: 1px solid rgba(45,46,51,0.08);
    border-radius: 16px;
    overflow: hidden;
    background: var(--c-white);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .icon-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
  }
  .icon-preview {
    height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .icon-img {
    max-width: 100%;
