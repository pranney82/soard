---
/**
 * Sunny & Ranney — Store Landing Page
 * Editorial, cinematic landing for the nonprofit home furnishings
 * store. Split hero with overlapping photos, scrolling marquee,
 * dramatic dark sections, testimonial, interactive hover cards.
 *
 * Matches the homepage's level of craft: staggered entrance
 * animations, parallax, polished responsive breakpoints.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { CF_BASE as CF } from '../utils/cf-image';
import { getSiteStats } from '../utils/stats';

const computed = await getSiteStats();

/* ── Image IDs ── */
const storeId = 'about/sunny-ranney-storefront';
const logoId = 'partners/sunny-and-ranney';

/* Show what purchases fund — kid room photos */
const roomRevealId = 'kids/griffin/hero';
const roomRevealId2 = 'kids/jackson/hero';

/* ── Hero images (preloaded) ── */
const heroImg600 = `${CF}/${storeId}/w=600,h=750,fit=cover,q=70`;
const heroImg900 = `${CF}/${storeId}/w=900,h=1125,fit=cover,q=70`;
const heroSrcset = `${heroImg600} 600w, ${heroImg900} 900w`;
const heroSizes = '(max-width:768px) 85vw, 420px';

/* ── Schema ── */
const pageUrl = 'https://sunshineonaranneyday.com/sunny-and-ranney/';
const pageDesc = 'Sunny & Ranney is a nonprofit home furnishings store in Roswell, GA. Designer furniture, décor & gifts — with 100% of profits funding dream room makeovers for children with special needs.';
const breadcrumbs = [
  { name: 'Home', url: 'https://sunshineonaranneyday.com/' },
  { name: 'Sunny & Ranney', url: pageUrl },
];
---

<BaseLayout
  title="Sunny & Ranney — Shop for a Cause"
  description={pageDesc}
  breadcrumbs={breadcrumbs}
>
  <link slot="head" rel="preload" as="image" imagesrcset={heroSrcset} imagesizes={heroSizes} fetchpriority="high" />

  <!-- ══════ HERO — Editorial Split ══════ -->
  <section class="sr-hero" aria-label="Sunny & Ranney store">
    <div class="sr-hero-inner">
      <div class="sr-hero-text">
        <p class="sr-eyebrow">Nonprofit Home Furnishings · Roswell, GA</p>
        <h1 class="sr-headline">Sunny <span class="sr-amp">&</span><br>Ranney</h1>
        <p class="sr-lead">Designer furniture, décor & gifts — with <strong>100% of profits</strong> building dream rooms for children with special needs.</p>
        <div class="sr-hero-ctas">
          <a href="/shop/" class="btn btn-primary sr-glow">Shop Now</a>
          <a href="#visit" class="btn btn-dark">Visit Our Store</a>
        </div>
      </div>
      <div class="sr-hero-photos">
        <div class="sr-photo-main">
          <img
            src={heroImg900}
            srcset={heroSrcset}
            sizes={heroSizes}
            alt="Inside the Sunny & Ranney store — beautifully styled furniture showroom"
            width="900" height="1125"
            loading="eager" fetchpriority="high" decoding="sync"
          />
        </div>
        <div class="sr-photo-float sr-photo-float--top">
          <img
            src={`${CF}/${roomRevealId}/w=320,h=240,fit=cover,q=65`}
            alt="A dream bedroom built with store profits"
            width="320" height="240"
            loading="eager" decoding="async"
          />
          <span class="sr-float-tag">What your purchase builds</span>
        </div>
        <div class="sr-photo-float sr-photo-float--bottom">
          <img
            src={`${CF}/${roomRevealId2}/w=280,h=210,fit=cover,q=65`}
            alt="A child's therapy room funded by Sunny & Ranney"
            width="280" height="210"
            loading="eager" decoding="async"
          />
        </div>
        <div class="sr-photo-accent" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <!-- ══════ MARQUEE — 100% of Profits ══════ -->
  <section class="sr-marquee" aria-label="100% of profits build dream rooms">
    <div class="sr-marquee-track" aria-hidden="true">
      {[...Array(8)].map(() => (
        <span class="sr-marquee-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--c-yellow)" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          100% of Profits Build Dream Rooms
        </span>
      ))}
    </div>
  </section>

  <!-- ══════ THE PROMISE — Three Pillars ══════ -->
  <section class="sr-pillars-section" aria-labelledby="sr-pillars-heading">
    <div class="sr-pillars-inner">
      <div class="sr-pillars-header" data-reveal>
        <div class="section-label" style="color:var(--c-yellow)">The Promise</div>
        <h2 id="sr-pillars-heading">Not just a store.<br>A <em class="highlight">movement</em>.</h2>
      </div>
      <div class="sr-pillars">
        <div class="sr-pillar" data-reveal>
          <span class="sr-pillar-num" aria-hidden="true">01</span>
          <h3>Every Dollar Matters</h3>
          <p>100% of store profits fund custom room makeovers for children with special needs. No admin fees. No overhead. Every purchase is a direct investment in a child's future.</p>
        </div>
        <div class="sr-pillar" data-reveal data-delay="1">
          <span class="sr-pillar-num" aria-hidden="true">02</span>
          <h3>Designer Quality</h3>
          <p>All brand-new, hand-selected by our design team. Statement sofas, artisan accents, curated gifts — pieces you'll love in your home, knowing the story behind them.</p>
        </div>
        <div class="sr-pillar" data-reveal data-delay="2">
          <span class="sr-pillar-num" aria-hidden="true">03</span>
          <h3>Community Hub</h3>
          <p>More than retail — a gathering place. Visit our Roswell showroom, meet the team, hear the stories. Shopping here connects you to something bigger.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ IMPACT — Dark Dramatic Section ══════ -->
  <section class="sr-impact" aria-labelledby="sr-impact-heading">
    <div class="sr-impact-inner">
      <div class="sr-impact-text" data-reveal>
        <div class="section-label" style="color:var(--c-yellow); justify-content:center;">The Impact</div>
        <h2 id="sr-impact-heading">Your home gets a new piece.<br>A child gets a new <em>world</em>.</h2>
        <p>Since opening in 2020, Sunny & Ranney has helped fund {computed.totalRooms}+ room makeovers — replacing a $470K annual gala with a year-round source of community-powered funding.</p>
      </div>
      <div class="sr-impact-stats">
        <div class="sr-stat" data-reveal>
          <span class="sr-stat-num">100<span class="sr-stat-pct">%</span></span>
          <span class="sr-stat-label">Of Profits to Kids</span>
        </div>
        <div class="sr-stat-divider" role="presentation"></div>
        <div class="sr-stat" data-reveal data-delay="1">
          <span class="sr-stat-num">{computed.totalRooms}+</span>
          <span class="sr-stat-label">Rooms Built</span>
        </div>
        <div class="sr-stat-divider" role="presentation"></div>
        <div class="sr-stat" data-reveal data-delay="2">
          <span class="sr-stat-num">{computed.totalKids}+</span>
          <span class="sr-stat-label">Kids Served</span>
        </div>
        <div class="sr-stat-divider" role="presentation"></div>
        <div class="sr-stat" data-reveal data-delay="3">
          <span class="sr-stat-num">{computed.years}</span>
          <span class="sr-stat-label">Years of Impact</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ ORIGIN STORY ══════ -->
  <section class="sr-origin" aria-labelledby="sr-origin-heading">
    <div class="sr-origin-split">
      <figure class="sr-origin-photo">
        <img
          src={`${CF}/${storeId}/w=900,q=70`}
          srcset={`${CF}/${storeId}/w=600,q=65 600w, ${CF}/${storeId}/w=900,q=70 900w`}
          sizes="(max-width:768px) 100vw, 55vw"
          alt="The Sunny & Ranney storefront in Roswell, Georgia"
          width="900" height="600"
          loading="lazy" decoding="async"
          class="sr-origin-img"
        />
        <div class="sr-origin-tag">Est. 2020 · Roswell, GA</div>
      </figure>
      <div class="sr-origin-content" data-reveal>
        <div class="section-label">Our Story</div>
        <span class="sr-origin-type">How It All Started</span>
        <h2 id="sr-origin-heading">A bold step to sustain the <em>mission</em>.</h2>
        <p>For years, Sunshine on a Ranney Day relied on a single annual gala to fund its room makeovers. Then came the idea: what if we built something that gave back <em>every single day</em>?</p>
        <p>In 2020, we opened Sunny & Ranney — a nonprofit home furnishings store where 100% of profits go directly to building dream bedrooms, accessible bathrooms, and therapy spaces for children with special needs.</p>
        <p>What began as an experiment has become the <strong>heartbeat of the mission</strong> — a place where the community can shop beautiful things and know that every purchase matters.</p>
        <a href="/about/" class="btn btn-dark">Read Our Full Story →</a>
      </div>
    </div>
  </section>

  <!-- ══════ TESTIMONIAL ══════ -->
  <section class="sr-testimonial" aria-label="Customer review">
    <div class="sr-testimonial-inner" data-reveal>
      <div class="sr-stars" aria-label="5 out of 5 stars">
        {[...Array(5)].map(() => (
          <svg width="24" height="24" viewBox="0 0 24 24" fill="var(--c-yellow)"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        ))}
      </div>
      <blockquote class="sr-quote">
        "I walked in expecting a charity shop. I walked out with the most beautiful console table I've ever owned — and the best feeling about a purchase I've ever had."
      </blockquote>
      <cite class="sr-cite">— Verified Customer, Google Reviews</cite>
    </div>
  </section>

  <!-- ══════ PRODUCT CATEGORIES ══════ -->
  <section class="sr-shop" aria-labelledby="sr-shop-heading">
    <div class="sr-shop-inner">
      <div class="sr-shop-header" data-reveal>
        <div class="section-label">What We Carry</div>
        <h2 id="sr-shop-heading">Beautifully curated. <em class="highlight">Purposefully</em> priced.</h2>
        <p class="sr-shop-sub">From statement sofas to handpicked accents — every piece brand-new, selected by our design team.</p>
      </div>
      <div class="sr-shop-grid">
        <a href="/shop/" class="sr-shop-tile" data-reveal>
          <div class="sr-tile-bg" aria-hidden="true">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5"><path d="M4 16v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/><path d="M2 10h20l-1.5-4.5A2 2 0 0 0 18.6 4H5.4a2 2 0 0 0-1.9 1.5L2 10z"/><path d="M6 10v6"/><path d="M18 10v6"/></svg>
          </div>
          <h3>Furniture</h3>
          <p>Sofas, chairs, tables & more</p>
          <span class="sr-tile-arrow">→</span>
        </a>
        <a href="/shop/" class="sr-shop-tile" data-reveal data-delay="1">
          <div class="sr-tile-bg" aria-hidden="true">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
          </div>
          <h3>Wall Art</h3>
          <p>Prints, canvases & frames</p>
          <span class="sr-tile-arrow">→</span>
        </a>
        <a href="/shop/" class="sr-shop-tile" data-reveal data-delay="2">
          <div class="sr-tile-bg" aria-hidden="true">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/></svg>
          </div>
          <h3>Lighting</h3>
          <p>Lamps, pendants & sconces</p>
          <span class="sr-tile-arrow">→</span>
        </a>
        <a href="/shop/" class="sr-shop-tile" data-reveal data-delay="1">
          <div class="sr-tile-bg" aria-hidden="true">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
          </div>
          <h3>Accents</h3>
          <p>Vases, objects & décor</p>
          <span class="sr-tile-arrow">→</span>
        </a>
        <a href="/shop/" class="sr-shop-tile" data-reveal data-delay="2">
          <div class="sr-tile-bg" aria-hidden="true">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </div>
          <h3>Gifts</h3>
          <p>Candles, books & treasures</p>
          <span class="sr-tile-arrow">→</span>
        </a>
        <a href="/shop/" class="sr-shop-tile" data-reveal data-delay="3">
          <div class="sr-tile-bg" aria-hidden="true">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5"><path d="M3 3h18v18H3z"/><path d="M3 9h18"/><path d="M9 3v18"/></svg>
          </div>
          <h3>Textiles</h3>
          <p>Rugs, throws & pillows</p>
          <span class="sr-tile-arrow">→</span>
        </a>
      </div>
      <div class="sr-shop-cta" data-reveal>
        <a href="/shop/" class="btn btn-primary sr-glow">Browse All Collections →</a>
      </div>
    </div>
  </section>

  <!-- ══════ VISIT US ══════ -->
  <section class="sr-visit" id="visit" aria-labelledby="sr-visit-heading">
    <div class="sr-visit-split">
      <div class="sr-visit-photo" data-reveal>
        <img
          src={`${CF}/${storeId}/w=800,h=600,fit=cover,q=70`}
          srcset={`${CF}/${storeId}/w=500,h=375,fit=cover,q=65 500w, ${CF}/${storeId}/w=800,h=600,fit=cover,q=70 800w`}
          sizes="(max-width:768px) 100vw, 50vw"
          alt="Inside the Sunny & Ranney showroom"
          width="800" height="600"
          loading="lazy" decoding="async"
        />
      </div>
      <div class="sr-visit-content" data-reveal data-delay="1">
        <div class="section-label" style="color:var(--c-yellow)">Visit Us</div>
        <h2 id="sr-visit-heading">Come see what shopping<br>for a cause <em>looks&nbsp;like</em>.</h2>
        <p>Step inside our Roswell showroom and experience the collection in person. Our team loves sharing the stories of the kids your purchase helps.</p>
        <div class="sr-visit-grid">
          <div class="sr-visit-block">
            <h4>Location</h4>
            <p>109A Oak Street<br>Roswell, GA 30075</p>
          </div>
          <div class="sr-visit-block">
            <h4>Hours</h4>
            <p>Tue – Thu: 10am – 5pm<br>Fri – Sat: 10am – 6pm</p>
          </div>
          <div class="sr-visit-block">
            <h4>Contact</h4>
            <p><a href="tel:7709902434">770.990.2434</a><br><a href="mailto:info@soardcharity.com">info@soardcharity.com</a></p>
          </div>
        </div>
        <a href="https://maps.google.com/?q=109A+Oak+Street+Roswell+GA+30075" target="_blank" rel="noopener noreferrer" class="btn btn-dark">Get Directions →</a>
      </div>
    </div>
  </section>

  <!-- ══════ FINALE — Yellow CTA ══════ -->
  <section class="sr-finale" aria-labelledby="sr-finale-heading">
    <div class="sr-finale-inner">
      <img src={`${CF}/sunny-pig/w=80,h=80,fit=contain`} alt="" class="sr-finale-pig" width="80" height="80" aria-hidden="true" loading="lazy" decoding="async" />
      <h2 id="sr-finale-heading" data-reveal>Every beautiful piece builds<br>a beautiful <em>future</em>.</h2>
      <p data-reveal data-delay="1">Shop online or visit us in Roswell. Either way, you're changing a child's world.</p>
      <div class="sr-finale-ctas" data-reveal data-delay="2">
        <a href="/shop/" class="btn btn-dark btn-lg">Shop Online</a>
        <a href="/donate/" class="btn sr-btn-outline">Make a Donation</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ═══════════════════════════════════════════
     Sunny & Ranney — Premium Store Landing
     ═══════════════════════════════════════════ */

  /* ── HERO — Editorial Split with Layered Photos ── */
  .sr-hero {
    position: relative;
    background: var(--c-cream);
    contain: layout style;
    padding: clamp(40px, 8vh, 100px) 0 0;
    overflow: hidden;
  }

  .sr-hero-inner {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: 0 var(--page-padding);
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(32px, 5vw, 80px);
    align-items: center;
    min-height: clamp(480px, 70vh, 720px);
  }

  .sr-eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-text-light);
    margin-bottom: 28px;
    opacity: 0;
    animation: srUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.05s both;
  }

  .sr-headline {
    font-size: clamp(48px, 7vw, 96px);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--c-dark);
    margin-bottom: 28px;
    animation: srSlideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .sr-amp {
    font-style: italic;
    color: var(--c-yellow-hover);
    font-size: 0.85em;
  }

  .sr-lead {
    font-size: clamp(16px, 1.3vw, 19px);
    line-height: 1.7;
    color: var(--c-text-muted);
    max-width: 460px;
    margin-bottom: 36px;
    opacity: 0;
    animation: srUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
  }

  .sr-lead strong {
    color: var(--c-dark);
    font-weight: 700;
  }

  .sr-hero-ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    opacity: 0;
    animation: srUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.25s both;
  }

  .sr-glow {
    animation: srPulseGlow 3s ease-in-out 3s infinite;
  }
  @keyframes srPulseGlow {
    0%, 100% { box-shadow: 0 8px 24px rgba(255, 218, 36, 0.3); }
    50% { box-shadow: 0 8px 40px rgba(255, 218, 36, 0.55); }
  }

  /* ── Hero photo collage ── */
  .sr-hero-photos {
    position: relative;
    animation: srPhotoIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .sr-photo-main {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.12), 0 8px 24px rgba(0, 0, 0, 0.06);
    z-index: 2;
  }
  .sr-photo-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: translate3d(0, var(--parallax-y, 0px), 0);
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Floating accent photos */
  .sr-photo-float {
    position: absolute;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.15);
    z-index: 3;
    border: 4px solid var(--c-cream);
  }
  .sr-photo-float img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sr-photo-float--top {
    width: 45%;
    top: -8%;
    left: -15%;
    opacity: 0;
    animation: srFloatIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both;
  }

  .sr-float-tag {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 8px 14px;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-yellow);
  }

  .sr-photo-float--bottom {
    width: 40%;
    bottom: 8%;
    right: -12%;
    opacity: 0;
    animation: srFloatIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.7s both;
  }

  .sr-photo-accent {
    position: absolute;
    bottom: -16px;
    right: -16px;
    width: 50%;
    height: 40%;
    border-radius: 20px;
    background: var(--c-yellow);
    z-index: 1;
    opacity: 0;
    animation: srAccentIn 1s cubic-bezier(0.16, 1, 0.3, 1) 0.7s both;
  }

  /* Animations */
  @keyframes srUp {
    from { opacity: 0; transform: translateY(28px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes srSlideUp {
    from { transform: translateY(16px); }
    to { transform: translateY(0); }
  }
  @keyframes srPhotoIn {
    from { transform: translateY(12px) scale(0.98); }
    to { transform: translateY(0) scale(1); }
  }
  @keyframes srAccentIn {
    from { opacity: 0; transform: translate(12px, 12px); }
    to { opacity: 1; transform: translate(0, 0); }
  }
  @keyframes srFloatIn {
    from { opacity: 0; transform: translateY(20px) scale(0.92); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* ── MARQUEE ── */
  .sr-marquee {
    background: var(--c-dark-deep);
    padding: 16px 0;
    overflow: hidden;
    contain: layout style;
  }

  .sr-marquee-track {
    display: flex;
    gap: 12px;
    animation: marquee 30s linear infinite;
    width: max-content;
  }

  .sr-marquee-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    white-space: nowrap;
    padding: 0 16px;
