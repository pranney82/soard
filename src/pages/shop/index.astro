---
/**
 * Shop Page — SSG Build-Time Rendering
 *
 * PERFORMANCE ARCHITECTURE:
 *   1. Collections + products fetched at BUILD TIME from Shopify Storefront API
 *   2. Collection grid renders as static HTML — instant paint, zero JS needed
 *   3. Product grids for each collection pre-rendered as hidden HTML
 *   4. Product detail data embedded as JSON for instant modal (no runtime fetch)
 *   5. JS only handles: hash navigation, modal interactions, variant selection
 *   6. Shopify webhook triggers rebuild on product/collection changes
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isShopifyConfigured, fetchAllCollections, formatPrice } from '../../lib/shopify';
import siteSettings from '../../content/site/settings.json';

let collections: any[] = [];
let productMap: Record<string, any> = {};
let buildError = false;

if (isShopifyConfigured()) {
  try {
    let allCollections = await fetchAllCollections();

    // Filter to admin-selected collections (if any selected)
    const selected: string[] = (siteSettings as any)?.shopCollections || [];
    if (selected.length > 0) {
      allCollections = allCollections.filter((c: any) => selected.includes(c.handle));
    }

    collections = allCollections;
    for (const c of collections) {
      for (const edge of c.products.edges) {
        productMap[edge.node.handle] = edge.node;
      }
    }
  } catch (err) {
    console.error('[shop] Build-time Shopify fetch failed:', err);
    buildError = true;
  }
}

const hasProducts = collections.length > 0;

function titleCase(str: string): string {
  return (str || '').toLowerCase().replace(/(?:^|\s)\S/g, (a) => a.toUpperCase());
}
function getCollectionImage(c: any): any {
  if (c.image) return c.image;
  if (c.products.edges.length > 0) {
    const fp = c.products.edges[0].node;
    return fp.featuredImage || fp.images?.edges?.[0]?.node || null;
  }
  return null;
}
function hasSale(p: any): boolean {
  const compare = p.compareAtPriceRange?.minVariantPrice;
  const price = p.priceRange.minVariantPrice;
  return !!(compare && parseFloat(compare.amount) > parseFloat(price.amount));
}
---

<BaseLayout
  title="Shop"
  description="Shop apparel and merchandise from Sunshine on a Ranney Day. Every purchase supports life-changing room makeovers for children with special needs."
>
  <section class="shop-hero">
    <div class="shop-hero-inner">
      <div class="section-label" style="color:var(--c-yellow)">Shop & Support</div>
      <h1>Every purchase builds <em>dreams</em></h1>
      <p class="shop-hero-lead">100% of proceeds go directly to creating life-changing spaces for children with special needs.</p>
    </div>
  </section>

  <section class="shop-grid-section" aria-label="Products">
    <div class="shop-grid-inner">
      <button type="button" class="shop-back" id="shop-back" style="display:none;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        All Collections
      </button>
      <h2 class="shop-collection-title" id="shop-collection-title" style="display:none;"></h2>

      {hasProducts ? (
        <>
          <div class="shop-grid shop-grid--collections" id="shop-collections">
            {collections.map((c) => {
              const img = getCollectionImage(c);
              const count = c.products.edges.length;
              const displayTitle = titleCase(c.title);
              return (
                <div class="collection-card" data-collection={c.handle} role="button" tabindex="0" aria-label={`Browse ${displayTitle}`}>
                  <div class="collection-card-photo">
                    {img ? (
                      <img src={`${img.url}${img.url.includes('?') ? '&' : '?'}width=800`} alt={img.altText || displayTitle} width="800" height="600" loading="lazy" decoding="async" />
                    ) : (
                      <div class="placeholder-icon"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg></div>
                    )}
                  </div>
                  <div class="collection-card-info">
                    <div class="collection-card-title">{displayTitle}</div>
                    <div class="collection-card-count">{count} item{count !== 1 ? 's' : ''}</div>
                  </div>
                </div>
              );
            })}
          </div>

          {collections.map((c) => (
            <div class="shop-grid shop-products-panel" id={`products-${c.handle}`} data-collection-panel={c.handle} style="display:none;">
              {c.products.edges.map(({ node: p }: any) => {
                const img = p.featuredImage || p.images?.edges?.[0]?.node;
                const price = p.priceRange.minVariantPrice;
                const compare = p.compareAtPriceRange?.minVariantPrice;
                const isSale = hasSale(p);
                const soldOut = !p.availableForSale;
                return (
                  <div class="product-card" data-handle={p.handle} role="button" tabindex="0" aria-label={`View ${p.title}`}>
                    <div class="product-card-photo">
                      {img ? (
                        <img src={`${img.url}&width=600`} alt={img.altText || p.title} width="600" height="600" loading="lazy" decoding="async" />
                      ) : (
                        <div class="placeholder-icon"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg></div>
                      )}
                      {soldOut && <span class="product-card-badge product-card-badge--sold-out">Sold Out</span>}
                      {isSale && !soldOut && <span class="product-card-badge product-card-badge--sale">Sale</span>}
                    </div>
                    <div class="product-card-info">
                      <div class="product-card-title">{p.title}</div>
                      <div class="product-card-price">
                        <span class={`product-card-amount${isSale ? ' product-card-amount--sale' : ''}`}>{formatPrice(price.amount, price.currencyCode)}</span>
                        {isSale && <span class="product-card-compare">{formatPrice(compare.amount, compare.currencyCode)}</span>}
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          ))}
        </>
      ) : (
        <div class="shop-error">
          <p>{buildError ? 'Unable to load products right now. Please try again later.' : 'No products available right now. Check back soon!'}</p>
        </div>
      )}
    </div>
  </section>

  <div class="pdp-backdrop" id="pdp-backdrop" aria-hidden="true"></div>
  <div class="pdp-modal" id="pdp-modal" role="dialog" aria-modal="true" aria-label="Product details" aria-hidden="true">
    <button type="button" class="pdp-modal-close" id="pdp-modal-close" aria-label="Close product details">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div class="pdp-modal-body" id="pdp-modal-body"></div>
  </div>

  <section class="shop-mission">
    <div class="shop-mission-inner" data-reveal>
      <h2>Where your money goes</h2>
      <p>Every dollar from the shop goes directly to building dream bedrooms, accessible bathrooms, and therapy rooms for children with special needs. No middlemen, no overhead — just kids and rooms.</p>
      <a href="/about/financials/" class="btn btn-dark">See Our Financials &rarr;</a>
    </div>
  </section>

  <script is:inline type="application/json" id="shop-product-data" set:html={JSON.stringify(productMap)}></script>
</BaseLayout>

