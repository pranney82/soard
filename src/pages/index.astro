  .finale-ctas { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; margin-bottom: 24px; }
  .finale-note { font-size: 13px; color: rgba(45,46,51,0.72); margin-bottom: 0; }
  .btn-outline-dark { background: transparent; color: var(--c-dark); border: 2px solid var(--c-dark); }
  .btn-outline-dark:hover { background: var(--c-dark); color: var(--c-yellow); transform: translateY(-3px); }
