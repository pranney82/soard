---
/**
 * Ways to Give — Editorial giving experience (Top 1%)
 *
 * DESIGN: Each section uses a unique layout. Photography woven in.
 * Impact ribbon, testimonials, emotional moments between methods.
 * Not a template — a narrative about generosity.
 *
 * PERF NOTES:
 * - 2 lazy-loaded images (editorial break + legacy) — both below fold
 * - All icons inline SVG (no external requests)
 * - contain: layout style on heavy sections
 * - data-reveal scroll animations with staggered entrance
 * - Anchor nav uses IntersectionObserver (~200 bytes)
 * - LQIP blur-up on all images
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import MediaLogos from '../components/ui/MediaLogos.astro';
import siteSettings from '../content/site/settings.json';
import { getSiteStats } from '../utils/stats';
import { cfRaw, cfUrl, cfSrcset, cfLqip } from '../utils/cf-image';

const computed = await getSiteStats();

const SITE_URL = 'https://sunshineonaranneyday.com';
const orgName = siteSettings.name;
const ein = siteSettings.ein;
const address = siteSettings.address;
const email = siteSettings.email;
const phone = siteSettings.phone;

/* ── Photos (from admin settings, with fallbacks) ── */
const wtg = siteSettings.waysToGivePhotos || {};
const heroPhotoId = wtg.hero || 'kids/summer/hero';
const breakPhoto = wtg.breakPhoto || 'kids/summer/hero';
const legacyPhoto = wtg.legacyPhoto || 'kids/oakley/photo-15';

const breadcrumbs = [
  { name: 'Home', url: `${SITE_URL}/` },
  { name: 'Donate', url: `${SITE_URL}/donate/` },
  { name: 'Ways to Give', url: `${SITE_URL}/ways-to-give/` },
];

const jsonLd = {
  "@type": "WebPage",
  "@id": `${SITE_URL}/ways-to-give/#webpage`,
  "name": "Ways to Give — Sunshine on a Ranney Day",
  "description": "Every way you can support SOARD — online donations, stock gifts, donor-advised funds, employer matching, planned giving, and more.",
  "url": `${SITE_URL}/ways-to-give/`,
  "isPartOf": { "@id": `${SITE_URL}/#website` },
  "about": { "@id": `${SITE_URL}/#organization` },
  "inLanguage": "en-US",
  "breadcrumb": { "@id": `${SITE_URL}/ways-to-give/#breadcrumb` }
};
---

<BaseLayout
  title="Ways to Give — Every Way to Support SOARD"
  description="Donate online, give stock, use your donor-advised fund, mail a check, set up employer matching, or include SOARD in your estate plan. Every gift builds dreams."
  jsonLd={jsonLd}
  breadcrumbs={breadcrumbs}
>

  <!-- Preload hero LCP image — srcset/sizes must match the <img> -->
  <link slot="head" rel="preload" as="image" imagesrcset={`${cfRaw(heroPhotoId, 'w=400,h=500,fit=cover,gravity=face,q=65')} 400w, ${cfRaw(heroPhotoId, 'w=560,h=700,fit=cover,gravity=face,q=65')} 560w, ${cfRaw(heroPhotoId, 'w=800,h=1000,fit=cover,gravity=face,q=65')} 800w`} imagesizes="(max-width:768px) 85vw, 420px" fetchpriority="high" />

  <!-- ══════ HERO — Editorial Split ══════ -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <p class="hero-eyebrow">Ways to Give</p>
        <h1 class="hero-headline">There are many ways to build a <em>dream</em>.</h1>
        <p class="hero-lead">Whether you give online, through stock, your employer, or your estate — every gift creates life-changing spaces for children with special needs.</p>
        <div class="hero-ctas">
          <a href="/donate" class="btn btn-primary btn-glow btn-lg">Donate Now →</a>
          <a href="#give-today" class="btn btn-outline-dark btn-lg">Explore Options ↓</a>
        </div>
        <div class="hero-trust">
          <span class="hero-trust-item"><svg class="hero-trust-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>501(c)(3) Nonprofit</span>
          <span class="hero-trust-item"><svg class="hero-trust-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 8H8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M16 12H8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>Tax-Deductible</span>
          <span class="hero-trust-item"><svg class="hero-trust-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 0 1 0 4H8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M12 18V6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>Zero Platform Fees</span>
        </div>
      </div>
      <div class="hero-photo-wrap">
        <div class="hero-frame" style={`background-image:url('${cfLqip(heroPhotoId)}')`}>
          <img
            src={cfRaw(heroPhotoId, 'w=800,h=1000,fit=cover,gravity=face,q=65')}
            srcset={`${cfRaw(heroPhotoId, 'w=400,h=500,fit=cover,gravity=face,q=65')} 400w, ${cfRaw(heroPhotoId, 'w=560,h=700,fit=cover,gravity=face,q=65')} 560w, ${cfRaw(heroPhotoId, 'w=800,h=1000,fit=cover,gravity=face,q=65')} 800w`}
            sizes="(max-width:768px) 85vw, 420px"
            alt="A child smiling in their new dream room built by SOARD donors"
            width="800" height="1000"
            fetchpriority="high"
            loading="eager"
            decoding="sync"
            class="hero-img lqip-img"
          />
        </div>
        <div class="hero-accent" aria-hidden="true"></div>
        <div class="hero-stat">
          <span class="hero-stat-num">{computed.totalRooms}+</span>
          <span class="hero-stat-label">rooms built<br/>by donors like you</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ DONOR TESTIMONIAL — Social proof before giving options ══════ -->
  <section class="wtg-testimonial">
    <div class="wtg-container">
      <div class="wtg-testimonial-inner" data-reveal>
        <svg class="wtg-testimonial-qm" viewBox="0 0 40 32" fill="none" aria-hidden="true"><path d="M0 20.8C0 12.267 5.867 5.067 14.4 2.4l1.6 3.2C10.133 8 7.467 12.267 6.933 16H14.4v13.6H0V20.8Zm22.4 0C22.4 12.267 28.267 5.067 36.8 2.4l1.6 3.2C32.533 8 29.867 12.267 29.333 16H36.8v13.6H22.4V20.8Z" fill="currentColor"/></svg>
        <blockquote class="wtg-testimonial-quote">Seeing the look on a child's face when they walk into their new room — there's nothing like it. We know our money went exactly where it should.</blockquote>
        <div class="wtg-testimonial-attr">
          <span class="wtg-testimonial-name">Sarah & Michael T.</span>
          <span class="wtg-testimonial-role">Monthly donors since 2023</span>
        </div>
      </div>
    </div>
  </section>

  <MediaLogos theme="dark" linked={true} />

  <!-- ══════ ANCHOR NAV ══════ -->
  <nav class="wtg-nav" aria-label="Giving options">
    <div class="wtg-nav-track">
      <div class="wtg-nav-pill" aria-hidden="true"></div>
      <a href="#give-today" class="wtg-nav-link is-active"><span>Give Today</span></a>
      <a href="#tax-smart" class="wtg-nav-link"><span>Tax-Smart</span></a>
      <a href="#workplace" class="wtg-nav-link"><span>Workplace</span></a>
      <a href="#legacy" class="wtg-nav-link"><span>Legacy</span></a>
      <a href="#in-kind" class="wtg-nav-link"><span>In-Kind</span></a>
    </div>
  </nav>

  <!-- ══════ 01 · GIVE TODAY — Featured + Secondary ══════ -->
  <section class="wtg-section" id="give-today">
    <div class="wtg-container">
      <div class="wtg-sh" data-reveal data-num="01">
        <div class="wtg-sh-text">
          <h2>Give <em>Today</em></h2>
          <p>The fastest way to make a difference.</p>
        </div>
      </div>

      <div class="wtg-give-grid">
        <!-- Primary: Donate Online -->
        <div class="wtg-give-primary" data-reveal>
          <div class="wtg-give-primary-inner">
            <div class="wtg-give-badge-wrap" aria-hidden="true">
              <div class="wtg-give-badge">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
              </div>
            </div>
            <h3>Donate Online</h3>
            <p>Credit card, debit, Apple Pay, or Google Pay. One-time or monthly — powered by Zeffy with <strong>zero platform fees</strong>.</p>
            <div class="wtg-give-trust">
              <span>
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" width="14" height="14"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Secure
              </span>
              <span>
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" width="14" height="14"><path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 8H8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M16 12H8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                Tax-deductible
              </span>
              <span>
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" width="14" height="14"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 0 1 0 4H8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M12 18V6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                Zero fees
              </span>
            </div>
            <a href="/donate" class="btn btn-primary btn-glow btn-lg wtg-give-cta">Donate Now →</a>
          </div>
        </div>

        <!-- Secondary: Mail a Check -->
        <div class="wtg-give-secondary" data-reveal data-delay="1">
          <div class="wtg-give-sec-badge" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <h3>Mail a Check</h3>
          <p>Make checks payable to <strong>{orgName}</strong></p>
          <address class="wtg-give-addr">
            {address.street}<br/>
            {address.city}, {address.state} {address.zip}
          </address>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ 02 · TAX-SMART — Three distinct methods ══════ -->
  <section class="wtg-section wtg-section--alt" id="tax-smart">
    <div class="wtg-container">
      <div class="wtg-sh" data-reveal data-num="02">
        <div class="wtg-sh-text">
          <h2>Tax-Smart <em>Giving</em></h2>
          <p>Maximize your impact while minimizing your tax liability.</p>
        </div>
      </div>

      <div class="wtg-methods">
        <div class="wtg-method" data-reveal>
          <div class="wtg-method-inner">
            <div class="wtg-method-badge-wrap" aria-hidden="true">
              <div class="wtg-method-badge">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
              </div>
            </div>
            <h3>Donate Stock</h3>
            <p>Avoid capital gains tax and claim the full market value as a deduction. Gifts processed through the <strong>National Christian Foundation</strong>.</p>
            <div class="wtg-pills">
              <span class="wtg-pill">Skip capital gains</span>
              <span class="wtg-pill">Full value deduction</span>
            </div>
            <div class="wtg-method-action">
              <a href={`mailto:${email}`} class="wtg-method-cta">Get Started →</a>
            </div>
          </div>
        </div>

        <div class="wtg-method wtg-method--featured" data-reveal data-delay="1">
          <div class="wtg-method-inner">
            <div class="wtg-method-flag">Most Common</div>
            <div class="wtg-method-badge-wrap" aria-hidden="true">
              <div class="wtg-method-badge">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" x2="21" y1="22" y2="22"/><line x1="6" x2="6" y1="18" y2="11"/><line x1="10" x2="10" y1="18" y2="11"/><line x1="14" x2="14" y1="18" y2="11"/><line x1="18" x2="18" y1="18" y2="11"/><polygon points="12 2 20 7 4 7"/></svg>
              </div>
            </div>
            <h3>Donor-Advised Fund</h3>
            <p>Recommend a grant from Fidelity Charitable, Schwab, Vanguard, or any DAF sponsor.</p>
            <div class="wtg-daf-info">
              <div class="wtg-daf-row"><span>Organization</span><strong>{orgName}</strong></div>
              <div class="wtg-daf-row"><span>EIN</span><strong>{ein}</strong></div>
            </div>
            <div class="wtg-pills">
              <span class="wtg-pill">Immediate deduction</span>
              <span class="wtg-pill">Grant at your pace</span>
            </div>
            <div class="wtg-method-action">
              <a href={`mailto:${email}?subject=DAF Grant to SOARD`} class="wtg-method-cta">Send a Grant →</a>
            </div>
          </div>
        </div>

        <div class="wtg-method" data-reveal data-delay="2">
          <div class="wtg-method-inner">
            <div class="wtg-method-badge-wrap" aria-hidden="true">
              <div class="wtg-method-badge">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
              </div>
            </div>
            <h3>IRA Distribution</h3>
            <p>If you're 70&frac12;+, donate up to $105,000/year directly from your IRA — <strong>tax-free</strong>. Counts toward your RMD.</p>
            <div class="wtg-pills">
              <span class="wtg-pill">Tax-free transfer</span>
              <span class="wtg-pill">Satisfies RMD</span>
            </div>
            <div class="wtg-method-action">
              <span class="wtg-method-hint">Ask your custodian to distribute to {orgName}</span>
              <span class="wtg-method-ein">EIN {ein}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ EDITORIAL BREAK — Photo + Impact Ribbon + Quote ══════ -->
  <section class="wtg-break" aria-label="Impact">
    <div class="wtg-break-photo" style={`background-image:url('${cfLqip(breakPhoto)}')`} data-reveal>
      <img
        src={cfUrl(breakPhoto, { w: 800, h: 1000, fit: 'cover', gravity: 'face', q: 80 })}
        srcset={cfSrcset(breakPhoto, [400, 600, 800, 1200, 1600], { fit: 'cover', gravity: 'face', aspectRatio: 5/4 })}
        sizes="(max-width:960px) 100vw, 45vw"
        alt="Summer smiling in her new dream room"
        width="800" height="1000"
        loading="lazy" decoding="async"
        class="wtg-break-img lqip-img"
      />
    </div>
    <div class="wtg-break-content">
      <div class="wtg-break-ribbon">
        <div class="wtg-break-stat" data-reveal>
          <span class="wtg-break-num">{computed.totalRooms}+</span>
          <span class="wtg-break-label">Rooms Built</span>
        </div>
        <div class="wtg-break-divider" aria-hidden="true"></div>
        <div class="wtg-break-stat" data-reveal data-delay="1">
          <span class="wtg-break-num">{computed.totalKids}+</span>
          <span class="wtg-break-label">Kids Served</span>
        </div>
        <div class="wtg-break-divider" aria-hidden="true"></div>
        <div class="wtg-break-stat" data-reveal data-delay="2">
          <span class="wtg-break-num">{computed.years}</span>
          <span class="wtg-break-label">Years of Impact</span>
        </div>
      </div>
      <blockquote class="wtg-break-quote" data-reveal data-delay="3">
        <p>Last year, stock gifts and DAF grants funded <strong>one in five</strong> room makeovers — proving that tax-smart giving isn't just efficient, it's <em>transformative</em>.</p>
      </blockquote>
    </div>
  </section>

  <!-- ══════ 03 · WORKPLACE — Split editorial layout ══════ -->
  <section class="wtg-section" id="workplace">
    <div class="wtg-container">
      <div class="wtg-sh" data-reveal data-num="03">
        <div class="wtg-sh-text">
          <h2>Workplace & <em>Corporate</em></h2>
          <p>Multiply your impact through your employer.</p>
        </div>
      </div>

      <div class="wtg-work-grid">
        <!-- Employer Matching -->
        <div class="wtg-work-card" data-reveal>
          <div class="wtg-work-card-inner">
            <div class="wtg-method-badge-wrap" aria-hidden="true">
              <div class="wtg-method-badge">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
            </div>
            <h3>Employer Matching Gifts</h3>
            <p>Many companies match donations — sometimes <strong>2:1 or even 3:1</strong>. A $500 gift could become $1,500.</p>
            <div class="wtg-employer-logos">
              <span>Bank of America</span>
              <span>Home Depot</span>
              <span>Google</span>
              <span>Microsoft</span>
              <span>Coca-Cola</span>
              <span>Delta</span>
            </div>
            <div class="wtg-method-action">
              <span class="wtg-method-hint">After donating, submit a matching request with our EIN. See <a href="#org-details" class="wtg-link">details below</a>.</span>
            </div>
          </div>
        </div>

        <!-- Corporate Sponsorship -->
        <div class="wtg-work-card wtg-work-card--accent" data-reveal data-delay="1">
          <div class="wtg-work-card-inner">
            <div class="wtg-method-badge-wrap" aria-hidden="true">
              <div class="wtg-method-badge">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m11 17 2 2a1 1 0 1 0 3-3"/><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"/><path d="m21 3 1 11h-2"/><path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"/><path d="M3 4h8"/></svg>
              </div>
            </div>
            <h3>Corporate Sponsorship</h3>
            <p>Sponsor a room makeover, fund an event, or provide in-kind services. Partners receive recognition on our website, at events, and in media.</p>
            <div class="wtg-method-action">
              <a href="/partners/" class="wtg-method-cta">Learn About Partnerships →</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Testimonial — full width below cards -->
      <div class="wtg-sponsor-quote" data-reveal data-delay="2">
        <blockquote>Partnering with SOARD has been the most rewarding thing our company has done. Our team shows up on build day and leaves changed.</blockquote>
        <div class="wtg-sponsor-attr">
          <strong>Corporate build partner</strong>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ 04 · LEGACY — Narrative + photo + bequest ══════ -->
  <section class="wtg-section wtg-section--alt" id="legacy">
    <div class="wtg-container">
      <div class="wtg-sh" data-reveal data-num="04">
        <div class="wtg-sh-text">
          <h2>Legacy <em>Giving</em></h2>
          <p>Build dreams that outlast a lifetime.</p>
        </div>
      </div>

      <div class="wtg-legacy" data-reveal>
        <div class="wtg-legacy-visual">
          <div class="wtg-legacy-photo" style={`background-image:url('${cfLqip(legacyPhoto)}')`}>
            <img
              src={cfRaw(legacyPhoto, 'w=600,h=500,fit=cover,gravity=face,q=80')}
              srcset={cfSrcset(legacyPhoto, [400, 600], { fit: 'cover', gravity: 'face', aspectRatio: 6/5 })}
              sizes="(max-width:960px) 90vw, 400px"
              alt="A child enjoying their newly transformed room"
              width="600" height="500"
              loading="lazy" decoding="async"
              class="lqip-img"
            />
          </div>
          <div class="wtg-legacy-narrative">
            <h3>Include SOARD in Your Will or Estate Plan</h3>
            <p>A bequest is one of the most meaningful gifts you can make. By naming {orgName} in your will or trust, you ensure that children with special needs will continue to receive life-changing room makeovers for generations to come.</p>
            <p class="wtg-fine">We recommend consulting your estate attorney. For questions, contact us at <a href={`mailto:${email}`}>{email}</a>.</p>
          </div>
        </div>
        <div class="wtg-legacy-bequest">
          <span class="wtg-bequest-label">Suggested Bequest Language</span>
          <blockquote>
            "I give, devise, and bequeath to Sunshine on a Ranney Day, Inc., a Georgia nonprofit corporation (EIN {ein}), located at {address.street}, {address.city}, {address.state} {address.zip}, <mark>[a specific dollar amount / percentage of my estate / the residue of my estate]</mark> to be used for its general charitable purposes."
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ 05 · IN-KIND — Visual wishlist columns ══════ -->
  <section class="wtg-section" id="in-kind">
    <div class="wtg-container">
      <div class="wtg-sh" data-reveal data-num="05">
        <div class="wtg-sh-text">
          <h2>In-Kind <em>Donations</em></h2>
          <p>Building materials and professional services.</p>
        </div>
      </div>

