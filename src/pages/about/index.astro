    .tl-track-fill { transform: scaleY(1) !important; }
    .tl-dot-ring, .tl-cursor { display: none !important; }
    .tl-cap { opacity: 1 !important; transform: none !important; }
    .tl-cap-icon { animation: none !important; }
    .tl-connector { width: 30px !important; }
