---
/**
 * Home Page
 * Hero, room types, stats, partner logos, newsletter
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1 class="hero__title">Building Dreams,<br/>One Room at a Time</h1>
      <p class="hero__subtitle">
        Sunshine on a Ranney Day is a 501(c)(3) nonprofit creating
        life-changing home makeovers for children with special needs — dream
        bedrooms, accessible bathrooms, and therapy spaces — <strong>all at no cost
        to families.</strong>
      </p>
      <div class="hero__actions">
        <Button href="/donate/" size="lg">Donate Today</Button>
        <Button href="/kids/" variant="outline" size="lg" class="hero__btn-outline">Meet the Kids</Button>
      </div>
    </div>
  </section>

  <!-- Room Types -->
  <section class="section">
    <div class="container">
      <div class="room-grid">
        <a href="/rooms/?type=accessible-bathroom" class="room-card">
          <div class="room-card__icon">🚿</div>
          <h3>Accessible Bathrooms</h3>
          <p>Giving a child with special needs independence in the bathroom reduces the stress placed on a caregiver.</p>
        </a>
        <a href="/rooms/?type=dream-bedroom" class="room-card">
          <div class="room-card__icon">🛏️</div>
          <h3>Dream Bedrooms</h3>
          <p>Every child deserves their own space to let their imagination soar and escape from their struggles.</p>
        </a>
        <a href="/rooms/?type=therapy-room" class="room-card">
          <div class="room-card__icon">🧩</div>
          <h3>Therapy Rooms</h3>
          <p>The freedom of being able to exercise the mind and body from within a child's home can be life changing.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section section--gray">
    <div class="container" style="text-align: center;">
      <h2 style="margin-bottom: var(--space-2xl);">Room Makeovers Since 2012</h2>
      <div class="stats-grid">
        <div class="stat">
          <span class="stat__number">106</span>
          <span class="stat__label">Rooms Completed</span>
        </div>
        <div class="stat">
          <span class="stat__number">132</span>
          <span class="stat__label">Kids Served</span>
        </div>
        <div class="stat">
          <span class="stat__number">45</span>
          <span class="stat__label">Partners</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="text-align: center;">
    <div class="container container--narrow">
      <SectionHeading subtitle="Each donation goes to building accessible bathrooms, dream bedrooms, and therapy rooms for children with special needs.">
        Help Us <span class="highlight">Build Dreams</span>
      </SectionHeading>
      <Button href="/donate/" size="lg">Donate Today</Button>
    </div>
  </section>
</BaseLayout>

<style>
  /* ─── Hero ─────────────────────────────── */
  .hero {
    background: var(--c-dark);
    color: var(--c-white);
    padding-block: var(--space-5xl) var(--space-4xl);
    text-align: center;
  }

  .hero__title {
    color: var(--c-white);
    font-size: clamp(2.25rem, 5vw + 0.5rem, 4rem);
    max-width: 800px;
    margin-inline: auto;
  }

  .hero__subtitle {
    margin-top: var(--space-lg);
    font-size: clamp(1rem, 1.5vw + 0.25rem, 1.2rem);
    color: rgba(255, 255, 255, 0.8);
    max-width: 680px;
    margin-inline: auto;
    line-height: 1.7;
  }

  .hero__actions {
    margin-top: var(--space-xl);
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero__btn-outline {
    color: var(--c-white) !important;
    box-shadow: inset 0 0 0 2px rgba(255,255,255,0.5) !important;
  }

  .hero__btn-outline:hover {
    background: var(--c-white) !important;
    color: var(--c-dark) !important;
  }

  /* ─── Room Cards ───────────────────────── */
  .room-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-xl);
  }

  .room-card {
    padding: var(--space-xl);
    background: var(--c-white);
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
    text-decoration: none;
  }

  .room-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .room-card__icon {
    font-size: 2.5rem;
    margin-bottom: var(--space-md);
  }

  .room-card h3 {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1.15rem;
    margin-bottom: var(--space-sm);
  }

  .room-card p {
    color: var(--c-text-muted);
    font-size: 0.95rem;
  }

  /* ─── Stats ────────────────────────────── */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    max-width: 700px;
    margin-inline: auto;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .stat__number {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--c-yellow);
    line-height: 1;
  }

  .stat__label {
    font-size: 0.9rem;
    color: var(--c-text-muted);
    font-weight: 500;
  }

  @media (max-width: 480px) {
    .stats-grid { grid-template-columns: 1fr; }
  }
</style>
