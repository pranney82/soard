    opacity: 0;
    animation: heroUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
  }

  .hero-ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    opacity: 0;
    animation: heroUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.25s both;
  }

  .hero-trust {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    margin-top: 24px;
    opacity: 0;
    animation: heroUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.35s both;
  }
  .hero-trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 500;
